	<!-- BLOODY GOTHIC -->
		<!-- LARGE FLOOR COVERING -->
			<ThingDef ParentName="BuildingFloorCoveringBroadBase">
				<defName>TMM_FloorCovering_BroadBloodyGothic</defName>
				<label>Bloody Gothic slab (broad)</label>
				<description>A stone bas relief of Bloody Gothic imagery for decorating a floor.</description>
				<dominantStyleCategory>TMM_StyleCategory_BloodyGothic</dominantStyleCategory>
				<graphicData>
					<graphicClass>Graphic_Random</graphicClass>
					<texPath>Modules/Styles/Buildings/BloodyGothic/FloorCoverings/SlabBloodyGothicBroad</texPath>
					<drawSize>(4,4)</drawSize>
				</graphicData>
				<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
				<stuffCategories>
					<li>Stony</li>
				</stuffCategories>
				<costStuffCount>150</costStuffCount>
				<researchPrerequisites>
					<li>Stonecutting</li>
				</researchPrerequisites>
			</ThingDef>
