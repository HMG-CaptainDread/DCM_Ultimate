			<ThingDef ParentName="BuildingFloorCoveringBroadBase">
				<defName>TMM_FloorCovering_BroadWirehead</defName>
				<label>wirehead floor hatch (broad)</label>
				<description>A techy-looking floor hatch that can potentially be used to conceal cables and other systems, for decorating a floor.</description>

				<dominantStyleCategory>TMM_StyleCategory_Wirehead</dominantStyleCategory>

				<graphicData>
					<graphicClass>Graphic_Random</graphicClass>
					<color>(105,105,105)</color>
