<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- <></> -->
	<!-- TMM_Style_ -->



	<!-- GRAPHIC BASES -->
		<!-- MULTI GRAPHIC BASE -->
			<ThingStyleDef Name="TMM_StyleMultiBase" Abstract="True">
				<graphicData>
					<graphicClass>Graphic_Multi</graphicClass>
				</graphicData>
			</ThingStyleDef>
		<!-- SINGLE BASE -->
			<ThingStyleDef Name="TMM_StyleSingleBase" Abstract="True">
				<graphicData>
					<graphicClass>Graphic_Single</graphicClass>
				</graphicData>
			</ThingStyleDef>
		<!-- RANDOM GRAPHIC BASE -->
			<ThingStyleDef Name="TMM_StyleRandomBase" Abstract="True">
				<graphicData>
					<graphicClass>Graphic_Random</graphicClass>
				</graphicData>
			</ThingStyleDef>
	<!-- BUILDING BASES -->
		<!-- ALTAR BASES -->
			<!-- GRAND ALTAR BASE -->
				<ThingStyleDef ParentName="TMM_StyleMultiBase" Name="TMM_StyleGrandAltarBase" Abstract="True">
					<graphicData>
						<drawSize>(3,3)</drawSize>
						<shadowData>
							<volume>(2.4, 1, 2.4)</volume>
						</shadowData>
					</graphicData>
				</ThingStyleDef>
			<!-- LARGE ALTAR BASE -->
				<ThingStyleDef ParentName="TMM_StyleMultiBase" Name="TMM_StyleLargeAltarBase" Abstract="True">
					<graphicData>
						<drawSize>(3,2)</drawSize>
						<shadowData>
							<volume>(2.4, 1, 1.6)</volume>
						</shadowData>
					</graphicData>
				</ThingStyleDef>
			<!-- MEDIUM ALTAR BASE -->
				<ThingStyleDef ParentName="TMM_StyleMultiBase" Name="TMM_StyleMediumAltarBase" Abstract="True">
					<graphicData>
						<drawSize>(3,1)</drawSize>
						<shadowData>
							<volume>(2.4, 1, 0.8)</volume>
						</shadowData>
					</graphicData>
				</ThingStyleDef>
			<!-- SMALL ALTAR BASE -->
				<ThingStyleDef ParentName="TMM_StyleMultiBase" Name="TMM_StyleSmallAltarBase" Abstract="True">
					<graphicData>
						<shadowData>
							<volume>(0.8, 1, 0.8)</volume>
						</shadowData>
					</graphicData>
				</ThingStyleDef>
		<!-- AUTODOOR BASE -->
			<ThingStyleDef ParentName="TMM_StyleSingleBase" Name="TMM_StyleAutodoorBase" Abstract="True">
				<graphicData>
					<damageData>
						<enabled>false</enabled>
					</damageData>
				</graphicData>
			</ThingStyleDef>
		<!-- IDEOGRAM BASE -->
			<ThingStyleDef ParentName="TMM_StyleSingleBase" Name="TMM_StyleIdeogramBase" Abstract="True">
				<graphicData>
					<drawSize>(3,3)</drawSize>
				</graphicData>
			</ThingStyleDef>
		<!-- SCULPTURE BASES -->
			<!-- GRAND SCULPTURE BASE -->
				<ThingStyleDef ParentName="TMM_StyleRandomBase" Name="TMM_StyleGrandSculptureBase" Abstract="True">
					<graphicData>
						<drawSize>(4,4)</drawSize>
					</graphicData>
				</ThingStyleDef>
			<!-- LARGE SCULPTURE BASE -->
				<ThingStyleDef ParentName="TMM_StyleRandomBase" Name="TMM_StyleLargeSculptureBase" Abstract="True">
					<graphicData>
						<drawSize>(3,3)</drawSize>
					</graphicData>
				</ThingStyleDef>
		<!-- TABLE BASES -->
			<!-- 1x2 -->
				<ThingStyleDef ParentName="IdeoTableStyleBase" Name="TMM_Style1x2TableBase" Abstract="True">
					<graphicData>
						<drawSize>(3,4)</drawSize>
					</graphicData>
				</ThingStyleDef>
			<!-- 2x2 -->
				<ThingStyleDef ParentName="IdeoTableStyleBase" Name="TMM_Style2x2TableBase" Abstract="True">
					<graphicData>
						<drawSize>(4,4)</drawSize>
					</graphicData>
				</ThingStyleDef>
			<!-- 2x4 -->
				<ThingStyleDef ParentName="IdeoTableStyleBase" Name="TMM_Style2x4TableBase" Abstract="True">
					<graphicData>
						<drawSize>(4,6)</drawSize>
					</graphicData>
				</ThingStyleDef>
			<!-- 3x3 -->
				<ThingStyleDef ParentName="IdeoTableStyleBase" Name="TMM_Style3x3TableBase" Abstract="True">
					<graphicData>
						<drawSize>(5,5)</drawSize>
					</graphicData>
				</ThingStyleDef>
	<!-- WEAPONS BASES -->
		<ThingStyleDef ParentName="TMM_StyleSingleBase" Name="TMM_StyleRotatedBase" Abstract="True">
			<graphicData>
				<onGroundRandomRotateAngle>30</onGroundRandomRotateAngle>
			</graphicData>
		</ThingStyleDef>
</Defs>