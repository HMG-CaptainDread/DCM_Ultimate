<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!-- <></> -->
	<!--  -->



	<!-- CROWNS -->
		<!-- CROWN BASE -->
			<ThingDef ParentName="ApparelBase" Name="TMM_CrownBase" Abstract="True">
				<smeltable>true</smeltable>
				<thingCategories>
					<li>HeadgearNoble</li>
				</thingCategories>
				<statBases>
					<MaxHitPoints>1000</MaxHitPoints>
					<WorkToMake> 24000</WorkToMake>
					<Mass>0.9</Mass>
					<EquipDelay>0.8</EquipDelay>
				</statBases>
				<recipeMaker>
					<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
					<workSkill>Crafting</workSkill>
					<effectWorking>Smith</effectWorking>
					<soundWorking>Recipe_Smith</soundWorking>
					<recipeUsers>
						<li>ElectricSmithy</li>
						<li>FueledSmithy</li>
					</recipeUsers>
					<researchPrerequisite>Smithing</researchPrerequisite>
				</recipeMaker>
				<graphicData>
					<graphicClass>Graphic_Single</graphicClass>
					<drawSize>(0.9, 0.9)</drawSize>
				</graphicData>
				<equippedStatOffsets>
					<SocialImpact>0.3</SocialImpact>
					<SuppressionPower MayRequire="Ludeon.RimWorld.Ideology">0.15</SuppressionPower>
					<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.3</SlaveSuppressionOffset>
				</equippedStatOffsets>
				<relicChance>1.2</relicChance>
				<apparel>
					<canBeDesiredForIdeo>true</canBeDesiredForIdeo>
					<countsAsClothingForNudity>false</countsAsClothingForNudity>
					<bodyPartGroups>
						<li>UpperHead</li>
					</bodyPartGroups>
					<layers>
						<li>Overhead</li>
					</layers>
					<canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
				</apparel>
			</ThingDef>
		<!-- BYZANTINE IMPERIAL CROWN -->
			<!-- BASE -->
				<ThingDef ParentName="TMM_CrownBase" Name="TMM_ByzantineCrownBase" Abstract="True">
					<label>Byzantine Imperial Crown</label>
					<description>A crown of metal with an elaborate design, truly worthy of a successor to Rome!</description>
					<apparel>
						<tags>
							<li>Royal</li>
							<li>RoyalTier5</li>
							<li>RoyalTier6</li>
							<li>RoyalTier7</li>
						</tags>
					</apparel>
				</ThingDef>
			<!-- REGULAR -->
				<ThingDef ParentName="TMM_ByzantineCrownBase">
					<defName>TMM_Headwear_Byzantine</defName>
					<graphicData>
						<texPath>Modules/Wardrobe/Clothing/2_Medieval/Headwear/Crowns/Byzantine/Regular/Byzantine</texPath>
					</graphicData>
					<costList>
						<Gold>40</Gold>
						<Cloth>30</Cloth>
					</costList>
					<apparel>
						<wornGraphicPath>Modules/Wardrobe/Clothing/2_Medieval/Headwear/Crowns/Byzantine/Regular/Byzantine</wornGraphicPath>
					</apparel>
				</ThingDef>
			<!-- STUFFABLE -->
				<ThingDef ParentName="TMM_ByzantineCrownBase">
					<defName>TMM_Headwear_Byzantine_Stuffable</defName>
					<recipeMaker>
						<defaultIngredientFilter>
							<categories>
								<li>Root</li>
							</categories>
							<disallowedThingDefs>
								<li>Jade</li>
								<li>Uranium</li>
							</disallowedThingDefs>
						</defaultIngredientFilter>
					</recipeMaker>
					<graphicData>
						<texPath>Modules/Wardrobe/Clothing/2_Medieval/Headwear/Crowns/Byzantine/Stuffable/ByzantineStuffable</texPath>
						<shaderType>CutoutComplex</shaderType>
					</graphicData>
					<costStuffCount>45</costStuffCount>
					<stuffCategories>
						<li>Metallic</li>
						<!-- Stuff like jade here maybe? -->
					</stuffCategories>
					<costList>
						<Gold>20</Gold>
						<Cloth>30</Cloth>
					</costList>
					<apparel>
						<wornGraphicPath>Modules/Wardrobe/Clothing/2_Medieval/Headwear/Crowns/Byzantine/Stuffable/ByzantineStuffable</wornGraphicPath>
						<useWornGraphicMask>true</useWornGraphicMask>
					</apparel>
					<colorGenerator Class="ColorGenerator_StandardApparel" />
				</ThingDef>
