		<!-- FIREFIGHTER -->
			<!-- GEAR -->
				<!-- BASE -->
					<ThingDef ParentName="ApparelMakeableBase" Name="TMM_Uniform_FirefighterGearBase" Abstract="True">
						<description>Also known as turnout gear, which includes an outer shell, a moisture barrier, and a thermal barrier. will protect you from deadly fire, and heat.</description>

						<graphicData>
							<graphicClass>Graphic_Single</graphicClass>
							<shaderType>CutoutComplex</shaderType>
							<drawSize>1.05</drawSize>
						</graphicData>

						<costStuffCount>90</costStuffCount>

						<stuffCategories>
							<li>Fabric</li>
						</stuffCategories>

						<costList>
							<ComponentIndustrial>1</ComponentIndustrial>
							<Steel>65</Steel>
						</costList>

						<thingCategories>
							<li>Apparel</li>
						</thingCategories>

						<statBases>
							<MaxHitPoints>350</MaxHitPoints>
							<WorkToMake>12000</WorkToMake>
							<Mass>12.5</Mass>
							<Flammability>0</Flammability>
							<StuffEffectMultiplierInsulation_Cold>0.45</StuffEffectMultiplierInsulation_Cold>
							<StuffEffectMultiplierInsulation_Heat>0.0</StuffEffectMultiplierInsulation_Heat>
							<ArmorRating_Heat>0.55</ArmorRating_Heat>
							<StuffEffectMultiplierArmor>0.9</StuffEffectMultiplierArmor>
							<ArmorRating_Sharp>0.08</ArmorRating_Sharp>
							<ArmorRating_Blunt>0.04</ArmorRating_Blunt>
							<Insulation_Heat>100</Insulation_Heat>
							<EquipDelay>4</EquipDelay>
						</statBases>

						<equippedStatOffsets>
							<MoveSpeed>-0.55</MoveSpeed>
							<ToxicEnvironmentResistance>0.2</ToxicEnvironmentResistance>
							<Flammability>-0.46</Flammability>
						</equippedStatOffsets>

						<apparel>
							<bodyPartGroups>
								<li>Torso</li>
								<li>Neck</li>
								<li>Shoulders</li>
								<li>Arms</li>
								<li>Legs</li>
								<li>Hands</li>
								<li>Feet</li>
							</bodyPartGroups>
							<layers>
								<li>Shell</li>
							</layers>
							<defaultOutfitTags>
								<li>Worker</li>
							</defaultOutfitTags>
							<useWornGraphicMask>true</useWornGraphicMask>
							<canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
						</apparel>

						<recipeMaker>
							<researchPrerequisite>ComplexClothing</researchPrerequisite>
							<skillRequirements>
								<Crafting>5</Crafting>
							</skillRequirements>
						</recipeMaker>
					</ThingDef>
