			<!-- HELMETS -->
				<!-- BASE -->
					<ThingDef ParentName="ArmorHelmetMakeableBase" Name="TMM_Uniform_FireHelmetBase" Abstract="True">
						<description>The modern Firefighter helmet is made of thermoplastic or composite materials. Such helmets were designed to provide a more modern, sleeker look, and lighter weight compared to the traditional firefighter helmet design while retaining the distinctive profile.</description>

						<techLevel>Industrial</techLevel>

						<graphicData>
							<graphicClass>Graphic_Single</graphicClass>
							<shaderType>CutoutComplex</shaderType>
						</graphicData>

						<uiIconScale>1.4</uiIconScale>

						<costStuffCount>55</costStuffCount>

						<stuffCategories>
							<li>Metallic</li>
						</stuffCategories>

						<costList>
							<Cloth>35</Cloth>
						</costList>

						<statBases>
							<WorkToMake>6500</WorkToMake>
							<MaxHitPoints>145</MaxHitPoints>
							<Mass>1.5</Mass>
							<StuffEffectMultiplierInsulation_Cold>0.15</StuffEffectMultiplierInsulation_Cold>
							<StuffEffectMultiplierInsulation_Heat>0</StuffEffectMultiplierInsulation_Heat>
							<StuffEffectMultiplierArmor>0.6</StuffEffectMultiplierArmor>
							<Insulation_Heat>35</Insulation_Heat>
							<EquipDelay>1.5</EquipDelay>
						</statBases>

						<equippedStatOffsets>
							<MoveSpeed>-0.05</MoveSpeed>
							<Flammability>-0.22</Flammability>
							<ToxicEnvironmentResistance>0.55</ToxicEnvironmentResistance>
						</equippedStatOffsets>

						<apparel>
							<developmentalStageFilter>Child, Adult</developmentalStageFilter>
							<immuneToToxGasExposure>true</immuneToToxGasExposure>
							<countsAsClothingForNudity>false</countsAsClothingForNudity>
							<bodyPartGroups>
								<li>FullHead</li>
							</bodyPartGroups>
							<layers>
								<li>Overhead</li>
							</layers>
							<useWornGraphicMask>true</useWornGraphicMask>
						</apparel>

						<recipeMaker>
							<researchPrerequisite>Smithing</researchPrerequisite>
							<recipeUsers>
								<li>ElectricSmithy</li>
								<li>FueledSmithy</li>
							</recipeUsers>
						</recipeMaker>
					</ThingDef>
