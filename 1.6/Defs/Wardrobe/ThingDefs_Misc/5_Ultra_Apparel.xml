			<!-- ADULT -->
				<ThingDef ParentName="TMM_VacSlipSuitBase">
					<defName>TMM_Bodywear_VacSlipSuit</defName>
					<label>Vac-Slipsuit</label>
					<description>A high-tech, skin-tight suit which offers some of the best protection from harsh environments available for gravship crews, special forces, explorers and scientists. It acts like a sort of second skin for the wearer. It monitors and regulates the body to keep it in working shape. It also comes with an invisible, thin vac-barrier hood for the head.</description>
					<graphicData>
						<texPath>Modules/Wardrobe/Clothing/5_Ultra/Bodywear/VacSlipSuit/Adult/Slipsuit</texPath>
					</graphicData>
					<apparel>
						<wornGraphicPath>Modules/Wardrobe/Clothing/5_Ultra/Bodywear/VacSlipSuit/Adult/Slipsuit</wornGraphicPath>
					</apparel>
					<costStuffCount>100</costStuffCount>
					<costList>
						<ComponentSpacer>2</ComponentSpacer>
						<Plasteel>10</Plasteel>
					</costList>
				</ThingDef>
