				<ThingDef ParentName="ApparelMakeableBase">
					<defName>NS_TechnopathRobe</defName>
					<label>nomad technopath robe</label>
					<description>Those who believe the Archotechs to be divine often make their way to the most barren landscapes in search of lost technology, artifacts, and the coveted digital-psychic “soul transfiguration”.\nDecorated with pieces of humming archotechnology shards, this raiment is worn by the prophets and technopaths who have some link to the Archotechs. Technopaths wear this robe as they lead their flock of machine-worshippers into the wastes in search of revelations and devices from ages long forgotten.</description>
					<graphicData>
						<texPath>Modules/Wardrobe/Clothing/OtherArticles/UI/Robes/TechnopathRobe</texPath>
						<drawSize>(1.2, 1.2)</drawSize>
						<graphicClass>Graphic_Single</graphicClass>
						<shaderType>CutoutComplex</shaderType>
					</graphicData>
					<techLevel>Neolithic</techLevel>
					<costStuffCount>60</costStuffCount>
					<stuffCategories>
						<li>Fabric</li>
						<li>Leathery</li>
					</stuffCategories>
					<costList>
						<Steel>10</Steel>
						<Silver>20</Silver>
					</costList>
					<tradeability>Sellable</tradeability>
					<statBases>
						<MaxHitPoints>500</MaxHitPoints>
						<WorkToMake>2500</WorkToMake>
						<Mass>1.5</Mass>
						<!-- <ArmorRating_Sharp>0.081</ArmorRating_Sharp>
						<ArmorRating_Blunt>0.081</ArmorRating_Blunt>
						<ArmorRating_Heat>0.081</ArmorRating_Heat> -->
						<StuffEffectMultiplierArmor>0.3</StuffEffectMultiplierArmor>
						<StuffEffectMultiplierInsulation_Cold>0.8</StuffEffectMultiplierInsulation_Cold>
						<StuffEffectMultiplierInsulation_Heat>1.4</StuffEffectMultiplierInsulation_Heat>
						<EquipDelay>1.5</EquipDelay>
					</statBases>
					<equippedStatOffsets>
						<ToxicEnvironmentResistance>0.15</ToxicEnvironmentResistance>
						<PsychicSensitivity>0.1</PsychicSensitivity>
						<PsychicEntropyMax MayRequire="ludeon.rimworld.royalty">0.07</PsychicEntropyMax>
						<SocialImpact>0.1</SocialImpact>
					</equippedStatOffsets>
					<thingCategories>
						<li>ApparelMisc</li>
					</thingCategories>
					<apparel>
						<bodyPartGroups>
							<li>Torso</li>
							<li>Legs</li>
						</bodyPartGroups>
						<wornGraphicPath>Modules/Wardrobe/Clothing/OtherArticles/Robes/TechnopathRobe/Robe01</wornGraphicPath>
						<useWornGraphicMask>true</useWornGraphicMask>
						<layers>
							<li>Shell</li>
						</layers>
						<tags>
							<li>Neolithic</li>
						</tags>
						<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
						<defaultOutfitTags>
							<li>Soldier</li>
						</defaultOutfitTags>
					</apparel>
					<recipeMaker>
						<skillRequirements>
							<Crafting>5</Crafting>
						</skillRequirements>
						<recipeUsers>
							<li>ElectricTailoringBench</li>
							<li>HandTailoringBench</li>
							<li>CraftingSpot</li>
						</recipeUsers>
						<displayPriority>200</displayPriority>
					</recipeMaker>
					<tradeTags>
						<li>BasicClothing</li>
					</tradeTags>
				</ThingDef>
