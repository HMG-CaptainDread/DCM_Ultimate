		<!-- VICTORIAN CLOTHES -->
			<!-- EYEGLASSES -->
				<ThingDef ParentName="HatMakeableBase">
					<defName>TMM_Eyewear_VictorianEyeglasses</defName>
					<label>Eyeglasses</label>
					<description>These glasses are round and fashionable. They look smart.</description>
					<graphicData>
						<texPath>Modules/Wardrobe/Clothing/OtherArticles/UI/Eyewear/Glasses</texPath>
						<graphicClass>Graphic_Single</graphicClass>
					</graphicData>
					<costStuffCount>10</costStuffCount>
					<stuffCategories>
						<li>Metallic</li>
					</stuffCategories>
					<tradeability>Sellable</tradeability>
					<generateCommonality>0</generateCommonality>
					<statBases>
						<MaxHitPoints>100</MaxHitPoints>
						<WorkToMake>1000</WorkToMake>
						<Mass>0.01</Mass>
						<ArmorRating_Sharp>0.05</ArmorRating_Sharp>
						<ArmorRating_Blunt>0.04</ArmorRating_Blunt>
						<ArmorRating_Heat>0.04</ArmorRating_Heat>
						<Insulation_Cold>0</Insulation_Cold>
						<Insulation_Heat>0</Insulation_Heat>
						<EquipDelay>0.4</EquipDelay>
					</statBases>
					<equippedStatOffsets>
						<PsychicSensitivity>-0.10</PsychicSensitivity>
						<SocialImpact>0.1</SocialImpact>
					</equippedStatOffsets>
					<apparel>
						<bodyPartGroups>
							<li>Eyes</li>
						</bodyPartGroups>
						<wornGraphicPath>Modules/Wardrobe/Clothing/OtherArticles/Eyewear/Glasses/Glasses</wornGraphicPath>
						<layers>
							<li>EyeCover</li>
						</layers>
						<tags>
							<li>IndustrialBasic</li>
						</tags>
						<defaultOutfitTags>
							<li>Worker</li>
						</defaultOutfitTags>
					</apparel>
					<recipeMaker>
						<skillRequirements>
							<Crafting>4</Crafting>
						</skillRequirements>
						<recipeUsers>
							<li>ElectricTailoringBench</li>
							<li>HandTailoringBench</li>
						</recipeUsers>
					</recipeMaker>
				</ThingDef>
