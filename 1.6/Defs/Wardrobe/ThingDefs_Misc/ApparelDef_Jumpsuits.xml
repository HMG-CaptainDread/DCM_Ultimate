					<apparel>
						<wornGraphicPath>Modules/Wardrobe/Clothing/Jumpsuits/PrisonUniforms/HighSecurity/PrisonJumpsuit_Red</wornGraphicPath>
					</apparel>
				</ThingDef>
			<!-- LOW SECURITY -->
				<ThingDef ParentName="TMM_Jumpsuit_PrisonUniformBase">
