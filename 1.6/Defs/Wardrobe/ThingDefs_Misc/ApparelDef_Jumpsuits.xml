					<description>A full body jumpsuit made out of thick fabric or leather, adorned with buttons for ease of use and a name tag for immediate identification. These jumpsuits are often worn by low-risk prisoners.</description>
					<graphicData>
						<texPath>Modules/Wardrobe/Clothing/Jumpsuits/UI/PrisonUniforms/PrisonJumpsuit_Blue</texPath>
					</graphicData>
					<apparel>
						<wornGraphicPath>Modules/Wardrobe/Clothing/Jumpsuits/PrisonUniforms/LowSecurity/PrisonJumpsuit_Blue</wornGraphicPath>
					</apparel>
				</ThingDef>
			<!-- MEDIUM SECURITY -->
				<ThingDef ParentName="TMM_Jumpsuit_PrisonUniformBase">
					<defName>TMM_Jumpsuit_PrisonUniformMedium</defName>
					<description>A full body jumpsuit made out of thick fabric or leather, adorned with buttons for ease of use and a name tag for immediate identification. These jumpsuits are often worn by medium-risk prisoners, more commonly known as "general population".</description>
					<graphicData>
						<texPath>Modules/Wardrobe/Clothing/Jumpsuits/UI/PrisonUniforms/PrisonJumpsuit_Orange</texPath>
					</graphicData>
					<apparel>
						<wornGraphicPath>Modules/Wardrobe/Clothing/Jumpsuits/PrisonUniforms/MediumSecurity/PrisonJumpsuit_Orange</wornGraphicPath>
