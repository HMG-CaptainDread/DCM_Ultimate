<Defs>
	<!-- <></> -->
	<!-- TMM_Jumpsuit_ -->



	<!-- BASES -->
		<!-- PRISON JUMPSUIT BASE -->
			<ThingDef ParentName="ApparelMakeableBase" Name="TMM_Jumpsuit_PrisonUniformBase" Abstract="True">
				<label>prisoner jumpsuit</label>
				<graphicData>
					<graphicClass>Graphic_Single</graphicClass>
					<shaderType>CutoutComplex</shaderType>
				</graphicData>
				<techLevel>Industrial</techLevel>
				<tradeability>Sellable</tradeability>
				<generateCommonality>0</generateCommonality>
				<costStuffCount>85</costStuffCount>
				<stuffCategories>
					<li>Fabric</li>
					<li>Leathery</li>
				</stuffCategories>
				<statBases>
					<WorkToMake>8600</WorkToMake>
					<Mass>0.8</Mass>
					<StuffEffectMultiplierArmor>0.10</StuffEffectMultiplierArmor>
					<StuffEffectMultiplierInsulation_Cold>1.00</StuffEffectMultiplierInsulation_Cold>
					<StuffEffectMultiplierInsulation_Heat>0.38</StuffEffectMultiplierInsulation_Heat>
					<EquipDelay>3.5</EquipDelay>
					<MaxHitPoints>300</MaxHitPoints>
				</statBases>
				<equippedStatOffsets>
					<WorkSpeedGlobal>0.1</WorkSpeedGlobal>
					<SocialImpact>0.05</SocialImpact>
					<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">0.2</SlaveSuppressionOffset>
				</equippedStatOffsets>
				<thingCategories Inherit='False'>
					<li>Apparel</li>
				</thingCategories>
				<apparel>
					<developmentalStageFilter>Child, Adult</developmentalStageFilter>
					<useWornGraphicMask>true</useWornGraphicMask>
					<bodyPartGroups>
						<li>Neck</li>
						<li>Torso</li>
						<li>Shoulders</li>
						<li>Arms</li>
						<li>Legs</li>
					</bodyPartGroups>
					<layers>
						<li>Middle</li>
					</layers>
					<tags>
						<li>IndustrialAdvanced</li>
					</tags>
					<defaultOutfitTags>
						<li>Slave</li>
					</defaultOutfitTags>
					<slaveApparel>true</slaveApparel>
				</apparel>
				<recipeMaker>
					<researchPrerequisite>ComplexClothing</researchPrerequisite> <!-- TODO: -->
					<recipeUsers Inherit="False">
						<li>ElectricTailoringBench</li>
						<li>HandTailoringBench</li>
					</recipeUsers>
				</recipeMaker>
			</ThingDef>
