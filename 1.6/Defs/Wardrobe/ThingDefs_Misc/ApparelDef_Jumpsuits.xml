		<!-- PRISON JUMPSUITS -->
			<!-- CUSTOM -->
				<ThingDef ParentName="TMM_Jumpsuit_PrisonUniformBase">
					<defName>TMM_Jumpsuit_PrisonUniformCustom</defName>
					<description>A full body jumpsuit made out of thick fabric or leather, adorned with buttons for ease of use and a name tag for immediate identification. These jumpsuits are meant to be dyed a specific colour that doesn't fit into the normal blue, orange or red combinations.</description>
					<graphicData>
						<texPath>Modules/Wardrobe/Clothing/Jumpsuits/UI/PrisonUniforms/PrisonJumpsuit_Custom</texPath>
					</graphicData>
					<apparel>
						<wornGraphicPath>Modules/Wardrobe/Clothing/Jumpsuits/PrisonUniforms/Custom/PrisonJumpsuit_Custom</wornGraphicPath>
					</apparel>
				</ThingDef>
			<!-- HIGH SECURITY -->
				<ThingDef ParentName="TMM_Jumpsuit_PrisonUniformBase">
