		<!-- PELT CAP -->
			<ThingDef ParentName="TMM_PeltClothingBase">
				<defName>TMM_Headwear_PeltCap</defName>
				<label>pelt cap</label>
				<description>This cap is made of animal fur.It's warm and protects the head.</description>
				<graphicData>
					<texPath>Modules/Wardrobe/Clothing/1_Neolithic/Headwear/Pelt/Cap/PeltCap</texPath>
				</graphicData>
				<costStuffCount>40</costStuffCount>
				<statBases>
					<MaxHitPoints>100</MaxHitPoints>
					<WorkToMake>6000</WorkToMake>
					<Mass>1.5</Mass>
					<StuffEffectMultiplierArmor>0.3</StuffEffectMultiplierArmor>
					<StuffEffectMultiplierInsulation_Cold>0.3</StuffEffectMultiplierInsulation_Cold>
					<StuffEffectMultiplierInsulation_Heat>0.2</StuffEffectMultiplierInsulation_Heat>
					<EquipDelay>1.5</EquipDelay>
				</statBases>
				<thingCategories>
					<li>Headgear</li>
				</thingCategories>
				<apparel>
					<bodyPartGroups>
						<li>UpperHead</li>
					</bodyPartGroups>
					<wornGraphicPath>Modules/Wardrobe/Clothing/1_Neolithic/Headwear/Pelt/Cap/PeltCap</wornGraphicPath>
					<layers>
						<li>Overhead</li>
					</layers>
					<defaultOutfitTags>
						<li>Soldier</li>
					</defaultOutfitTags>
				</apparel>
			</ThingDef>
		<!-- PELT MANTLE -->
			<ThingDef ParentName="TMM_PeltClothingBase">
				<defName>TMM_Bodywear_PeltMantle</defName>
				<label>pelt mantle</label>
				<description>This mantle is made from sewn animal pelts. It is one of the wisdom of the tribesmen to protect themselves from the cold.</description>
				<graphicData>
					<texPath>Modules/Wardrobe/Clothing/1_Neolithic/Bodywear/Pelt/Mantle/PeltMantle</texPath>
				</graphicData>
				<costStuffCount>80</costStuffCount>
				<thingCategories>
					<li>Apparel</li>
				</thingCategories>
				<statBases>
					<MaxHitPoints>100</MaxHitPoints>
					<WorkToMake>6000</WorkToMake>
					<Mass>2</Mass>
					<StuffEffectMultiplierArmor>0.45</StuffEffectMultiplierArmor>
					<StuffEffectMultiplierInsulation_Cold>1.0</StuffEffectMultiplierInsulation_Cold>
					<StuffEffectMultiplierInsulation_Heat>0.25</StuffEffectMultiplierInsulation_Heat>
					<EquipDelay>1.5</EquipDelay>
