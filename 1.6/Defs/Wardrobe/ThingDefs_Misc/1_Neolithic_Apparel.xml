					<apparel>
						<bodyPartGroups>
							<li>Torso</li>
							<li>Neck</li>
							<li>Shoulders</li>
							<li>Arms</li>
							<li>Legs</li>
						</bodyPartGroups>
						<layers>
							<li>Shell</li>
						</layers>
						<tags>
							<li>Neolithic</li>
						</tags>
						<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
					</apparel>
					<colorGenerator Class="ColorGenerator_Options">
						<options>
						<li>
							<weight>10</weight>
							<only>(0.4,0.3,0.15)</only>
						</li>
						<li>
							<weight>15</weight>
							<only>(0.6,0.45,0.18)</only>
						</li>
						<li>
							<weight>20</weight>
							<only>(0.8,0.6,0.23)</only>
						</li>
