		<!-- HELMETS -->
			<!-- CAPTAIN'S HELMET -->
				<ThingDef ParentName="TMM_Spacesuit_HelmetBase">
					<defName>TMM_Spacesuit_CaptainHelmet</defName>
					<label>gravship captain helmet</label>
					<description>A helmet that efficiently recycles the user's oxygen, allowing them to breathe in the vacuum of space for hours at a time. The process isn't perfectly efficient, so the user must periodically return to a pressurized environment. This helmet has been adorned with a hat often worn by gravship captains.</description>
					<graphicData>
						<texPath>Modules/Wardrobe/Clothing/Spacesuits/UI/Helmets/CaptainHelmet</texPath>
					</graphicData>
					<statBases>
						<WorkToMake>20000</WorkToMake>
						<MaxHitPoints>120</MaxHitPoints>
						<Mass>1.5</Mass>
						<Flammability>0.4</Flammability>
						<ArmorRating_Sharp>0.52</ArmorRating_Sharp>
						<ArmorRating_Blunt>0.24</ArmorRating_Blunt>
						<ArmorRating_Heat>0.66</ArmorRating_Heat>
						<Insulation_Cold>6</Insulation_Cold>
						<Insulation_Heat>4</Insulation_Heat>
						<EquipDelay>4</EquipDelay>
					</statBases>
					<equippedStatOffsets>
						<SocialImpact>0.20</SocialImpact>
						<ToxicEnvironmentResistance>0.8</ToxicEnvironmentResistance>
						<VacuumResistance MayRequire="ludeon.rimWorld.odyssey">0.69</VacuumResistance>
						<DecompressionResistance MayRequire="kentington.saveourship2">0.69</DecompressionResistance>
						<PilotingAbility MayRequire="ludeon.rimWorld.odyssey">0.15</PilotingAbility>
					</equippedStatOffsets>
					<apparel>
						<wornGraphicPath>Modules/Wardrobe/Clothing/Spacesuits/Helmets/Captain/CaptainHelmet</wornGraphicPath>
						<useWornGraphicMask>true</useWornGraphicMask>
					</apparel>
					<costList>
						<ComponentIndustrial>2</ComponentIndustrial>
						<Steel>40</Steel>
					</costList>
				</ThingDef>
			<!-- ODYSSEUS HELMET -->
				<ThingDef ParentName="TMM_Spacesuit_HelmetBase">
					<defName>TMM_Spacesuit_OdysseusHelmet</defName>
					<label>odysseus vacsuit helmet</label>
					<description>A helmet that efficiently recycles the user's oxygen, allowing them to breathe in the vacuum of space for hours at a time. The process isn't perfectly efficient, so the user must periodically return to a pressurized environment. This more rugged and advanced vacsuit strikes a balance between armor and agility which makes it a perfect middle ground between vacsuits and power armors and as such is favoured by independent explorer crews.</description>
					<graphicData>
						<texPath>Modules/Wardrobe/Clothing/Spacesuits/UI/Helmets/OdysseusHelmet</texPath>
					</graphicData>
					<statBases>
						<WorkToMake>30000</WorkToMake>
						<MaxHitPoints>120</MaxHitPoints>
						<Mass>1.5</Mass>
						<Flammability>0.4</Flammability>
						<ArmorRating_Sharp>0.62</ArmorRating_Sharp>
						<ArmorRating_Blunt>0.44</ArmorRating_Blunt>
						<ArmorRating_Heat>0.66</ArmorRating_Heat>
						<Insulation_Cold>6</Insulation_Cold>
						<Insulation_Heat>6</Insulation_Heat>
						<EquipDelay>4</EquipDelay>
					</statBases>
					<equippedStatOffsets>
						<PilotingAbility MayRequire="ludeon.rimWorld.odyssey">0.05</PilotingAbility>
						<ToxicEnvironmentResistance>0.8</ToxicEnvironmentResistance>
						<VacuumResistance MayRequire="ludeon.rimWorld.odyssey">0.69</VacuumResistance>
						<DecompressionResistance MayRequire="kentington.saveourship2">0.69</DecompressionResistance>
					</equippedStatOffsets>
					<apparel>
