		<!-- VICTORIAN CLOTHES -->
			<!-- ADVENTURE DRESS -->
				<ThingDef ParentName="TMM_VictorianDressBase">
					<defName>TMM_Dress_AdventureDress</defName>
					<label>adventure dress</label>
					<description>These sturdy dresses are made for active ladies who are looking for adventure and exploring new lands.</description>
					<graphicData>
						<texPath>Modules/Wardrobe/Clothing/OtherArticles/UI/Dresses/Adventure</texPath>
						<shaderType>CutoutComplex</shaderType>
					</graphicData>
					<costStuffCount>80</costStuffCount>
					<statBases>
						<MaxHitPoints>100</MaxHitPoints>
						<WorkToMake>10000</WorkToMake>
						<Mass>1.5</Mass>
						<StuffEffectMultiplierArmor>0.35</StuffEffectMultiplierArmor>
						<StuffEffectMultiplierInsulation_Cold>0.3</StuffEffectMultiplierInsulation_Cold>
						<StuffEffectMultiplierInsulation_Heat>0.3</StuffEffectMultiplierInsulation_Heat>
						<EquipDelay>1.5</EquipDelay>
					</statBases>
					<equippedStatOffsets>
						<SocialImpact>0.15</SocialImpact>
						<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.1</SlaveSuppressionOffset>
					</equippedStatOffsets>
					<apparel>
						<bodyPartGroups>
							<li>Neck</li>
							<li>Torso</li>
							<li>Shoulders</li>
							<li>Arms</li>
							<li>Legs</li>
						</bodyPartGroups>
						<wornGraphicPath>Modules/Wardrobe/Clothing/OtherArticles/Dresses/Adventure/Adventure</wornGraphicPath>
						<useWornGraphicMask>true</useWornGraphicMask>
						<tags>
							<li>IndustrialAdvanced</li>
						</tags>
					</apparel>
					<recipeMaker>
						<skillRequirements>
							<Crafting>4</Crafting>
						</skillRequirements>
					</recipeMaker>
				</ThingDef>
