		<!-- VICTORIAN DRESS BASE -->
			<ThingDef ParentName="ApparelMakeableBase" Name="TMM_VictorianDressBase" Abstract="True">
				<graphicData>
					<graphicClass>Graphic_Single</graphicClass>
				</graphicData>
				<stuffCategories>
					<li>Fabric</li>
					<li>Leathery</li>
				</stuffCategories>
				<tradeability>Sellable</tradeability>
				<thingCategories>
					<li>Apparel</li>
				</thingCategories>
				<apparel>
					<layers>
						<li>OnSkin</li>
					</layers>
					<gender>Female</gender>
				</apparel>
				<recipeMaker>
					<recipeUsers>
						<li>ElectricTailoringBench</li>
						<li>HandTailoringBench</li>
					</recipeUsers>
				</recipeMaker>
				<colorGenerator Class="ColorGenerator_StandardApparel" />
			</ThingDef>


