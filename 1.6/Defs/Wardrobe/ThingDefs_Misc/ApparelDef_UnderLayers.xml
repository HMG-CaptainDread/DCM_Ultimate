		<!-- SLIPSUIT -->
			<!-- ADULT -->
				<ThingDef ParentName="TMM_UnderLayer_SlipsuitBase">
					<defName>TMM_UnderLayer_VacSlipsuitAdult</defName>
					<label>Vac-Slipsuit</label>
					<description>A high-tech, skin-tight suit which offers some of the best protection from harsh environments available for gravship crews, special forces, explorers and scientists. It acts like a sort of second skin for the wearer. It monitors and regulates the body to keep it in working shape. It also comes with an invisible, thin vac-barrier hood for the head.</description>

					<graphicData>
						<texPath>Modules/Wardrobe/Clothing/UnderLayers/UI/Slipsuit</texPath>
					</graphicData>

					<apparel>
						<wornGraphicPath>Modules/Wardrobe/Clothing/UnderLayers/VacSlipSuit/Adult/Slipsuit</wornGraphicPath>
					</apparel>

					<costStuffCount>100</costStuffCount>

					<costList> <!-- TODO: -->
						<ComponentSpacer>2</ComponentSpacer>
						<Plasteel>10</Plasteel>
					</costList>
				</ThingDef>
			<!-- CHILD -->
				<ThingDef ParentName="TMM_UnderLayer_SlipsuitBase">
					<defName>TMM_UnderLayer_VacSlipsuitChild</defName>
					<label>Child Vac-Slipsuit</label>
					<description>A high-tech, skin-tight suit which offers some of the best protection from harsh environments available for gravship crews, special forces, explorers and scientists. It acts like a sort of second skin for the wearer. It monitors and regulates the body to keep it in working shape. It also comes with an invisible, thin vac-barrier hood for the head. This one's for kids.</description>

					<graphicData>
						<texPath>Modules/Wardrobe/Clothing/UnderLayers/UI/KidSlipsuit</texPath>
					</graphicData>

					<apparel>
						<developmentalStageFilter>Child</developmentalStageFilter>
						<wornGraphicPath>Modules/Wardrobe/Clothing/UnderLayers/VacSlipSuit/Child/SlipsuitKid</wornGraphicPath>
					</apparel>

					<costStuffCount>75</costStuffCount>

					<costList> <!-- TODO: -->
						<ComponentSpacer>1</ComponentSpacer>
						<Plasteel>5</Plasteel>
					</costList>
				</ThingDef>
	<!-- 6 - ARCHOTECH -->



	<!-- SORT -->
		<!-- NOMAD WEAR -->
			<ThingDef ParentName="ApparelMakeableBase">
				<defName>NS_NomadWear</defName>
				<label>nomadwear</label>
				<description>Those who believe the Archotechs to be divine often make their way to the most barren landscapes in search of lost technology, artifacts, and the coveted digital-psychic “soul transfiguration”.\nA bodysuit and waist cape that is the result of years of ingenuity, practical engineering, and scavenging ancient technology. Often worn by the survivors of a forgotten apocalypse who came to view their lost tech as divine, or entire tribes on harsh worlds who left everything behind to seek communion with the Archotechs. These signature clothes of nomads and seekers alike are rather simple to produce despite the relative sophistication of its technology.</description>
				<graphicData>
					<texPath>Modules/Wardrobe/Clothing/UnderLayers/UI/UnderRobe</texPath>
					<graphicClass>Graphic_Single</graphicClass>
					<shaderType>CutoutComplex</shaderType>
				</graphicData>
				<techLevel>Neolithic</techLevel>
				<costStuffCount>50</costStuffCount>
				<stuffCategories>
					<li>Fabric</li>
					<li>Leathery</li>
				</stuffCategories>
				<costList>
					<Steel>15</Steel>
					<ComponentIndustrial>1</ComponentIndustrial>
				</costList>
				<tradeability>Sellable</tradeability>
				<statBases>
					<MaxHitPoints>400</MaxHitPoints>
					<WorkToMake>2500</WorkToMake>
					<Mass>0.6</Mass>
					<!-- <ArmorRating_Sharp>0.08</ArmorRating_Sharp>
					<ArmorRating_Blunt>0.08</ArmorRating_Blunt> -->
					<!-- <ArmorRating_Heat>0.5</ArmorRating_Heat> -->
					<StuffEffectMultiplierArmor>0.26</StuffEffectMultiplierArmor>
					<StuffEffectMultiplierInsulation_Cold>0.75</StuffEffectMultiplierInsulation_Cold>
					<StuffEffectMultiplierInsulation_Heat>0.25</StuffEffectMultiplierInsulation_Heat>
					<EquipDelay>1.5</EquipDelay>
				</statBases>
				<equippedStatOffsets>
					<ToxicEnvironmentResistance>0.05</ToxicEnvironmentResistance>
				</equippedStatOffsets>
				<thingCategories>
					<li>ApparelMisc</li>
				</thingCategories>
				<apparel>
					<bodyPartGroups>
						<li>Torso</li>
						<li>Neck</li>
						<li>Shoulders</li>
						<li>Arms</li>
						<li>Legs</li>
					</bodyPartGroups>
					<wornGraphicPath>Modules/Wardrobe/Clothing/UnderLayers/Nomad/UnderRobe</wornGraphicPath>
					<useWornGraphicMask>true</useWornGraphicMask>
					<layers>
						<li>OnSkin</li>
					</layers>
					<tags>
						<li>Neolithic</li>
					</tags>
					<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
					<defaultOutfitTags>
						<li>Soldier</li>
					</defaultOutfitTags>
				</apparel>
				<recipeMaker>
					<skillRequirements>
						<Crafting>5</Crafting>
					</skillRequirements>
					<recipeUsers>
						<li>ElectricTailoringBench</li>
						<li>HandTailoringBench</li>
						<li>CraftingSpot</li>
					</recipeUsers>
					<displayPriority>200</displayPriority>
				</recipeMaker>
				<tradeTags>
					<li>BasicClothing</li>
				</tradeTags>
			</ThingDef>
</Defs>