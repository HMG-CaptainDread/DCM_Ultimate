		<!-- VAC SLIPSUIT -->
			<ThingDef ParentName="ApparelBase" Name="TMM_UnderLayer_SlipsuitBase" Abstract="True">
				<graphicData>
					<graphicClass>Graphic_Single</graphicClass>
				</graphicData>

				<statBases>
					<WorkToMake>40000</WorkToMake>
					<MaxHitPoints>180</MaxHitPoints>
					<Mass>5</Mass>
					<Flammability>0.2</Flammability>
					<ArmorRating_Sharp>0.3</ArmorRating_Sharp>
					<ArmorRating_Blunt>0.1</ArmorRating_Blunt>
					<ArmorRating_Heat>0.70</ArmorRating_Heat>
					<Insulation_Cold>90</Insulation_Cold>
					<Insulation_Heat>90</Insulation_Heat>
					<StuffEffectMultiplierArmor>0.2</StuffEffectMultiplierArmor>
					<EquipDelay>5</EquipDelay>
				</statBases>

				<equippedStatOffsets>
					<MoveSpeed>0.1</MoveSpeed>
					<VacuumResistance MayRequire="ludeon.rimWorld.odyssey">0.6</VacuumResistance>
					<DecompressionResistance MayRequire="kentington.saveourship2">0.6</DecompressionResistance>
					<ToxicEnvironmentResistance>0.5</ToxicEnvironmentResistance>
				</equippedStatOffsets>

				<thingCategories>
					<li>ApparelArmor</li>
				</thingCategories>

				<tradeTags>
					<li>HiTechArmor</li>
					<li>Armor</li>
				</tradeTags>

				<smeltable>true</smeltable>

				<apparel>
					<bodyPartGroups>
						<li>Torso</li>
						<li>Neck</li>
						<li>Shoulders</li>
						<li>Arms</li>
						<li>Legs</li>
					</bodyPartGroups>

					<layers>
						<li>TMM_ApparelLayer_UnderLayer</li>
					</layers>

					<tags>
						<li>Vacsuit</li>
					</tags>

					<defaultOutfitTags>
						<li>Spacefarer</li>
					</defaultOutfitTags>

					<soundWear>Wear_PowerArmor</soundWear>
					<soundRemove>Remove_PowerArmor</soundRemove>
					<canBeGeneratedToSatisfyWarmth>true</canBeGeneratedToSatisfyWarmth>
					<canBeGeneratedToSatisfyToxicEnvironmentResistance>true</canBeGeneratedToSatisfyToxicEnvironmentResistance>
				</apparel>

				<thingSetMakerTags>
					<li>RewardStandardMidFreq</li>
				</thingSetMakerTags>

				<stuffCategories>
					<li>Fabric</li>
				</stuffCategories>

				<recipeMaker>
					<unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
					<displayPriority>235</displayPriority>
					<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
					<workSkill>Crafting</workSkill>
					<effectWorking>Smith</effectWorking>
					<soundWorking>Recipe_Smith</soundWorking>

					<recipeUsers>
						<li>TableMachining</li>
					</recipeUsers>

					<researchPrerequisite>
						<li>Fabrication</li> <!-- TODO: -->
					</researchPrerequisite>
				</recipeMaker>
			</ThingDef>
