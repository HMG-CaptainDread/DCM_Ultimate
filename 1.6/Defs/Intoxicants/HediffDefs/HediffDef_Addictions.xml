	<!-- TMM_Addiction_ -->



	<!-- FLOXACAINE ADDICTION -->
		<HediffDef ParentName="AddictionBase">
			<defName>TMM_Addiction_Floxacine</defName>
			<description>what are you doing with this? Floxacine isn't addictive.</description>
			<hediffClass>Hediff_Addiction</hediffClass>
			<label>floxacine addiction</label>
			<chemicalNeed>TMM_Need_Floxacine</chemicalNeed>
			<comps>
				<li Class="HediffCompProperties_SeverityPerDay">
					<severityPerDay>-500.0</severityPerDay>
				</li>
			</comps>
			<stages>
				<li />
				<li>
					<label>withdrawal</label>
					<mentalStateGivers>
						<li>
							<mentalState>Binging_DrugExtreme</mentalState>
							<mtbDays>5000</mtbDays>
						</li>
					</mentalStateGivers>
				</li>
			</stages>
		</HediffDef>
	<!-- MECHSHROOM ADDICTION -->
