	<!-- SOLDIER PILL ADDICTION -->
		<HediffDef ParentName="AddictionBase">
			<defName>TMM_Addiction_SoldierPill</defName>
			<description>The pawn is adjusted to soldier pills, and if taken off of soldier pills, can cause severe digestion issues, non-stop exhaustion, and acute hunger.</description>
			<hediffClass>Hediff_Addiction</hediffClass>
			<label>soldier pill addiction</label>
			<chemicalNeed>TMM_Need_SoldierPill</chemicalNeed>
			<comps>
				<li Class="HediffCompProperties_SeverityPerDay">
					<severityPerDay>-0.0333</severityPerDay>
				</li>
			</comps>
			<stages>
				<li />
				<li>
					<label>withdrawal</label>
					<restFallFactor>3</restFallFactor>
					<hungerRateFactorOffset>3.0</hungerRateFactorOffset>
					<vomitMtbDays>.5</vomitMtbDays>
					<mentalStateGivers>
						<li>
							<mentalState>Binging_Food</mentalState>
							<mtbDays>5</mtbDays>
						</li>
					</mentalStateGivers>
				</li>
			</stages>
		</HediffDef>
	<!-- SUNSHINE -->
		<HediffDef ParentName="AddictionBase">
			<defName>TMM_Addiction_Sunshine</defName>
			<description>Sunshine has built up in the pawn's system and has become reliant on its euphoria. Withdrawal will cause the pawn to wander confused commonly.</description>
			<hediffClass>Hediff_Addiction</hediffClass>
			<label>sunshine addiction</label>
			<chemicalNeed>TMM_Need_Sunshine</chemicalNeed>
			<comps>
				<li Class="HediffCompProperties_SeverityPerDay">
					<severityPerDay>-.03333</severityPerDay>
				</li>
			</comps>
			<stages>
				<li />
				<li>
					<label>withdrawal</label>
					<mentalStateGivers>
						<li>
							<mentalState>WanderConfused</mentalState>
							<mtbDays>.5</mtbDays>
						</li>
					</mentalStateGivers>
				</li>
			</stages>
		</HediffDef>
	<!-- TANGO -->
		<HediffDef ParentName="AddictionBase">
			<defName>TMM_Addiction_Tango</defName>
			<description>the pawn now relies on Tango, and will become aggressive, tired, and less pain-resistant without regular dosages.</description>
			<hediffClass>Hediff_Addiction</hediffClass>
			<label>tango addiction</label>
			<chemicalNeed>TMM_Need_Tango</chemicalNeed>
			<comps>
				<li Class="HediffCompProperties_SeverityPerDay">
					<severityPerDay>-.03333</severityPerDay>
				</li>
			</comps>
			<stages>
				<li />
				<li>
					<label>withdrawal</label>
					<restFallFactor>1.75</restFallFactor>
					<painFactor>1.2</painFactor>
					<vomitMtbDays>.5</vomitMtbDays>
					<capMods>
						<li>
							<capacity>Consciousness</capacity>
							<postFactor>0.80</postFactor>
						</li>
					</capMods>
					<statOffsets>
						<MentalBreakThreshold>0.16</MentalBreakThreshold>
						<RestRateMultiplier>-0.50</RestRateMultiplier>
					</statOffsets>
					<mentalStateGivers>
						<li>
							<mentalState>Binging_DrugExtreme</mentalState>
							<mtbDays>30</mtbDays>
						</li>
						<li>
							<mentalState>Wander_Psychotic</mentalState>
							<mtbDays>15</mtbDays>
						</li>
					</mentalStateGivers>
				</li>
			</stages>
		</HediffDef>
</Defs>