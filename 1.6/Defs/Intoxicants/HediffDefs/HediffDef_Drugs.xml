	<!-- BLUESKY HIGH -->
		<HediffDef>
			<defName>TMM_Hediff_BlueSkyHigh</defName>
			<description>Blue Sky reduces rest factor by a little, increases conciousness and moving slightly, but greatly increases aggressiveness.</description>
			<hediffClass>HediffWithComps</hediffClass>
			<label>high on blue sky</label>
			<labelNoun>a blue sky high</labelNoun>
			<defaultLabelColor>(1,0,0.5)</defaultLabelColor>
			<scenarioCanAdd>true</scenarioCanAdd>
			<maxSeverity>1.0</maxSeverity>
			<isBad>false</isBad>
			<comps>
				<li Class="HediffCompProperties_SeverityPerDay">
					<severityPerDay>-1.5</severityPerDay>
				</li>
			</comps>
			<stages>
				<li>
					<restFallFactor>0.9</restFallFactor>
					<socialFightChanceFactor>3.0</socialFightChanceFactor>
					<capMods>
						<li>
							<capacity>Consciousness</capacity>
							<offset>0.1</offset>
						</li>
						<li>
							<capacity>Moving</capacity>
							<offset>0.1</offset>
						</li>
					</capMods>
					<statOffsets>
						<WorkSpeedGlobal>0.25</WorkSpeedGlobal>
					</statOffsets>
					<hediffGivers>
						<li Class="HediffGiver_Random">
							<hediff>HeartAttack</hediff>
							<mtbDays>80</mtbDays>
							<partsToAffect>
								<li>Heart</li>
							</partsToAffect>
						</li>
						<li Class="HediffGiver_Random">
							<hediff>ChemicalDamageModerate</hediff>
							<mtbDays>180</mtbDays>
							<partsToAffect>
								<li>Heart</li>
							</partsToAffect>
						</li>
					</hediffGivers>
					<mentalStateGivers>
						<li>
							<mentalState>Slaughterer</mentalState>
							<mtbDays>60</mtbDays>
						</li>
						<li>
							<mentalState>MurderousRage</mentalState>
							<mtbDays>75</mtbDays>
						</li>
						<li>
							<mentalState>Tantrum</mentalState>
							<mtbDays>30</mtbDays>
						</li>
						<li>
							<mentalState>BedroomTantrum</mentalState>
							<mtbDays>15</mtbDays>
						</li>
						<li>
							<mentalState>SadisticRage</mentalState>
							<mtbDays>45</mtbDays>
						</li>
						<li>
							<mentalState>Berserk</mentalState>
							<mtbDays>120</mtbDays>
						</li>
					</mentalStateGivers>
				</li>
			</stages>
		</HediffDef>
	<!-- FLOXACAINE HIGH -->
		<HediffDef>
			<defName>TMM_Hediff_FloxacineHigh</defName>
			<description>Floxacine boosts immunity almost completely. Taking floxacine too much can cause severe liver damage.</description>
			<hediffClass>HediffWithComps</hediffClass>
