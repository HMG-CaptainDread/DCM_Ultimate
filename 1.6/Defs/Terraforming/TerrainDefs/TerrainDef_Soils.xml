	<!-- ANIMA SOIL -->
		<TerrainDef ParentName="FloorBase">
			<defName>TMM_Soil_Anima</defName>
			<label>anima soil</label>
			<description>Synthetic loam engineered for starships. Too poor for crops, but anima and gauranlen roots can bite into it.</description>
			<!-- texture -->
			<texturePath>Modules/Terraforming/Terrain/Soil/Anima/AnimaSoilBlueGreen</texturePath>
			<!-- <texturePath>Terrain/Surfaces/AnimaSoilBlueGreen</texturePath> -->
			<!-- stats -->
			<fertility>0.10</fertility> <!-- psy-trees OK, crops NO -->
			<terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
			<statBases>
				<WorkToBuild>600</WorkToBuild>
				<Beauty>1</Beauty>
			</statBases>
			<pathCost>2</pathCost>
			<!-- build cost -->
			<costList>
				<Steel>4</Steel>
				<Chemfuel>2</Chemfuel>
			</costList>
			<!-- appears under Architect ▶ Floors immediately -->
			<designationCategory>TMM_TerraformingDesignator</designationCategory>
		</TerrainDef>
