	<!--  -->



	<!-- CHAMOMILE TEA -->
		<HediffDef ParentName="TMM_CompHediffGoodBase">
			<defName>TMM_ChamomileTeaEffect</defName>
			<label>Warm Embrace</label>
			<description>This pawn feels gentle warmth and ease. Chamomile boosts immunity and improves social connection.</description>
			<comps>
				<li Class="HediffCompProperties_SeverityPerDay">
					<severityPerDay>-2.4</severityPerDay>
					<showHoursToRecover>true</showHoursToRecover>
				</li>
			</comps>
			<stages>
				<li>
					<statOffsets>
						<ImmunityGainSpeed>0.1</ImmunityGainSpeed>
						<SocialImpact>0.15</SocialImpact>
					</statOffsets>
				</li>
			</stages>
		</HediffDef>
	<!-- GINKGO TEA -->
		<HediffDef ParentName="TMM_CompHediffGoodBase">
			<defName>TMM_GinkgoTeaEffect</defName>
			<label>Heart and Mind</label>
			<description>This pawn experiences improved clarity and circulation. Ginkgo tea stimulates brain and heart function.</description>
			<comps>
				<li Class="HediffCompProperties_SeverityPerDay">
					<severityPerDay>-2.0</severityPerDay>
					<showHoursToRecover>true</showHoursToRecover>
				</li>
			</comps>
			<stages>
				<li>
					<capMods>
						<li>
							<capacity>Consciousness</capacity>
							<offset>0.08</offset>
						</li>
						<li>
							<capacity>BloodFiltration</capacity>
							<offset>0.10</offset>
						</li>
					</capMods>
				</li>
			</stages>
		</HediffDef>
	<!-- LINDEN TEA -->
		<HediffDef ParentName="TMM_CompHediffGoodBase">
			<defName>TMM_LindenTeaEffect</defName>
			<label>Quiet Mind</label>
			<description>This pawn feels calm and relaxed, with aches eased and tension gently melting away thanks to the linden tea.</description>
			<comps>
				<li Class="HediffCompProperties_SeverityPerDay">
					<severityPerDay>-3.0</severityPerDay>
					<showHoursToRecover>true</showHoursToRecover>
				</li>
			</comps>
			<stages>
				<li>
					<painFactor>0.85</painFactor>
					<statOffsets>
						<MentalBreakThreshold>-0.4</MentalBreakThreshold>
					</statOffsets>
				</li>
			</stages>
		</HediffDef>
	<!-- THYME TEA -->
		<HediffDef ParentName="TMM_CompHediffGoodBase">
			<defName>TMM_ThymeTeaEffect</defName>
			<label>Breath of Life</label>
			<description>This pawn breathes easier and feels less fatigued. Thyme tea supports physical movement and clarity.</description>
			<comps>
				<li Class="HediffCompProperties_SeverityPerDay">
					<severityPerDay>-2.0</severityPerDay>
					<showHoursToRecover>true</showHoursToRecover>
				</li>
			</comps>
			<stages>
				<li>
					<capMods>
						<li>
							<capacity>Breathing</capacity>
							<offset>0.08</offset>
						</li>
						<li>
							<capacity>Moving</capacity>
							<offset>0.04</offset>
						</li>
					</capMods>
				</li>
			</stages>
		</HediffDef>
</Defs>