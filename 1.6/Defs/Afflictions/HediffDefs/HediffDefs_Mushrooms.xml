	<!-- FLY AGARIC POISONING -->
		<HediffDef ParentName="TMM_CompHediffBadBase">
			<defName>TMM_FlyAgaricPoisoning</defName>
			<label>Fly Agaric Poisoning</label>
			<description>This pawn has eaten a Fly Agaric mushroom. The toxins cloud the mind, bringing nausea, confusion, and strange hallucinations.</description>
			<comps>
				<li Class="HediffCompProperties_SeverityPerDay">
					<severityPerDay>-0.5</severityPerDay>
					<showHoursToRecover>true</showHoursToRecover>
				</li>
			</comps>
			<stages>
				<li>
					<capMods>
						<li>
							<capacity>Consciousness</capacity>
							<offset>-0.10</offset>
						</li>
						<li>
							<capacity>Manipulation</capacity>
							<offset>-0.40</offset>
						</li>
						<li>
							<capacity>Sight</capacity>
							<offset>-0.50</offset>
						</li>
						<li>
							<capacity>Moving</capacity>
							<offset>-0.30</offset>
						</li>
					</capMods>
					<statOffsets>
						<GlobalLearningFactor>-1.0</GlobalLearningFactor>
					</statOffsets>
					<statFactors>
						<RestFallRateFactor>1.4</RestFallRateFactor>
					</statFactors>
				</li>
			</stages>
		</HediffDef>
	<!-- FOOL'S FUNNEL POISONING -->
		<HediffDef ParentName="TMM_CompHediffBadBase">
			<defName>TMM_FoolsFunnelPoisoning</defName>
			<label>Fool's Funnel Poisoning</label>
			<description>This pawn has eaten a Fool's Funnel mushroom. Dangerous muscarine toxins disrupt the body, causing sweating, weakness, stomach distress, and fading consciousness.</description>
			<comps>
				<li Class="HediffCompProperties_SeverityPerDay">
					<severityPerDay>-1.0</severityPerDay>
					<showHoursToRecover>true</showHoursToRecover>
				</li>
			</comps>
			<stages>
				<li>
					<painFactor>1.5</painFactor>
					<capMods>
						<li>
							<capacity>Consciousness</capacity>
							<offset>-0.20</offset>
						</li>
						<li>
							<capacity>Manipulation</capacity>
							<offset>-0.25</offset>
						</li>
						<li>
							<capacity>Moving</capacity>
							<offset>-0.35</offset>
						</li>
					</capMods>
					<statOffsets>
						<GlobalLearningFactor>-0.25</GlobalLearningFactor>
					</statOffsets>
					<statFactors>
						<RestFallRateFactor>1.2</RestFallRateFactor>
					</statFactors>
				</li>
			</stages>
		</HediffDef>
	<!-- JACK-O'-LANTERN POISONING -->
		<HediffDef ParentName="TMM_CompHediffBadBase">
			<defName>TMM_JackOLanternPoisoning</defName>
			<label>Jack-o'-Lantern Poisoning</label>
			<description>This pawn has consumed a Jack-o'-Lantern mushroom. The toxins cause violent stomach distress, bringing intense cramps, nausea, and relentless vomiting.</description>
			<comps>
				<li Class="HediffCompProperties_SeverityPerDay">
					<severityPerDay>-0.3</severityPerDay>
					<showHoursToRecover>true</showHoursToRecover>
				</li>
			</comps>
			<stages>
				<li>
					<painFactor>2.0</painFactor>
					<capMods>
						<li>
							<capacity>Moving</capacity>
							<offset>-0.20</offset>
						</li>
					</capMods>
					<statOffsets>
						<GlobalLearningFactor>-0.20</GlobalLearningFactor>
					</statOffsets>
					<statFactors>
						<RestFallRateFactor>1.2</RestFallRateFactor>
					</statFactors>
				</li>
			</stages>
		</HediffDef>
</Defs>