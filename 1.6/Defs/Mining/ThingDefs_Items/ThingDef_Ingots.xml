				<SharpDamageMultiplier>0.8</SharpDamageMultiplier>
				<BluntDamageMultiplier>0.92</BluntDamageMultiplier>
			</statBases>

			<stuffProps>
				<color>(236,146,121)</color>
				<commonality>0.8</commonality>

				<statFactors>
					<MaxHitPoints>0.7</MaxHitPoints>
					<Beauty>1.05</Beauty>
					<WorkToMake>0.75</WorkToMake>
					<WorkToBuild>0.75</WorkToBuild>
					<MeleeWeapon_CooldownMultiplier>1.2</MeleeWeapon_CooldownMultiplier>
