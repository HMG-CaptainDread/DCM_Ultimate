	<!-- LEAD -->
		<ThingDef ParentName="TMM_IngotBase">
			<defName>TMM_Ingot_Lead</defName>
			<label>lead</label>
			<description>A heavy, dark gray-bluish metal that is malleable and soft. While it is not very suitable for weapons and armor due to its weight and low resistance, lead is a very useful metal. It is widely used as a chemical additive and to make industrial batteries. It is also an essential material in the weapon industry, being the main component of most bullets and ammunition. Lead is toxic to the human body, and can contaminate soil and food if it evaporates or burns. Lead poisoning can cause chemical damage to the kidneys and brain, and if not tended properly, death.</description>

			<graphicData>
				<color>(126,136,148)</color>
			</graphicData>

			<statBases>
				<MarketValue>2.4</MarketValue>
				<Mass>0.15</Mass>
