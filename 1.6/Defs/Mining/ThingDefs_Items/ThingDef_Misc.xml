	<!-- COAL -->
		<ThingDef ParentName="TMM_ResourceBase">
			<defName>TMM_Resource_Coal</defName>
			<label>coal</label>
			<description>A combustible, black sedimentary rock formed by dead plant matter turned into peat and converted into coal by the heat and pressure of deep burial over millions of years. Coal is mostly carbon with variable amounts of other elements. It is used as a common fuel and also as a source of carbon, which is required in some important alloys like steel.</description>

			<graphicData>
				<texPath>Modules/Mining/Things/Resources/Coal</texPath>
			</graphicData>

			<statBases>
				<MaxHitPoints>120</MaxHitPoints>
				<Flammability>0.8</Flammability>
				<DeteriorationRate>0.4</DeteriorationRate>
				<MarketValue>1</MarketValue>
				<Mass>0.35</Mass>
			</statBases>

			<deepCommonality>4</deepCommonality>
			<deepCountPerPortion>40</deepCountPerPortion>
			<deepLumpSizeRange>25~50</deepLumpSizeRange>
			<burnableByRecipe>false</burnableByRecipe>
		</ThingDef>
	<!-- METALS -->
		<!-- GALLIUM -->
			<ThingDef ParentName="TMM_OreBase">
				<defName>TMM_Ore_Gallium</defName>
				<label>gallium</label>
				<description>A rare metal that almost melts at ambient temperature</description>

				<graphicData>
					<texPath>Modules/Mining/Things/Ores/Gallium</texPath>
				</graphicData>

				<statBases>
					<MarketValue>2.4</MarketValue>
				</statBases>
			</ThingDef>
		<!-- GERMANIUM -->
			<ThingDef ParentName="TMM_OreBase">
				<defName>TMM_Ore_Germanium</defName>
				<label>germanium</label>
				<description>A lustrous greyish-white metal very valuable in advanced industry and microelectronics. Germanium is rare, and can only be found scattered in very small amounts in some rocks. It is widely used in the production of optical elements and microelectronic components such as chips and processors.</description>

				<graphicData>
					<texPath>Modules/Mining/Things/Ores/Germanium</texPath>
				</graphicData>

				<statBases>
					<MarketValue>2.8</MarketValue>
				</statBases>
			</ThingDef>
		<!-- SILICON -->
			<ThingDef ParentName="TMM_OreBase">
				<defName>TMM_Ore_Silicon</defName>
				<label>silicon</label>
				<description>A silver, brittle metal found scattered across planets. Despite its abundance, it does not occur pure as other minerals, finding it requires drilling for deep veins and processing certain types of rocks. Silicon is widely used as a mineral additive to various materials like mortars, porcelain or glass, but its most important implementation is as a semiconductor for microelectronics and integrated circuits.</description>

				<graphicData>
					<texPath>Modules/Mining/Things/Ores/Silicon</texPath>
				</graphicData>

				<statBases>
					<MarketValue>2.9</MarketValue>
				</statBases>

				<deepCommonality>2</deepCommonality>
				<deepCountPerPortion>40</deepCountPerPortion>
				<deepLumpSizeRange>8~12</deepLumpSizeRange>
			</ThingDef>
</Defs>