	<!-- BASE -->
		<ThingDef ParentName="RockBase" Name="TMM_Rock_GemBase" Abstract="True">
			<graphicData>
				<texPath>Things/Building/Linked/RockFlecked_Atlas</texPath>
				<graphicClass>Graphic_Single</graphicClass>
				<shaderType>CutoutComplex</shaderType>
			</graphicData>

			<statBases>
				<MaxHitPoints>1500</MaxHitPoints>
			</statBases>

			<building>
				<isResourceRock>true</isResourceRock>
				<mineableYield>30</mineableYield>
				<mineableScatterCommonality>0.012</mineableScatterCommonality>
				<mineableScatterLumpSizeRange>2~6</mineableScatterLumpSizeRange>
				<veinMineable IgnoreIfNoMatchingField="True">true</veinMineable>
			</building>
		</ThingDef>
