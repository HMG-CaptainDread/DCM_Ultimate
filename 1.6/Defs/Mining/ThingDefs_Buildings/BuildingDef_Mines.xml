	<!-- TMM_Mine_ -->




	<!-- MINE -->
		<ThingDef ParentName="BuildingBase">
			<defName>TMM_Mine_Medieval</defName>
			<label>medieval mine</label>
			<description>A place for your pawns to excavate the treasures of the earth</description>
			<thingClass>Building_WorkTable</thingClass>
			<designationCategory>Production</designationCategory>
			<graphicData>
				<texPath>Modules/Mining/Buildings/Mines/Medieval/Mineshaft</texPath>
				<graphicClass>Graphic_Multi</graphicClass>
				<shaderType>CutoutComplex</shaderType>
				<drawSize>(5,5)</drawSize>
				<drawRotated>false</drawRotated>
			</graphicData>
			<size>(5,4)</size>
			<rotatable>true</rotatable>
			<fillPercent>0.75</fillPercent>
			<passability>PassThroughOnly</passability>
			<pathCost>70</pathCost>
			<blockWind>true</blockWind>
			<statBases>
				<MaxHitPoints>200</MaxHitPoints>
				<WorkToBuild>2400</WorkToBuild>
				<Flammability>1.0</Flammability>
				<Beauty>-25</Beauty>
			</statBases>
			<hasInteractionCell>true</hasInteractionCell>
			<interactionCellOffset>(0,0,-2)</interactionCellOffset>
			<inspectorTabs>
				<li>ITab_Bills</li>
			</inspectorTabs>
			<stuffCategories>
				<li>Woody</li>
				<li>Stony</li>
			</stuffCategories>
			<costStuffCount>100</costStuffCount>
			<costList>
				<Steel>10</Steel>
			</costList>
			<drawerType>MapMeshAndRealTime</drawerType>
			<terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
			<altitudeLayer>Building</altitudeLayer>
			<drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
		</ThingDef>
</Defs>