	<!-- TMM_Mineable_ -->



	<!-- BASE -->
		<ThingDef ParentName="RockBase" Name="TMM_Rock_MetalBase" Abstract="True">
			<graphicData>
				<texPath>Things/Building/Linked/RockFlecked_Atlas</texPath>
				<graphicClass>Graphic_Single</graphicClass>
				<shaderType>CutoutComplex</shaderType>
			</graphicData>

			<statBases>
				<MaxHitPoints>900</MaxHitPoints>
			</statBases>

			<building>
				<isResourceRock>true</isResourceRock>
				<mineableYield>50</mineableYield>
				<mineableScatterCommonality>1.1</mineableScatterCommonality>
				<mineableScatterLumpSizeRange>12~25</mineableScatterLumpSizeRange>
				<veinMineable IgnoreIfNoMatchingField="True">true</veinMineable>
			</building>
		</ThingDef>
