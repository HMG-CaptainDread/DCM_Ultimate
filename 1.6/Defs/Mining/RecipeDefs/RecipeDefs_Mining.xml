	<!-- MINING BASE -->
		<RecipeDef Name="TMM_MineableRecipeBase" Abstract="True">
			<jobString>Mining.</jobString>
			<workSpeedStat>MiningSpeed</workSpeedStat>
			<effectWorking>CutStone</effectWorking>
