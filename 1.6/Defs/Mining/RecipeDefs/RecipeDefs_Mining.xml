		</RecipeDef>
	<!-- MINERALS -->
		<!-- SALT -->
			<!-- MINE SALT -->
				<RecipeDef ParentName="TMM_MineableRecipeBase">
					<defName>TMM_MineSalt</defName>
					<label>Mine Salt</label>
					<description>Mine salt from rough stone.</description>
					<workAmount>1000</workAmount>
					<products>
						<VCE_Salt>5</VCE_Salt>
					</products>
				</RecipeDef>
			<!-- MINE SALT (BULK) -->
				<RecipeDef ParentName="TMM_MineableRecipeBase">
					<defName>TMM_MineSaltBulk</defName>
					<label>Mine Salt (Large Scale)</label>
					<description>Mine a larger amount of salt from rough stone. Takes more work, but more efficient in the long run.</description>
					<workAmount>2000</workAmount>
					<products>
						<VCE_Salt>20</VCE_Salt>
					</products>
				</RecipeDef>
