<Defs>
	<!-- <></> -->
	<!-- Modules/Transport/Vehicles/Air/Arnie_Helicopter/ArnieHelicopter -->



	<Vehicles.VehicleBuildDef ParentName="VehicleBaseBuildable">
		<defName>TMM_VehicleBlueprint_Arnie</defName>
		<label>Arnie</label>
		<description>The Arnie "Pie-in-the-Sky" helicopter has been in production for many years, a utility helicopter of the Newton family of helicopters popular with law enforcement and newscasters reporting on the most recent pileup of ore runners on industrial-worlds.</description>

		<designationCategory>TMM_TransportDesignator</designationCategory>
		<graphicData>
			<texPath>Modules/Transport/Vehicles/Air/Arnie_Helicopter/ArnieHelicopter</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(5, 9)</drawSize>
		</graphicData>

		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>24000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>

		<size>(3,7)</size>

		<researchPrerequisites>
			<li>VVE_ComplexVehicles</li>
		</researchPrerequisites>

		<costList>
			<VVE_EngineBlock>4</VVE_EngineBlock>
			<VVE_CarAlternator>4</VVE_CarAlternator>
			<VVE_CarExhaust>2</VVE_CarExhaust>
			<VVE_CarFuelTank>1</VVE_CarFuelTank>
			<VVE_CarTransmission>2</VVE_CarTransmission>
			<VVE_CarRadiator>1</VVE_CarRadiator>
			<VVE_CarWiring>4</VVE_CarWiring>
			<VVE_CarBattery>1</VVE_CarBattery>
			<Steel>420</Steel>
			<ComponentIndustrial>15</ComponentIndustrial>
		</costList>

		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>

		<thingToSpawn>TMM_Vehicle_Arnie</thingToSpawn>

		<constructionSkillPrerequisite>5</constructionSkillPrerequisite>
	</Vehicles.VehicleBuildDef>
</Defs>