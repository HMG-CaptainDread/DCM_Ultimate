	<Vehicles.VehicleBuildDef ParentName="VehicleBaseBuildable">
		<defName>TMM_VehicleBlueprint_Slammer</defName>
		<label>Slammer</label>
		<description>The Slammer is a bus chassis that was manufactured by for a wide variety of uses. Primarily manufactured as a means to shift a large number of people (mostly prisoners or school attendees) across planets all over the universe.</description>

		<designationCategory>TMM_TransportDesignator</designationCategory>
		<graphicData>
			<texPath>Modules/Transport/Vehicles/Land/Slammer_Bus/SlammerBus</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(3,8)</drawSize>
		</graphicData>
		
		<statBases>
			<MaxHitPoints>700</MaxHitPoints>
			<WorkToBuild>20000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		
		<size>(2,7)</size>
		
		<researchPrerequisites>
			<li>VVE_ComplexVehicles</li>
		</researchPrerequisites>
		
		<costList>
			<!-- <EngineMedium>1</EngineMedium> TODO: -->
			<VVE_CarAlternator>2</VVE_CarAlternator>
			<VVE_CarExhaust>2</VVE_CarExhaust>
			<VVE_CarSuspension>4</VVE_CarSuspension>
			<!-- <ComponentWheelTire>4</ComponentWheelTire> TODO: -->
			<VVE_CarBattery>1</VVE_CarBattery>
			<VVE_CarFuelTank>1</VVE_CarFuelTank>
			<Steel>350</Steel>
			<ComponentIndustrial>35</ComponentIndustrial>
		</costList>
		
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		
		<thingToSpawn>TMM_Vehicle_Slammer</thingToSpawn>
		
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
	</Vehicles.VehicleBuildDef>
</Defs>