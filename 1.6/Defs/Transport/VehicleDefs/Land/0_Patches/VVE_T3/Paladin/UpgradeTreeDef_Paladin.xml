	<Vehicles.UpgradeTreeDef ParentName="TMM_UpgradeTree_WheeledLandBase">
		<defName>TMM_UpgradeTree_Paladin</defName>

		<nodes>
			<!-- ESCORT TURRETS -->
				<li>
					<key>EscortTurrets_Paladin</key>
					<label>Escort Turrets</label>
