<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!-- <></> -->
	<!--  -->



	<Vehicles.UpgradeTreeDef ParentName="TMM_UpgradeTree_WheeledLandBase">
		<defName>TMM_UpgradeTree_Lightning</defName>

		<nodes>
			<!-- PERFORMANCE WHEELS -->
				<li>
					<key>PerformanceWheels_Lightning</key>
					<label>Performance Wheels</label>
					<description>Install advanced high performance wheels that improve grip, increasing the top speed of the vehicle.</description>

					<icon>Modules/Transport/UI/Upgrades/Upgrade_BigRims</icon>

					<work>1200</work>

					<gridCoordinate>(3, 3)</gridCoordinate>
					<drawSize>(80, 80)</drawSize>

					<upgrades>
						<li Class="Vehicles.StatUpgrade">
							<vehicleStats>
								<li>
									<def>MoveSpeed</def>
									<value>1</value>
								</li>
							</vehicleStats>
							<statCategories>
								<li>
									<def>WorldSpeedMultiplier</def>
									<value>0.15</value>
									<type>Add</type>
								</li>
							</statCategories>
						</li>
					</upgrades>

					<ingredients>
						<VVE_CarWheel>4</VVE_CarWheel>
						<Plasteel>25</Plasteel>
						<Chemfuel>50</Chemfuel>
					</ingredients>

					<graphicOverlays>
						<li>
							<graphicData>
								<texPath>Modules/Transport/Upgrades/Land/Lightning_Sport/PerformanceWheels/PerformanceWheels</texPath>
								<graphicClass>Vehicles.Graphic_Vehicle</graphicClass>
								<drawSize>(3,5)</drawSize>
								<layer>1</layer>
								<shaderType>CutoutComplex</shaderType>
							</graphicData>
						</li>
					</graphicOverlays>
				</li>
			<!-- RACING SPOILER -->
				<li>
					<key>Spoiler_Lightning</key>
					<label>Racing Spoiler</label>
					<description>Install a lightweight plasteel spoiler that improves downforce, increasing the top speed of the vehicle.</description>

					<icon>Modules/Transport/UI/Upgrades/Upgrade_Spoiler</icon>

					<work>2400</work>

					<gridCoordinate>(9, 3)</gridCoordinate>
					<drawSize>(80, 80)</drawSize>

					<upgrades>
						<li Class="Vehicles.StatUpgrade">
							<vehicleStats>
								<li>
									<def>MoveSpeed</def>
									<value>2</value>
								</li>
							</vehicleStats>
							<statCategories>
								<li>
									<def>WorldSpeedMultiplier</def>
									<value>0.3</value>
									<type>Add</type>
								</li>
							</statCategories>
						</li>
					</upgrades>

					<ingredients>
						<Plasteel>45</Plasteel>
						<ComponentIndustrial>1</ComponentIndustrial>
					</ingredients>

					<graphicOverlays>
						<li>
							<graphicData>
								<texPath>Modules/Transport/Upgrades/Land/Lightning_Sport/RacingSpoiler/RacingSpoiler</texPath>
								<graphicClass>Vehicles.Graphic_Vehicle</graphicClass>
								<drawSize>(3,5)</drawSize>
								<layer>2</layer>
								<shaderType>CutoutComplex</shaderType>
							</graphicData>
						</li>
					</graphicOverlays>
				</li>
		</nodes>
	</Vehicles.UpgradeTreeDef>
</Defs>