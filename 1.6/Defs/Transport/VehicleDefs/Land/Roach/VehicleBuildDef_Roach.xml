	<!--  -->



	<Vehicles.VehicleBuildDef ParentName="VehicleBaseBuildable">
		<defName>TMM_VehicleBlueprint_Roach</defName>
		<label>Roach</label>
		<description>An industrial garbage hauler that can potentially carry an insanely significant amount of cargo. While it cannot hold very much fuel or move very fast in comparison, its function of large-scale transport more than makes up for it.\n\n&lt;color=#bb8f04&gt;Crew:&lt;/color&gt; Driver x1, Passenger x1\n&lt;color=#bb8f04&gt;Fuel type:&lt;/color&gt; Chemfuel</description>

		<designationCategory>TMM_TransportDesignator</designationCategory>
		<graphicData>
			<texPath>Modules/Transport/Vehicles/Land/Roach_Truck/RoachTruck</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(4,7)</drawSize>
		</graphicData>

		<statBases>
			<MaxHitPoints>500</MaxHitPoints> <!-- TO ADJUST! -->
			<WorkToBuild>11000</WorkToBuild> <!-- TO ADJUST! -->
			<Flammability>0.05</Flammability>
		</statBases>

		<size>(3,6)</size>

		<researchPrerequisites>
			<li>VVE_ComplexVehicles</li>
		</researchPrerequisites>

		<costList>
			<VVE_EngineBlock>2</VVE_EngineBlock>
			<VVE_CarAlternator>2</VVE_CarAlternator>
			<VVE_CarExhaust>2</VVE_CarExhaust>
			<VVE_CarSuspension>6</VVE_CarSuspension>
			<VVE_CarWheel>6</VVE_CarWheel>
			<Steel>300</Steel> <!-- TO ADJUST! -->
			<ComponentIndustrial>6</ComponentIndustrial> <!-- TO ADJUST! -->
			<VVE_CarFuelTank>1</VVE_CarFuelTank>
			<VVE_CarTransmission>1</VVE_CarTransmission>
			<VVE_CarRadiator>2</VVE_CarRadiator>
		</costList>

		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>

		<thingToSpawn>TMM_Vehicle_Roach</thingToSpawn>

		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
	</Vehicles.VehicleBuildDef>
</Defs>