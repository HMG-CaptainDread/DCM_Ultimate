<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!-- <></> -->
	<!--  -->



	<Vehicles.UpgradeTreeDef ParentName="TMM_UpgradeTree_WheeledLandBase">
		<defName>TMM_UpgradeTree_Soho</defName>

		<nodes>
			<!-- ARMOURS -->
				<!-- TIER 1 -->
					<li>
						<key>ArmourT1_Soho</key>
						<label>Mesh Armour</label>
						<description>By welding a wire mesh across all the windows, the vehicle will fare better against most low impact projectiles such as bottles and rocks.</description>

						<icon>Modules/Transport/UI/Upgrades/Upgrade_Armour_T1</icon>

						<work>1200</work>

						<gridCoordinate>(3, 3)</gridCoordinate>
						<drawSize>(80, 80)</drawSize>

						<disableIfUpgradeNodesEnabled>
							<li>ArmourT2_Soho</li>
						</disableIfUpgradeNodesEnabled>

						<upgrades>
							<li Class = "Vehicles.StatUpgrade">
								<vehicleStats>
									<li>
										<def>Mass</def>
										<value>30</value>
									</li>
								</vehicleStats>
								<stats>
									<li>
										<def>ArmorRating_Sharp</def>
										<value>0.12</value>
									</li>
									<li>
										<def>ArmorRating_Blunt</def>
										<value>0.08</value>
									</li>
								</stats>
							</li>
						</upgrades>

						<ingredients>
							<Steel>60</Steel>
						</ingredients>

						<graphicOverlays>
							<li>
								<graphicData>
									<texPath>Modules/Transport/Upgrades/Land/Soho_SUV/Armour_T1/WireArmour</texPath>
									<graphicClass>Vehicles.Graphic_Vehicle</graphicClass>
									<drawSize>(3, 5)</drawSize>
									<layer>2</layer>
									<shaderType>CutoutComplexPattern</shaderType>
								</graphicData>
							</li>
						</graphicOverlays>
					</li>
				<!-- TIER 2 -->
					<li>
						<key>ArmourT2_Soho</key>
						<label>Plate Armour</label>
						<description>Utilising armoured techniques common on LAVs and MRAPs, the vehicle will be protected from most small arms fire, albeit slower, and heavier.</description>

						<icon>Modules/Transport/UI/Upgrades/Upgrade_Armour_T2</icon>

						<work>1800</work>

						<gridCoordinate>(9, 3)</gridCoordinate>
						<drawSize>(80, 80)</drawSize>

						<disableIfUpgradeNodesEnabled>
							<li>ArmourT1_Soho</li>
						</disableIfUpgradeNodesEnabled>

						<upgrades>
							<li Class = "Vehicles.StatUpgrade">
								<vehicleStats>
									<li>
										<def>AccelerationRate</def>
										<value>-0.01</value>
									</li>
									<li>
										<def>Mass</def>
										<value>90</value>
									</li>
								</vehicleStats>
								<stats>
									<li>
										<def>ArmorRating_Sharp</def>
										<value>0.28</value>
									</li>
									<li>
										<def>ArmorRating_Blunt</def>
										<value>0.18</value>
									</li>
								</stats>
							</li>
						</upgrades>

						<ingredients>
							<Steel>120</Steel>
						</ingredients>

						<graphicOverlays>
							<li>
								<graphicData>
									<texPath>Modules/Transport/Upgrades/Land/Soho_SUV/Armour_T2/PlateArmour</texPath>
									<graphicClass>Vehicles.Graphic_Vehicle</graphicClass>
									<drawSize>(3, 5)</drawSize>
									<layer>2</layer>
									<shaderType>CutoutComplexPattern</shaderType>
								</graphicData>
							</li>
						</graphicOverlays>
					</li>
			<!-- ROOF RACK -->
				<!-- TIER 1 -->
					<li>
						<key>RoofRackT1_Soho</key>
						<label>Roof Rack</label>
						<description>Made up of welded steel struts, the roof rack will give plenty of storage for the budding rimworld explorer or safari goer.</description>

						<icon>Modules/Transport/UI/Upgrades/Upgrade_RoofRack_T1</icon>

						<work>1200</work>

						<gridCoordinate>(15, 3)</gridCoordinate>
						<drawSize>(80, 80)</drawSize>

						<disableIfUpgradeNodesEnabled>
							<li>RoofRackT2_Soho</li>
						</disableIfUpgradeNodesEnabled>

						<upgrades>
							<li Class = "Vehicles.StatUpgrade">
								<vehicleStats>
									<li>
										<def>CargoCapacity</def>
										<value>100</value>
									</li>
								</vehicleStats>
							</li>
						</upgrades>

						<ingredients>
							<Steel>80</Steel>
						</ingredients>

						<graphicOverlays>
							<li>
								<graphicData>
									<texPath>Modules/Transport/Upgrades/Land/Soho_SUV/RoofRack_T1/RoofRackT1</texPath>
									<graphicClass>Vehicles.Graphic_Vehicle</graphicClass>
									<drawSize>(3, 5)</drawSize>
									<layer>3</layer>
									<shaderType>CutoutComplexPattern</shaderType>
								</graphicData>
							</li>
						</graphicOverlays>
					</li>
				<!-- TIER 2 -->
					<li>
						<key>RoofRackT2_Soho</key>
						<label>Roof Rack with Box</label>
						<description>To protect against the worst environments that the universe has to throw at any possible cargo. Attach spacious and gyroscopic boxes to a roof rack to protect them, and offer even more space to store things.</description>

						<icon>Modules/Transport/UI/Upgrades/Upgrade_RoofRack_T2</icon>

						<work>1800</work>

						<gridCoordinate>(21, 3)</gridCoordinate>
						<drawSize>(80, 80)</drawSize>

						<disableIfUpgradeNodesEnabled>
							<li>RoofRackT1_Soho</li>
						</disableIfUpgradeNodesEnabled>

						<upgrades>
							<li Class = "Vehicles.StatUpgrade">
								<vehicleStats>
									<li>
										<def>CargoCapacity</def>
										<value>150</value>
									</li>
								</vehicleStats>
							</li>
						</upgrades>

						<ingredients>
							<Steel>40</Steel>
							<Cloth>120</Cloth>
						</ingredients>

						<graphicOverlays>
							<li>
								<graphicData>
									<texPath>Modules/Transport/Upgrades/Land/Soho_SUV/RoofRack_T2/RoofRackT2</texPath>
									<graphicClass>Vehicles.Graphic_Vehicle</graphicClass>
									<drawSize>(3, 5)</drawSize>
									<layer>3</layer>
									<shaderType>CutoutComplexPattern</shaderType>
								</graphicData>
							</li>
						</graphicOverlays>
					</li>
		</nodes>
	</Vehicles.UpgradeTreeDef>
</Defs>