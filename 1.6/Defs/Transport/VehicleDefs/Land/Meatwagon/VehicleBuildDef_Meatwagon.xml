	<Vehicles.VehicleBuildDef ParentName="VehicleBaseBuildable">
		<defName>TMM_VehicleBlueprint_Meatwagon</defName>
		<label>Meatwagon</label>
		<description>The Meatwagon is a family of larger vehicles, a versatile choice and popular with both medical and fire departments to aid in emergency responses.</description>

		<designationCategory>TMM_TransportDesignator</designationCategory>
		<graphicData>
			<texPath>Modules/Transport/Vehicles/Land/Meatwagon_Ambulance/MeatwagonAmbulance</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(3,6)</drawSize>
		</graphicData>
		
		<statBases>
			<MaxHitPoints>700</MaxHitPoints>
			<WorkToBuild>12000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		
		<size>(2,5)</size>
		
		<researchPrerequisites>
			<li>VVE_ComplexVehicles</li>
		</researchPrerequisites>
		
		<costList>
			<!-- <EngineMedium>1</EngineMedium> TODO: -->
			<VVE_CarAlternator>2</VVE_CarAlternator>
			<VVE_CarExhaust>2</VVE_CarExhaust>
			<VVE_CarSuspension>4</VVE_CarSuspension>
			<!-- <ComponentWheelTire>4</ComponentWheelTire> TODO: -->
			<VVE_CarBattery>1</VVE_CarBattery>
			<VVE_CarFuelTank>1</VVE_CarFuelTank>
			<Steel>290</Steel>
			<ComponentIndustrial>20</ComponentIndustrial>
		</costList>
		
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		
		<thingToSpawn>TMM_Vehicle_Meatwagon</thingToSpawn>
		
		<constructionSkillPrerequisite>7</constructionSkillPrerequisite>
	</Vehicles.VehicleBuildDef>
