<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!-- <></> -->
	<!--  -->



	<Vehicles.VehicleBuildDef ParentName="VehicleBaseBuildable">
		<defName>TMM_VehicleBlueprint_Barter</defName>
		<label>Barter</label>
		<description>The Barter is a 2-ton cargo truck which has been a frequent flier of trading companies within the universe due to its hardy nature, and spacious cargo bed. Initially used by military logistics, this family of trucks was then subsequently utilised for civilian operations wherever they remained as military surplus, this civilian use saw it evolve a family of specialisations.</description>

		<designationCategory>TMM_TransportDesignator</designationCategory>
		<graphicData>
			<texPath>Modules/Transport/Vehicles/Land/Barter_Truck/BarterTruck</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(3,6)</drawSize>
		</graphicData>
		
		<statBases>
			<MaxHitPoints>700</MaxHitPoints>
			<WorkToBuild>20000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		
		<size>(2,5)</size>
		
		<researchPrerequisites>
			<li>VVE_ComplexVehicles</li>
		</researchPrerequisites>
		
		<costList>
			<EngineMedium>1</EngineMedium>
			<VVE_CarAlternator>2</VVE_CarAlternator>
			<VVE_CarExhaust>2</VVE_CarExhaust>
			<VVE_CarSuspension>4</VVE_CarSuspension>
			<ComponentWheelTire>6</ComponentWheelTire>
			<VVE_CarBattery>1</VVE_CarBattery>
			<VVE_CarFuelTank>1</VVE_CarFuelTank>
			<Steel>450</Steel>
			<ComponentIndustrial>10</ComponentIndustrial>
		</costList>
		
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		
		<thingToSpawn>TMM_Vehicle_Barter</thingToSpawn>
		
		<constructionSkillPrerequisite>8</constructionSkillPrerequisite>
	</Vehicles.VehicleBuildDef>
</Defs>