	<Vehicles.VehicleBuildDef ParentName="VehicleBaseBuildable">
		<defName>TMM_VehicleBlueprint_Bobcat</defName>
		<label>Bobcat</label>
		<description>The Bobcat is a wheeled armoured vehicle designed primarily for military and law enforcement use in high conflict situations.</description>

		<designationCategory>TMM_TransportDesignator</designationCategory>
		<graphicData>
			<texPath>Modules/Transport/Vehicles/Land/Bobcat_MRAP/BobcatMRAP</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(3,6)</drawSize>
		</graphicData>
		
		<statBases>
			<MaxHitPoints>700</MaxHitPoints>
			<WorkToBuild>30000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		
		<size>(2,5)</size>
		
		<researchPrerequisites>
			<li>VVE_ComplexVehicles</li>
		</researchPrerequisites>
		
		<costList>
			<EngineMedium>1</EngineMedium>
			<VVE_CarAlternator>2</VVE_CarAlternator>
			<VVE_CarExhaust>2</VVE_CarExhaust>
			<VVE_CarSuspension>4</VVE_CarSuspension>
			<ComponentWheelTire>4</ComponentWheelTire>
			<VVE_CarBattery>1</VVE_CarBattery>
			<VVE_CarFuelTank>1</VVE_CarFuelTank>
			<Steel>200</Steel>
			<Plasteel>250</Plasteel>
			<ComponentIndustrial>30</ComponentIndustrial>
		</costList>
		
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		
		<thingToSpawn>TMM_Vehicle_Bobcat</thingToSpawn>
		
		<constructionSkillPrerequisite>7</constructionSkillPrerequisite>
	</Vehicles.VehicleBuildDef>
</Defs>