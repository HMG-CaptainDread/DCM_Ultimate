<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!-- <></> -->
	<!--  -->



	<!-- GROUND SUPPORT TURRET -->
		<Vehicles.VehicleTurretDef Name="TMM_Turret_GroundSupport" ParentName="VehicleTurretBase">
			<defName>TMM_Turret_GroundSupport</defName>
			<label>Mounted Gun</label>
			<description>A machine gun mounted onto the hull of a helicopter.</description>

			<turretType>Rotatable</turretType>
			<shotSound>Shot_Minigun</shotSound>

			<projectile>Bullet_SniperRifle</projectile>
			<reloadTimer>2.4</reloadTimer>
			<warmUpTimer>1.2</warmUpTimer>

			<chargePerAmmoCount>0.25</chargePerAmmoCount>

			<magazineCapacity>200</magazineCapacity>
			<genericAmmo>true</genericAmmo>

			<autoSnapTargeting>true</autoSnapTargeting>

			<projectileOffset>1</projectileOffset>

			<maxRange>41.9</maxRange>

			<recoil>
				<distanceTotal>0.12</distanceTotal>
				<distancePerTick>0.04</distancePerTick>
				<speedMultiplierPostRecoil>0.15</speedMultiplierPostRecoil>
			</recoil>

			<attachProjectileFlag>VVE_Tank</attachProjectileFlag>

			<fireModes>
				<li>
					<shotsPerBurst>1</shotsPerBurst>
					<ticksBetweenShots>10</ticksBetweenShots>
					<ticksBetweenBursts>20</ticksBetweenBursts>
					<label>Single</label>
					<texPath>UI/Gizmos/FireRate_Single</texPath>
				</li>

				<li>
					<shotsPerBurst>6</shotsPerBurst>
					<ticksBetweenShots>5</ticksBetweenShots>
					<ticksBetweenBursts>160</ticksBetweenBursts>
					<label>Burst</label>
					<texPath>UI/Gizmos/FireRate_Burst</texPath>
				</li>
			</fireModes>

			<graphicData>
				<texPath>Modules/Transport/Weapons/Turrets/GroundSupportTurret</texPath>
				<graphicClass>Vehicles.Graphic_Turret</graphicClass>
				<shaderType>CutoutComplexPattern</shaderType>
				<drawSize>(3.15, 3.15)</drawSize>
			</graphicData>

			<ammunition>
				<thingDefs>
					<li>Steel</li>
				</thingDefs>
			</ammunition>
		</Vehicles.VehicleTurretDef>
</Defs>