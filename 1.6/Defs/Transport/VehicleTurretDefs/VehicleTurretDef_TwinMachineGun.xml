<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!-- <></> -->
	<!--  -->



	<!-- TWIN MACHINE GUN TURRET -->
		<Vehicles.VehicleTurretDef ParentName="VehicleTurretBase">
			<defName>TMM_Turret_TwinMG</defName>
			<label>Twin Machine Gun Turret</label>
			
			<turretType>Rotatable</turretType>
			<shotSound>TMM_Sound_WeaponMG</shotSound>
			
			<projectile>Bullet_LMG</projectile>
			<reloadTimer>3.5</reloadTimer>
			<warmUpTimer>1.2</warmUpTimer>
			<chargePerAmmoCount>0.25</chargePerAmmoCount>
			
			<magazineCapacity>200</magazineCapacity>
			<genericAmmo>true</genericAmmo>
			
			<autoSnapTargeting>false</autoSnapTargeting>
			<rotationSpeed>1.95</rotationSpeed>
			
			<projectileOffset>1.8</projectileOffset>
			<projectileShifting>
				<li>0.3</li>
				<li>-0.3</li>
			</projectileShifting>

			<maxRange>32.9</maxRange>
			
			<recoil>
				<distanceTotal>0.15</distanceTotal>
				<distancePerTick>0.05</distancePerTick>
				<speedMultiplierPostRecoil>0.1</speedMultiplierPostRecoil>
			</recoil>
			
			<fireModes>
				<li>
					<shotsPerBurst>10~20</shotsPerBurst>
					<ticksBetweenShots>4</ticksBetweenShots>
					<ticksBetweenBursts>55~65</ticksBetweenBursts>
					<accuracyTouch>0.20</accuracyTouch>
					<accuracyShort>0.25</accuracyShort>
					<accuracyMedium>0.25</accuracyMedium>
					<accuracyLong>0.15</accuracyLong>
					<label>Burst</label>
					<texPath>UI/Gizmos/FireRate_Burst</texPath>
				</li>
			</fireModes>

			<graphicData>
				<texPath>Modules/Transport/Weapons/Turrets/TwinMGTurret</texPath>
				<graphicClass>Vehicles.Graphic_Turret</graphicClass>
				<shaderType>Cutout</shaderType>
				<drawSize>(9, 9)</drawSize>
			</graphicData>
			<gizmoIconTexPath>Modules/Transport/Weapons/Turrets/TwinMGTurret</gizmoIconTexPath>
			
			<ammunition>
				<thingDefs>
					<li>Steel</li>
				</thingDefs>
			</ammunition>
		</Vehicles.VehicleTurretDef>
</Defs>