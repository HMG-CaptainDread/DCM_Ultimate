<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!-- <></> -->
	<!--  -->



	<!-- MINI TURRET -->
		<Vehicles.VehicleTurretDef Name="TMM_Turret_Mini" ParentName="VehicleTurretBase">
			<defName>TMM_Turret_Mini</defName>
			<label>Mounted Turret</label>
			<description>An autonomous gun turret mounted on a mobile siege engine.</description>
			<turretType>Rotatable</turretType>
			<shotSound>GunShotA</shotSound>
			<projectile>Bullet_MiniTurret</projectile>
			<reloadTimer>2.4</reloadTimer>
			<warmUpTimer>1.2</warmUpTimer>
			<chargePerAmmoCount>0.25</chargePerAmmoCount>
			<magazineCapacity>75</magazineCapacity>
			<genericAmmo>true</genericAmmo>

			<autoSnapTargeting>true</autoSnapTargeting>
			<projectileOffset>1</projectileOffset>
			<maxRange>28.9</maxRange>
			<recoil>
				<distanceTotal>0.12</distanceTotal>
				<distancePerTick>0.04</distancePerTick>
				<speedMultiplierPostRecoil>0.15</speedMultiplierPostRecoil>
			</recoil>
			<attachProjectileFlag>VVE_Tank</attachProjectileFlag>
			<fireModes>
				<li>
					<shotsPerBurst>5</shotsPerBurst>
					<ticksBetweenShots>8</ticksBetweenShots>
					<ticksBetweenBursts>90</ticksBetweenBursts>
					<spreadRadius>1</spreadRadius>
					<label>Burst</label>
					<texPath>UI/Gizmos/FireRate_Burst</texPath>
				</li>
				<li>
					<shotsPerBurst>1</shotsPerBurst>
					<ticksBetweenShots>10</ticksBetweenShots>
					<ticksBetweenBursts>20</ticksBetweenBursts>
					<label>Single</label>
					<texPath>UI/Gizmos/FireRate_Single</texPath>
				</li>
			</fireModes>
			<graphicData>
				<texPath>Modules/Transport/Weapons/Turrets/HeavyTurret</texPath>
				<graphicClass>Vehicles.Graphic_Turret</graphicClass>
				<shaderType>Cutout</shaderType>
				<drawSize>(1.4, 1.4)</drawSize>
			</graphicData>
			<ammunition>
				<thingDefs>
					<li>Steel</li>
				</thingDefs>
			</ammunition>
		</Vehicles.VehicleTurretDef>
</Defs>