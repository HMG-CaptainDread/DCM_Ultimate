	<!-- INDUSTRIAL GUNSMITH TABLE -->
		<ThingDef ParentName="TMM_Workbench_GunsmithBase">
			<defName>TMM_Workbench_GunsmithIndustrial</defName>
			<label>Industrial Gunsmith</label>
			<description>An industrial gunsmithing table fit for producing industrial firearms.</description>
			<graphicData>
				<texPath>Modules/Production/Buildings/Benches/Gunsmiths/Industrial/GunsmithIndustrial</texPath>
				<drawSize>(3.5,1.5)</drawSize>
			</graphicData>
			<staticSunShadowHeight>0.20</staticSunShadowHeight>
			<costList>
				<WoodLog>10</WoodLog>
				<Steel>40</Steel>
				<ComponentIndustrial>3</ComponentIndustrial>
			</costList>
			<statBases>
				<WorkToBuild>4000</WorkToBuild>
				<MaxHitPoints>180</MaxHitPoints>
				<Flammability>1.0</Flammability>
				<Cleanliness>-2</Cleanliness>
			</statBases>
			<size>(3,1)</size>
			<interactionCellOffset>(0,0,-1)</interactionCellOffset>
			<constructionSkillPrerequisite>4</constructionSkillPrerequisite>
			<comps>
				<li Class="CompProperties_Breakdownable"/>
			</comps>
			<constructEffect>ConstructMetal</constructEffect>
			<!-- <researchPrerequisites>
				<li>CGF1_MWP_Research_T4_IndustrialFirearms</li>
			</researchPrerequisites> -->
		</ThingDef>
