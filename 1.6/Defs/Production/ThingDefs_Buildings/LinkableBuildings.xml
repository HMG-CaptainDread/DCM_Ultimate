<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!-- <></> -->
	<!--  -->



	<!-- LINKABLE BASE -->
		<ThingDef ParentName="BuildingBase" Name="TMM_LinkableBase" Abstract="True">
			<graphicData>
				<graphicClass>Graphic_Multi</graphicClass>
			</graphicData>
			<altitudeLayer>Building</altitudeLayer>
			<passability>PassThroughOnly</passability>
			<canOverlapZones>false</canOverlapZones>
			<pathCost>60</pathCost>
			<rotatable>true</rotatable>
			<statBases>
				<Flammability>1.0</Flammability>
			</statBases>
			<designationCategory>Misc</designationCategory>
			<minifiedDef>MinifiedThing</minifiedDef>
			<thingCategories>
				<li>BuildingsMisc</li>
			</thingCategories>
			<placeWorkers>
				<li>PlaceWorker_ShowFacilitiesConnections</li>
			</placeWorkers>
		</ThingDef>
	<!-- ADVANCED MULTI-ANALYSER -->
		<ThingDef ParentName="TMM_LinkableBase">
			<defName>TMM_AdvancedMultiAnalyzer</defName>
			<label>advanced multi-analyzer</label>
			<description>Greatly increases research speed (+25%) when placed near a research bench.\nOne research bench can only be connected to one advanced multi-analyzer but can still be connected to the normal multi-analyzer.</description>
			<graphicData>
				<texPath>Modules/Production/Building/Linkables/Research/AdvancedAnalyser/AdvancedMultiAnalyser</texPath>
				<drawSize>(3,2)</drawSize>
				<damageData>
					<rect>(0.15,0.15,1.7,1.7)</rect>
				</damageData>
			</graphicData>
			<castEdgeShadows>true</castEdgeShadows>
			<staticSunShadowHeight>0.35</staticSunShadowHeight>
			<fillPercent>0.5</fillPercent>
			<statBases>
				<MaxHitPoints>800</MaxHitPoints>
				<WorkToBuild>10000</WorkToBuild>
				<Mass>200</Mass>
			</statBases>
			<size>(3,2)</size>
			<costList>
				<ComponentSpacer>2</ComponentSpacer>
				<ComponentIndustrial>10</ComponentIndustrial>
				<Steel>200</Steel>
				<Plasteel>100</Plasteel>
				<Gold>50</Gold>
			</costList>
			<researchPrerequisites>
				<li>AdvancedMultiAnalyzer</li>
			</researchPrerequisites>
			<constructionSkillPrerequisite>10</constructionSkillPrerequisite>
			<comps>
				<li Class="CompProperties_Power">
					<compClass>CompPowerTrader</compClass>
					<shortCircuitInRain>true</shortCircuitInRain>
					<basePowerConsumption>500</basePowerConsumption>
				</li>
				<li Class="CompProperties_Flickable" />
				<li Class="CompProperties_Facility">
					<statOffsets>
						<ResearchSpeedFactor>0.25</ResearchSpeedFactor>
					</statOffsets>
					<maxSimultaneous>1</maxSimultaneous>
				</li>
			</comps>
		</ThingDef>
	<!-- SURGICAL INSTRUMENTS -->
		<ThingDef ParentName="TMM_LinkableBase">
			<defName>TMM_SurgicalInstruments</defName>
			<label>surgical instruments</label>
			<description>Increases medical tend quality (+10%), and immunity gain speed (+1%) when placed directly adjacent to a hospital bed. Only works for hospital beds - normal beds will not benefit. Attaching more than one surgical instruments to the same bed will have no effect.</description>
			<graphicData>
				<texPath>Modules/Production/Building/Linkables/Hospital/SurgicalInstruments/SurgicalInstruments</texPath>
				<drawSize>(1,1)</drawSize>
				<damageData>
					<cornerTL>Damage/Corner</cornerTL>
					<cornerTR>Damage/Corner</cornerTR>
					<cornerBL>Damage/Corner</cornerBL>
					<cornerBR>Damage/Corner</cornerBR>
				</damageData>
			</graphicData>
			<statBases>
				<MaxHitPoints>50</MaxHitPoints>
				<WorkToBuild>1500</WorkToBuild>
				<Mass>20</Mass>
			</statBases>
			<costList>
				<Steel>40</Steel>
				<Plasteel>40</Plasteel>
				<ComponentIndustrial>1</ComponentIndustrial>
			</costList>
			<researchPrerequisites>
				<li>SurgicalInstruments</li>
			</researchPrerequisites>
			<comps>
				<li Class="CompProperties_Facility">
					<statOffsets>
						<MedicalTendQualityOffset>0.1</MedicalTendQualityOffset>
						<ImmunityGainSpeedFactor>0.01</ImmunityGainSpeedFactor>
					</statOffsets>
					<maxSimultaneous>1</maxSimultaneous>
					<mustBePlacedAdjacent>true</mustBePlacedAdjacent>
				</li>
			</comps>
		</ThingDef>
	<!-- SURGICAL LAMP -->
		<ThingDef ParentName="TMM_LinkableBase">
			<defName>TMM_SurgicalLamp</defName>
			<label>surgical lamp</label>
			<description>Increases surgery success chance (+10%), and immunity gain speed (+1%) when placed directly adjacent to a hospital bed. Only works for hospital beds - normal beds will not benefit. Attaching more than one surgical lamp to the same bed will have no effect.</description>
			<graphicData>
				<texPath>Modules/Production/Building/Linkables/Hospital/SurgicalLamp/SurgicalLamp</texPath>
				<drawSize>(1,1)</drawSize>
				<damageData>
					<cornerTL>Damage/Corner</cornerTL>
					<cornerTR>Damage/Corner</cornerTR>
					<cornerBL>Damage/Corner</cornerBL>
					<cornerBR>Damage/Corner</cornerBR>
				</damageData>
			</graphicData>
			<statBases>
				<MaxHitPoints>100</MaxHitPoints>
				<WorkToBuild>3000</WorkToBuild>
				<Mass>40</Mass>
			</statBases>
			<costList>
				<Steel>40</Steel>
				<ComponentIndustrial>1</ComponentIndustrial>
			</costList>
			<researchPrerequisites>
				<li>SurgicalLamp</li>
			</researchPrerequisites>
			<comps>
				<li Class="CompProperties_Power">
					<compClass>CompPowerTrader</compClass>
					<basePowerConsumption>400</basePowerConsumption>
				</li>
				<li Class="CompProperties_Glower">
					<glowRadius>5</glowRadius>
					<overlightRadius>3</overlightRadius>
					<glowColor>(217,217,208,0)</glowColor>
				</li>
				<li Class="CompProperties_Facility">
					<statOffsets>
						<ImmunityGainSpeedFactor>0.01</ImmunityGainSpeedFactor>
						<SurgerySuccessChanceFactor>0.1</SurgerySuccessChanceFactor>
					</statOffsets>
					<maxSimultaneous>1</maxSimultaneous>
					<mustBePlacedAdjacent>true</mustBePlacedAdjacent>
				</li>
				<li Class="CompProperties_Flickable" />
			</comps>
		</ThingDef>
</Defs>