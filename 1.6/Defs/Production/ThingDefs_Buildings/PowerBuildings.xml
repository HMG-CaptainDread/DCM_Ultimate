						<glowColor>(155,226,231,0)</glowColor>
					</li>
				</comps>
				<!-- <researchPrerequisites>
					<li>MicroelectronicsBasics</li>
				</researchPrerequisites> -->
				<constructionSkillPrerequisite>12</constructionSkillPrerequisite>
