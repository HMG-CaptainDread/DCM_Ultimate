	<!-- RTGs -->
		<!-- PORTABLE RTG -->
			<ThingDef ParentName="TMM_PowerUnbreakableBase">
				<defName>TMM_PortableRTG</defName>
				<label>Portable RTG</label>
				<description>A radioisotope thermoelectric generator (RTG) is a type of generator that generate electricity by the Seebeck effect, which has no moving parts so it won't breakdown.</description>
				<graphicData>
					<texPath>Modules/Production/Buildings/Power/RTGs/Portable/PortableRTG</texPath>
					<graphicClass>Graphic_Single</graphicClass>
					<drawSize>(3,3)</drawSize>
					<shadowData>
						<volume>(1.93,1,1.69)</volume>
						<offset>(-0.03,0,-0.1)</offset>
					</shadowData>
				</graphicData>
				<uiIconScale>0.5</uiIconScale>
				<rotatable>false</rotatable>
				<statBases>
					<Mass>50</Mass>
					<MaxHitPoints>300</MaxHitPoints>
					<WorkToBuild>2000</WorkToBuild>
					<Flammability>0.5</Flammability>
					<Beauty>5</Beauty>
				</statBases>
				<size>(1,1)</size>
				<costList>
					<Steel>50</Steel>
					<Uranium>60</Uranium>
					<ComponentIndustrial>2</ComponentIndustrial>
				</costList>
				<comps>
					<li Class="CompProperties_Power">
						<compClass>CompPowerPlant</compClass>
						<basePowerConsumption>-750</basePowerConsumption>
						<transmitsPower>true</transmitsPower>
						<soundAmbientProducingPower>ChemfuelFiredGenerator_Ambience</soundAmbientProducingPower>
					</li>
					<li Class="CompProperties_Refuelable">
						<fuelConsumptionRate>1.0</fuelConsumptionRate>
						<fuelCapacity>60.0</fuelCapacity>
						<fuelFilter>
							<thingDefs>
								<li>Uranium</li>
							</thingDefs>
						</fuelFilter>
						<showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
					</li>
				</comps>
				<!-- <researchPrerequisites>
					<li>MicroelectronicsBasics</li>
				</researchPrerequisites> -->
				<constructionSkillPrerequisite>10</constructionSkillPrerequisite>
			</ThingDef>
