	<!-- BASES -->
		<!-- POWER BASE -->
			<ThingDef ParentName="BuildingBase" Name="TMM_PowerBase" Abstract="True">
				<thingClass>Building</thingClass>
				<drawerType>MapMeshAndRealTime</drawerType>
				<altitudeLayer>Building</altitudeLayer>
				<passability>PassThroughOnly</passability>
				<pathCost>50</pathCost>
				<blockWind>true</blockWind>
				<fillPercent>1.0</fillPercent>
				<minifiedDef>MinifiedThing</minifiedDef>
				<thingCategories>
					<li>BuildingsPower</li>
				</thingCategories>
				<tickerType>Normal</tickerType>
				<canOverlapZones>false</canOverlapZones>
				<building>
					<destroySound>BuildingDestroyed_Metal_Medium</destroySound>
				</building>
				<comps>
					<li Class="CompProperties_Flickable" />
				</comps>
				<terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
				<designationCategory>Power</designationCategory>
				<constructEffect>ConstructMetal</constructEffect>
			</ThingDef>
		<!-- BREAKABLE POWER GENERATOR BASE -->
			<ThingDef ParentName="TMM_PowerBase" Name="TMM_PowerBreakableBase" Abstract="True">
				<statBases>
					<Mass>50</Mass>
					<MaxHitPoints>300</MaxHitPoints>
					<WorkToBuild>2500</WorkToBuild>
					<Flammability>1.0</Flammability>
					<Beauty>-20</Beauty>
				</statBases>
				<comps>
					<li Class="CompProperties_Breakdownable"/>
					<li Class="CompProperties_HeatPusher">
						<compClass>CompHeatPusherPowered</compClass>
						<heatPerSecond>6</heatPerSecond>
					</li>
					<li Class="CompProperties_Glower">
						<glowRadius>6</glowRadius>
						<glowColor>(80,112,180,0)</glowColor>
					</li>
					<li Class="CompProperties_Explosive">
						<explosiveRadius>0</explosiveRadius>
						<explosiveExpandPerFuel>0.95</explosiveExpandPerFuel>
						<explosiveDamageType>Flame</explosiveDamageType>
						<destroyThingOnExplosionSize>2</destroyThingOnExplosionSize>
						<startWickHitPointsPercent>0.333</startWickHitPointsPercent>
						<preExplosionSpawnThingDef>Filth_Fuel</preExplosionSpawnThingDef>
						<preExplosionSpawnChance>1</preExplosionSpawnChance>
						<wickTicks>70~150</wickTicks>
					</li>
				</comps>
			</ThingDef>
		<!-- UNBREAKABLE POWER GENERATOR BASE -->
			<ThingDef ParentName="TMM_PowerBase" Name="TMM_PowerUnbreakableBase" Abstract="True">
				<comps>
					<li Class="CompProperties_HeatPusher">
						<compClass>CompHeatPusherPowered</compClass>
						<heatPerSecond>6</heatPerSecond>
					</li>
					<li Class="CompProperties_Glower">
						<glowRadius>3</glowRadius>
						<glowColor>(155,226,231,0)</glowColor>
					</li>
					<li Class="CompProperties_Explosive">
						<explosiveRadius>0</explosiveRadius>
						<explosiveExpandPerFuel>0.05</explosiveExpandPerFuel>
						<explosiveDamageType>Flame</explosiveDamageType>
						<destroyThingOnExplosionSize>2</destroyThingOnExplosionSize>
						<startWickHitPointsPercent>0.333</startWickHitPointsPercent>
						<preExplosionSpawnChance>1</preExplosionSpawnChance>
						<wickTicks>70~150</wickTicks>
					</li>
				</comps>
			</ThingDef>
	<!-- JADE GENERATORS -->
		<!-- JADE GENERATOR -->
			<ThingDef ParentName="TMM_PowerBreakableBase">
				<defName>TMM_JadeGenerator</defName>
				<label>Jade Generator</label>
				<description>Net output: +1,000W If you've ever walked past a big air conditioning unit in real life, you know just how much it sucks to stand near one of these.</description>
				<graphicData>
					<texPath>Modules/Production/Buildings/Power/JadeGenerators/Regular/JadeGeneratorSmall</texPath>
					<graphicClass>Graphic_Single</graphicClass>
					<drawSize>(2,2)</drawSize>
					<shadowData>
						<volume>(1.8,1.5,1.5)</volume>
						<offset>(0,0,-0.23)</offset>
					</shadowData>
				</graphicData>
				<rotatable>false</rotatable>
				<size>(2,2)</size>
				<costList>
					<Steel>150</Steel>
					<ComponentIndustrial>3</ComponentIndustrial>
					<Jade>100</Jade>
				</costList>
				<comps>
					<li Class="CompProperties_Power">
						<compClass>CompPowerPlant</compClass>
						<basePowerConsumption>-1000</basePowerConsumption>
						<transmitsPower>true</transmitsPower>
						<soundAmbientProducingPower>ChemfuelFiredGenerator_Ambience</soundAmbientProducingPower>
					</li>
				</comps>
				<!-- <researchPrerequisites>
					<li>ucp_industrialgenerators</li>
				</researchPrerequisites> -->
				<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
			</ThingDef>
