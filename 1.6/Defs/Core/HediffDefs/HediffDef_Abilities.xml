	<!-- TMM_Hediff_ -->



	<!-- NOVAKIN -->
		<!-- DEAD EYE -->
			<HediffDef ParentName="TMM_Hediff_NK_Base">
				<defName>TMM_Hediff_DeadEye</defName>
				<label>Dead Eye</label>
				<defaultLabelColor>(0.9, 0.27, 0.3)</defaultLabelColor>
				<description>Enhances the user's shooting accuracy.\n\n"You can go anywhere, but you won't be away from my gaze."</description>
				<descriptionHyperlinks>
					<AbilityDef>TMM_Ability_NK_DeadEye</AbilityDef>
				</descriptionHyperlinks>
				<isBad>false</isBad>
				<comps>
					<li Class="HediffCompProperties_Disappears">
						<disappearsAfterTicks>17500~17500</disappearsAfterTicks>
						<showRemainingTime>True</showRemainingTime>
					</li>
				</comps>
				<stages>
					<li>
						<statFactors>
							<ShootingAccuracyPawn>3</ShootingAccuracyPawn>
							<AimingDelayFactor>0.75</AimingDelayFactor>
						</statFactors>
					</li>
				</stages>
			</HediffDef>
		<!-- TRIGGER FINGER -->
			<HediffDef ParentName="TMM_Hediff_NK_Base">
				<defName>TMM_Hediff_TriggerFinger</defName>
				<label>Trigger Finger</label>
				<defaultLabelColor>(0.47, 0.76, 0.44)</defaultLabelColor>
				<description>Decreases the user's firing speed.\n\n"It's high noon. Let's dance, Partner!."</description>
				<descriptionHyperlinks>
					<AbilityDef>TMM_Ability_NK_TriggerFinger</AbilityDef>
				</descriptionHyperlinks>
				<isBad>false</isBad>
				<comps>
					<li Class="HediffCompProperties_Disappears">
						<disappearsAfterTicks>17500~17500</disappearsAfterTicks>
						<showRemainingTime>True</showRemainingTime>
					</li>
				</comps>
				<stages>
					<li>
						<statFactors>
						<RangedCooldownFactor>0.25</RangedCooldownFactor>
						</statFactors>
					</li>
				</stages>
			</HediffDef>
		<!-- MAGNETIC SHIELD -->
			<HediffDef ParentName="TMM_Hediff_NK_Base">
				<defName>TMM_Hediff_MagneticShield</defName>
				<label>Magnetic Shield</label>
				<defaultLabelColor>(0.16, 0.67, 0.89)</defaultLabelColor>
				<description>Enhances the user's magnetic field to increase damage resistance.\n\n"My magnetic wave took that personally."</description>
				<descriptionHyperlinks>
					<AbilityDef>TMM_Ability_NK_MagneticShield</AbilityDef>
				</descriptionHyperlinks>
				<isBad>false</isBad>
				<comps>
					<li Class="HediffCompProperties_Disappears">
						<disappearsAfterTicks>17500~17500</disappearsAfterTicks>
						<showRemainingTime>True</showRemainingTime>
					</li>
				</comps>
				<stages>
					<li>
						<painFactor>0.5</painFactor>
						<statFactors>
						<IncomingDamageFactor>0.75</IncomingDamageFactor>
						<StaggerDurationFactor>0.5</StaggerDurationFactor>
						</statFactors>
					</li>
				</stages>
			</HediffDef>
		<!-- IS IT CE COMPATIBLE -->
			<HediffDef ParentName="TMM_Hediff_NK_Base">
				<defName>TMM_Hediff_IsItCECompatible</defName>
				<label>Is It CE Compatible</label>
				<defaultLabelColor>(0.98, 0.93, 0.13)</defaultLabelColor>
				<description>Enhances the user's melee compatibility to stronger hits, decreases cooldown, and increases movement speed.\n\n"I alone am the compatible one."</description>
				<descriptionHyperlinks>
					<AbilityDef>TMM_Ability_NK_IsItCECompatible</AbilityDef>
				</descriptionHyperlinks>
				<isBad>false</isBad>
				<comps>
					<li Class="HediffCompProperties_Disappears">
						<disappearsAfterTicks>17500~17500</disappearsAfterTicks>
						<showRemainingTime>True</showRemainingTime>
					</li>
				</comps>
				<stages>
					<li>
						<statFactors>
						<MoveSpeed>2</MoveSpeed>
						<MeleeCooldownFactor>0.5</MeleeCooldownFactor>
						<VEF_MeleeAttackDamageFactor MayRequire="OskarPotocki.VanillaFactionsExpanded.Core">2</VEF_MeleeAttackDamageFactor>
						</statFactors>
					</li>
				</stages>
			</HediffDef>
</Defs>