<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!-- <></> -->
	<!-- TMM_Thought_ -->



	<!-- FURNITURE -->
		<!-- SLEPT IN ARMY TENT -->
			<ThoughtDef>
				<defName>TMM_Thought_ArmyTent</defName>
				<durationDays>0.05</durationDays>
				<validWhileDespawned>true</validWhileDespawned>
				<stages>
					<li>
						<label>sleeping in tent</label>
						<description>Good enough for whatever army made these? Good enough for me.</description>
						<baseMoodEffect>2</baseMoodEffect>
					</li>
				</stages>
			</ThoughtDef>
		<!-- SLEPT IN SCRAPS -->
			<ThoughtDef>
				<defName>TMM_Thought_ScrapShelter</defName>
				<durationDays>0.05</durationDays>
				<validWhileDespawned>true</validWhileDespawned>
				<nullifyingPrecepts>
					<li MayRequire="Ludeon.RimWorld.Ideology">RoughLiving_Welcomed</li>
				</nullifyingPrecepts>
				<stages>
					<li>
						<label>sleeping under sheets</label>
						<description>I'm sleeping under sheets, not the kind of sheets I'd like, but it's something.</description>
						<baseMoodEffect>-2</baseMoodEffect>
					</li>
				</stages>
			</ThoughtDef>
		<!-- SLEPT ON SOFA -->
			<ThoughtDef>
				<defName>TMM_Thought_SleptOnSofa</defName>
				<durationDays>1</durationDays>
				<stackLimit>1</stackLimit>
				<nullifyingPrecepts>
					<li MayRequire="Ludeon.RimWorld.Ideology">RoughLiving_Welcomed</li>
				</nullifyingPrecepts>
				<stages>
					<li>
						<label>slept on sofa</label>
						<description>Ow! There's a crick in my neck and I'm still a little tired, better than the floor though.</description>
						<baseMoodEffect>-1</baseMoodEffect>
					</li>
				</stages>
			</ThoughtDef>
	<!-- HARVEST TIME -->
		<!-- RAW GRAIN -->
			<ThoughtDef>
				<defName>TMM_AteGrain</defName>
				<thoughtClass>Thought_FoodEaten</thoughtClass>
				<showBubble>true</showBubble>
				<icon>Things/Mote/ThoughtSymbol/Food</icon>
				<durationDays>1</durationDays>
				<nullifyingGenes>
					<li MayRequire="Ludeon.RimWorld.Biotech">RobustDigestion</li>
				</nullifyingGenes>
				<stages>
					<li>
						<label>ate raw grain</label>
						<description>I had to eat raw grains. We need to get a millstone to turn the grain into flour to cook with, or at least make a stew out of the grain.</description>
						<baseMoodEffect>-10</baseMoodEffect>
					</li>
				</stages>
			</ThoughtDef>
	<!--  -->
</Defs>