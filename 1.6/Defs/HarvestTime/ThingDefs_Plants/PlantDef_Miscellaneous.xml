	<!-- FARMABLE -->
		<!-- BAMBOO -->
			<ThingDef ParentName="TMM_HydroponicsPlantBase">
				<defName>TMM_BambooTree</defName>
				<label>Bamboo Plant</label>
				<description>A fast-growing tree-like species that grows in clusters. Bamboo can be harvested for a somewhat sturdy wood-like material, whilst the plant itself is not beautiful, the resulting constructions can often be quite ornate.</description>
				<graphicData>
					<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Miscellaneous/Bamboo</texPath>
					<shadowData>
						<volume>(0.38, 0.3, 0.15)</volume>
						<offset>(0,0,-0.47)</offset>
					</shadowData>
				</graphicData>
				<plant>
					<harvestedThingDef>TMM_RawBamboo</harvestedThingDef>
					<harvestTag>Wood</harvestTag>
					<harvestYield>14</harvestYield>
					<sowMinSkill>4</sowMinSkill>
					<growDays>10</growDays>
					<fertilitySensitivity>0.75</fertilitySensitivity>
					<wildClusterRadius>5</wildClusterRadius>
					<wildClusterWeight>15</wildClusterWeight>
					<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Miscellaneous/Bamboo</immatureGraphicPath>
					<treeLoversCareIfChopped>false</treeLoversCareIfChopped>
					<wildOrder>2</wildOrder>
				</plant>
			</ThingDef>
		<!-- BIRCH WITH OYSTER MUSHROOM -->
			<ThingDef ParentName="TMM_DeciduousFruitTreeBase">
				<defName>TMM_BirchTreeOyster</defName>
				<label>Birch Tree with Oyster Mushrooms</label>
				<description>A temperate-biome tree known for its thin, white, paper-like bark. Clusters of Oyster Mushrooms grow along its trunk.</description>
				<graphicData>
					<texPath>Modules/HarvestTime/Plants/Mature/Trees/Mushrooms/BirchOyster</texPath>
					<shadowData>
						<volume>(0.15, 0.3, 0.1)</volume>
						<offset>(-0.03,0,-0.44)</offset>
					</shadowData>
				</graphicData>
				<statBases>
					<Beauty>2</Beauty>
					<BeautyOutdoors>2</BeautyOutdoors>
				</statBases>
				<plant>
					<growDays>20</growDays>
					<harvestYield>12</harvestYield>
					<harvestFailable>true</harvestFailable>
					<soundHarvesting>Harvest_Standard</soundHarvesting>
					<soundHarvestFinish>Harvest_Standard_Finish</soundHarvestFinish>
					<harvestAfterGrowth>0.20</harvestAfterGrowth>
					<harvestedThingDef>TMM_RawOysterMushroom</harvestedThingDef>
					<leaflessGraphicPath>Modules/HarvestTime/Plants/Mature/Trees/LeaflessTree/Mushrooms/BirchOyster_Leafless</leaflessGraphicPath>
					<leaflessSnowOverlayGraphicPath>Modules/HarvestTime/Plants/Miscellaneous/Trees/Snowy/Mushrooms/BirchOyster_Snowy</leaflessSnowOverlayGraphicPath>
				</plant>
			</ThingDef>
		<!-- CLOVER -->
			<ThingDef ParentName="TMM_GroundOnlyPlantBase">
				<defName>TMM_CloverPlant</defName>
				<label>Clover</label>
				<description>A fast-growing plant with trifoliate leaves. Clover matures quickly and provides a modest but reliable forage for livestock.</description>
				<statBases>
					<Flammability>1.0</Flammability>
					<Nutrition>0.3</Nutrition>
				</statBases>
				<graphicData>
					<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Miscellaneous/Clover</texPath>
				</graphicData>
				<plant>
					<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Miscellaneous/Clover</immatureGraphicPath>
					<fertilitySensitivity>0.1</fertilitySensitivity>
					<growDays>3.5</growDays>
					<maxMeshCount>4</maxMeshCount>
					<harvestedThingDef>TMM_WetCloverGrass</harvestedThingDef>
					<harvestYield>10</harvestYield>
					<topWindExposure>0.05</topWindExposure>
					<visualSizeRange>0.4~0.8</visualSizeRange>
					<wildOrder>1</wildOrder>
					<purpose>Food</purpose>
					<sowResearchPrerequisites>
						<li>TMM_Research_HarvestTime_NeolithicAgriculture</li>
					</sowResearchPrerequisites>
				</plant>
			</ThingDef>
		<!-- GINSENG -->
			<ThingDef ParentName="TMM_HydroponicsPlantBase">
				<defName>TMM_GinsengPlant</defName>
				<label>Ginseng</label>
				<description>A hardy medicinal plant cultivated for its thick, forked root, ginseng is renowned for boosting vitality and resilience and is a prized ingredient in traditional decoctions.</description>
				<statBases>
					<MaxHitPoints>90</MaxHitPoints>
					<Nutrition>0.02</Nutrition>
				</statBases>
				<graphicData>
					<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Miscellaneous/Ginseng</texPath>
				</graphicData>
				<ingestible/>
				<plant>
					<fertilityMin>1.0</fertilityMin>
					<harvestedThingDef>TMM_GinsengRoots</harvestedThingDef>
					<harvestYield>8</harvestYield>
					<sowMinSkill>10</sowMinSkill>
					<topWindExposure>0.05</topWindExposure>
					<growDays>12</growDays>
					<neverBlightable>true</neverBlightable>
					<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Miscellaneous/Ginseng</immatureGraphicPath>
					<harvestWork>420</harvestWork>
					<visualSizeRange>0.4~1.0</visualSizeRange>
					<wildOrder>2</wildOrder>
					<humanFoodPlant>true</humanFoodPlant>
					<sowResearchPrerequisites>
						<li>TMM_Research_HarvestTime_HerbFarming</li>
						<li>TMM_Research_HarvestTime_NeolithicAgriculture</li>
					</sowResearchPrerequisites>
				</plant>
			</ThingDef>
		<!-- GLITTERWORLD ALYSSUM -->
			<ThingDef ParentName="TMM_HydroponicsPlantBase">
				<defName>TMM_AlyssumPlant</defName>
				<label>Alyssum</label>
				<description>A beautiful red flower, genetically engineered by Glitterworld scientists for an eco-friendly method to make Glitterworld Neutroamine, a higher tier drug and medicine base.</description>
				<graphicData>
					<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Miscellaneous/GlitterworldAlyssum</texPath>
				</graphicData>
				<statBases>
					<Beauty>10</Beauty>
				</statBases>
				<plant>
					<harvestedThingDef>TMM_AlyssumTrimmings</harvestedThingDef>
					<harvestYield>2</harvestYield>
					<sowMinSkill>10</sowMinSkill>
					<growDays>15</growDays>
					<fertilitySensitivity>1</fertilitySensitivity>
					<visualSizeRange>0.65~1</visualSizeRange>
					<neverBlightable>true</neverBlightable>
					<pollution>Any</pollution>
					<sowResearchPrerequisites>
						<li>TMM_Research_HarvestTime_SpacerAgricultureI</li>
					</sowResearchPrerequisites>
				</plant>
			</ThingDef>
		<!-- MAPLE WITH SHIITAKE MUSHROOM -->
			<ThingDef ParentName="TMM_DeciduousFruitTreeBase">
				<defName>TMM_MapleTreeShiitake</defName>
				<label>Maple Tree with Shiitake Mushrooms</label>
				<description>A common medium-sized tree, easily identifiable by its distinct three-pointed leaves. Clusters of Shiitake Mushrooms grow along its trunk.</description>
				<graphicData>
					<texPath>Modules/HarvestTime/Plants/Mature/Trees/Mushrooms/MapleShiitake</texPath>
					<shadowData>
						<volume>(0.14, 0.32, 0.12)</volume>
						<offset>(0,0,-0.44)</offset>
					</shadowData>
				</graphicData>
				<statBases>
					<Beauty>2</Beauty>
					<BeautyOutdoors>2</BeautyOutdoors>
				</statBases>
				<plant>
					<growDays>27</growDays>
					<harvestYield>9</harvestYield>
					<harvestFailable>true</harvestFailable>
					<harvestAfterGrowth>0.20</harvestAfterGrowth>
					<soundHarvesting>Harvest_Standard</soundHarvesting>
					<soundHarvestFinish>Harvest_Standard_Finish</soundHarvestFinish>
					<harvestedThingDef>TMM_RawShiitakeMushroom</harvestedThingDef>
					<leaflessGraphicPath>Modules/HarvestTime/Plants/Mature/Trees/LeaflessTree/Mushrooms/MapleShiitake_Leafless</leaflessGraphicPath>
					<leaflessSnowOverlayGraphicPath>Modules/HarvestTime/Plants/Miscellaneous/Trees/Snowy/Mushrooms/MapleShiitake_Snowy</leaflessSnowOverlayGraphicPath>
				</plant>
			</ThingDef>
		<!-- NEUTRO FLOWER -->
			<ThingDef ParentName="TMM_HydroponicsPlantBase">
				<defName>TMM_NeutroFlower</defName>
				<label>Neutro Flower</label>
				<description>A beautiful yellow-orange flower, genetically engineered by Glitterworld scientists for an eco-friendly method to make Neutroamine, a medicine base.</description>
				<graphicData>
					<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Miscellaneous/NeutroFlower</texPath>
				</graphicData>
				<statBases>
					<MaxHitPoints>85</MaxHitPoints>
					<Beauty>10</Beauty>
				</statBases>
				<plant>
					<harvestedThingDef>TMM_NeutroPetal</harvestedThingDef>
					<harvestYield>5</harvestYield>
					<sowMinSkill>7</sowMinSkill>
					<growDays>10</growDays>
					<fertilitySensitivity>1</fertilitySensitivity>
					<sowResearchPrerequisites>
						<li>TMM_Research_HarvestTime_SpacerAgriculture</li>
					</sowResearchPrerequisites>
				</plant>
			</ThingDef>
		<!-- OAK WITH SHIITAKE MUSHROOM -->
			<ThingDef ParentName="TMM_DeciduousFruitTreeBase">
				<defName>TMM_OakTreeShiitake</defName>
				<label>Oak Tree with Shiitake Mushrooms</label>
				<description>A hardy tree that takes a long time to grow. Clusters of Shiitake Mushrooms grow along its trunk.</description>
