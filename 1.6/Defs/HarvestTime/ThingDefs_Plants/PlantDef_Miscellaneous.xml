		<!-- PINCUSHION CACTUS -->
			<ThingDef ParentName="PlantBase">
				<defName>TMM_PincushionCactus</defName>
				<label>pincushion cactus</label>
				<description>A short cactus. It is so named because it resembles a pincushion.</description>
				<statBases>
					<MaxHitPoints>150</MaxHitPoints>
					<Nutrition>0.25</Nutrition>
				</statBases>
				<graphicData>
					<texPath>Things/Plant/PincushionCactus</texPath>
				</graphicData>
				<plant>
					<fertilityMin>0.05</fertilityMin>
					<fertilitySensitivity>0</fertilitySensitivity>
					<growDays>2.5</growDays>
					<visualSizeRange>0.40~0.65</visualSizeRange>
					<topWindExposure>0.0</topWindExposure>
					<wildClusterRadius>4</wildClusterRadius>
					<wildClusterWeight>4</wildClusterWeight>
					<maxMeshCount>4</maxMeshCount>
					<dieIfLeafless>true</dieIfLeafless>
					<harvestTag>Standard</harvestTag>
					<harvestedThingDef>TMM_RawCactusFruit</harvestedThingDef>
					<treeLoversCareIfChopped>false</treeLoversCareIfChopped>
					<harvestYield>3</harvestYield>
					<purpose>Food</purpose>
					<wildOrder>2</wildOrder>
				</plant>
			</ThingDef>
		<!-- POPLAR WITH OYSTER MUSHROOM -->
			<ThingDef ParentName="TMM_DeciduousFruitTreeBase">
				<defName>TMM_PoplarTreeOyster</defName>
				<label>Poplar Tree with Oyster Mushrooms</label>
				<description>A fast-growing tree commonly found in temperate regions. Clusters of Oyster Mushrooms grow along its trunk.</description>
				<graphicData>
					<texPath>Modules/HarvestTime/Plants/Mature/Trees/Mushrooms/PoplarOyster</texPath>
					<shadowData>
						<volume>(0.15, 0.3, 0.1)</volume>
						<offset>(-0.03,0,-0.44)</offset>
					</shadowData>
				</graphicData>
				<statBases>
					<Beauty>1</Beauty>
					<BeautyOutdoors>1.5</BeautyOutdoors>
				</statBases>
				<plant>
					<growDays>15</growDays>
					<harvestYield>12</harvestYield>
					<harvestFailable>true</harvestFailable>
					<harvestAfterGrowth>0.20</harvestAfterGrowth>
					<soundHarvesting>Harvest_Standard</soundHarvesting>
					<soundHarvestFinish>Harvest_Standard_Finish</soundHarvestFinish>
					<harvestedThingDef>TMM_RawOysterMushroom</harvestedThingDef>
					<leaflessGraphicPath>Modules/HarvestTime/Plants/Mature/Trees/LeaflessTree/Mushrooms/PoplarOyster_Leafless</leaflessGraphicPath>
					<leaflessSnowOverlayGraphicPath>Modules/HarvestTime/Plants/Miscellaneous/Trees/Snowy/Mushrooms/PoplarOyster_Snowy</leaflessSnowOverlayGraphicPath>
				</plant>
			</ThingDef>
		<!-- REED -->
			<ThingDef ParentName="TMM_GroundOnlyPlantBase">
				<defName>TMM_ReedPlant</defName>
				<label>Reed Plant</label>
				<description>Unlike the wild reeds that thrive only in marshy, waterlogged soils, this reed's deep root system lets it grow on ordinary, well-drained ground. While it can still be found near wetlands, it doesn’t require constantly soggy conditions, making it a versatile crop suitable for a wider range of environments. Cultivated for its strong stalks, it provides valuable materials for construction and crafting.</description>
				<graphicData>
					<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Miscellaneous/Reed</texPath>
				</graphicData>
				<plant>
					<growDays>9</growDays>
					<harvestWork>280</harvestWork>
					<harvestedThingDef>TMM_ReedStalk</harvestedThingDef>
					<fertilityMin>0.6</fertilityMin>
					<harvestYield>6</harvestYield>
					<sowMinSkill>4</sowMinSkill>
					<topWindExposure>0.15</topWindExposure>
					<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Miscellaneous/Reed</immatureGraphicPath>
					<visualSizeRange>0.5~1.3</visualSizeRange>
					<wildOrder>2</wildOrder>
					<sowResearchPrerequisites>
						<li>TMM_Research_HarvestTime_MedievalAgriculture</li>
					</sowResearchPrerequisites>
				</plant>
			</ThingDef>
