<Defs>
	<!-- <></> -->
	<!--  -->



	<!-- Modules/HarvestTime/Plants/Mature/NewPlants/Textiles/ -->
	<!-- Modules/HarvestTime/Plants/Immature/NewPlants/Textiles/ -->

	<!-- FLAX -->
		<ThingDef ParentName="TMM_HydroponicsPlantBase">
			<defName>TMM_Flax</defName>
			<label>Flax</label>
			<description>A flower which, when spun, create fibres that can be used to make cloth.</description>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Textiles/Flax</texPath>
			</graphicData>
			<plant>
				<harvestedThingDef>TMM_RawFlax</harvestedThingDef>
				<harvestYield>9</harvestYield>
				<sowMinSkill>4</sowMinSkill>
				<growDays>16.1</growDays>
				<fertilitySensitivity>1.0</fertilitySensitivity>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Textiles/Flax</immatureGraphicPath>
				<sowResearchPrerequisites>
					<li>TMM_Research_HarvestTime_AnimalAgricultureI</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
	<!-- JUTE -->
		<ThingDef ParentName="TMM_HydroponicsPlantBase">
			<defName>TMM_JutePlant</defName>
			<label>Jute</label>
			<description>A tall, sturdy plant cultivated for its fibrous stalks. Jute grows moderately fast, yields a reliable harvest of raw fibers, and is valued for making textiles.</description>
			<statBases>
				<MaxHitPoints>120</MaxHitPoints>
			</statBases>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Textiles/Jute</texPath>
			</graphicData>
			<pathCost>20</pathCost>
			<plant>
				<growDays>6</growDays>
				<harvestWork>400</harvestWork>
				<neverBlightable>true</neverBlightable>
				<harvestedThingDef>TMM_RawJute</harvestedThingDef>
				<fertilityMin>0.6</fertilityMin>
				<harvestYield>8</harvestYield>
				<sowMinSkill>3</sowMinSkill>
				<topWindExposure>0.15</topWindExposure>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Textiles/Jute</immatureGraphicPath>
				<visualSizeRange>0.3~1.05</visualSizeRange>
				<wildOrder>2</wildOrder>
				<sowResearchPrerequisites>
					<li>TMM_Research_HarvestTime_AnimalAgricultureI</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
	<!-- RAMIE -->
		<ThingDef ParentName="TMM_HydroponicsPlantBase">
			<defName>TMM_RamiePlant</defName>
			<label>Ramie</label>
			<description>A tall, resilient plant grown for its strong, silky fibres. Ramie takes longer to mature but provides a generous harvest of high-quality fibers for durable textiles.</description>
			<statBases>
				<MaxHitPoints>95</MaxHitPoints>
			</statBases>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Textiles/Ramie</texPath>
			</graphicData>
			<pathCost>14</pathCost>
			<plant>
				<growDays>10</growDays>
				<harvestWork>200</harvestWork>
				<neverBlightable>true</neverBlightable>
				<harvestedThingDef>TMM_RawRamie</harvestedThingDef>
				<fertilityMin>0.6</fertilityMin>
				<harvestYield>12</harvestYield>
				<sowMinSkill>4</sowMinSkill>
				<topWindExposure>0.15</topWindExposure>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Textiles/Ramie</immatureGraphicPath>
				<visualSizeRange>0.3~1.02</visualSizeRange>
				<wildOrder>2</wildOrder>
				<sowResearchPrerequisites>
					<li>TMM_Research_HarvestTime_AnimalAgricultureI</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
	<!-- RATTAN -->
		<ThingDef ParentName="TMM_HydroponicsPlantBase">
			<defName>TMM_RattanPlant</defName>
			<label>Rattan</label>
			<description>A fast-growing, flexible vine. Rattan is harvested for crafting furniture and light construction materials, making it a versatile industrial crop.</description>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Textiles/Rattan</texPath>
			</graphicData>
			<pathCost>14</pathCost>
			<plant>
				<growDays>10</growDays>
				<harvestWork>300</harvestWork>
				<harvestedThingDef>TMM_Rattan</harvestedThingDef>
				<fertilityMin>0.7</fertilityMin>
				<harvestYield>5</harvestYield>
				<sowMinSkill>5</sowMinSkill>
				<topWindExposure>0.15</topWindExposure>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Textiles/Rattan</immatureGraphicPath>
				<visualSizeRange>0.5~1.1</visualSizeRange>
				<wildOrder>2</wildOrder>
				<sowResearchPrerequisites>
					<li>TMM_Research_HarvestTime_AnimalAgricultureI</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
</Defs>