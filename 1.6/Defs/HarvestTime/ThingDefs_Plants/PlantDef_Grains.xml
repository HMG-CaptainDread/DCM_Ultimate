	<!-- MILLET -->
		<ThingDef ParentName="PlantBase">
			<defName>TMM_MilletPlant</defName>
			<label>millet</label>
			<description>A fast-growing cereal crop valued for its resilience. Millet tolerates poor soil and dry conditions better than most food plants, making it a reliable fallback in harsh environments. While the harvest is modest, its short growing time ensures a steady food supply.</description>
			<statBases>
				<MaxHitPoints>85</MaxHitPoints>
				<Nutrition>0.18</Nutrition>
			</statBases>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Grains/Millet</texPath>
				<graphicClass>Graphic_Random</graphicClass>
			</graphicData>
			<selectable>true</selectable>
			<pathCost>14</pathCost>
			<ingestible/>
			<plant>
				<fertilityMin>0.4</fertilityMin>
				<fertilitySensitivity>0.4</fertilitySensitivity>
				<dieIfLeafless>true</dieIfLeafless>
				<harvestTag>Standard</harvestTag>
				<harvestedThingDef>TMM_RawMillet</harvestedThingDef>
				<harvestYield>10</harvestYield>
				<sowTags>
					<li>Ground</li>
					<li>Hydroponic</li>
				</sowTags>
				<topWindExposure>0.1</topWindExposure>
				<growDays>4</growDays>
				<neverBlightable>true</neverBlightable>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Grains/Millet</immatureGraphicPath>
				<visualSizeRange>0.5~1.0</visualSizeRange>
				<wildOrder>2</wildOrder>
				<purpose>Food</purpose>
				<humanFoodPlant>true</humanFoodPlant>
				<sowResearchPrerequisites>
					<li>TMM_Research_HarvestTime_AnimalAgriculture</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
