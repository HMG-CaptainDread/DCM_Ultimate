	<!-- ALFALFA -->
		<ThingDef ParentName="PlantBase">
			<defName>TMM_Alfalfa</defName>
			<label>alfalfa</label>
			<description>A medium-speed legume with deep-green leaves. Alfalfa yields a large harvest, ideal for sustaining livestock over time.</description>
			<statBases>
				<MaxHitPoints>80</MaxHitPoints>
				<Flammability>1.0</Flammability>
				<Nutrition>0.3</Nutrition>
			</statBases>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Grains/Alfalfa</texPath>
				<graphicClass>Graphic_Random</graphicClass>
			</graphicData>
			<selectable>true</selectable>
			<pathCost>14</pathCost>
			<ingestible/>
			<plant>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Grains/Alfalfa</immatureGraphicPath>
				<fertilitySensitivity>0.6</fertilitySensitivity>
				<growDays>5</growDays>
				<dieIfLeafless>true</dieIfLeafless>
				<maxMeshCount>4</maxMeshCount>
				<harvestTag>Standard</harvestTag>
				<harvestedThingDef>TMM_WetAlfalfaGrass</harvestedThingDef>
				<harvestYield>16</harvestYield>
				<sowTags>
					<li>Ground</li>
				</sowTags>
				<topWindExposure>0.1</topWindExposure>
				<visualSizeRange>0.5~0.8</visualSizeRange>
				<wildOrder>1</wildOrder>
				<purpose>Food</purpose>
				<sowResearchPrerequisites>
					<li>TMM_Research_HarvestTime_AnimalAgricultureII</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
	<!-- AMARANTH -->
		<ThingDef ParentName="PlantBase">
			<defName>TMM_AmaranthPlant</defName>
			<label>amaranth</label>
