	<!-- BLACKBERRY -->
		<ThingDef ParentName="TMM_BushPlantBase">
			<defName>TMM_BlackberryBush</defName>
			<label>Blackberry Bush</label>
			<description>A small fruit-bearing shrub producing clusters of dark berries. Blackberry bushes grow slowly and yield a generous harvest, making them a dependable source of food for the colony.</description>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Fruits/Blackberry</texPath>
			</graphicData>
			<statBases>
				<MaxHitPoints>130</MaxHitPoints>
			</statBases>
			<plant>
				<growDays>11</growDays>
				<visualSizeRange>0.8~1.5</visualSizeRange>
				<sowMinSkill>4</sowMinSkill>
				<fertilityMin>0.6</fertilityMin>
				<topWindExposure>0.20</topWindExposure>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Fruits/Blackberry</immatureGraphicPath>
				<leaflessGraphicPath>Modules/HarvestTime/Plants/Mature/NewPlants/Leafless/Blackberry_Leafless</leaflessGraphicPath>
				<leaflessSnowOverlayGraphicPath>Modules/HarvestTime/Plants/Miscellaneous/Fruits/Snowy/Blackberry_Snowy</leaflessSnowOverlayGraphicPath>
				<harvestWork>500</harvestWork>
				<harvestYield>14</harvestYield>
				<harvestedThingDef>TMM_RawBlackberry</harvestedThingDef>
				<harvestFailable>true</harvestFailable>
				<harvestAfterGrowth>0.20</harvestAfterGrowth>
				<sowResearchPrerequisites>
					<li>TMM_HT_AgricultureI</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
	<!-- BLACKCURRANT -->
		<ThingDef ParentName="TMM_BushPlantBase">
			<defName>TMM_BlackcurrantBush</defName>
			<label>Blackcurrant Bush</label>
			<description>A small fruit-bearing shrub producing dark purple-black berries. Blackcurrant bushes grow steadily and yield a generous harvest, making them a reliable source of food.</description>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Fruits/Blackcurrant</texPath>
			</graphicData>
			<statBases>
				<MaxHitPoints>100</MaxHitPoints>
			</statBases>
			<plant>
				<growDays>10</growDays>
				<visualSizeRange>0.8~1.5</visualSizeRange>
				<sowMinSkill>4</sowMinSkill>
				<fertilityMin>0.6</fertilityMin>
				<topWindExposure>0.20</topWindExposure>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Fruits/Blackcurrant</immatureGraphicPath>
				<leaflessGraphicPath>Modules/HarvestTime/Plants/Mature/NewPlants/Leafless/Blackcurrant_Leafless</leaflessGraphicPath>
				<leaflessSnowOverlayGraphicPath>Modules/HarvestTime/Plants/Miscellaneous/Fruits/Snowy/Blackcurrant_Snowy</leaflessSnowOverlayGraphicPath>
				<harvestWork>400</harvestWork>
				<harvestYield>12</harvestYield>
				<harvestedThingDef>TMM_RawBlackcurrant</harvestedThingDef>
				<harvestFailable>true</harvestFailable>
				<harvestAfterGrowth>0.20</harvestAfterGrowth>
				<sowResearchPrerequisites>
					<li>TMM_HT_AgricultureII</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
	<!-- CLOUDBERRY -->
		<ThingDef ParentName="TMM_BushPlantBase">
			<defName>TMM_CloudberryBush</defName>
			<label>Cloudberry Bush</label>
			<description>A berry bush that grows well in cold climates.</description>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Fruits/Cloudberry</texPath>
			</graphicData>
			<plant>
				<harvestedThingDef>TMM_RawCloudberry</harvestedThingDef>
				<harvestYield>7</harvestYield>
				<sowMinSkill>6</sowMinSkill>
				<growDays>6</growDays>
				<fertilitySensitivity>0.6</fertilitySensitivity>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Fruits/Cloudberry</immatureGraphicPath>
				<wildOrder>2</wildOrder>
				<purpose>Food</purpose>
				<sowResearchPrerequisites>
					<li>TMM_HT_AgricultureIV</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
	<!-- DRAGON FRUIT -->
		<ThingDef ParentName="TMM_BushPlantBase">
			<defName>TMM_DragonFruitPlant</defName>
			<label>Dragon Fruit Plant</label>
			<description>A cactus-like plant producing large, colourful fruits. Dragon fruit grows slowly but provides a nutritious and visually striking harvest for the colony.</description>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Fruits/DragonFruit</texPath>
			</graphicData>
			<statBases>
				<Beauty>2</Beauty>
				<BeautyOutdoors>2</BeautyOutdoors>
				<MaxHitPoints>150</MaxHitPoints>
			</statBases>
			<ingestible/>
			<plant>
				<growDays>12</growDays>
				<visualSizeRange>0.6~1.5</visualSizeRange>
				<sowMinSkill>5</sowMinSkill>
				<fertilityMin>0.7</fertilityMin>
				<topWindExposure>0.15</topWindExposure>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Fruits/DragonFruit</immatureGraphicPath>
				<leaflessGraphicPath>Modules/HarvestTime/Plants/Mature/NewPlants/Leafless/DragonFruit_Leafless</leaflessGraphicPath>
				<leaflessSnowOverlayGraphicPath>Modules/HarvestTime/Plants/Miscellaneous/Fruits/Snowy/DragonFruit_Snowy</leaflessSnowOverlayGraphicPath>
				<harvestWork>400</harvestWork>
				<harvestYield>8</harvestYield>
				<harvestedThingDef>TMM_RawDragonFruit</harvestedThingDef>
				<harvestFailable>true</harvestFailable>
				<harvestAfterGrowth>0.20</harvestAfterGrowth>
				<sowResearchPrerequisites>
					<li>TMM_HT_AgricultureIV</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
