	<!-- KIWI -->
		<ThingDef ParentName="TMM_HydroponicsPlantBase">
			<defName>TMM_KiwiPlant</defName>
			<label>Kiwi Plant</label>
			<description>An edible berry that is roughly ovoid in shape and about the size of a large hen's egg. It has a fibrous, dull greenish-brown skin and bright green or golden flesh with rows of tiny, black, edible seeds. The fruit has a soft texture with a sweet and unique flavour.</description>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Fruits/Kiwi</texPath>
			</graphicData>
			<plant>
				<harvestedThingDef>TMM_RawKiwi</harvestedThingDef>
				<harvestYield>6</harvestYield>
				<sowMinSkill>4</sowMinSkill>
				<growDays>3.25</growDays>
				<fertilitySensitivity>0.6</fertilitySensitivity>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Fruits/Kiwi</immatureGraphicPath>
				<purpose>Food</purpose>
				<sowResearchPrerequisites>
					<li>TMM_HT_AgricultureIV</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
