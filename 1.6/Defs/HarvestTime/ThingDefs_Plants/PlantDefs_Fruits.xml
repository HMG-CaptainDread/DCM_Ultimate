	<!-- BLACKBERRY -->
		<ThingDef ParentName="TMM_BushPlantBase">
			<defName>TMM_BlackberryBush</defName>
			<label>Blackberry Bush</label>
			<description>A small fruit-bearing shrub producing clusters of dark berries. Blackberry bushes grow slowly and yield a generous harvest, making them a dependable source of food for the colony.</description>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Fruits/Blackberry</texPath>
			</graphicData>
			<statBases>
				<MaxHitPoints>130</MaxHitPoints>
			</statBases>
			<plant>
				<growDays>11</growDays>
				<visualSizeRange>0.8~1.5</visualSizeRange>
				<sowMinSkill>4</sowMinSkill>
				<fertilityMin>0.6</fertilityMin>
				<topWindExposure>0.20</topWindExposure>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Fruits/Blackberry</immatureGraphicPath>
				<leaflessGraphicPath>Modules/HarvestTime/Plants/Mature/NewPlants/Leafless/Blackberry_Leafless</leaflessGraphicPath>
				<leaflessSnowOverlayGraphicPath>Modules/HarvestTime/Plants/Miscellaneous/Fruits/Snowy/Blackberry_Snowy</leaflessSnowOverlayGraphicPath>
				<harvestWork>500</harvestWork>
				<harvestYield>14</harvestYield>
				<harvestedThingDef>TMM_RawBlackberry</harvestedThingDef>
				<harvestFailable>true</harvestFailable>
				<harvestAfterGrowth>0.20</harvestAfterGrowth>
				<sowResearchPrerequisites>
					<li>TMM_HT_AgricultureI</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
