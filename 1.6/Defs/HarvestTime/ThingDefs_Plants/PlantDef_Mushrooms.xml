		<!-- MECHSHROOM -->
			<ThingDef ParentName="TMM_HydroponicsPlantBase">
				<defName>TMM_MechshroomPlant</defName>
				<label>Mechshroom</label>
				<description>This robust mushroom has been genetically engineered and cultivated to produce a peculiar psychedelic substance utilising a mixture of old-earth psilocybin and microscopic nanites. Able to be grown in hydroponics stations.</description>
				<graphicData>
					<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Mushrooms/Mechshroom</texPath>
				</graphicData>
				<statBases>
					<Nutrition>0.08</Nutrition>
				</statBases>
				<fillPercent>0.01</fillPercent>
				<pathCost>5</pathCost>
				<ingestible>
					<preferability>RawTasty</preferability>
					<outcomeDoers>
						<li Class="IngestionOutcomeDoer_GiveHediff">
							<hediffDef>TMM_Hediff_MechshroomHigh</hediffDef>
							<severity>1.0</severity>
							<toleranceChemical>TMM_Chemical_Mechshroom</toleranceChemical>
						</li>
						<li Class="IngestionOutcomeDoer_GiveHediff">
							<hediffDef>TMM_Tolerance_Mechshroom</hediffDef>
							<severity>0.032</severity>
							<divideByBodySize>true</divideByBodySize>
						</li>
					</outcomeDoers>
				</ingestible>
				<comps>
					<li Class="CompProperties_Drug">
						<chemical>TMM_Chemical_Mechshroom</chemical>
						<addictiveness>0.0</addictiveness>
						<minToleranceToAddict>1.00</minToleranceToAddict>
						<existingAddictionSeverityOffset>0.1</existingAddictionSeverityOffset>
						<needLevelOffset>1</needLevelOffset>
						<listOrder>30</listOrder>
						<overdoseSeverityOffset>
							<min>0.18</min>
							<max>0.35</max>
						</overdoseSeverityOffset>
						<largeOverdoseChance>0.02</largeOverdoseChance>
					</li>
				</comps>
				<plant>
					<harvestedThingDef>TMM_RawMechshroom</harvestedThingDef>
					<harvestYield>3</harvestYield>
					<harvestWork>100</harvestWork>
					<maxMeshCount>9</maxMeshCount>
					<sowMinSkill>10</sowMinSkill>
					<visualSizeRange>0.3~0.5</visualSizeRange>
					<topWindExposure>0</topWindExposure>
					<wildClusterWeight>500</wildClusterWeight>
					<wildClusterRadius>5</wildClusterRadius>
					<wildOrder>2</wildOrder>
					<growDays>3</growDays>
					<fertilitySensitivity>0</fertilitySensitivity>
					<fertilityMin>0.03</fertilityMin>
					<lifespanDaysPerGrowDays>4</lifespanDaysPerGrowDays>
					<neverBlightable>true</neverBlightable>
					<growMinGlow>0</growMinGlow>
					<growOptimalGlow>0</growOptimalGlow>
					<sowResearchPrerequisites>
						<li>TMM_Research_HarvestTime_SpacerAgriculture</li>
					</sowResearchPrerequisites>
				</plant>
			</ThingDef>
