	<!-- EDIBLE -->
		<!-- BLACK TRUFFLE -->
			<ThingDef ParentName="PlantBase">
				<defName>TMM_BlackTrufflePlant</defName>
				<label>Black Truffle</label>
				<description>A rare underground mushroom with a dark, knobby surface and earthy scent, found beneath tree roots. It is a treasure of the forest.</description>
				<statBases>
					<MaxHitPoints>40</MaxHitPoints>
					<Nutrition>0.3</Nutrition>
				</statBases>
				<graphicData>
					<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Mushrooms/BlackTruffle</texPath>
					<graphicClass>Graphic_Random</graphicClass>
					<drawSize>(0.8,0.8)</drawSize>
				</graphicData>
				<selectable>true</selectable>
				<neverMultiSelect>false</neverMultiSelect>
				<pathCost>2</pathCost>
				<plant>
					<growMinGlow>0</growMinGlow>
					<fertilityMin>0.7</fertilityMin>
					<fertilitySensitivity>0.5</fertilitySensitivity>
					<dieIfLeafless>true</dieIfLeafless>
					<harvestFailable>true</harvestFailable>
					<topWindExposure>0</topWindExposure>
					<growDays>18</growDays>
					<harvestYield>1</harvestYield>
					<harvestTag>Standard</harvestTag>
					<harvestedThingDef>TMM_RawBlackTruffle</harvestedThingDef>
					<sowTags/>
					<purpose>Food</purpose>
					<neverBlightable>true</neverBlightable>
					<sowResearchPrerequisites>
						<li>TMM_Research_HarvestTime_IndustrialAgriculture</li>
					</sowResearchPrerequisites>
				</plant>
			</ThingDef>
