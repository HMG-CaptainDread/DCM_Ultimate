	<!-- ARTICHOKE -->
		<ThingDef ParentName="TMM_HydroponicsPlantBase">
			<defName>TMM_ArtichokePlant</defName>
			<label>Artichoke</label>
			<description>A large, slow-growing plant yielding edible flower buds. Artichokes require patience but offer reliable harvests for the colony.</description>
			<statBases>
				<Nutrition>0.18</Nutrition>
			</statBases>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Vegetables/Artichoke</texPath>
			</graphicData>
			<pathCost>14</pathCost>
			<plant>
				<fertilityMin>0.7</fertilityMin>
				<harvestedThingDef>TMM_RawArtichoke</harvestedThingDef>
				<harvestYield>6</harvestYield>
				<topWindExposure>0.1</topWindExposure>
				<growDays>6</growDays>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Vegetables/Artichoke</immatureGraphicPath>
				<visualSizeRange>0.5~1.0</visualSizeRange>
				<wildOrder>2</wildOrder>
				<purpose>Food</purpose>
				<humanFoodPlant>true</humanFoodPlant>
				<sowResearchPrerequisites>
					<li>TMM_Research_HarvestTime_IndustrialAgriculture</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
	<!-- ASPARAGUS -->
		<ThingDef ParentName="TMM_HydroponicsPlantBase">
			<defName>TMM_AsparagusPlant</defName>
			<label>Asparagus</label>
			<description>A slow-growing vegetable harvested for its tender green shoots. Asparagus matures over an extended period and provides a modest, reliable harvest for the farm.</description>
			<statBases>
				<Nutrition>0.12</Nutrition>
			</statBases>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Vegetables/Asparagus</texPath>
			</graphicData>
			<pathCost>14</pathCost>
			<ingestible/>
			<plant>
				<fertilityMin>0.7</fertilityMin>
				<harvestedThingDef>TMM_RawAsparagus</harvestedThingDef>
				<harvestYield>8</harvestYield>
				<topWindExposure>0.05</topWindExposure>
				<growDays>6</growDays>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Vegetables/Asparagus</immatureGraphicPath>
				<visualSizeRange>0.4~0.6</visualSizeRange>
				<wildOrder>2</wildOrder>
				<purpose>Food</purpose>
				<humanFoodPlant>true</humanFoodPlant>
				<sowResearchPrerequisites>
					<li>TMM_Research_HarvestTime_MedievalAgriculture</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
