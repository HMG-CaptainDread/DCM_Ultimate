	<!-- SNOW BEET -->
		<ThingDef ParentName="TMM_HydroponicsPlantBase">
			<defName>TMM_SnowBeetPlant</defName>
			<label>Snow Beet</label>
			<description>A simple but highly nutritious plant. Grows well even in somewhat poor soil and harvests quickly. Both strong and versatile, the crop does not die in cold weather.</description>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Vegetables/SnowBeet</texPath>
			</graphicData>
			<plant>
				<dieIfLeafless>false</dieIfLeafless>
				<harvestedThingDef>TMM_RawSnowBeet</harvestedThingDef>
				<harvestYield>11</harvestYield>
				<sowMinSkill>6</sowMinSkill>
				<growDays>6</growDays>
				<fertilitySensitivity>0.4</fertilitySensitivity>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Vegetables/SnowBeet</immatureGraphicPath>
				<wildOrder>2</wildOrder>
				<purpose>Food</purpose>
				<sowResearchPrerequisites>
					<li>TMM_Research_HarvestTime_AnimalAgriculture</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
