				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
	<!-- BROCCOLI -->
		<ThingDef ParentName="PlantBase">
			<defName>TMM_BroccoliPlant</defName>
			<label>Broccoli</label>
			<description>A food crop that produces compact green florets. Its longer growing time makes it better suited for stable, planned farming.</description>
			<statBases>
				<Nutrition>0.17</Nutrition>
			</statBases>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Vegetables/Broccoli</texPath>
			</graphicData>
			<pathCost>14</pathCost>
			<plant>
				<fertilityMin>0.7</fertilityMin>
				<harvestedThingDef>TMM_RawBroccoli</harvestedThingDef>
				<harvestYield>8</harvestYield>
				<sowTags>
					<li>Ground</li>
					<li>Hydroponic</li>
				</sowTags>
				<topWindExposure>0.1</topWindExposure>
				<growDays>5</growDays>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Vegetables/Broccoli</immatureGraphicPath>
				<visualSizeRange>0.5~0.8</visualSizeRange>
				<wildOrder>2</wildOrder>
				<purpose>Food</purpose>
				<humanFoodPlant>true</humanFoodPlant>
				<sowResearchPrerequisites>
					<li>TMM_Research_HarvestTime_MedievalAgriculture</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
