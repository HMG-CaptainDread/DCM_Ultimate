	<!-- LEMON BALM -->
		<ThingDef ParentName="PlantBase">
			<defName>TMM_LemonBalmPlant</defName>
			<label>lemon balm plant</label>
			<description>A fragrant medicinal herb from the mint family, lemon balm is prized for its soothing, mood-lifting effects and is often used in advanced herbal medicine.</description>
			<statBases>
				<MaxHitPoints>75</MaxHitPoints>
				<Nutrition>0.02</Nutrition>
			</statBases>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Herbs/LemonBalm</texPath>
				<graphicClass>Graphic_Random</graphicClass>
			</graphicData>
			<selectable>true</selectable>
			<pathCost>14</pathCost>
			<ingestible/>
			<plant>
				<fertilityMin>0.7</fertilityMin>
				<dieIfLeafless>true</dieIfLeafless>
				<harvestTag>Standard</harvestTag>
				<harvestedThingDef>TMM_LemonBalmLeaf</harvestedThingDef>
				<harvestYield>14</harvestYield>
				<sowTags>
					<li>Ground</li>
				</sowTags>
				<sowMinSkill>6</sowMinSkill>
				<topWindExposure>0.1</topWindExposure>
				<growDays>6</growDays>
				<neverBlightable>true</neverBlightable>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Herbs/LemonBalm</immatureGraphicPath>
				<harvestWork>260</harvestWork>
				<visualSizeRange>0.5~1.1</visualSizeRange>
				<wildOrder>2</wildOrder>
				<humanFoodPlant>true</humanFoodPlant>
				<sowResearchPrerequisites>
					<li>TMM_HerbFarming</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
