	<!-- BLACK TRUFFLE -->
		<ThingDef ParentName="TMM_RawMushroomBase">
			<defName>TMM_RawBlackTruffle</defName>
			<label>Black Truffle</label>
			<description>A rare subterranean delicacy prized for its intense aroma and flavour.</description>
			<graphicData>
				<texPath>Modules/HarvestTime/Things/NewThings/Mushrooms/BlackTruffle</texPath>
			</graphicData>
			<statBases>
				<MarketValue>75</MarketValue>
			</statBases>
			<comps>
				<li Class="CompProperties_Rottable">
					<daysToRotStart>30</daysToRotStart>
					<rotDestroys>true</rotDestroys>
				</li>
			</comps>
		</ThingDef>
