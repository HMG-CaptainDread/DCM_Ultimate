	<!-- FLY AGARIC -->
		<ThingDef ParentName="TMM_RawMushroomBase">
			<defName>TMM_RawFlyAgaric</defName>
			<label>Fly Agaric</label>
			<description>A striking red mushroom covered with white speckles. Despite its iconic appearance, this fungus is toxic. Eating it raw can cause nausea, confusion, and disturbing hallucinations.</description>
			<graphicData>
				<texPath>Modules/HarvestTime/Things/NewThings/Mushrooms/FlyAgaric</texPath>
			</graphicData>
			<statBases>
				<MarketValue>0.4</MarketValue>
			</statBases>
			<ingestible>
				<preferability>RawBad</preferability>
				<outcomeDoers>
					<li Class="IngestionOutcomeDoer_GiveHediff">
						<hediffDef>FoodPoisoning</hediffDef>
						<severity>0.10</severity>
						<chance>1.0</chance>
					</li>
					<li Class="IngestionOutcomeDoer_GiveHediff">
						<hediffDef>TMM_FlyAgaricPoisoning</hediffDef>
						<severity>1.0</severity>
						<chance>1.0</chance>
					</li>
				</outcomeDoers>
			</ingestible>
			<comps>
				<li Class="CompProperties_Rottable">
					<daysToRotStart>15</daysToRotStart>
					<rotDestroys>true</rotDestroys>
				</li>
			</comps>
		</ThingDef>
