				<texPath>Modules/HarvestTime/Things/NewThings/Vegetables/RedLentil</texPath>
			</graphicData>
			<statBases>
				<FoodPoisonChanceFixedHuman>0.02</FoodPoisonChanceFixedHuman>
				<MarketValue>2</MarketValue>
