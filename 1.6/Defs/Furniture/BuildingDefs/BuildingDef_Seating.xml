						<drawSize>(2.4,2.4)</drawSize>
						<texPath>Modules/Furniture/Buildings/Seats/Thrones/GrandThroneA/GrandThrone_A</texPath>
						<graphicClass>Graphic_Multi</graphicClass>
						<shaderType>CutoutComplex</shaderType>
						<shadowData>
							<volume>(0.5,0.35,0.4)</volume>
						</shadowData>
						<damageData>
							<rect>(0.2,0,2, 0.6, 0.6)</rect>
						</damageData>
					</graphicData>
					<ritualFocus>
						<spectateDistance>2</spectateDistance>
						<allowedSpectateSides>Up</allowedSpectateSides>
					</ritualFocus>
					<placeWorkers>
						<li>PlaceWorker_RitualFocus</li>
					</placeWorkers>
					<drawPlaceWorkersWhileSelected>True</drawPlaceWorkersWhileSelected>
				</ThingDef>
