										<points>
											<li>(0,   -0.05)</li>
											<li>(30,   0.00)</li>
											<li>(60,   0.04)</li>
											<li>(100,  0.08)</li>
											<li>(170,  0.10)</li>
										</points>
									</curve>
								</li>
							</offsets>
						</li>
