	<!-- MISCELLANEOUS -->
		<!-- SOFA BED -->
			<ThingDef ParentName="Bed">
				<defName>TMM_Seating_SofaBed</defName>
				<label>sofa</label>
				<description>A large double-wide seat which is cushioned for maximum comfort. Perfect for a luxurious rec room or a homey reading nook, or even something to crash on if no beds are available.</description>
				<graphicData>
					<texPath>Modules/Furniture/Buildings/Seats/Sofa/Sofa</texPath>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>(2.1)</drawSize>
				</graphicData>
				<statBases Inherit="False">
					<MaxHitPoints>160</MaxHitPoints>
					<WorkToBuild>20000</WorkToBuild>
					<Mass>70</Mass>
					<Flammability>1.0</Flammability>
					<Beauty>4</Beauty>
					<Comfort>0.85</Comfort>
					<BedRestEffectiveness>0.95</BedRestEffectiveness>
				</statBases>
				<size>(1,2)</size>
				<researchPrerequisites>
					<li>ComplexFurniture</li>
				</researchPrerequisites>
				<stuffCategories Inherit="False">
					<li>Fabric</li>
					<li>Leathery</li>
				</stuffCategories>
				<costStuffCount>85</costStuffCount>
				<pathCost>30</pathCost>
				<fillPercent>0.40</fillPercent>
				<defaultPlacingRot>East</defaultPlacingRot>
				<constructionSkillPrerequisite>4</constructionSkillPrerequisite>
				<building>
					<bed_showSleeperBody>true</bed_showSleeperBody>
					<bed_countsForBedroomOrBarracks>false</bed_countsForBedroomOrBarracks>
					<paintable>true</paintable>
					<isSittable>true</isSittable>
					<multiSittable>true</multiSittable>
					<destroySound>BuildingDestroyed_Soft_Small</destroySound>
				</building>
				<comps>
					<li Class="CompProperties_AssignableToPawn">
						<drawAssignmentOverlay>true</drawAssignmentOverlay>
						<compClass>CompAssignableToPawn_Bed</compClass>
					</li>
				</comps>
			</ThingDef>
