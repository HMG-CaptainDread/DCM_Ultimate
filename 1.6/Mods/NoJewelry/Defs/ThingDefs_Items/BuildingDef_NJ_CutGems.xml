			<!-- RUBY -->
				<ThingDef ParentName="TMM_CutGemBase">
					<defName>TMM_GemCut_Ruby</defName>
					<label>cut ruby</label>
					<description>A blood-red variety of corundum, finely cut in order to be used for making things.</description>

					<graphicData>
						<texPath>Modules/Mining/Things/Gems/Cut/CutRuby</texPath>
					</graphicData>

					<statBases>
						<MarketValue>7</MarketValue>
						<BluntDamageMultiplier>1.7</BluntDamageMultiplier>
						<SharpDamageMultiplier>1.2</SharpDamageMultiplier>
					</statBases>

					<stuffProps>
						<color>(179,56,52)</color>

						<statOffsets>
							<Beauty>10</Beauty>
						</statOffsets>

						<statFactors>
							<MaxHitPoints>0.7</MaxHitPoints>
							<WorkToMake>1.55</WorkToMake>
							<WorkToBuild>5.25</WorkToBuild>
							<Beauty>3</Beauty>
							<WorkTableWorkSpeedFactor>1.4</WorkTableWorkSpeedFactor>
							<JoyGainFactor>1.1</JoyGainFactor>
							<Comfort>1.1</Comfort>
							<BedRestEffectiveness>1.2</BedRestEffectiveness>
							<MedicalTendQualityOffset>1.3</MedicalTendQualityOffset>
							<ImmunityGainSpeedFactor>1.3</ImmunityGainSpeedFactor>
							<SurgerySuccessChanceFactor>1.3</SurgerySuccessChanceFactor>
						</statFactors>
					</stuffProps>
				</ThingDef>
