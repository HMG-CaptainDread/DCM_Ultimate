	<!-- BASES -->
		<!-- PIPE -->
			<!-- PASTE VAT BASE -->
				<ThingDef ParentName="BuildingBase" Name="TMM_NutrientPasteVatBase" Abstract="True">
					<drawerType>MapMeshAndRealTime</drawerType>
					<graphicData>
						<texPath>Things/Building/NutrientPasteVat</texPath>
						<graphicClass>Graphic_Single</graphicClass>
						<damageData>
							<cornerTL>Damage/Corner</cornerTL>
							<cornerTR>Damage/Corner</cornerTR>
						</damageData>
					</graphicData>
					<designatorDropdown>TMM_NutrientPasteVatGroup</designatorDropdown>
					<altitudeLayer>Building</altitudeLayer>
					<passability>Impassable</passability>
					<blockWind>true</blockWind>
					<castEdgeShadows>true</castEdgeShadows>
					<fillPercent>1</fillPercent>
					<statBases>
						<Flammability>1.0</Flammability>
					</statBases>
					<comps>
						<li Class="VNPE.CompProperties_RegisterIngredients"/>
					</comps>
					<tickerType>Rare</tickerType>
					<rotatable>false</rotatable>
					<terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
					<staticSunShadowHeight>0.2</staticSunShadowHeight>
					<constructEffect>ConstructMetal</constructEffect>
					<canOverlapZones>false</canOverlapZones>
					<designationCategory>VCHE_PipeNetworks</designationCategory>
					<researchPrerequisites>
						<li>NutrientPaste</li>
					</researchPrerequisites>
				</ThingDef>
	<!-- NUTRIENT PASTE -->
		<!-- SMALL PASTE VAT -->
			<ThingDef ParentName="TMM_NutrientPasteVatBase">
				<defName>TMM_NutrientPasteVat_Small</defName>
				<label>nutrient paste vat (small)</label>
				<description>A small size tank that can store up to 45 nutrient paste meals in it. Makes a big mess when destroyed.</description>
				<graphicData>
					<drawSize>(1.5,1.5)</drawSize>
				</graphicData>
				<statBases>
					<MaxHitPoints>75</MaxHitPoints>
					<WorkToBuild>400</WorkToBuild>
					<Mass>10</Mass>
					<Flammability>1.0</Flammability>
				</statBases>
				<size>(1,1)</size>
				<costList>
					<Steel>80</Steel>
				</costList>
				<comps>
					<li Class="PipeSystem.CompProperties_ResourceStorage">
						<pipeNet>VNPE_NutrientPasteNet</pipeNet>
						<storageCapacity>45</storageCapacity>
						<barSize>(0.36, 0.10)</barSize>
						<margin>0.03</margin>
						<centerOffset>(0, 0, -0.18)</centerOffset>
						<destroyOption>
							<filth>VNPE_Filth_Paste</filth>
							<ratio>1</ratio>
							<maxRadius>3</maxRadius>
						</destroyOption>
						<contentRequirePower>true</contentRequirePower>
					</li>
					<li Class="CompProperties_Power">
						<compClass>CompPowerTrader</compClass>
						<basePowerConsumption>75</basePowerConsumption>
					</li>
				</comps>
			</ThingDef>
