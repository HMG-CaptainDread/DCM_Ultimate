	<!-- TMM_Drug_ -->



	<!-- DREAMSTICK --> <!-- MORPHINE --> <!-- TODO: move this into the thingy to account for classics -->
		<ThingDef ParentName="MakeableDrugBase">
			<defName>RC2_Dreamstick</defName>
			<label>dreamstick</label>
			<description>A carefully refined zopioid known for its medical uses, dreamsticks, as they are known on the Rim, are a combat pain reliever prized by soldiers and doctors alike.  By using a specially designed, one-use auto-injector, the drug can be safely and quickly injected to relieve pain quickly and relatively safely.  Useful for keeping a soldier in combat longer or helping get one to safety.  Be warned however, once it wears off the pain comes back stronger for a short time.</description>
			<graphicData>
				<texPath>RC2_Things/RC2_Drugs/Dreamstick</texPath> <!-- TODO: -->
				<graphicClass>Graphic_StackCount</graphicClass>
			</graphicData>
			<rotatable>false</rotatable>
			<statBases>
				<WorkToMake>500</WorkToMake>
				<MarketValue>20</MarketValue>
				<Mass>0.1</Mass>
			</statBases>
			<techLevel>Industrial</techLevel>
			<ingestible>
				<foodType>Processed</foodType>
				<joyKind>Chemical</joyKind>
				<joy>0.05</joy>
				<baseIngestTicks>50</baseIngestTicks>
				<nurseable>true</nurseable>
				<drugCategory>Hard</drugCategory>
				<ingestSound>Ingest_Inject</ingestSound>
				<ingestHoldOffsetStanding>
					<northDefault>
						<offset>(0.18,0,0)</offset>
						<behind>true</behind>
					</northDefault>
				</ingestHoldOffsetStanding>
				<ingestHoldUsesTable>false</ingestHoldUsesTable>
				<ingestCommandString>Inject {0}</ingestCommandString>
				<ingestReportString>Injecting {0}.</ingestReportString>
				<useEatingSpeedStat>false</useEatingSpeedStat>
				<chairSearchRadius>0</chairSearchRadius>
				<outcomeDoers>
					<li Class="IngestionOutcomeDoer_GiveHediff">
						<hediffDef>RC2_DreamstickHigh</hediffDef> <!-- TODO: -->
						<severity>0.2</severity>
						<toleranceChemical>RC2_Zopioid</toleranceChemical>
					</li>
					<li Class="IngestionOutcomeDoer_GiveHediff">
						<hediffDef>RC2_ZopioidTolerance</hediffDef> <!-- TODO: -->
						<severity>0.02</severity>
						<divideByBodySize>true</divideByBodySize>
					</li>
				</outcomeDoers>
			</ingestible>
			<recipeMaker>
				<researchPrerequisite>RC2_ZopioidRefining</researchPrerequisite>
				<recipeUsers>
					<li>DrugLab</li>
				</recipeUsers>
			</recipeMaker>
			<costList>
				<RC2_Zope>2</RC2_Zope>
				<Neutroamine>1</Neutroamine>
				<MedicineHerbal>1</MedicineHerbal>
			</costList>
			<comps>
				<li Class="CompProperties_Drug">
					<chemical>RC2_Zopioid</chemical>
					<addictiveness>0.1</addictiveness>
					<minToleranceToAddict>0.14</minToleranceToAddict>
					<existingAddictionSeverityOffset>0.2</existingAddictionSeverityOffset>
					<needLevelOffset>1</needLevelOffset>
					<listOrder>20</listOrder>
					<overdoseSeverityOffset>
						<min>0.05</min>
						<max>0.10</max>
					</overdoseSeverityOffset>
					<isCombatEnhancingDrug>true</isCombatEnhancingDrug>
				</li>
			</comps>
		</ThingDef>
	<!-- SKAG --> <!-- HEROIN --> <!-- TODO: move this into the thingy like dreamstick -->
		<ThingDef ParentName="MakeableDrugBase">
			<defName>RC2_Skag</defName>
			<label>skag</label>
			<description>A refined and condensed Zopioid based on Zope.  This stuff is far more powerful and will knock anyone who injects it out for a few hours with a euphoric high.  Overdosing is quite easy on this stuff and there are a number of sideffects; however, many of those addicted tend to not care as they chase that high which becomes more and more difficult to obtain.</description>
			<graphicData>
			<texPath>RC2_Things/RC2_Drugs/Skag</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
			</graphicData>
			<rotatable>false</rotatable>
			<statBases>
			<WorkToMake>800</WorkToMake>
			<MarketValue>35</MarketValue>
			<Mass>0.05</Mass>
			</statBases>
			<techLevel>Industrial</techLevel>
			<ingestible>
			<foodType>Processed, Fluid</foodType>
			<joy>0.8</joy>
			<joyKind>Chemical</joyKind>
			<baseIngestTicks>300</baseIngestTicks>
			<nurseable>true</nurseable>
			<drugCategory>Hard</drugCategory>
			<ingestSound>Ingest_Inject</ingestSound>
			<ingestHoldOffsetStanding>
				<northDefault>
				<offset>(0.18,0,0)</offset>
				<behind>true</behind>
				</northDefault>
			</ingestHoldOffsetStanding>
			<ingestHoldUsesTable>false</ingestHoldUsesTable>
			<ingestCommandString>Inject {0}</ingestCommandString>
			<ingestReportString>Injecting {0}.</ingestReportString>
			<useEatingSpeedStat>false</useEatingSpeedStat>
			<outcomeDoers>
				<li Class="IngestionOutcomeDoer_GiveHediff">
				<hediffDef>RC2_SkagHigh</hediffDef>
				<severity>0.75</severity>
				<toleranceChemical>RC2_Zopioid</toleranceChemical>
				</li>
				<li Class="IngestionOutcomeDoer_OffsetNeed">
				<need>Rest</need>
				<offset>-0.5</offset>
				</li>
				<li Class="IngestionOutcomeDoer_GiveHediff">
				<hediffDef>RC2_ZopioidTolerance</hediffDef>
				<severity>0.05</severity>
				<divideByBodySize>true</divideByBodySize>
				</li>
			</outcomeDoers>
			</ingestible>
			<recipeMaker>
			<researchPrerequisite>RC2_ZopioidRefining</researchPrerequisite>
			<recipeUsers>
				<li>CraftingSpot</li>
				<li>DrugLab</li>
			</recipeUsers>
			</recipeMaker>
			<costList>
			<RC2_Zope>3</RC2_Zope>
			</costList>
			<comps>
			<li Class="CompProperties_Drug">
				<chemical>RC2_Zopioid</chemical>
				<addictiveness>0.3</addictiveness>
				<minToleranceToAddict>0.00</minToleranceToAddict>
				<existingAddictionSeverityOffset>0.5</existingAddictionSeverityOffset>
				<needLevelOffset>1</needLevelOffset>
				<listOrder>20</listOrder>
				<overdoseSeverityOffset>
				<min>0.18</min>
				<max>0.35</max>
				</overdoseSeverityOffset>
				<largeOverdoseChance>0.03</largeOverdoseChance>
			</li>
			</comps>
		</ThingDef>
	<!-- VIKO --> <!-- VICODIN --> <!-- TODO: another opium thingy -->
		<ThingDef ParentName="MakeableDrugPillBase">
			<defName>RC2_Viko</defName>
			<label>viko</label>
			<description>Combining zope and healroot into a paste then drying it into a powder and pressing it into little pellets or tablets, Viko is a mild pain relief medicine commonly found on the Rim.  Although mildly addictive, it is relatively safe to use if done so carefully.  Great for chronic pain.  Often put into drinks to make 'purple drank'.</description>
			<graphicData>
			<texPath>RC2_Things/RC2_Drugs/Viko</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
			</graphicData>
			<rotatable>false</rotatable>
			<statBases>
			<WorkToMake>300</WorkToMake>
			<MarketValue>18</MarketValue>
			<Mass>0.005</Mass>
			</statBases>
			<techLevel>Industrial</techLevel>
			<ingestible>
			<foodType>Processed</foodType>
			<joy>0.1</joy>
			<joyKind>Chemical</joyKind>
			<baseIngestTicks>120</baseIngestTicks>
			<nurseable>true</nurseable>
			<drugCategory>Social</drugCategory>
			<ingestHoldOffsetStanding>
				<northDefault>
				<offset>(0.18,0,0)</offset>
				<behind>true</behind>
				</northDefault>
			</ingestHoldOffsetStanding>
			<outcomeDoers>
				<li Class="IngestionOutcomeDoer_GiveHediff">
				<hediffDef>RC2_VikoHigh</hediffDef>
				<severity>1.0</severity>
				<toleranceChemical>RC2_Zopioid</toleranceChemical>
				</li>
				<li Class="IngestionOutcomeDoer_OffsetNeed">
				<need>Rest</need>
				<offset>-0.1</offset>
				</li>
				<li Class="IngestionOutcomeDoer_GiveHediff">
				<hediffDef>RC2_ZopioidTolerance</hediffDef>
				<severity>0.01</severity>
				<divideByBodySize>true</divideByBodySize>
				</li>
			</outcomeDoers>
			</ingestible>
			<recipeMaker>
			<researchPrerequisite>RC2_AdvancedZopioidRefining</researchPrerequisite>
			<recipeUsers>
				<li>DrugLab</li>
			</recipeUsers>
			</recipeMaker>
			<costList>
			<RC2_Zope>1</RC2_Zope>
			<MedicineHerbal>1</MedicineHerbal>
			</costList>
			<comps>
			<li Class="CompProperties_Drug">
				<chemical>RC2_Zopioid</chemical>
				<addictiveness>0.05</addictiveness>
				<minToleranceToAddict>0.5</minToleranceToAddict>
				<existingAddictionSeverityOffset>0.1</existingAddictionSeverityOffset>
				<needLevelOffset>1</needLevelOffset>
				<listOrder>20</listOrder>
				<overdoseSeverityOffset>
				<min>0.08</min>
				<max>0.14</max>
				</overdoseSeverityOffset>
			</li>
			</comps>
		</ThingDef>
	<!-- ZOPE --> <!-- OPIUM --> <!-- TODO: merge and shit -->
		<ThingDef ParentName="MakeableDrugBase">
			<defName>RC2_Zope</defName>
			<label>zope</label>
			<description>Zope, the base drug for a number of zopioids, is a dried and processed gum-like latex from the dreamflower plant. Either smoked or used to make stronger drugs.</description>
			<graphicData>
			<texPath>RC2_Things/RC2_Drugs/Zope</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
			</graphicData>
			<rotatable>false</rotatable>
			<statBases>
			<WorkToMake>350</WorkToMake>
			<MarketValue>10</MarketValue>
			<Mass>0.05</Mass>
			</statBases>
			<techLevel>Neolithic</techLevel>
			<ingestible>
			<foodType>Processed</foodType>
			<joy>0.3</joy>
			<joyKind>Chemical</joyKind>
			<baseIngestTicks>720</baseIngestTicks>
			<nurseable>true</nurseable>
			<drugCategory>Social</drugCategory>
			<ingestSound>Ingest_Smoke</ingestSound>
			<ingestEffect>Smoke_Joint</ingestEffect>
			<ingestEffectEat>EatVegetarian</ingestEffectEat>
			<ingestHoldOffsetStanding>
				<northDefault>
				<offset>(0.27,0,0.08)</offset>
				<behind>true</behind>
				</northDefault>
				<east>
				<offset>(0.45,0,0.08)</offset>
				</east>
				<south>
				<offset>(0.27,0,0.08)</offset>
				</south>
				<west>
