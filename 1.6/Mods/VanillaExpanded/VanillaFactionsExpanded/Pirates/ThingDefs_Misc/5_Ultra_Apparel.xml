			<!-- HELMET -->
				<VFEPirates.WarcasketDef MayRequire="Ludeon.RimWorld.Biotech" ParentName="VFEP_WarcasketHelmetBase">
					<defName>WarcasketHelmet_Centurion</defName>
					<label>centurion helmet</label>
					<shortDescription>centurion is a modification of the tyrant, which is designed for mechnators.</shortDescription>
					<description>The centurion's full-coverage helmet is equipped with an experimental electromagnetic jammer, which can effectively interfere electronic equipment from a long distance. n\n\ also there are pair of antenna which helps the wearer, a mechnator control their mechs.</description>
					<graphicData>
						<texPath>Modules/Clothing/5_Ultra/Warcaskets/Centurion/Helmet/WarcasketHelmet</texPath>
					</graphicData>
					<uiIconScale>1.25</uiIconScale>
					<statBases>
						<Mass>12</Mass>
						<ArmorRating_Sharp>1.2</ArmorRating_Sharp>
						<ArmorRating_Blunt>0.8</ArmorRating_Blunt>
						<ArmorRating_Heat>1.2</ArmorRating_Heat>
						<Insulation_Cold>4</Insulation_Cold>
						<Insulation_Heat>2</Insulation_Heat>
						<EquipDelay>1</EquipDelay>
					</statBases>
					<equippedStatOffsets>
						<MechBandwidth>8</MechBandwidth>
						<MoveSpeed>-0.2</MoveSpeed>
						<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">0.1</SlaveSuppressionOffset>
					</equippedStatOffsets>
					<costList>
						<SignalChip>1</SignalChip>
						<ComponentIndustrial>2</ComponentIndustrial>
						<Steel>70</Steel>
						<Uranium>10</Uranium>
					</costList>
					<researchPrerequisites>
						<li>VFEP_SpecialisedWarcaskets</li>
					</researchPrerequisites>
					<comps>
						<li Class="CompProperties_ApparelReloadable">
							<maxCharges>4</maxCharges>
							<ammoDef>ComponentIndustrial</ammoDef>
							<ammoCountPerCharge>1</ammoCountPerCharge>
							<baseReloadTicks>60</baseReloadTicks>
							<soundReload>Standard_Reload</soundReload>
							<hotKey>Misc3</hotKey>
							<chargeNoun>grenade</chargeNoun>
							<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
						</li>
					</comps>
					<verbs>
						<li Class="VFEPirates.VerbProps_MultipleProjectiles">
							<label>electromagnetic jammer</label>
							<verbClass>VFEPirates.Verb_LaunchProjectileStaticMultiple</verbClass>
							<hasStandardCommand>true</hasStandardCommand>
							<onlyManualCast>True</onlyManualCast>
							<range>31.9</range>
							<forcedMissRadius>3.9</forcedMissRadius>
							<warmupTime>5</warmupTime>
							<noiseRadius>4</noiseRadius>
							<projectileCount>1</projectileCount>
							<commandIcon>UI/Abilities/GrenadeBarrage</commandIcon>
							<ai_IsBuildingDestroyer>false</ai_IsBuildingDestroyer>
							<soundCast>Shot_IncendiaryLauncher</soundCast>
							<soundCastTail>GunTail_Medium</soundCastTail>
							<muzzleFlashScale>40</muzzleFlashScale>
							<drawHighlightWithLineOfSight>true</drawHighlightWithLineOfSight>
							<targetParams>
								<canTargetLocations>true</canTargetLocations>
							</targetParams>
							<defaultProjectile>WC_Bullet_EMPLauncher</defaultProjectile>
							<rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
						</li>
					</verbs>
					<apparel>
						<mechanitorApparel>true</mechanitorApparel>
						<bodyPartGroups>
							<li>FullHead</li>
						</bodyPartGroups>
						<wornGraphicPath>Modules/Clothing/5_Ultra/Warcaskets/Centurion/Helmet/WarcasketHelmet</wornGraphicPath>
						<layers>
							<li>Overhead</li>
						</layers>
						<tags>
							<li>Warcasket</li>
							<li>WarcasketVeteran</li>
							<li>WarcasketAll</li>
						</tags>
					</apparel>
				</VFEPirates.WarcasketDef>
