<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<!-- <></> -->
	<!--  -->



	<!-- Modules/Pawns/Retextures/NL_FacialAnimation/Pawns/HumanLikes/Heads_Blank/VRE_Genies/ -->

	<!-- FACIAL ANIMATIONS -->
		<Operation Class="PatchOperationSequence">
			<success>Normal</success>
			<operations>
				<!-- HEAD TYPES -->
					<!-- ELONGATED HEAD -->
						<!-- FURSKIN -->
							<li Class="PatchOperationAdd">
								<xpath>/Defs</xpath>
								<value>
									<FacialAnimation.HeadTypeDef>
										<defName>FurskinElongatedHead</defName>
										<texPath>Modules/Pawns/Retextures/NL_FacialAnimation/Pawns/HumanLikes/Heads_Blank/VRE_Genies/FurCoveredElongated</texPath>
										<probability>1</probability>
										<shader>Map/CutoutSkin</shader>
										<shaderColorOverride>Map/CutoutSkinOverride</shaderColorOverride>
										<targetGeneDefs>
											<li>Furskin</li>
											<li>VRE_ElongatedHead</li>
										</targetGeneDefs>
									</FacialAnimation.HeadTypeDef>
								</value>
							</li>
						<!-- NORMAL -->
							<li Class="PatchOperationAdd">
								<xpath>/Defs</xpath>
								<value>
									<FacialAnimation.HeadTypeDef>
										<defName>ElongatedHead</defName>
										<texPath>Modules/Pawns/Retextures/NL_FacialAnimation/Pawns/HumanLikes/Heads_Blank/VRE_Genies/Elongated</texPath>
										<probability>1</probability>
										<shader>Map/CutoutSkin</shader>
										<shaderColorOverride>Map/CutoutSkinOverride</shaderColorOverride>
										<targetGeneDefs>
											<li>VRE_ElongatedHead</li>
										</targetGeneDefs>
									</FacialAnimation.HeadTypeDef>
								</value>
							</li>
						<!-- CONDITIONALS -->
							<!-- BARK SKIN (PHYTOKIN) -->
								<li Class="PatchOperationFindMod">
									<mods>
										<li>Vanilla Races Expanded - Phytokin</li>
									</mods>
									<match Class="PatchOperationAdd">
										<xpath>/Defs</xpath>
										<value>
											<FacialAnimation.HeadTypeDef>
												<defName>BarkSkinElongatedHead</defName>
												<texPath>Modules/Pawns/Retextures/NL_FacialAnimation/Pawns/HumanLikes/Heads_Blank/VRE_Genies/BarkSkinElongated</texPath>
												<probability>1</probability>
												<shader>Map/CutoutSkin</shader>
												<shaderColorOverride>Map/CutoutSkinOverride</shaderColorOverride>
												<targetGeneDefs>
													<li>VRE_BarkSkin</li>
													<li>VRE_ElongatedHead</li>
												</targetGeneDefs>
											</FacialAnimation.HeadTypeDef>
										</value>
									</match>
								</li>
							<!-- SCALE SKIN (SAURID) -->
								<li Class="PatchOperationFindMod">
									<mods>
										<li>Vanilla Races Expanded - Saurid</li>
									</mods>
									<match Class="PatchOperationAdd">
										<xpath>/Defs</xpath>
										<value>
											<FacialAnimation.HeadTypeDef>
												<defName>ScaleSkinElongatedHead</defName>
												<texPath>Modules/Pawns/Retextures/NL_FacialAnimation/Pawns/HumanLikes/Heads_Blank/VRE_Genies/ScaleSkinElongated</texPath>
												<probability>1</probability>
												<shader>Map/CutoutSkin</shader>
												<shaderColorOverride>Map/CutoutSkinOverride</shaderColorOverride>
												<targetGeneDefs>
													<li>VRESaurids_ScaleSkin</li>
													<li>VRE_ElongatedHead</li>
												</targetGeneDefs>
											</FacialAnimation.HeadTypeDef>
										</value>
									</match>
								</li>
			</operations>
		</Operation>
	<!--  -->
</Patch>