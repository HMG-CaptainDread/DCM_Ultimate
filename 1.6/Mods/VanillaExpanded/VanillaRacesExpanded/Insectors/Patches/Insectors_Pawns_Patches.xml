	<!-- Modules/Pawns/Retextures/NL_FacialAnimation/Pawns/HumanLikes/Heads_Blank/VRE_Insectors/ -->

	<!-- FACIAL ANIMATIONS -->
		<Operation Class="PatchOperationSequence">
			<success>Normal</success>
			<operations>
				<!-- HEAD TYPES -->
					<!-- INSECT SKIN -->
						<!-- GAUNT -->
							<FacialAnimation.HeadTypeDef>
								<defName>InsectSkinGaunt</defName>
								<texPath>Modules/Pawns/Retextures/NL_FacialAnimation/Pawns/HumanLikes/Heads_Blank/VRE_Insectors/InsectSkinGaunt</texPath>
								<probability>1</probability>
								<shader>Map/CutoutSkin</shader>
								<shaderColorOverride>Map/CutoutSkinOverride</shaderColorOverride>
								<targetGeneDefs>
									<li>VRE_InsectSkin</li>
									<li>Head_Gaunt</li>
								</targetGeneDefs>
							</FacialAnimation.HeadTypeDef>
						<!-- HEAVY JAW -->
							<FacialAnimation.HeadTypeDef>
								<defName>InsectSkinHeavyJaw</defName>
								<texPath>Modules/Pawns/Retextures/NL_FacialAnimation/Pawns/HumanLikes/Heads_Blank/VRE_Insectors/InsectSkinHeavyJaw</texPath>
								<probability>1</probability>
								<shader>Map/CutoutSkin</shader>
								<shaderColorOverride>Map/CutoutSkinOverride</shaderColorOverride>
								<targetGeneDefs>
									<li>VRE_InsectSkin</li>
									<li>Jaw_Heavy</li>
								</targetGeneDefs>
							</FacialAnimation.HeadTypeDef>
						<!-- NORMAL -->
							<FacialAnimation.HeadTypeDef>
								<defName>InsectSkin</defName>
								<texPath>Modules/Pawns/Retextures/NL_FacialAnimation/Pawns/HumanLikes/Heads_Blank/VRE_Insectors/InsectSkin</texPath>
								<probability>1</probability>
								<shader>Map/CutoutSkin</shader>
								<shaderColorOverride>Map/CutoutSkinOverride</shaderColorOverride>
								<targetGeneDefs>
									<li>VRE_InsectSkin</li>
								</targetGeneDefs>
							</FacialAnimation.HeadTypeDef>
			</operations>
		</Operation>
