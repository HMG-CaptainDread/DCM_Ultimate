<!--========== Adding Stuff from Medieval Overhaul ==========-->
		
	<Operation Class="PatchOperationFindMod">
	<mods>
      <li>Medieval Overhaul</li>
    </mods>
		<match Class="PatchOperationSequence">
		<operations>
			<li Class="PatchOperationAdd">
			<xpath>Defs/WorldObjectDef[defName="Outpost_Mining"]/modExtensions/li[1]/Resources</xpath>
			<value>
				<DankPyon_Coal>10</DankPyon_Coal>
				<DankPyon_Citrine>20</DankPyon_Citrine>
				<DankPyon_Amber>20</DankPyon_Amber>
				<DankPyon_Onyx>20</DankPyon_Onyx>
				<DankPyon_Emerald>20</DankPyon_Emerald>
				<DankPyon_Sapphire>20</DankPyon_Sapphire>
				<DankPyon_Ruby>20</DankPyon_Ruby>				
			</value>
			</li>
			
			<li Class="PatchOperationRemove">
			<xpath>Defs/WorldObjectDef[defName="Outpost_Mining"]/modExtensions/li[1]/Resources/ComponentIndustrial</xpath>
			</li>
			
			<li Class="PatchOperationReplace">
			<xpath>Defs/WorldObjectDef[defName="Outpost_Mining"]/modExtensions/li[1]/Resources/Steel</xpath>
			<value>
				<DankPyon_IronOre>15</DankPyon_IronOre>
			</value>
			</li>
			
			<li Class="PatchOperationReplace">
			<xpath>Defs/WorldObjectDef[defName="Outpost_Mining"]/modExtensions/li[1]/Resources/Silver</xpath>
			<value>
				<DankPyon_SilverOre>30</DankPyon_SilverOre>
			</value>
			</li>
			
			<li Class="PatchOperationReplace">
			<xpath>Defs/WorldObjectDef[defName="Outpost_Mining"]/modExtensions/li[1]/Resources/Gold</xpath>
			<value>
				<DankPyon_GoldOre>35</DankPyon_GoldOre>
			</value>
			</li>
			
		</operations>
		</match>
	</Operation>

