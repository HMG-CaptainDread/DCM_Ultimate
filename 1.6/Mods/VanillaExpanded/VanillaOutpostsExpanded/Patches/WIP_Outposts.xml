	<!--========== removes Diamond, Ruby, Sapphire if Jewelry Mod is activ ==========-->
	
	<Operation Class="PatchOperationFindMod">
	<mods>
      <li>Gemstones</li>
	  <li>Jewelry</li>
    </mods>
		<match Class="PatchOperationSequence">
			<operations>

			<li Class="PatchOperationRemove">
			<xpath>Defs/WorldObjectDef[defName="Outpost_Mining"]/modExtensions/li[1]/Resources/Z_Diamond</xpath>
			</li>
			
			<li Class="PatchOperationRemove">
			<xpath>Defs/WorldObjectDef[defName="Outpost_Mining"]/modExtensions/li[1]/Resources/Z_Ruby</xpath>
			</li>
			
			<li Class="PatchOperationRemove">
			<xpath>Defs/WorldObjectDef[defName="Outpost_Mining"]/modExtensions/li[1]/Resources/Z_Sapphire</xpath>
			</li>

			</operations>
		</match>
	</Operation>

