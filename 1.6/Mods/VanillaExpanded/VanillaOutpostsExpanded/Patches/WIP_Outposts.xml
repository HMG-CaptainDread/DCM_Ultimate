<?xml version="1.0" encoding="utf-8"?>
<Patch>

<!--========== Adding Glas and Ebony from MorroRim ==========-->

	<Operation Class="PatchOperationFindMod">
	<mods>
      <li>MorrowRim - Glass and Ebony</li>
    </mods>
		<match Class="PatchOperationAdd">
		<xpath>Defs/WorldObjectDef[defName="Outpost_Mining"]/modExtensions/li[1]/Resources</xpath>
			<value>
				<MorrowRim_Glass>40</MorrowRim_Glass>
				<MorrowRim_Ebony>40</MorrowRim_Ebony>
			</value>
		</match>
	</Operation>
	
