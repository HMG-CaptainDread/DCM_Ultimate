	<!--  -->



	<!-- FIRE EXTINGUISHER -->
		<Operation Class="PatchOperationFindMod">
			<mods>
				<li>Fire Extinguisher</li>
				<li>Fire Extinguisher (Continued)</li>
			</mods>
			<match Class="PatchOperationSequence">
				<success>Normal</success>
				<operations>
					<!-- ALLOW SPACE BREATHING -->
						<li Class="PatchOperationAdd">
							<xpath>Defs/AlienRace.ThingDef_AlienRace[defName="NFFDrone"]/alienRace/raceRestriction/whiteApparelList</xpath>
							<value>
								<li>Gun_Fire_Ext</li>
							</value>
						</li>
				</operations>
			</match>
		</Operation>
	<!-- FIRE WARDEN -->
		<Operation Class="PatchOperationFindMod">
			<mods>
				<li>Fire Warden</li>
				<li>Fire Warden (Continued)</li>
			</mods>
			<match Class="PatchOperationSequence">
				<success>Normal</success>
				<operations>
					<!-- ALLOW SPACE BREATHING -->
						<li Class="PatchOperationAdd">
							<xpath>Defs/AlienRace.ThingDef_AlienRace[defName="NFFDrone"]/alienRace/raceRestriction/whiteApparelList</xpath>
							<value>
								<li>Firebeater</li>
							</value>
						</li>
				</operations>
			</match>
		</Operation>
</Patch>