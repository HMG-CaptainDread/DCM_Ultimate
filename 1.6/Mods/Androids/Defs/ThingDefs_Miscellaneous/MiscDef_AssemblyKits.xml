	<!-- ASSEMBLY BASE -->
		<ThingDef ParentName="ResourceBase" Name="TMM_AndroidAssemblyKit_Base" Abstract="True">
			<thingClass>ThingWithComps</thingClass>
			<graphicData>
				<graphicClass>Graphic_Single</graphicClass>
			</graphicData>
			<resourceReadoutPriority>Middle</resourceReadoutPriority>
			<stackLimit>1</stackLimit>
			<useHitPoints>true</useHitPoints>
			<statBases>
				<MaxHitPoints>70</MaxHitPoints>
				<Mass>30.0</Mass>
			</statBases>
			<thingCategories>
				<li>Items</li>
			</thingCategories>
			<tradeability>All</tradeability>
			<techLevel>Spacer</techLevel>
			<tradeTags>
				<li>ExoticMisc</li>
			</tradeTags>
			<comps>
				<li Class="CompProperties_UseEffectDestroySelf" />
			</comps>
		</ThingDef>
	<!-- ARCHDROID -->
		<ThingDef ParentName="ResourceBase">
			<defName>NArchDroidKit</defName>
			<label>Archdroid assembly kit</label>
			<thingClass>ThingWithComps</thingClass>
			<description>A kit containing a disassembled archdroid with all the tools required to assemble it.</description>
			<graphicData>
			<texPath>Things/Item/DroidAssemblyKit</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			</graphicData>
			<resourceReadoutPriority>Middle</resourceReadoutPriority>
			<stackLimit>1</stackLimit>
			<useHitPoints>true</useHitPoints>
			<statBases>
			<MarketValue>5000</MarketValue>
			<MaxHitPoints>100</MaxHitPoints>
			<Mass>60.0</Mass>
			</statBases>
			<thingCategories>
			<li>Items</li>
			</thingCategories>
			<tradeability>All</tradeability>
			<techLevel>Archotech</techLevel>
			<tradeTags>
			<li>ExoticMisc</li>
			</tradeTags>
			<comps>
			<li Class="CompProperties_Usable">
				<useJob>UseItem</useJob>
				<useLabel>Assemble ArchDroid</useLabel>
				<useDuration>600</useDuration>
			</li>
			<li Class="Androids.CompProperties_SpawnPawn">
				<compClass>Androids.CompUseEffect_SpawnDroid</compClass>
				<pawnKind>ChjArchDroidColonist</pawnKind>
			</li>
			<li Class="CompProperties_UseEffectDestroySelf" />
			</comps>
		</ThingDef>
