<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<!-- <></> -->
	<!--  -->



	<!-- Modules/PastTime/Retextures/Buildings// -->

	<!-- MISC. TRAINING -->
		<Operation Class="PatchOperationFindMod">
			<mods>
				<li>Misc. Training</li>
			</mods>
			<match Class="PatchOperationSequence">
				<success>Normal</success>
				<operations>
					<!-- CODE BASED RETEXTURING -->
						<!-- ARCHERY TARGET -->
							<li Class="PatchOperationAdd">
								<xpath>Defs/ThingDef[defName="ArcheryTarget"]</xpath>
								<value>
									<graphicData>
										<shaderType>CutoutComplex</shaderType>
										<drawSize>2.4</drawSize>
									</graphicData>
									<uiIconScale>1.6</uiIconScale>
								</value>
							</li>
						<!-- MARTIAL ARTS TARGET -->
							<li Class="PatchOperationAdd">
								<xpath>Defs/ThingDef[defName="MartialArtsTarget"]</xpath>
								<value>
									<graphicData>
										<shaderType>CutoutComplex</shaderType>
										<drawSize>2.4</drawSize>
									</graphicData>
									<uiIconScale>1.6</uiIconScale>
								</value>
							</li>
						<!-- SHOOTING RANGE TARGET -->
							<li Class="PatchOperationAdd">
								<xpath>Defs/ThingDef[defName="ShootingRangeTarget"]</xpath>
								<value>
									<graphicData>
										<shaderType>CutoutComplex</shaderType>
										<drawSize>2.0</drawSize>
									</graphicData>
									<uiIconScale>1.6</uiIconScale>
								</value>
							</li>
					<!-- MAIN RETEXTURING -->
						<!-- ARCHERY MOTES -->
							<li Class="PatchOperationReplace">
								<xpath>Defs/ThingDef[defName = "Mote_ArcheryArrow"]/graphicData/texPath</xpath>
								<value>
									<texPath>Modules/PastTime/Retextures/Buildings/ArcheryTarget/Motes/Arrow</texPath>
								</value>
							</li>
						<!-- ARCHERY TARGET -->
							<li Class="PatchOperationReplace">
								<xpath>Defs/ThingDef[defName = "ArcheryTarget"]/graphicData/texPath</xpath>
								<value>
									<texPath>Modules/PastTime/Retextures/Buildings/ArcheryTarget/ArcheryStand</texPath>
								</value>
							</li>
						<!-- MARTIAL ARTS TARGET -->
							<li Class="PatchOperationReplace">
								<xpath>Defs/ThingDef[defName = "MartialArtsTarget"]/graphicData/texPath</xpath>
								<value>
									<texPath>Modules/PastTime/Retextures/Buildings/MartialArtsTarget/MartialArtsTarget</texPath>
								</value>
							</li>
						<!-- SHOOTING RANGE TARGET -->
							<li Class="PatchOperationReplace">
								<xpath>Defs/ThingDef[defName = "ShootingRangeTarget"]/graphicData/texPath</xpath>
								<value>
									<texPath>Modules/PastTime/Retextures/Buildings/ShootingRangeTarget/ShootingRangeTarget</texPath>
								</value>
							</li>
				</operations>
			</match>
		</Operation>
</Patch>