	<!-- FACIAL ANIMATIONS -->
		<!-- MODS -->
			<!-- EYE GENES 2 -->
				<Operation Class="PatchOperationFindMod">
					<mods>
						<li>[BT] EyeGenes2 | Base - [NL] Facial Animation |</li>
					</mods>
					<match Class="PatchOperationSequence">
						<success>Always</success>
						<operations>
							<li Class="PatchOperationRemove" MayRequire="oppey.eyegenes2">
								<xpath>Defs/FacialAnimation.LidTypeDef[defName="Biotech_Eyes_Gray"]</xpath>
							</li>
							<li Class="PatchOperationRemove" MayRequire="oppey.eyegenes2">
								<xpath>Defs/FacialAnimation.LidTypeDef[defName="Biotech_Eyes_Red"]</xpath>
							</li>
							<li Class="PatchOperationRemove">
								<xpath>Defs/FacialAnimation.LidTypeDef[defName = "LidStaredown"]</xpath>
							</li>
							<li Class="PatchOperationRemove">
								<xpath>Defs/FacialAnimation.LidTypeDef[defName = "LidAwkward"]</xpath>
							</li>
							<li Class="PatchOperationRemove">
								<xpath>Defs/FacialAnimation.LidTypeDef[defName = "LidIrritated"]</xpath>
							</li>
							<li Class="PatchOperationRemove">
								<xpath>Defs/FacialAnimation.LidTypeDef[defName = "LidMoody"]</xpath>
							</li>
							<li Class="PatchOperationRemove">
								<xpath>Defs/FacialAnimation.LidTypeDef[defName = "LidAnger"]</xpath>
							</li>
							<li Class="PatchOperationRemove">
								<xpath>Defs/FacialAnimation.LidTypeDef[defName = "LidDisappointed"]</xpath>
							</li>
							<li Class="PatchOperationRemove">
								<xpath>Defs/FacialAnimation.LidTypeDef[defName = "LidAndroid"]</xpath>
							</li>
						</operations>
					</match>
				</Operation>
	<!-- ROO'S -->
