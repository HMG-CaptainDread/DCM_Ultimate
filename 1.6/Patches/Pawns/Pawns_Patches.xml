			<!-- ADDS STYLE TAG TO ASTROPOLITAN CULTURES -->
				<Operation Class="PatchOperationConditional">
					<xpath>Defs/CultureDef[defName="Astropolitan"]/styleItemTags</xpath>
					<match Class="PatchOperationAdd">
						<xpath>Defs/CultureDef[defName="Astropolitan"]/styleItemTags</xpath>
						<value>
							<li>
								<tag>NaturalTattoo</tag>
								<baseWeight>0.01</baseWeight>
								<weightFactor>1</weightFactor>
							</li>
							<li>
								<tag>NaturalTattooRare</tag>
								<baseWeight>0.005</baseWeight>
								<weightFactor>1</weightFactor>
