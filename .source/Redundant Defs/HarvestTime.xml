<Defs>
	<!-- <></> -->
	<!--  -->



	<!-- BLUEBERRY -->
		<ThingDef ParentName="TMM_BushPlantBase">
			<defName>TMM_BlueberryBush</defName>
			<label>Blueberry Bush</label>
			<description>A deep blue coloured berry that grows in bushes, tart and tasty!</description>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Fruits/Blueberry</texPath>
			</graphicData>
			<plant>
				<harvestedThingDef>TMM_RawBlueberry</harvestedThingDef>
				<harvestYield>8</harvestYield>
				<sowMinSkill>6</sowMinSkill>
				<growDays>6.5</growDays>
				<fertilitySensitivity>0.6</fertilitySensitivity>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Fruits/Blueberry</immatureGraphicPath>
				<wildOrder>2</wildOrder>
				<purpose>Food</purpose>
				<sowResearchPrerequisites>
					<li>TMM_Research_HarvestTime_NeolithicAgriculture</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
	<!-- CACAO BUSH -->
		<ThingDef ParentName="TMM_HydroponicsPlantBase">
			<defName>TMM_CacaoBush</defName>
			<label>Cacao Bush</label>
			<description>A tropical bush that produces chocolate, genetically engineered to sweeten its own product, and survive in slightly less-warm climates, the bushy variant produces a lot less than their arboreal counterpart.</description>
			<graphicData>
				<texPath>Modules/HarvestTime/Plants/Mature/NewPlants/Miscellaneous/CacaoBush</texPath>
			</graphicData>
			<plant>
				<harvestedThingDef>TMM_RawCacaoBean</harvestedThingDef>
				<harvestYield>2</harvestYield>
				<sowMinSkill>5</sowMinSkill>
				<growDays>6</growDays>
				<fertilitySensitivity>0.6</fertilitySensitivity>
				<immatureGraphicPath>Modules/HarvestTime/Plants/Immature/NewPlants/Miscellaneous/CacaoBush</immatureGraphicPath>
				<sowResearchPrerequisites>
					<li>Cocoa</li>
				</sowResearchPrerequisites>
			</plant>
		</ThingDef>
</Defs>