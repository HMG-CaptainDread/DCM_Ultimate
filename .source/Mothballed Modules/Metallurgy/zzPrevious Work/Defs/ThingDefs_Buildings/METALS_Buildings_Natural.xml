<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!-- MINEABLE ORE -->
        <!-- COPPER ORE -->
            <ThingDef ParentName="DCM_MineableBase">
                <defName>DCM_U_MineableMalachite</defName>
                <label>malachite</label>
                <description>A rock that, when melted at sufficient temperatures, will produce vast amounts of copper.</description>
                <graphicData>
                    <color>(98,110,89)</color>
                    <colorTwo>(127,189,165)</colorTwo>
                </graphicData>
                <statBases>
                    <MaxHitPoints>600</MaxHitPoints>
                </statBases>
                <building>
                    <mineableThing>DCM_U_Malachite</mineableThing>
                    <mineableYield>40</mineableYield>
                    <mineableScatterCommonality>1.0</mineableScatterCommonality>
                    <mineableScatterLumpSizeRange>30~50</mineableScatterLumpSizeRange>
                </building>
            </ThingDef>
