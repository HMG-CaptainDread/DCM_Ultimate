	<!-- Modules/Structures/Terrain/Floors/Matting/ -->

	<!-- ALFALFA MATTING -->
		<TerrainDef ParentName="FloorBase">
			<defName>TMM_AlfalfaMatting</defName>
			<label>Alfalfa Matting</label>
			<description>Rough and affordable matting made from alfalfa, ideal for animal barns. It provides comfort while minimizing filth buildup.</description>
			<texturePath>Modules/Structures/Terrain/Floors/Matting/AlfalfaMatting</texturePath>
			<pollutionColor>(1, 1, 1, 1)</pollutionColor>
			<pollutionTintColor>(1, 1, 1, 1)</pollutionTintColor>
			<edgeType>Hard</edgeType>
			<renderPrecedence>240</renderPrecedence>
			<pathCost>1</pathCost>
			<statBases>
				<Beauty>-1</Beauty>
				<Cleanliness>-0.1</Cleanliness>
				<WorkToBuild>120</WorkToBuild>
				<FilthMultiplier>0.05</FilthMultiplier>
				<Flammability>1.5</Flammability>
			</statBases>
			<costList>
				<TMM_DriedAlfalfaHay>2</TMM_DriedAlfalfaHay>
			</costList>
			<uiOrder>2011</uiOrder>
		</TerrainDef>
