			<texturePath>Modules/Structures/Terrain/Floors/Wood/CedarFloor</texturePath>
			<color>(201,151,112)</color>
			<isPaintable>true</isPaintable>
			<renderPrecedence>255</renderPrecedence>
			<statBases>
				<WorkToBuild>80</WorkToBuild>
				<Flammability>0.28</Flammability>
				<Beauty>1</Beauty>
