	<!-- HERBAL OINTMENTS -->
		<!-- RESTORATIVE HERBAL OINTMENT -->
			<ThingDef ParentName="TMM_HerbalOintmentBase">
				<defName>TMM_RestorativeHerbalOintment</defName>
				<label>Restorative Herbal Ointment</label>
				<description>A robust ointment made from St. John's wort and nettle, prized for their strengthening qualities. Used to aid in injury recovery.</description>
				<graphicData>
					<texPath>Modules/Afflictions/Medicines/Ointments/Herbal/Restorative</texPath>
				</graphicData>
				<statBases>
					<MarketValue>14</MarketValue>
					<WorkToMake>600</WorkToMake>
				</statBases>
				<costList>
					<TMM_StJohnsWortBlossom>10</TMM_StJohnsWortBlossom>
					<TMM_NettleLeaf>10</TMM_NettleLeaf>
				</costList>
				<recipeMaker>
					<skillRequirements>
						<Crafting>3</Crafting>
						<Intellectual>3</Intellectual>
					</skillRequirements>
					<displayPriority>2003</displayPriority>
				</recipeMaker>
			</ThingDef>
		<!-- SOOTHING HERBAL OINTMENT -->
			<ThingDef ParentName="TMM_HerbalOintmentBase">
				<defName>TMM_SoothingHerbalOintment</defName>
				<label>Soothing Herbal Ointment</label>
				<description>A gentle ointment crafted from calendula and yarrow, known for their soothing touch. Used to heal wounds and calm irritated skin.</description>
				<graphicData>
					<texPath>Modules/Afflictions/Medicines/Ointments/Herbal/Soothing</texPath>
				</graphicData>
				<statBases>
					<MarketValue>14</MarketValue>
					<WorkToMake>1000</WorkToMake>
				</statBases>
				<costList>
					<TMM_CalendulaBlossom>20</TMM_CalendulaBlossom>
					<TMM_YarrowBlossom>20</TMM_YarrowBlossom>
				</costList>
				<recipeMaker>
					<skillRequirements>
						<Crafting>4</Crafting>
						<Intellectual>4</Intellectual>
					</skillRequirements>
					<displayPriority>2002</displayPriority>
				</recipeMaker>
			</ThingDef>
</Defs>