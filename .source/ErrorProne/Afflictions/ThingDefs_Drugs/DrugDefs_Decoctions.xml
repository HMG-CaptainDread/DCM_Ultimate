	<!-- Modules/Afflictions/Drugs/Decoctions/ -->

	<!-- ECHINACEA -->
		<ThingDef ParentName="TMM_DecoctionBase">
			<defName>TMM_EchinaceaDecoction</defName>
			<label>Echinacea Decoction</label>
			<description>A strong, bitter decoction brewed from echinacea flowers. Despite the repulsive taste, it boosts immunity, reduces pain, and helps the body recover faster.</description>
			<graphicData>
				<texPath>Modules/Afflictions/Drugs/Decoctions/EchinaceaDecoction</texPath>
			</graphicData>
			<statBases>
				<WorkToMake>1100</WorkToMake>
				<MarketValue>17</MarketValue>
			</statBases>
			<ingestible>
				<joy>-0.15</joy>
				<drugCategory>Medical</drugCategory>
				<outcomeDoers>
					<li Class="IngestionOutcomeDoer_GiveHediff">
						<hediffDef>TMM_EchinaceaDecoctionEffect</hediffDef>
						<severity>1.0</severity>
					</li>
				</outcomeDoers>
			</ingestible>
			<recipeMaker>
				<displayPriority>1465</displayPriority>
			</recipeMaker>
			<costList>
				<TMM_EchinaceaBlossoms>12</TMM_EchinaceaBlossoms>
			</costList>
			<comps>
				<li Class="CompProperties_Drug">
					<addictiveness>0</addictiveness>
					<listOrder>215</listOrder>
				</li>
			</comps>
		</ThingDef>
