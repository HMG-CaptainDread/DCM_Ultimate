<?xml version="1.0" encoding="utf-8" ?>

<Patch>
	<!-- 引擎工業 -->
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Engine Industries</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>				
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="RT_Fa_223_Drache"]/costList</xpath>
					<value>
						<EngineMedium>1</EngineMedium>
					</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="RT_Po_2_Polikarpov"]/costList</xpath>
					<value>
						<EngineLight>2</EngineLight>
					</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="RT_Tb_1_Tupolev"]/costList</xpath>
					<value>
						<EngineMedium>2</EngineMedium>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
</Patch>