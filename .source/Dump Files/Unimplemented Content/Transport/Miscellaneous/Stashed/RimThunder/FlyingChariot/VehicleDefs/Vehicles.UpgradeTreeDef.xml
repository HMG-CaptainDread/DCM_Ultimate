<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<Vehicles.UpgradeTreeDef>
		<defName>RT_C130_Vehicle_UpgradeTree</defName>
		<nodes>
			<li>
				<key>Cargo</key>
				<label>Cargo</label>
				<description>Switch to cargo transport.</description>
				<icon>UI/cargo</icon>
				<work>1000</work>
				<gridCoordinate>(5,5)</gridCoordinate>
				<drawSize>(80, 80)</drawSize>
				<disableIfUpgradeNodeEnabled>Passenger</disableIfUpgradeNodeEnabled>
				<upgrades>
					<li Class = "Vehicles.StatUpgrade"> <!--基础属性修改，可用add/set，具体修改范围参考文档-->
						<vehicleStats>
							<li>
								<def>CargoCapacity</def>
								<value>5000</value>
							</li>
						</vehicleStats>
					</li>
					<li Class = "Vehicles.VehicleUpgrade">
						<roles>
							<li> <!--编辑已有乘员-->
								<key>passenger</key>
								<editKey>passengerExpansion</editKey> <!--开启编辑-->
								<label>Passenger</label>
								<slots>3</slots> <!--修改为2-->
							</li>
   						</roles>
					</li>
				</upgrades>
				<ingredients>
					<Steel>30</Steel>
				</ingredients>
			</li>
			<li>
				<key>Passenger</key>
				<label>Passenger</label>
				<description>Switch to passenger transport.</description>
				<icon>UI/passenger</icon>
				<work>1000</work>
				<gridCoordinate>(5,10)</gridCoordinate>
				<drawSize>(80, 80)</drawSize>
				<disableIfUpgradeNodeEnabled>Cargo</disableIfUpgradeNodeEnabled>
				<upgrades>
					<li Class = "Vehicles.StatUpgrade"> <!--基础属性修改，可用add/set，具体修改范围参考文档-->
						<vehicleStats>
							<li>
								<def>CargoCapacity</def>
								<value>-12000</value>
							</li>
						</vehicleStats>
					</li>
					<li Class = "Vehicles.VehicleUpgrade">
						<roles>
							<li> <!--编辑已有乘员-->
								<key>passenger</key>
								<editKey>passengerExpansion</editKey> <!--开启编辑-->
								<label>Passenger</label>
								<slots>64</slots> <!--修改为2-->
							</li>
   						</roles>
					</li>
				</upgrades>
				<ingredients>
					<Steel>30</Steel>
				</ingredients>
			</li>
		</nodes>
	</Vehicles.UpgradeTreeDef>

