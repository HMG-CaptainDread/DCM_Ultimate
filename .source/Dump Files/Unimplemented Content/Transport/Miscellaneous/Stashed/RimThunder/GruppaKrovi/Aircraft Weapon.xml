	<!--SU25 GSH302-->
	
	<ThingDef ParentName="MYDE_AerocraftFramework_WeaponBase_XmlParent">
		<defName>RT_Weapon_GSH302_AutoCannon</defName>
		<label>GSH-30-2</label>
		<description>GSH-30-2 AutoCannon</description>
		<graphicData>
			<texPath>AerocraftFramework/UniversalWeapon/BaseGun</texPath>
		</graphicData>
		<soundInteract>Interact_Rifle</soundInteract>
		<weaponClasses>
			<li>LongShots</li>
			<li>RangedHeavy</li>
		</weaponClasses>
