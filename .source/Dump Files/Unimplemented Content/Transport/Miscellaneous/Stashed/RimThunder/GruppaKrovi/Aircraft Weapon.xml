			<AccuracyMedium>0.72</AccuracyMedium>
			<AccuracyLong>0.61</AccuracyLong>
			<RangedWeapon_Cooldown>4.3</RangedWeapon_Cooldown>
		</statBases>
		<costList>
			<Steel>60</Steel>
			<ComponentIndustrial>4</ComponentIndustrial>
		</costList>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RT_Bullte_GSH302_AutoCannon</defaultProjectile>
				<warmupTime>0.5</warmupTime>
				<ticksBetweenBurstShots>2.3</ticksBetweenBurstShots>
				<burstShotCount>12</burstShotCount>
				<range>40</range>
				<soundCast>Shot_Autocannon</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
			</li>
		</verbs>
	</ThingDef>
	<ThingDef ParentName="BaseBullet">
		<defName>RT_Bullte_GSH302_AutoCannon</defName>
		<label>30mm Shell</label>
		<graphicData>
			<texPath>Things/Projectile/Bullet_Small</texPath>
