<?xml version="1.0" encoding="UTF-8"?>
<Defs>

	<Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild">
		<!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_M4A3_Sherman_Blueprint</defName>
		<label>M4A3 Sherman</label>
		<description>An old-time classic tank, well-known in almost every human world, eqipped with a 75mm gun and well armor.</description>
		<graphicData>
			<texPath>M4a3e8/vehicle</texPath>
			<drawSize>(4, 6)</drawSize>
		</graphicData>
		<statBases>
			<!--平衡相关-->
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>30000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(3, 5)</size>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		<costList>
			<EngineHeavy>1</EngineHeavy>
			<ComponentFuelTank>1</ComponentFuelTank>
			<ComponentTransmission>1</ComponentTransmission>
			<ComponentWheelRoad>16</ComponentWheelRoad>
			<ComponentIndustrial>10</ComponentIndustrial>
			<Steel>250</Steel>
		</costList>
		<thingToSpawn>RT_M4A3_Sherman</thingToSpawn>
		<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

