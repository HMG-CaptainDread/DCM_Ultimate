<?xml version="1.0" encoding="UTF-8"?>
<Defs>

  <Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild"><!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_M18_Hellcat_Blueprint</defName>
		<label>M18 Hellcat</label>
		<description>A light tank with high speed, while it almost has no armor.</description>
		<graphicData>
			<texPath>M18/vehicle</texPath>
			<drawSize>(4,5)</drawSize>
		</graphicData>	
		<statBases><!--平衡相关--> 		
			<MaxHitPoints>600</MaxHitPoints>
			<WorkToBuild>25000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(3,4)</size>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>	
		<costList>
			<EngineHeavy>1</EngineHeavy>
			<ComponentFuelTank>1</ComponentFuelTank>
			<ComponentTransmission>1</ComponentTransmission>
			<ComponentWheelRoad>14</ComponentWheelRoad>
			<ComponentIndustrial>10</ComponentIndustrial>
			<Steel>180</Steel>
		</costList>
		<thingToSpawn>RT_M18_Hellcat</thingToSpawn>	<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

	<!-- 載具本體 -->
	<Vehicles.VehicleDef ParentName="RT_BaseVehicle">
		<defName>RT_M18_Hellcat</defName>
		<label>M18 Hellcat</label>
		<description>A light tank with high speed, while it almost has no armor.</description>
		<buildDef>RT_M18_Hellcat_Blueprint</buildDef>
		<graphicData>
			<texPath>M18/vehicle</texPath>
			<drawSize>(4,5)</drawSize>
		</graphicData>
		<size>(3,4)</size>
		<fillPercent>1</fillPercent>
		<vehicleCategory>Combat</vehicleCategory>
		<statBases><!--平衡相关-->
			<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
			<Flammability>0</Flammability>
			<MarketValue>2750</MarketValue>
		</statBases>
		<vehicleStats><!--平衡相关-->
			<Mass>885</Mass>
			<MoveSpeed>10</MoveSpeed>
			<CargoCapacity>300</CargoCapacity>
			<RepairRate>0.4</RepairRate>
		</vehicleStats>
		<soundOneShotsOnEvent Inherit = "False">
			<li>
				<key>PawnEntered</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>PawnExited</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>IgnitionOn</key>
				<value>RT_M18VehicleStart</value>
			</li>
			<li>
				<key>IgnitionOff</key>
				<value>RT_M18VehicleStop</value>
			</li>
		</soundOneShotsOnEvent>
		<soundSustainersOnEvent Inherit="false"> 
			<li>
				<start>IgnitionOn</start>
				<stop>IgnitionOff</stop>
				<value>RT_M18VehicleEngine</value>
			</li>
		</soundSustainersOnEvent>
		<race>
			<baseBodySize>3</baseBodySize>
		</race>	
		<properties>	<!-- 座位與功能 -->
			<customRoadCosts AssignDefaults = "0.4"/>
			<worldSpeedMultiplier>1</worldSpeedMultiplier>
			<winterSpeedMultiplier>1</winterSpeedMultiplier>
			<vehicleJobLimitations>
				<li>(RepairVehicle, 5)</li>
			</vehicleJobLimitations>
			<roles>
				<li>
					<key>driver</key>
					<label>driver</label>
					<slots>2</slots>		
					<slotsToOperate>1</slotsToOperate>	
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
				</li>				
				<li>
					<key>gunner</key>
					<label>gunner</label>
					<slots>2</slots>
					<slotsToOperate>1</slotsToOperate>			
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>mainTurret</li>
					</turretIds>
				</li>
				<li>
					<key>commander</key>
					<label>commander</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>topMG</li>
					</turretIds>
				</li>
			</roles>
		</properties>	
		<components>	<!-- 各種零件 --><!--平衡相关-->
		<!-- Internal mobile Part 內部驅動部件-->
			<li>
				<!--Engine 100-->
				<key>Engine</key>
				<label>Engine</label>
				<health>70</health>
				<priorityStatEfficiency>true</priorityStatEfficiency>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.25</chance>
						<maxHealth>0.3</maxHealth>
						<radius>3</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>		
				<hitbox>
					<cells>
						<li>(0, 0)</li>
					</cells>
				</hitbox>
			</li>		
			<li><!-- fuel tank 100-->
				<key>FuelTank</key>
				<label>fuel tank</label>
				<health>70</health>
				<depth>Internal</depth>			
				<reactors><li Class = "Vehicles.Reactor_FuelLeak"/></reactors>			
				<hitbox>
					<cells>
						<li>(-1, 0)</li>
						<li>(1, 0)</li>
					</cells>
				</hitbox>
			</li>
			<li><!-- Gearbox 50-->
				<key>Gearbox</key>
				<label>gearbox</label>
				<health>35</health>
				<depth>Internal</depth>
				<categories><li>MoveSpeed</li></categories>	
				<hitbox><cells><li>(0, 2)</li></cells></hitbox>			
			</li>
			<li><!-- AmmoRack 50-->
				<key>AmmoRack</key>
				<label>ammo rack</label>
				<health>35</health>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.5</chance>
						<maxHealth>0.5</maxHealth>
						<radius>5</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>	
				<hitbox><cells><li>(0, 1)</li></cells></hitbox>
			</li>
			<li><!-- transmission shaft 40 -->
				<key>TransmissionShaft</key>
				<label>transmission shaft</label>
				<health>30</health>
				<depth>Internal</depth>
			</li>			
		<!-- External mobile Part 外部驅動部件-->		
		<li><!-- LeftTrack 150-->
			<key>LeftTrack</key>
			<label>left track</label>
			<health>150</health>
			<depth>External</depth>
			<categories><li>MoveSpeed</li></categories>
			<tags><li>Wheel</li></tags>
			<hitWeight>2</hitWeight>
			<hitbox>
				<fallthrough>false</fallthrough>
				<side>Left</side>
			</hitbox>
		</li>
		<li><!-- RightTrack 150-->
			<key>RightTrack</key>
			<label>right track</label>
			<health>150</health>
			<depth>External</depth>
			<categories><li>MoveSpeed</li></categories>	
			<tags><li>Wheel</li></tags>
			<hitWeight>2</hitWeight>
			<hitbox>
				<fallthrough>false</fallthrough>
				<side>Right</side>
			</hitbox>
		</li>
		<li><!-- LeftRoadWheels 100-->
			<key>LeftRoadWheels</key>
			<label>left road wheels</label>
			<health>100</health>
			<depth>External</depth>
			<categories><li>MoveSpeed</li></categories>				
			<tags><li>Wheel</li></tags>		
			<hitbox>
				<fallthrough>false</fallthrough>
				<side>Left</side>
			</hitbox>
		</li>
		<li><!-- RightRoadWheels 100-->
			<key>RightRoadWheels</key>
			<label>right road wheels</label>
			<health>100</health>
			<depth>External</depth>
			<categories><li>MoveSpeed</li></categories>				
			<tags><li>Wheel</li></tags>		
			<hitbox>
				<fallthrough>false</fallthrough>
				<side>Right</side>
			</hitbox>
		</li>
		<li><!-- LeftDriveSprocket 75-->
			<key>LeftDriveSprocket</key>
			<label>left drive sprocket</label>
			<health>75</health>
			<depth>External</depth>
			<categories><li>MoveSpeed</li></categories>				
			<tags><li>Wheel</li></tags>		
			<hitbox>
				<fallthrough>false</fallthrough>
				<cells><li>(-1, -1)</li></cells><!--左前-->
			</hitbox>
		</li>
		<li><!-- RightDriveSprocket 75-->
			<key>RightDriveSprocket</key>
			<label>right drive sprocket</label>
			<health>75</health>
			<depth>External</depth>
			<categories><li>MoveSpeed</li></categories>				
			<tags><li>Wheel</li></tags>		
			<hitbox>
				<fallthrough>false</fallthrough>
				<cells><li>(1, -1)</li></cells><!--右前-->
			</hitbox>
		</li>
		<li><!-- LeftTensionerWheel 75-->
			<key>LeftTensionerWheel</key>
			<label>left tensioner wheel</label>
			<health>75</health>
			<depth>External</depth>
			<categories><li>MoveSpeed</li></categories>				
			<tags><li>Wheel</li></tags>					
			<hitbox>
				<fallthrough>false</fallthrough>
				<cells><li>(-1, 2)</li></cells><!--左後-->
			</hitbox>
		</li>
		<li><!-- RightTensionerWheel 75-->
			<key>RightTensionerWheel</key>
			<label>right tensioner wheel</label>
			<health>75</health>
			<depth>External</depth>
			<categories><li>MoveSpeed</li></categories>				
			<tags><li>Wheel</li></tags>				
			<hitbox>
				<fallthrough>false</fallthrough>
				<cells><li>(1, 2)</li></cells><!--右後-->
			</hitbox>
		</li>
		<!-- External Platings 外部防禦部件 -->
			<li>
				<!-- FrontArmorPlating 200-->
				<key>FrontArmorPlating</key>
				<label>front armor Plating</label>
				<health>168</health>
				<depth>External</depth>
				<hitWeight>8</hitWeight>
				<armor>
					<ArmorRating_Blunt>1.00</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.8</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Front</side>
				</hitbox>
			</li>
			<li>
				<!-- LeftArmorPlating 180-->
				<key>LeftArmorPlating</key>
				<label>left armor plating</label>
				<health>151</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<armor>
					<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Left</side>
				</hitbox>
			</li>
			<li>
				<!-- RightArmorPlating 180-->
				<key>RightArmorPlating</key>
				<label>right armor plating</label>
				<health>151</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<armor>
					<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Right</side>
				</hitbox>
			</li>
			<li>
				<!-- RoofArmorPlating 150 -->
				<key>RoofArmorPlating</key>
				<label>roof armor plating</label>
				<health>168</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<hitbox><side>Body</side></hitbox>
				<armor>
					<ArmorRating_Blunt>0.9</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.7</ArmorRating_Sharp>
				</armor>
			</li>
			<li>
				<!-- BackArmorPlating 150-->
				<key>BackArmorPlating</key>
				<label>rear armor plating</label>
				<health>126</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<hitbox>
					<side>Back</side>
				</hitbox>
			</li>
			<!-- 炮塔-->
			<li>
				<!-- mainTurret 250-->
				<key>MainTurret</key>
				<label>Main Turret</label>
				<health>168</health>
				<depth>External</depth>
				<hitWeight>6</hitWeight>
				<armor>
					<ArmorRating_Blunt>1.00</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.8</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<cells>
						<li>(-1, 1)</li>
						<li>(0, 1)</li>
						<li>(1, 1)</li>
						<li>(-1, 0)</li>
						<li>(0, 0)</li>
						<li>(1, 0)</li>
					</cells>
				</hitbox>
			</li>
		</components>
		<comps>
			<li Class="Vehicles.CompProperties_FueledTravel">	<!-- 油箱與油耗 -->
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>30</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>1</fuelConsumptionWorldMultiplier>
				<fuelCapacity>120</fuelCapacity>
			</li>
			<li Class="Vehicles.CompProperties_VehicleTurrets">	<!-- 砲塔 -->
				<turrets>
					<li>
						<turretDef>RT_M18_Main_Turret</turretDef>					
						<renderProperties>
							<north>(0, 0.5)</north>
							<south>(0, 0.2)</south>
							<east>(0.1, 0.4)</east>
							<west>(-0.1, 0.4)</west>
						</renderProperties>
						
						<gizmoLabel>Main Turret</gizmoLabel>
						<aimPieOffset>(0, 2.6)</aimPieOffset>	<!-- 預熱指示器的x,z偏移 -->
						<drawLayer>2</drawLayer>						
						<key>mainTurret</key>
					</li>

					<li><!--车顶機槍-->	
                        <turretDef>RT_M2HB_WW2_MGTurret</turretDef>
                        <renderProperties><!--這裡的坐標系是無視旋轉的,所以x就是恆定左右偏移-->	
                            <north>(-0.6,0)</north><!-- x,y -->
                            <south>(0.6,0)</south><!-- -x,-y -->
                            <east>(0,0.6)</east><!-- y,-x -->
                            <west>(0,-0.6)</west><!-- -y,x -->
                        </renderProperties>
                        <gizmoLabel>support MG</gizmoLabel>
                        <aimPieOffset>(0, 0)</aimPieOffset>
                        <key>topMG</key>
						<drawLayer>3</drawLayer>					
                        <parentKey>mainTurret</parentKey>
                    </li>
				</turrets>
			</li>
		</comps>
	</Vehicles.VehicleDef>

	<!-- 主砲的Def --><!--平衡相关-->
	<Vehicles.VehicleTurretDef ParentName="RT_BaseTurret">
		<defName>RT_M18_Main_Turret</defName>
		<label>main turret</label>
		<!-- 砲塔的渲染顯示 -->
		<graphicData>
			<texPath>M18/MainTurret</texPath>
			<drawSize>(7,7)</drawSize>
		</graphicData>
		<!-- 彈藥與裝填容量相關 -->
		<gizmoIconTexPath>M18/MainTurret_gizmo</gizmoIconTexPath>
		<!-- 彈藥與裝填容量相關 -->
		<reloadTimer>6</reloadTimer>
		<reloadTimerMultiplierPerCrewCount>
			<points>
				<li>(1, 1.5)</li>
				<li>(2, 1)</li>
			</points>
		</reloadTimerMultiplierPerCrewCount>
		<magazineCapacity>1</magazineCapacity>
		<chargePerAmmoCount>5</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<ammunition>
			<thingDefs>
				<li>Steel</li>
			</thingDefs>
		</ammunition>
		<!-- 射程與射界相關 -->
		<minRange>4</minRange>
		<maxRange>44.9</maxRange>
		<rotationSpeed>1</rotationSpeed>
		<!-- 射擊相關 -->
		<warmUpTimer>2</warmUpTimer>
		<shotSound>RT_Shot_M1Sound</shotSound>
		<reloadSound>RT_ManpowerReloadSound</reloadSound>
		<projectile>RT_Bullet_M4A3E8Shell</projectile>
		<projectileOffset>3.5</projectileOffset>
		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>
			<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<!-- <li>-1</li> -->
			<li>0</li>
		</projectileShifting>
		<!-- 炮口製退動畫 -->
		<graphics>
			<li>
				<graphicData>
					<texPath>M18/MainTurret_barrel</texPath>
					<drawSize>(7,7)</drawSize>
					<graphicClass>Vehicles.Graphic_Turret</graphicClass>
					<shaderType>CutoutComplexPattern</shaderType>
				</graphicData>
				<recoil>
					<distanceTotal>0.2</distanceTotal>
					<distancePerTick>0.05</distancePerTick>
					<speedMultiplierPostRecoil>0.1</speedMultiplierPostRecoil>
				</recoil>
			</li>
		</graphics>
		<!-- 射擊模式 -->
		<fireModes>
			<li>
				<shotsPerBurst>1</shotsPerBurst>
				<ticksBetweenBursts>1</ticksBetweenBursts>
				<spreadRadius>3</spreadRadius>
				<label>Single Shot</label>
				<texPath>UI/Gizmos/FireRate_Single</texPath>
			</li>
		</fireModes>
		<motes>
			<li>
				<cycles>1</cycles>
				<moteDef>Mote_CannonPlume</moteDef>
				<animationType>Reset</animationType>
				<offset>(0,0,3)</offset>
			</li>
		</motes>
	</Vehicles.VehicleTurretDef>
</Defs>