<?xml version="1.0" encoding="UTF-8"?>
<Defs>

  <Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild"><!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_Harley_Davidson_WLA_Blueprint</defName>
		<label>Harley Davidson WLA</label>
		<description>A famous motorcycle, deeply loved by some piartes.</description>
		<graphicData>
			<texPath>HD WLA/vehicle</texPath>
			<drawSize>(2,2)</drawSize>
		</graphicData>	
		<statBases> 		
			<MaxHitPoints>300</MaxHitPoints>
			<WorkToBuild>4000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(1,2)</size>
		<constructionSkillPrerequisite>4</constructionSkillPrerequisite>	
		<costList>
			<EngineLight>1</EngineLight>
			<ComponentHeavyCasting>1</ComponentHeavyCasting>
			<ComponentWheelTire>2</ComponentWheelTire>
			<ComponentIndustrial>3</ComponentIndustrial>
			<Steel>30</Steel>
		</costList>
		<thingToSpawn>RT_Harley_Davidson_WLA_Vehicle</thingToSpawn>	<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

	<!-- 載具本體 -->
	<Vehicles.VehicleDef ParentName="RT_BaseVehicle">
		<defName>RT_Harley_Davidson_WLA_Vehicle</defName>
		<label>Harley Davidson WLA</label>
		<description>A famous motorcycle, deeply loved by some piartes.</description>
		<buildDef>RT_Harley_Davidson_WLA_Blueprint</buildDef>
		<graphicData>
			<texPath>HD WLA/vehicle</texPath>
			<drawSize>(2,2)</drawSize>
		</graphicData>
		<size>(1,2)</size>
		<fillPercent>1</fillPercent>
		<vehicleCategory>Combat</vehicleCategory>
		<statBases><!--平衡相关-->
			<ArmorRating_Blunt>0.22</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.38</ArmorRating_Sharp>
			<Flammability>0</Flammability>
			<MarketValue>700</MarketValue>
		</statBases>
		<vehicleStats><!--平衡相关-->
			<Mass>100</Mass>
			<MoveSpeed>12</MoveSpeed>
			<CargoCapacity>60</CargoCapacity>
			<RepairRate>0.5</RepairRate>
		</vehicleStats>
		<race>
			<baseBodySize>5</baseBodySize>
		</race>	
		<properties>	<!-- 座位與功能 -->
			<diagonalRotation>false</diagonalRotation>
			<customRoadCosts AssignDefaults = "0.4"/>
			<worldSpeedMultiplier>1</worldSpeedMultiplier>
			<winterSpeedMultiplier>1</winterSpeedMultiplier>
			<vehicleJobLimitations>
				<li>(RepairVehicle, 1)</li>
			</vehicleJobLimitations>
			<roles>
				<li>
					<key>rider</key>
					<label>Rider</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<exposed>true</exposed>
					
					<hitbox>
						<side>Body</side>
					</hitbox>
					
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
				
					<pawnRenderer>
						<layer>1</layer>
						<layerNorth>1</layerNorth>
						<layerSouth>-1</layerSouth>
						<angleNorth>0</angleNorth>
						<angleEast>0</angleEast>
						<angleNorthEast>0</angleNorthEast>
						<angleSouthEast>0</angleSouthEast>
						<drawOffsetNorth>(0,0,0.25)</drawOffsetNorth>
						<drawOffsetSouth>(0,0,0.5)</drawOffsetSouth>
						<drawOffsetEast>(0,0,0.25)</drawOffsetEast>
					</pawnRenderer>
				</li>
			</roles>
		</properties>	
		<components>	<!-- 各種零件 --><!--平衡相关-->
		<!-- Internal mobile Part 內部驅動部件-->
			<li><!--Engine 100-->
				<key>Engine</key>
				<label>engine</label>
				<health>25</health>
				<priorityStatEfficiency>true</priorityStatEfficiency>
				<categories><li>MoveSpeed</li></categories>
				<depth>Internal</depth>		
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.25</chance>
						<radius>3</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>							
			</li>		
			<li><!-- fuel tank 100-->
				<key>FuelTank</key>
				<label>fuel tank</label>
				<health>25</health>
				<depth>Internal</depth>			
				<reactors><li Class = "Vehicles.Reactor_FuelLeak"/></reactors>			
			</li>
			<li><!-- transmission shaft 40 -->
				<key>TransmissionShaft</key>
				<label>transmission shaft</label>
				<health>30</health>
				<depth>Internal</depth>
			</li>			
		<!-- External mobile Part 外部驅動部件-->		
			<li>
				<key>FrontWheel</key>
				<label>Front Wheel</label>
				<health>20</health>
				<depth>External</depth>
				<armor>
					<ArmorRating_Blunt>0</ArmorRating_Blunt>
					<ArmorRating_Sharp>0</ArmorRating_Sharp>
				</armor>
				<tags>
					<li>Wheel</li>
				</tags>
				<categories>
					<li>MoveSpeed</li>
				</categories>
			</li>
			<li>
				<key>BackWheel</key>
				<label>Back Wheel</label>
				<health>20</health>
				<depth>External</depth>
				<armor>
					<ArmorRating_Blunt>0</ArmorRating_Blunt>
					<ArmorRating_Sharp>0</ArmorRating_Sharp>
				</armor>
				<tags>
					<li>Wheel</li>
				</tags>
				<categories>
					<li>MoveSpeed</li>
				</categories>
			</li>
		</components>
		<comps><!--平衡相关-->
			<li Class="Vehicles.CompProperties_FueledTravel">	<!-- 油箱與油耗 -->
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>4</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>1</fuelConsumptionWorldMultiplier>
				<fuelCapacity>30</fuelCapacity>
			</li>
		</comps>
	</Vehicles.VehicleDef>
</Defs>