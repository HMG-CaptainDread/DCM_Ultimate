<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!--flamethrower -->
	
	<Vehicles.VehicleTurretDef ParentName="RT_BaseTurret">
		<defName>RT_M4A3R3_Flamethrower</defName>
		<label>flamethrower</label>
		<projectile>RT_Bullet_M4A3R3_Flamethrower</projectile>
		<reloadTimer>8</reloadTimer>
		<warmUpTimer>1.25</warmUpTimer>
		<magazineCapacity>1</magazineCapacity>
		<chargePerAmmoCount>5</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<rotationSpeed>3.6</rotationSpeed>
		<projectileOffset>0</projectileOffset>
		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>
			<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<li>0</li>
		</projectileShifting>
		<maxRange>19.9</maxRange>
		<minRange>2.9</minRange>
		<fireModes>
			<li>
				<shotsPerBurst>1</shotsPerBurst>
				<ticksBetweenBursts>1</ticksBetweenBursts>
				<spreadRadius>2.9</spreadRadius>
				<label>Fire Spew</label>
				<texPath>UI/Gizmos/FireRate_Single</texPath>
			</li>
		</fireModes>
		<graphicData>
			<texPath>M4a3e8/Nothing</texPath>
			<drawSize>(1,1)</drawSize>
		</graphicData>
		<gizmoIconTexPath>M4a3e8/Flamethrower</gizmoIconTexPath>
		<ammunition>
			<thingDefs>
				<li>Chemfuel</li>
			</thingDefs>
		</ammunition>
	</Vehicles.VehicleTurretDef>

	<VEF.Weapons.ExpandableProjectileDef ParentName="BaseBullet">
		<defName>RT_Bullet_M4A3R3_Flamethrower</defName>
		<label>spew</label>
		<thingClass>VEF.Weapons.FlamethrowProjectile</thingClass>
		<graphicData>
			<texPath>Projectile/Proj_FlameBurn</texPath>
			<texPathFadeOut>Projectile/Proj_FlameFade</texPathFadeOut>
			<shaderType>MoteGlow</shaderType>
		</graphicData>
		<projectile>
			<damageDef>Flame</damageDef>
			<speed>45</speed>
			<damageAmountBase>20</damageAmountBase>
		</projectile>

		<drawOffscreen>true</drawOffscreen>
		<lifeTimeDuration>120</lifeTimeDuration>
		<widthScaleFactor>0.65</widthScaleFactor>
		<heightScaleFactor>1</heightScaleFactor>
		<startingPositionOffset>(0, 0, -1)</startingPositionOffset>
		<totalSizeScale>1.15</totalSizeScale>
		<tickFrameRate>2</tickFrameRate>
		<finalTickFrameRate>5</finalTickFrameRate>
		<tickDamageRate>20</tickDamageRate>
		<dealsDamageOnce>true</dealsDamageOnce>
		<minDistanceToAffect>2</minDistanceToAffect>
	</VEF.Weapons.ExpandableProjectileDef>

	<!-- E8 -->
	

	<Vehicles.VehicleTurretDef ParentName="RT_BaseTurret">
		<defName>RT_M4A3E8_Main_Turret</defName>
		<label>main turret</label>
		<!-- 砲塔的渲染顯示 -->
		<graphicData>
			<texPath>M4a3e8/LB</texPath>
			<drawSize>(8,8)</drawSize>
		</graphicData>
		<gizmoIconTexPath>M4a3e8/LB_gizmo</gizmoIconTexPath>
		<!-- 彈藥與裝填容量相關 -->
		<reloadTimer>6</reloadTimer>
		<reloadTimerMultiplierPerCrewCount>
			<points>
				<li>(1, 1.5)</li>
				<li>(2, 1)</li>
			</points>
		</reloadTimerMultiplierPerCrewCount>
		<magazineCapacity>1</magazineCapacity>
		<chargePerAmmoCount>5</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<ammunition>
			<thingDefs>
				<li>Steel</li>
			</thingDefs>
		</ammunition>
		<!-- 射程與射界相關 -->
		<minRange>4</minRange>
		<maxRange>44.9</maxRange>
		<rotationSpeed>1</rotationSpeed>
		<!-- 射擊相關 -->
		<warmUpTimer>2</warmUpTimer>
		<shotSound>RT_Shot_M1Sound</shotSound>
		<reloadSound>RT_ManpowerReloadSound</reloadSound>
		<projectile>RT_Bullet_M4A3E8Shell</projectile>
		<projectileOffset>3.5</projectileOffset>
		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>
			<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<!-- <li>-1</li> -->
			<li>0</li>
		</projectileShifting>
		<!-- 炮口製退動畫 -->
		<graphics>
			<li>
				<graphicData>
					<texPath>M4a3e8/LB_barrel</texPath>
					<drawSize>(8,8)</drawSize>
					<graphicClass>Vehicles.Graphic_Turret</graphicClass>
					<shaderType>CutoutComplexPattern</shaderType>
				</graphicData>
				<recoil>
					<distanceTotal>0.2</distanceTotal>
					<distancePerTick>0.05</distancePerTick>
					<speedMultiplierPostRecoil>0.1</speedMultiplierPostRecoil>
				</recoil>
			</li>
		</graphics>
		<!-- 射擊模式 -->
		<fireModes>
			<li>
				<shotsPerBurst>1</shotsPerBurst>
				<ticksBetweenBursts>1</ticksBetweenBursts>
				<spreadRadius>3</spreadRadius>
				<label>Single Shot</label>
				<texPath>UI/Gizmos/FireRate_Single</texPath>
			</li>
		</fireModes>
		<motes>
			<li>
				<cycles>1</cycles>
				<moteDef>Mote_CannonPlume</moteDef>
				<animationType>Reset</animationType>
				<offset>(0,0,3)</offset>
			</li>
		</motes>
	</Vehicles.VehicleTurretDef>

	<ThingDef ParentName="BaseBullet">
		<defName>RT_Bullet_M4A3E8Shell</defName>
		<label>high-explosive shell</label>
		<thingClass>Projectile_Explosive</thingClass>
		<graphicData>
			<texPath>Things/Projectile/Bullet_Big</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>2</drawSize>
		</graphicData>
		<projectile>
			<damageDef>Bomb</damageDef>
			<damageAmountBase>65</damageAmountBase>
			<armorPenetrationBase>0.77</armorPenetrationBase>
			<speed>90</speed>
			<explosionRadius>2.9</explosionRadius>
			<soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
			<soundExplode>Explosion_GiantBomb</soundExplode>
			<soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
			<soundAmbient>MortarRound_Ambient</soundAmbient>
		</projectile>
	</ThingDef>

