<?xml version="1.0" encoding="utf-8" ?>

<Defs>
	<Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild">
		<!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_BTR40A_Vehicle_Blueprint</defName>
		<label>Type 55 SPAA</label>
		<description>An armored vehicle, replaced the space of crew with a twin 14.5mm machine gun to work as a SPAA.</description>
		<graphicData>
			<texPath>BTR40A/vehicle</texPath>
			<drawSize>(2.5,5)</drawSize>
		</graphicData>
		<size>(2,4)</size>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>7000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		<costList>
			<EngineMedium>1</EngineMedium>
			<ComponentFuelTank>1</ComponentFuelTank>
			<ComponentTransmission>1</ComponentTransmission>
			<ComponentWheelTire>6</ComponentWheelTire>
			<ComponentIndustrial>15</ComponentIndustrial>
			<Steel>100</Steel>
		</costList>
		<thingToSpawn>RT_BTR40A_Vehicle</thingToSpawn>
		<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

	<Vehicles.VehicleDef ParentName="RT_BaseVehicle">
		<defName>RT_BTR40A_Vehicle</defName>
		<label>Type 55 SPAA</label>
		<description>An armored vehicle, replaced the space of crew with a twin 14.5mm machine gun to work as a SPAA.</description>
		<buildDef>RT_BTR40A_Vehicle_Blueprint</buildDef>
		<graphicData>
			<texPath>BTR40A/vehicle</texPath>
			<drawSize>(2.5,5)</drawSize>
		</graphicData>
		<size>(2,4)</size>
		<fillPercent>1</fillPercent>
		<vehicleCategory>Transport</vehicleCategory>
		<statBases>
			<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
			<Flammability>0</Flammability>
			<MarketValue>6000</MarketValue>
		</statBases>
		<vehicleStats>
			<Mass>650</Mass>
			<MoveSpeed>10</MoveSpeed>
			<CargoCapacity>600</CargoCapacity>
			<RepairRate>0.4</RepairRate>
		</vehicleStats>
		<soundOneShotsOnEvent Inherit = "False">
			<li>
				<key>PawnEntered</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>PawnExited</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>IgnitionOn</key>
				<value>RT_BRDMVehicleStart</value>
			</li>
			<li>
				<key>IgnitionOff</key>
				<value>RT_BRDMVehicleStop</value>
			</li>
		</soundOneShotsOnEvent>
		<soundSustainersOnEvent Inherit="false"> 
			<li>
				<start>IgnitionOn</start>
				<stop>IgnitionOff</stop>
				<value>RT_BRDMVehicleEngine</value>
			</li>
		</soundSustainersOnEvent>
		<race>
			<baseBodySize>3</baseBodySize>
		</race>
		<properties>
			<customRoadCosts AssignDefaults = "0.25"/>
			<worldSpeedMultiplier>1</worldSpeedMultiplier>
			<offRoadMultiplier>2</offRoadMultiplier>
			<winterSpeedMultiplier>4</winterSpeedMultiplier>
			<manhunterTargetsVehicle>true</manhunterTargetsVehicle>
			<vehicleJobLimitations>
				<li>(RepairVehicle, 4)</li>
			</vehicleJobLimitations>
			<roles>
				<li>
					<key>driver</key>
					<label>driver</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<exposed>true</exposed>
					<hitbox>
						<side>Body</side>
					</hitbox>
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
					<pawnRenderer>
						<!-- 左1-->
						<layerEast>1</layerEast>
						<layerWest>2</layerWest>
						<layerNorth>1</layerNorth>
						<layerSouth>2</layerSouth>
						<angleNorth>0</angleNorth>
						<angleEast>0</angleEast>
						<angleNorthEast>0</angleNorthEast>
						<angleSouthEast>0</angleSouthEast>
						<drawOffsetEast>(0.29,0.3,0.62)</drawOffsetEast>
						<drawOffsetWest>(-0.29,0.3,0.12)</drawOffsetWest>
						<drawOffsetNorth>(-0.3,0,0.6)</drawOffsetNorth>
						<drawOffsetSouth>(0.38,0.5,0.7)</drawOffsetSouth>
					</pawnRenderer>
				</li>
				<li>
					<key>gunner</key>
					<label>gunner</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>mainTurret</li>
					</turretIds>
					<exposed>true</exposed>
					<hitbox>
						<side>Body</side>
					</hitbox>
					<pawnRenderer>
						<!-- 炮手-->
						<layer>4</layer>
						<angleNorth>0</angleNorth>
						<angleEast>0</angleEast>
						<angleNorthEast>0</angleNorthEast>
						<angleSouthEast>0</angleSouthEast>
						<drawOffsetEast>(-0.66,0,0.3)</drawOffsetEast>
						<drawOffsetWest>(0.66,0,0.3)</drawOffsetWest>
						<drawOffsetNorth>(0,0,0)</drawOffsetNorth>
						<drawOffsetSouth>(0,0,1.27)</drawOffsetSouth>
					</pawnRenderer>
				</li>
				<li>
					<key>passengera</key>
					<label>passenger (1)</label>
					<slots>1</slots>
					<exposed>true</exposed>
					<hitbox>
						<side>Body</side>
					</hitbox>
					<pawnRenderer>
						<!-- 右1-->
						<layerEast>2</layerEast>
						<layerWest>1</layerWest>
						<layerNorth>1</layerNorth>
						<layerSouth>2</layerSouth>
						<angleNorth>0</angleNorth>
						<angleEast>0</angleEast>
						<angleNorthEast>0</angleNorthEast>
						<angleSouthEast>0</angleSouthEast>
						<drawOffsetEast>(0.29,0.3,0.12)</drawOffsetEast>
						<drawOffsetWest>(-0.29,0.3,0.62)</drawOffsetWest>
						<drawOffsetNorth>(0.3,0.1,0.6)</drawOffsetNorth>
						<drawOffsetSouth>(-0.38,0,0.7)</drawOffsetSouth>
					</pawnRenderer>
				</li>
				<li>
					<key>passengerb</key>
					<label>passenger (2)</label>
					<slots>1</slots>
					<exposed>true</exposed>
					<hitbox>
						<side>Body</side>
					</hitbox>
					<pawnRenderer>
						<!-- 屁股-->
						<layerEast>1</layerEast>
						<layerWest>2</layerWest>
						<layerNorth>1</layerNorth>
						<layerSouth>2</layerSouth>
						<angleNorth>0</angleNorth>
						<angleEast>0</angleEast>
						<angleNorthEast>0</angleNorthEast>
						<angleSouthEast>0</angleSouthEast>
						<drawOffsetEast>(-1.77,0,0.37)</drawOffsetEast>
						<drawOffsetWest>(1.77,0,0.37)</drawOffsetWest>
						<drawOffsetNorth>(0,0,-1)</drawOffsetNorth>
						<drawOffsetSouth>(0,0,1.85)</drawOffsetSouth>
					</pawnRenderer>
				</li>
			</roles>
		</properties>
		<components>
			<!-- Internal mobile Part 內部驅動部件-->
			<li>
				<!-- Engine 100-->
				<key>Engine</key>
				<label>Engine</label>
				<health>100</health>
				<priorityStatEfficiency>true</priorityStatEfficiency>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.25</chance>
						<maxHealth>0.3</maxHealth>
						<radius>3</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>
				<hitbox>
					<cells>
						<li>(0, 2)</li>
						<li>(1, 2)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- LeftFrontSuspension 40-->
				<key>LeftFrontSuspension</key>
				<label>left front Suspension</label>
				<health>40</health>
				<depth>Internal</depth>
				<hitbox>
					<cells>
						<li>(0, 2)</li>
					</cells>
				</hitbox>
				<categories>
					<li>MoveSpeed</li>
				</categories>
			</li>
			<li>
				<!-- RightFrontSuspension 40-->
				<key>RightFrontSuspension</key>
				<label>right front suspension</label>
				<health>40</health>
				<depth>Internal</depth>
				<hitbox>
					<cells>
						<li>(1, 2)</li>
					</cells>
				</hitbox>
				<categories>
					<li>MoveSpeed</li>
				</categories>
			</li>
			<li>
				<!-- LeftRearSuspension 40-->
				<key>LeftRearSuspension</key>
				<label>left rear suspension</label>
				<health>40</health>
				<depth>Internal</depth>
				<hitbox>
					<cells>
						<li>(0, -1)</li>
					</cells>
				</hitbox>
				<categories>
					<li>MoveSpeed</li>
				</categories>
			</li>
			<li>
				<!-- RightRearSuspension 40-->
				<key>RightRearSuspension</key>
				<label>right rear suspension</label>
				<health>40</health>
				<depth>Internal</depth>
				<hitbox>
					<cells>
						<li>(1, -1)</li>
					</cells>
				</hitbox>
				<categories>
					<li>MoveSpeed</li>
				</categories>
			</li>
			<li>
				<!-- Gearbox 45-->
				<key>Gearbox</key>
				<label>gear box</label>
				<health>45</health>
				<depth>Internal</depth>
				<hitbox>
					<cells>
						<li>(0, 1)</li>
						<li>(1, 1)</li>
					</cells>
				</hitbox>
				<categories>
					<li>MoveSpeed</li>
				</categories>
			</li>
			<li>
				<!-- FuelTank 40-->
				<key>FuelTank</key>
				<label>fuel tank</label>
				<health>40</health>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_FuelLeak"/>
				</reactors>
				<hitbox>
					<cells>
						<li>(1, 0)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- AmmoRack 50-->
				<key>AmmoRack</key>
				<label>ammo rack</label>
				<health>50</health>
				<depth>Internal</depth>
				<hitbox>
					<cells>
						<li>(0, 0)</li>
					</cells>
				</hitbox>
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.2</chance>
						<maxHealth>0.2</maxHealth>
						<radius>2</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>
			</li>
			<!-- External mobile Part 外部驅動部件-->
			<li>
				<!-- LeftFrontWheel 30-->
				<key>LeftFrontWheel</key>
				<label>left front Wheel</label>
				<health>30</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<armor>
					<ArmorRating_Blunt>0</ArmorRating_Blunt>
					<ArmorRating_Sharp>0</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(0, 2)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- RightFrontWheel 30-->
				<key>RightFrontWheel</key>
				<label>right front Wheel</label>
				<health>30</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<armor>
					<ArmorRating_Blunt>0</ArmorRating_Blunt>
					<ArmorRating_Sharp>0</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(1, 2)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- LeftRearWheel	30-->
				<key>LeftRearWheel</key>
				<label>left rear wheel</label>
				<health>30</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<armor>
					<ArmorRating_Blunt>0</ArmorRating_Blunt>
					<ArmorRating_Sharp>0</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(0, -1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- RightRearWheel 30-->
				<key>RightRearWheel</key>
				<label>right rear Wheel</label>
				<health>30</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<armor>
					<ArmorRating_Blunt>0</ArmorRating_Blunt>
					<ArmorRating_Sharp>0</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(1, -1)</li>
					</cells>
				</hitbox>
			</li>
			<!-- External Shell Part 外殼部件-->
			<li>
				<!-- EngineHood 40-->
				<key>EngineHood</key>
				<label>engine hood</label>
				<health>60</health>
				<depth>External</depth>
				<hitbox>
					<side>Body</side>
				</hitbox>
			</li>
			<li>
				<!-- Roof 40-->
				<key>Roof</key>
				<label>roof</label>
				<health>60</health>
				<depth>External</depth>
				<hitbox>
					<side>Body</side>
				</hitbox>
			</li>
			<li>
				<!-- LeftDoorPanel 40-->
				<key>LeftDoorPanel</key>
				<label>left door panel</label>
				<health>60</health>
				<depth>External</depth>
				<hitbox>
					<side>Left</side>
				</hitbox>
			</li>
			<li>
				<!-- RightDoorPanel 40-->
				<key>RightDoorPanel</key>
				<label>right door panel</label>
				<health>60</health>
				<depth>External</depth>
				<hitbox>
					<side>Right</side>
				</hitbox>
			</li>
			<li>
				<!-- FrontBumper 30-->
				<key>FrontBumper</key>
				<label>front bumper</label>
				<health>45</health>
				<depth>External</depth>
				<hitbox>
					<side>Front</side>
				</hitbox>
			</li>
			<li>
				<!-- RearBumper 25-->
				<key>RearBumper</key>
				<label>rear bumper</label>
				<health>40</health>
				<depth>External</depth>
				<hitbox>
					<side>Back</side>
				</hitbox>
			</li>

			<!-- Internal Shell Part 內裝部件-->
			<li>
				<!-- Interior 30-->
				<key>Interior</key>
				<label>interior</label>
				<health>30</health>
				<depth>Internal</depth>
			</li>
			<li>
				<!-- Dashboard 30-->
				<key>Dashboard</key>
				<label>dashboard</label>
				<health>30</health>
				<depth>Internal</depth>
			</li>
			<li>
				<!-- SteeringWheel 20-->
				<key>SteeringWheel</key>
				<label>steering wheel</label>
				<health>20</health>
				<depth>Internal</depth>
			</li>
		</components>
		<comps>
			<li Class="Vehicles.CompProperties_FueledTravel">
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>18</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>0.7</fuelConsumptionWorldMultiplier>
				<fuelCapacity>120</fuelCapacity>
			</li>
			<li Class="Vehicles.CompProperties_VehicleTurrets">
				<!-- 砲塔 -->
				<turrets>
					<li>
						<turretDef>RT_BTR40A_Tank_Turret</turretDef>
						<renderProperties>
							<north>(0, -0.3)</north>
							<south>(0, 0.97)</south>
							<east>(-0.66, 0.3)</east>
							<west>(0.66, 0.3)</west>
						</renderProperties>

						<gizmoLabel>Main Turret</gizmoLabel>
						<aimPieOffset>(0, 1.5)</aimPieOffset>
						<!-- 預熱指示器的x,z偏移 -->
						<drawLayer>3</drawLayer>
						<key>mainTurret</key>
					</li>
				</turrets>
			</li>
		</comps>
	</Vehicles.VehicleDef>
	<!-- 主砲的Def -->
	<Vehicles.VehicleTurretDef ParentName="RT_BaseVehicleMG_Heavy">
		<defName>RT_BTR40A_Tank_Turret</defName>
		<label>main turret</label>
		<!-- 砲塔的渲染顯示 -->
		<graphicData>
			<texPath>BTR40A/MainTurret</texPath>
			<drawSize>(4,4)</drawSize>
		</graphicData>
		<ammunition Inherit="false">
			<thingDefs>
				<li>Steel</li>
			</thingDefs>
		</ammunition>
		<!-- 彈藥與裝填容量相關 -->
		<reloadTimer>8</reloadTimer>
		<magazineCapacity>80</magazineCapacity>
		<genericAmmo>true</genericAmmo>
		<rotationSpeed>1</rotationSpeed>
		<projectileOffset>1.82</projectileOffset>
		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>
			<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<li>0.11</li>
			<li>-0.11</li>
		</projectileShifting>
		<!-- 炮口製退動畫 -->
		<recoil>
			<distanceTotal>0.15</distanceTotal>
			<distancePerTick>0.05</distancePerTick>
			<speedMultiplierPostRecoil>0.1</speedMultiplierPostRecoil>
		</recoil>
		<!-- 射擊模式 -->
		<fireModes Inherit = "false">
			<li>
				<shotsPerBurst>8</shotsPerBurst>
				<ticksBetweenShots>3</ticksBetweenShots>
				<ticksBetweenBursts>70</ticksBetweenBursts>
				<label>Auto</label>
				<texPath>UI/Gizmos/FireRate_Auto</texPath>
			</li>
			<li>
				<shotsPerBurst>2</shotsPerBurst>
				<ticksBetweenShots>3</ticksBetweenShots>
				<ticksBetweenBursts>70</ticksBetweenBursts>
				<label>Burst</label>
				<texPath>UI/Gizmos/FireRate_Burst</texPath>
			</li>
		</fireModes>
		<motes>
			<li>
				<cycles>1</cycles>
				<moteDef>Mote_CannonPlume</moteDef>
				<animationType>Reset</animationType>
				<offset>(0,0,2.1)</offset>
				<scale>0.1</scale>
			</li>
		</motes>
	</Vehicles.VehicleTurretDef>
</Defs>