<?xml version="1.0" encoding="UTF-8"?>
<Defs>

	<Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild">
		<!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_Type62_Vehicle_Blueprint</defName>
		<label>ZTQ62</label>
		<description>A old-time light tank, with bad ergonomics but cheap enouth, have 2 external fuel tank to go farther place.</description>
		<graphicData>
			<texPath>Type62/vehicle</texPath>
			<drawSize>(3,6)</drawSize>
		</graphicData>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>16000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(3,5)</size>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		<costList>
			<EngineHeavy>1</EngineHeavy>
			<ComponentFuelTank>2</ComponentFuelTank>
			<ComponentTransmission>1</ComponentTransmission>
			<ComponentWheelRoad>14</ComponentWheelRoad>
			<ComponentIndustrial>15</ComponentIndustrial>
			<Steel>150</Steel>
		</costList>
		<thingToSpawn>RT_Type62_Vehicle</thingToSpawn>
		<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

	<!-- 載具本體 -->
	<Vehicles.VehicleDef ParentName="RT_BaseVehicle">
		<defName>RT_Type62_Vehicle</defName>
		<label>ZTQ62</label>
		<description>A old-time light tank, with bad ergonomics but cheap enouth, have 2 external fuel tank to go farther place.</description>
		<buildDef>RT_Type62_Vehicle_Blueprint</buildDef>
		<graphicData>
			<texPath>Type62/vehicle</texPath>
			<drawSize>(3,6)</drawSize>
		</graphicData>
		<size>(3,5)</size>
		<fillPercent>1</fillPercent>
		<vehicleCategory>Combat</vehicleCategory>
		<statBases>
			<ArmorRating_Blunt>0.8</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.6</ArmorRating_Sharp>
			<Flammability>0</Flammability>
			<MarketValue>1750</MarketValue>
		</statBases>
		<vehicleStats>
			<Mass>1000</Mass>
			<MoveSpeed>10</MoveSpeed>
			<CargoCapacity>500</CargoCapacity>
			<RepairRate>0.3</RepairRate>
		</vehicleStats>
		<soundOneShotsOnEvent Inherit = "False">
			<li>
				<key>PawnEntered</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>PawnExited</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>IgnitionOn</key>
				<value>RT_T34VehicleStart</value>
			</li>
			<li>
				<key>IgnitionOff</key>
				<value>RT_T34VehicleStop</value>
			</li>
		</soundOneShotsOnEvent>
		<soundSustainersOnEvent Inherit="false"> 
			<li>
				<start>IgnitionOn</start>
				<stop>IgnitionOff</stop>
				<value>RT_T34VehicleEngine</value>
			</li>
		</soundSustainersOnEvent>
		<race>
			<baseBodySize>4</baseBodySize>
		</race>
		<properties>
			<!-- 座位與功能 -->
			<customRoadCosts AssignDefaults = "0.4"/>
			<worldSpeedMultiplier>1</worldSpeedMultiplier>
			<winterSpeedMultiplier>1</winterSpeedMultiplier>
			<customHillinessCosts>
				<SmallHills>0.2</SmallHills>
				<LargeHills>0.8</LargeHills>
				<Mountainous>1.5</Mountainous>
			</customHillinessCosts>
			<vehicleJobLimitations>
				<li>(RepairVehicle, 4)</li>
			</vehicleJobLimitations>
			<roles>
				<li>
					<key>driver</key>
					<label>driver</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
				</li>
				<li>
					<key>gunner</key>
					<label>gunner</label>
					<slots>2</slots>
					<slotsToOperate>1</slotsToOperate>
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>mainTurret</li>
						<li>coaxialMG</li>
					</turretIds>
				</li>
				<li>
					<key>commander</key>
					<label>commander</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>topMG</li>
					</turretIds>
				</li>
			</roles>
		</properties>
		<components>
			<!-- 各種零件 -->
			<!-- Internal mobile Part 內部驅動部件-->
			<li>
				<!--Engine 100-->
				<key>Engine</key>
