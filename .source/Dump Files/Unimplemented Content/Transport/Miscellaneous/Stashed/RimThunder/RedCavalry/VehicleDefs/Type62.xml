	<!--平衡相关-->
	<Vehicles.VehicleTurretDef ParentName="RT_BaseVehicleMG_Heavy">
		<defName>RT_DShK_MGTurret</defName>
		<label>machine gun</label>
		<!-- 砲塔的渲染顯示 -->
		<gizmoIconTexPath>Type62/DShK_gizmo</gizmoIconTexPath>
		<graphicData>
