				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>30</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>1</fuelConsumptionWorldMultiplier>
				<fuelCapacity>240</fuelCapacity>
			</li>
			<li Class="Vehicles.CompProperties_VehicleTurrets">
				<!-- 砲塔 -->
				<turrets>
					<li>
						<turretDef>RT_Type62_Tank_Turret</turretDef>
						<renderProperties>
							<north>(0, 0.52)</north>
							<south>(0, 0.14)</south>
							<east>(0.35, 0.25)</east>
							<west>(-0.35, 0.25)</west>
						</renderProperties>

						<gizmoLabel>Main Turret</gizmoLabel>
						<aimPieOffset>(0, 3)</aimPieOffset>
						<!-- 預熱指示器的x,z偏移 -->
						<drawLayer>1</drawLayer>
						<key>mainTurret</key>
						<component>
							<key>MainTurret</key>
							<healthPercent>0.01</healthPercent>
						</component>
					</li>

					<li>
						<!--車頂機槍-->
						<turretDef>RT_DShK_MGTurret</turretDef>
						<renderProperties>
							<!--這裡的坐標系是無視旋轉的,所以x就是恆定左右偏移-->
							<north>(0.45,0)</north>
							<south>(-0.45,0)</south>
							<east>(0,-0.55)</east>
							<west>(0,-0.45)</west>
						</renderProperties>
						<gizmoLabel>support MG</gizmoLabel>
						<aimPieOffset>(0, 0)</aimPieOffset>
						<key>topMG</key>
						<drawLayer>2</drawLayer>
						<parentKey>mainTurret</parentKey>
					</li>

					<li>
						<!--同軸機槍-->
						<turretDef>RT_SGMT_MGTurret</turretDef>
						<renderProperties>
							<north>(0.28,1.6)</north>
							<south>(-0.28,-1.6)</south>
							<east>(1.6,-0.28)</east>
							<west>(-1.6,0.28)</west>
						</renderProperties>
						<gizmoLabel>coaxial MG</gizmoLabel>
						<angleRestricted>(345,15)</angleRestricted>
						<aimPieOffset>(0, 0)</aimPieOffset>
						<key>coaxialMG</key>
						<drawLayer>0</drawLayer>
						<parentKey>mainTurret</parentKey>
					</li>
				</turrets>
			</li>
