<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<ThingCategoryDef>
		<defName>BDS_152MMShell</defName>
		<label>152mm naval shells</label>
		<parent>Manufactured</parent>
		<iconPath>UI/Icons/ThingCategories/MortarShells</iconPath>
	</ThingCategoryDef>

	<ThingDef Name="BDS_152ShellBase" ParentName="ResourceBase" Abstract="True">
		<soundInteract>Metal_Drop</soundInteract>
		<soundDrop>Standard_Drop</soundDrop>
		<tickerType>Normal</tickerType>
		<stackLimit>10</stackLimit>
		<techLevel>Industrial</techLevel>
		<graphicData>
			<drawSize>1.2</drawSize>
		</graphicData>
		<statBases>
			<MaxHitPoints>100</MaxHitPoints>
			<Mass>5</Mass>
			<Flammability>1.0</Flammability>
			<DeteriorationRate>1.5</DeteriorationRate>
		</statBases>
		<thingCategories>
			<li>BDS_152MMShell</li>
		</thingCategories>
		<recipeMaker>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<effectWorking>Cook</effectWorking>
			<soundWorking>Recipe_Machining</soundWorking>
			<workAmount>2000</workAmount>
			<targetCountAdjustment>5</targetCountAdjustment>
			<workSkill>Crafting</workSkill>
			<recipeUsers>
				<li>TableMachining</li>
			</recipeUsers>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
		</recipeMaker>
	</ThingDef>

	<ThingDef Name="BDS_152ProjBase" ParentName="BaseBullet" Abstract="True">
		<graphicData>
			<drawSize>1.5</drawSize>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<thingClass>Projectile_Explosive</thingClass>
		<projectile>
			<speed>41</speed>
			<flyOverhead>true</flyOverhead>
			<soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
			<soundExplode>MortarBomb_Explode</soundExplode>
			<soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
			<soundAmbient>MortarRound_Ambient</soundAmbient>
		</projectile>
	</ThingDef>

	<!-- High-explosive -->

	<ThingDef ParentName="BDS_152ShellBase">
		<defName>BDS_152Shell_HighExplosive</defName>
		<label>naval high-explosive shell</label>
		<description>A shell filled with high explosives. Can be fired from the main gun of HMS Aurora. Explodes when damaged.</description>
		<possessionCount>1</possessionCount>
		<graphicData>
			<texPath>Things/Item/Resource/Shell/Shell_HighExplosive</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>5.9</explosiveRadius>
				<explosiveDamageType>Bomb</explosiveDamageType>
				<explosiveExpandPerStackcount>0.4</explosiveExpandPerStackcount>
				<startWickHitPointsPercent>0.7</startWickHitPointsPercent>
				<wickTicks>30~60</wickTicks>
			</li>
		</comps>
		<projectileWhenLoaded>BDS_Bullet_152Shell_HighExplosive</projectileWhenLoaded>
		<costList>
			<Steel>35</Steel>
			<Chemfuel>75</Chemfuel>
		</costList>
		<recipeMaker>
			<researchPrerequisite>Mortars</researchPrerequisite>
		</recipeMaker>
	</ThingDef>

	<ThingDef ParentName="BDS_152ProjBase">
		<defName>BDS_Bullet_152Shell_HighExplosive</defName>
		<label>high-explosive shell</label>
		<graphicData>
			<texPath>Things/Projectile/ShellHighExplosive</texPath>
		</graphicData>
		<projectile>
			<damageDef>Bomb</damageDef>
			<explosionRadius>5.9</explosionRadius>
		</projectile>
	</ThingDef>

	<!-- Incendiary -->

	<ThingDef ParentName="BDS_152ShellBase">
		<defName>BDS_152Shell_Incendiary</defName>
		<label>naval incendiary shell</label>
		<description>A shell filled with flammable gel and a small explosive charge. Starts fires when detonated. Can be fired from the main gun of HMS Aurora. Explodes when damaged.</description>
		<possessionCount>1</possessionCount>
		<graphicData>
			<texPath>Things/Item/Resource/Shell/Shell_Incendiary</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>2.9</explosiveRadius>
				<explosiveDamageType>Flame</explosiveDamageType>
				<explosiveExpandPerStackcount>0.4</explosiveExpandPerStackcount>
				<startWickHitPointsPercent>0.7</startWickHitPointsPercent>
				<wickTicks>30~60</wickTicks>
			</li>
		</comps>
		<projectileWhenLoaded>BDS_Bullet_152Shell_Incendiary</projectileWhenLoaded>
		<costList>
			<Steel>20</Steel>
			<Chemfuel>45</Chemfuel>
		</costList>
		<recipeMaker>
			<researchPrerequisite>Mortars</researchPrerequisite>
		</recipeMaker>
	</ThingDef>

	<ThingDef ParentName="BDS_152ProjBase">
		<defName>BDS_Bullet_152Shell_Incendiary</defName>
		<label>incendiary shell</label>
		<graphicData>
			<texPath>Things/Projectile/ShellIncendiary</texPath>
		</graphicData>
		<projectile>
			<damageDef>Flame</damageDef>
			<soundExplode>MortarIncendiary_Explode</soundExplode>
			<explosionRadius>4.9</explosionRadius>
			<preExplosionSpawnThingDef>Filth_Fuel</preExplosionSpawnThingDef>
			<preExplosionSpawnChance>0.25</preExplosionSpawnChance>
			<ai_IsIncendiary>true</ai_IsIncendiary>
		</projectile>
	</ThingDef>

	<!-- EMP -->

	<ThingDef ParentName="BDS_152ShellBase">
		<defName>BDS_152Shell_EMP</defName>
		<label>naval EMP shell</label>
		<description>A shell filled with batteries and antennas, for generating an electromagnetic pulse when detonated. Electromagnetic pulses temporarily disable electrical devices and mechanoids. Can be fired from the main gun of HMS Aurora. Explodes when damaged.</description>
		<possessionCount>1</possessionCount>
		<graphicData>
			<texPath>Things/Item/Resource/Shell/Shell_EMP</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>13.9</explosiveRadius>
				<explosiveDamageType>EMP</explosiveDamageType>
				<explosiveExpandPerStackcount>0.4</explosiveExpandPerStackcount>
				<startWickHitPointsPercent>0.7</startWickHitPointsPercent>
				<wickTicks>30~60</wickTicks>
			</li>
		</comps>
		<projectileWhenLoaded>BDS_Bullet_152Shell_EMP</projectileWhenLoaded>
		<costList>
			<Steel>30</Steel>
			<ComponentIndustrial>4</ComponentIndustrial>
		</costList>
		<recipeMaker>
			<researchPrerequisite>MicroelectronicsBasics</researchPrerequisite>
		</recipeMaker>
	</ThingDef>

	<ThingDef ParentName="BDS_152ProjBase">
		<defName>BDS_Bullet_152Shell_EMP</defName>
		<label>EMP shell</label>
		<graphicData>
			<texPath>Things/Projectile/ShellEMP</texPath>
		</graphicData>
		<projectile>
			<damageDef>EMP</damageDef>
			<explosionRadius>13.9</explosionRadius>
			<soundExplode>Explosion_EMP</soundExplode>
		</projectile>
	</ThingDef>

	<!-- Smoke -->

	<ThingDef ParentName="BDS_152ShellBase">
		<defName>BDS_152Shell_Smoke</defName>
		<label>naval smoke shell</label>
		<description>A shell that generates a cloud of smoke when detonated, obscuring incoming shots and preventing turrets from locking on. Can be fired from the main gun of HMS Aurora. Explodes when damaged.</description>
		<possessionCount>2</possessionCount>
		<graphicData>
			<texPath>Things/Item/Resource/Shell/Shell_Smoke</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveDamageType>Smoke</explosiveDamageType>
				<explosiveRadius>11</explosiveRadius>
				<postExplosionGasType>BlindSmoke</postExplosionGasType>
				<wickTicks>30~60</wickTicks>
			</li>
		</comps>
		<projectileWhenLoaded>BDS_Bullet_152Shell_Smoke</projectileWhenLoaded>
		<costList>
			<Steel>50</Steel>
		</costList>
		<recipeMaker>
			<researchPrerequisite>Mortars</researchPrerequisite>
			<displayPriority>110</displayPriority>
		</recipeMaker>
	</ThingDef>

	<ThingDef ParentName="BDS_152ProjBase">
		<defName>BDS_Bullet_152Shell_Smoke</defName>
		<label>smoke shell</label>
		<graphicData>
			<texPath>Things/Projectile/ShellSmoke</texPath>
		</graphicData>
		<projectile>
			<damageDef>Smoke</damageDef>
			<explosionRadius>11</explosionRadius>
			<flyOverhead>true</flyOverhead>
			<soundExplode>Explosion_Smoke</soundExplode>
			<postExplosionGasType>BlindSmoke</postExplosionGasType>
		</projectile>
	</ThingDef>
</Defs>
