<?xml version="1.0" encoding="UTF-8"?>
<Defs>

	<Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild">
		<!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_Type61_Vehicle_Blueprint</defName>
		<label>Type61</label>
		<description>A 1st generation MBT, equipped with a 90mm cannon and 12.7mm machine gun, not the one in gundam.</description>
		<graphicData>
			<texPath>Type61/vehicle</texPath>
			<drawSize>(5.7,5.7)</drawSize>
		</graphicData>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>18000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(3,5)</size>
		<researchPrerequisites>
			<li>MicroelectronicsBasics</li>
		</researchPrerequisites>
		<constructionSkillPrerequisite>8</constructionSkillPrerequisite>
		<costList>
			<EngineHeavy>1</EngineHeavy>
			<ComponentFuelTank>2</ComponentFuelTank>
			<ComponentTransmission>1</ComponentTransmission>
			<ComponentWheelRoad>16</ComponentWheelRoad>
			<ComponentIndustrial>20</ComponentIndustrial>
			<Steel>250</Steel>
		</costList>
		<thingToSpawn>RT_Type61_Vehicle</thingToSpawn>
		<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

	<!-- 載具本體 -->
	<Vehicles.VehicleDef ParentName="RT_BaseVehicle">
		<defName>RT_Type61_Vehicle</defName>
		<label>Type61</label>
		<description>A 1st generation MBT, equipped with a 90mm cannon and 12.7mm machine gun, not the one in gundam.</description>
		<buildDef>RT_Type61_Vehicle_Blueprint</buildDef>
		<graphicData>
			<texPath>Type61/vehicle</texPath>
			<drawSize>(5.7,5.7)</drawSize>
		</graphicData>
		<size>(3,5)</size>
		<fillPercent>0.8</fillPercent>
		<vehicleCategory>Combat</vehicleCategory>
		<statBases>
			<ArmorRating_Blunt>0.8</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.6</ArmorRating_Sharp>
			<Flammability>0</Flammability>
			<MarketValue>4350</MarketValue>
		</statBases>
		<vehicleStats>
			<Mass>2000</Mass>
			<MoveSpeed>8</MoveSpeed>
			<CargoCapacity>500</CargoCapacity>
			<RepairRate>0.4</RepairRate>
		</vehicleStats>
		<soundOneShotsOnEvent Inherit = "False">
			<li>
				<key>PawnEntered</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>PawnExited</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>IgnitionOn</key>
				<value>RT_M60VehicleStart</value>
			</li>
			<li>
				<key>IgnitionOff</key>
				<value>RT_M60VehicleStop</value>
			</li>
		</soundOneShotsOnEvent>
		<soundSustainersOnEvent Inherit="false"> 
			<li>
				<start>IgnitionOn</start>
				<stop>IgnitionOff</stop>
				<value>RT_M60VehicleEngine</value>
			</li>
		</soundSustainersOnEvent>
		<race>
			<baseBodySize>4</baseBodySize>
		</race>
		<properties>
			<!-- 座位與功能 -->
			<customRoadCosts AssignDefaults = "0.4"/>
			<worldSpeedMultiplier>1.0</worldSpeedMultiplier>
			<winterSpeedMultiplier>1.0</winterSpeedMultiplier>
			<customHillinessCosts>
				<SmallHills>0.3</SmallHills>
				<LargeHills>1.0</LargeHills>
				<Mountainous>2</Mountainous>
			</customHillinessCosts>
			<vehicleJobLimitations>
				<li>(RepairVehicle, 5)</li>
			</vehicleJobLimitations>
			<roles>
				<li>
					<key>driver</key>
					<label>driver</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<hitbox>
						<cells>
							<li>(-1, 2)</li>
						</cells>
					</hitbox>
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
				</li>
				<li>
					<key>gunner</key>
					<label>gunner</label>
					<slots>2</slots>
					<slotsToOperate>1</slotsToOperate>
					<hitbox>
						<cells>
							<li>(-1, 0)</li>
							<li>(-1, -1)</li>
						</cells>
					</hitbox>
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>mainTurret</li>
						<li>coaxialMG</li>
					</turretIds>
				</li>
				<li>
					<key>Commander</key>
					<label>Commander</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<hitbox>
						<cells>
							<li>(1, 0)</li>
						</cells>
					</hitbox>
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>topMG</li>
					</turretIds>
				</li>
			</roles>
		</properties>
		<components>
			<!-- 各種零件 -->
			<!-- Internal mobile Part 內部驅動部件-->
			<li>
				<!--Engine 100-->
				<key>Engine</key>
				<label>Engine</label>
				<health>100</health>
				<priorityStatEfficiency>true</priorityStatEfficiency>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.25</chance>
						<maxHealth>0.3</maxHealth>
						<radius>3</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>
				<hitbox>
					<cells>
						<li>(0, -2)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- fuel tank 100-->
				<key>FuelTank</key>
				<label>fuel tank</label>
				<health>100</health>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_FuelLeak"/>
				</reactors>
				<hitbox>
					<cells>
						<li>(0, -2)</li>
						<li>(0, -1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- Gearbox 50-->
				<key>Gearbox</key>
				<label>gearbox</label>
				<health>50</health>
				<depth>Internal</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<hitbox>
					<cells>
						<li>(0, -2)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- AmmoRack 50-->
				<key>AmmoRack</key>
				<label>ammo rack</label>
				<health>50</health>
				<depth>Internal</depth>
				<hitWeight>0.2</hitWeight>
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.5</chance>
						<radius>5</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>
				<hitbox>
					<cells>
						<li>(-1, 0)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- transmission shaft 40 -->
				<key>TransmissionShaft</key>
				<label>transmission shaft</label>
				<health>40</health>
				<depth>Internal</depth>
			</li>
			<!-- External mobile Part 外部驅動部件-->
			<li>
				<!-- LeftTrack 150-->
				<key>LeftTrack</key>
				<label>left track</label>
				<health>150</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitWeight>2</hitWeight>
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Left</side>
				</hitbox>
			</li>
			<li>
				<!-- RightTrack 150-->
				<key>RightTrack</key>
				<label>right track</label>
				<health>150</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitWeight>2</hitWeight>
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Right</side>
				</hitbox>
			</li>
			<li>
				<!-- LeftRoadWheels 100-->
				<key>LeftRoadWheels</key>
				<label>left road wheels</label>
				<health>100</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Left</side>
				</hitbox>
			</li>
			<li>
				<!-- RightRoadWheels 100-->
				<key>RightRoadWheels</key>
				<label>right road wheels</label>
				<health>100</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Right</side>
				</hitbox>
			</li>
			<li>
				<!-- LeftDriveSprocket 75-->
				<key>LeftDriveSprocket</key>
				<label>left drive sprocket</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(-1, -2)</li>
					</cells>
					<!--左前-->
				</hitbox>
			</li>
			<li>
				<!-- RightDriveSprocket 75-->
				<key>RightDriveSprocket</key>
				<label>right drive sprocket</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(1, -2)</li>
					</cells>
					<!--右前-->
				</hitbox>
			</li>
			<li>
				<!-- LeftTensionerWheel 75-->
				<key>LeftTensionerWheel</key>
				<label>left tensioner wheel</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(-1, 2)</li>
					</cells>
					<!--左後-->
				</hitbox>
			</li>
			<li>
				<!-- RightTensionerWheel 75-->
				<key>RightTensionerWheel</key>
				<label>right tensioner wheel</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(1, 2)</li>
					</cells>
					<!--右後-->
				</hitbox>
			</li>
			<!-- External Platings 外部防禦部件 -->
			<li>
				<!-- FrontArmorPlating 200-->
				<key>FrontArmorPlating</key>
				<label>front armor Plating</label>
				<health>270</health>
				<depth>External</depth>
				<hitWeight>8</hitWeight>
				<armor>
					<ArmorRating_Blunt>1.2</ArmorRating_Blunt>
					<ArmorRating_Sharp>1.2</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Front</side>
				</hitbox>
			</li>
			<li>
				<!-- LeftArmorPlating 180-->
				<key>LeftArmorPlating</key>
				<label>left armor plating</label>
				<health>243</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<armor>
					<ArmorRating_Blunt>0.84</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.84</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Left</side>
				</hitbox>
			</li>
			<li>
				<!-- RightArmorPlating 180-->
				<key>RightArmorPlating</key>
				<label>right armor plating</label>
				<health>243</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<armor>
					<ArmorRating_Blunt>0.84</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.84</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Right</side>
				</hitbox>
			</li>
			<li>
				<!-- RoofArmorPlating 150 -->
				<key>RoofArmorPlating</key>
				<label>roof armor plating</label>
				<health>270</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<armor>
					<ArmorRating_Blunt>1.08</ArmorRating_Blunt>
					<ArmorRating_Sharp>1.08</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Body</side>
				</hitbox>
			</li>
			<li>
				<!-- BackArmorPlating 150-->
				<key>BackArmorPlating</key>
				<label>rear armor plating</label>
				<health>203</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<hitbox>
					<side>Back</side>
				</hitbox>
			</li>
			<!-- 炮塔-->
			<li>
				<!-- mainTurret 250-->
				<key>MainTurret</key>
				<label>Main Turret</label>
				<health>270</health>
				<depth>External</depth>
				<hitWeight>6</hitWeight>
				<armor>
					<ArmorRating_Blunt>1.2</ArmorRating_Blunt>
					<ArmorRating_Sharp>1.2</ArmorRating_Sharp>
				</armor>
