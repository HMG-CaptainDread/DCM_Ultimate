		<comps>
			<li Class="Vehicles.CompProperties_FueledTravel">
				<!-- 油箱與油耗 -->
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>30</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>1</fuelConsumptionWorldMultiplier>
				<fuelCapacity>160</fuelCapacity>
			</li>
			<li Class="Vehicles.CompProperties_VehicleTurrets">
				<!-- 砲塔 -->
				<turrets>
					<li>
						<turretDef>RT_Type61_Tank_Turret</turretDef>
						<renderProperties>
							<north>(0, 0.3)</north>
							<south>(0, -0.1)</south>
							<east>(0.2, 0.3)</east>
							<west>(-0.2, 0.3)</west>
						</renderProperties>

						<gizmoLabel>Main Turret</gizmoLabel>
						<aimPieOffset>(0, 3.5)</aimPieOffset>
						<!-- 預熱指示器的x,z偏移 -->
						<drawLayer>1</drawLayer>
						<key>mainTurret</key>
						<component>
							<key>MainTurret</key>
							<healthPercent>0.01</healthPercent>
						</component>
					</li>

					<li>
						<!--車頂機槍-->
						<turretDef>RT_m2hb_MGTurret</turretDef>
						<renderProperties>
							<!--這裡的坐標系是無視旋轉的,所以x就是恆定左右偏移-->
							<north>(0.50,-0.05)</north>
							<south>(-0.50,0.05)</south>
							<east>(-0.05,-0.50)</east>
							<west>(0.05,-0.50)</west>
						</renderProperties>
						<gizmoLabel>support MG</gizmoLabel>
						<aimPieOffset>(0, 0)</aimPieOffset>
						<key>topMG</key>
						<drawLayer>2</drawLayer>
						<parentKey>mainTurret</parentKey>
					</li>

					<li>
						<!--同軸機槍-->
						<turretDef>RT_Type74_MGTurret</turretDef>
						<renderProperties>
							<north>(0.27,0.95)</north>
							<south>(-0.27,-0.95)</south>
							<east>(0.95,-0.27)</east>
							<west>(-0.95,0.27)</west>
						</renderProperties>
						<gizmoLabel>coaxial MG</gizmoLabel>
						<angleRestricted>(355,5)</angleRestricted>
						<aimPieOffset>(0, 0)</aimPieOffset>
						<key>coaxialMG</key>
						<drawLayer>0</drawLayer>
						<parentKey>mainTurret</parentKey>
					</li>
				</turrets>
			</li>
		</comps>
	</Vehicles.VehicleDef>

	<!-- 主砲的Def -->
	<Vehicles.VehicleTurretDef ParentName="RT_BaseTurret">
		<defName>RT_Type61_Tank_Turret</defName>
		<label>main turret</label>
		<!-- 炮塔图标 -->
		<gizmoIconTexPath>Type61/vehicle_turret_gizmo</gizmoIconTexPath>
		<!-- 炮塔部分 -->
		<graphicData>
			<texPath>Type61/vehicle_turret</texPath>
			<graphicClass>Vehicles.Graphic_Turret</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType> 
			<drawSize>(8,8)</drawSize>
			<layer>0</layer>
		</graphicData>
		<!-- 炮管后座部分 -->
		<graphics>
			<li>
				<graphicData>
					<texPath>Type61/vehicle_barrel</texPath>
					<drawSize>(8,8)</drawSize>
					<graphicClass>Vehicles.Graphic_Turret</graphicClass>
					<shaderType>CutoutComplexPattern</shaderType>
				</graphicData>
				<recoil>
					<distanceTotal>0.35</distanceTotal>
					<distancePerTick>0.05</distancePerTick>
					<speedMultiplierPostRecoil>0.1</speedMultiplierPostRecoil>
				</recoil>
			</li>	
		</graphics>
		
		<!-- 彈藥與裝填容量相關 -->
		<reloadTimer>7.5</reloadTimer>
		<reloadTimerMultiplierPerCrewCount>
			<points>
				<li>(1, 1.5)</li>
				<li>(2, 1)</li>
			</points>
		</reloadTimerMultiplierPerCrewCount>
		<magazineCapacity>1</magazineCapacity>
		<chargePerAmmoCount>5</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<ammunition>
			<thingDefs>
				<li>Steel</li>
			</thingDefs>
		</ammunition>
		<!-- 射程與射界相關 -->
		<minRange>2</minRange>
		<maxRange>45.9</maxRange>
		<rotationSpeed>1.2</rotationSpeed>
		<!-- 射擊相關 -->
		<warmUpTimer>1.5</warmUpTimer>
		<shotSound>RT_Shot_M3Sound</shotSound>
		<reloadSound>RT_ManpowerReloadSound</reloadSound>
		<projectile>RT_Bullet_Type61Shell</projectile>
		<projectileOffset>4.15</projectileOffset>
		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>
			<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<li>0</li>
		</projectileShifting>
		<!-- 炮口製退動畫 -->

		<!-- 射擊模式 -->
		<fireModes>
			<li>
				<shotsPerBurst>1</shotsPerBurst>
				<ticksBetweenBursts>1</ticksBetweenBursts>
				<spreadRadius>3</spreadRadius>
				<label>Single Shot</label>
				<texPath>UI/Gizmos/FireRate_Single</texPath>
			</li>
		</fireModes>
		<motes>
			<li>
				<cycles>1</cycles>
				<moteDef>Mote_CannonPlume</moteDef>
				<animationType>Reset</animationType>
				<offset>(0,0,4.0)</offset>
			</li>
		</motes>
	</Vehicles.VehicleTurretDef>

	<!-- 主砲的投射物 -->
	<ThingDef ParentName="BaseBullet">
		<defName>RT_Bullet_Type61Shell</defName>
		<label>high-explosive shell</label>
		<thingClass>Projectile_Explosive</thingClass>
		<graphicData>
			<texPath>Things/Projectile/Bullet_Big</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>2</drawSize>
		</graphicData>
		<projectile>
			<damageDef>Bomb</damageDef>
			<damageAmountBase>100</damageAmountBase>
			<armorPenetrationBase>0.77</armorPenetrationBase>
			<speed>100</speed>
			<explosionRadius>2.9</explosionRadius>
			<soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
			<soundExplode>Explosion_GiantBomb</soundExplode>
			<soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
			<soundAmbient>MortarRound_Ambient</soundAmbient>
		</projectile>
	</ThingDef>

	<Vehicles.VehicleTurretDef ParentName="RT_BaseVehicleMG_Heavy">
		<defName>RT_m2hb_MGTurret</defName>
		<label>machine gun</label>
		<gizmoIconTexPath>Type61/m2hb</gizmoIconTexPath>
		<!-- 砲塔的渲染顯示 -->
		<graphicData>
			<texPath>Type61/m2hb</texPath>
			<drawSize>(2,2)</drawSize>
