<?xml version="1.0" encoding="UTF-8"?>
<Defs>

	<Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild">
		<!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_Type73_Vehicle_Blueprint</defName>
		<label>Type73 APC</label>
		<description>An APC with lower cargo capacity but can take more crews, equipped with RWS and smoke launchers.</description>
		<graphicData>
			<texPath>Type73/vehicle</texPath>
			<drawSize>(5.7,5.7)</drawSize>
		</graphicData>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>16000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(3,4)</size>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		<costList>
			<EngineMedium>1</EngineMedium>
			<ComponentFuelTank>1</ComponentFuelTank>
			<ComponentTransmission>1</ComponentTransmission>
			<ComponentWheelRoad>14</ComponentWheelRoad>
			<ComponentIndustrial>15</ComponentIndustrial>
			<Steel>150</Steel>
		</costList>
		<thingToSpawn>RT_Type73_Vehicle</thingToSpawn>
		<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

	<!-- 載具本體 -->
	<Vehicles.VehicleDef ParentName="RT_BaseVehicle">
		<defName>RT_Type73_Vehicle</defName>
		<label>Type73 APC</label>
		<description>An APC with lower cargo capacity but can take more crews, equipped with RWS and smoke launchers.</description>
		<buildDef>RT_Type73_Vehicle_Blueprint</buildDef>
		<graphicData>
			<texPath>Type73/vehicle</texPath>
			<drawSize>(5.7,5.7)</drawSize>
		</graphicData>
		<size>(3,4)</size>
		<fillPercent>0.8</fillPercent>
		<vehicleCategory>Combat</vehicleCategory>
		<statBases>
			<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
			<Flammability>0</Flammability>
			<MarketValue>1800</MarketValue>
		</statBases>
		<vehicleStats>
			<Mass>800</Mass>
			<MoveSpeed>7</MoveSpeed>
			<CargoCapacity>400</CargoCapacity>
			<RepairRate>0.3</RepairRate>
		</vehicleStats>
		<soundOneShotsOnEvent Inherit = "False">
			<li>
				<key>PawnEntered</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>PawnExited</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>IgnitionOn</key>
				<value>RT_BMPVehicleStart</value>
			</li>
			<li>
				<key>IgnitionOff</key>
				<value>RT_BMPVehicleStop</value>
			</li>
		</soundOneShotsOnEvent>
		<soundSustainersOnEvent Inherit="false"> 
			<li>
				<start>IgnitionOn</start>
				<stop>IgnitionOff</stop>
				<value>RT_BMPVehicleEngine</value>
			</li>
		</soundSustainersOnEvent>
		<race>
			<baseBodySize>4</baseBodySize>
		</race>
		<properties>
			<!-- 座位與功能 -->
			<customRoadCosts AssignDefaults = "0.4"/>
			<worldSpeedMultiplier>1</worldSpeedMultiplier>
			<winterSpeedMultiplier>1</winterSpeedMultiplier>
			<customHillinessCosts>
				<SmallHills>0.2</SmallHills>
				<LargeHills>0.8</LargeHills>
				<Mountainous>1.5</Mountainous>
			</customHillinessCosts>
			<customRiverCosts AssignDefaults = "0.4"/>	
			<customTerrainCosts AllowTerrainWithTag = "Water" PathCost = "1">
				<li>
					<key>Mud</key>
					<value>1</value>
				</li>
			</customTerrainCosts> 
			<customBiomeCosts>
				<li>
					<key>Ocean</key>
					<value>4</value>
				</li>
				<li>
					<key>Lake</key>
					<value>4</value>
				</li>
			</customBiomeCosts>
			<vehicleJobLimitations>
				<li>(RepairVehicle, 4)</li>
			</vehicleJobLimitations>
			<roles>
				<li>
					<key>driver</key>
					<label>driver</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
				</li>
				<li>
					<key>gunner</key>
					<label>gunner</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>mainTurret</li>
						<li>leftSmoke</li>
						<li>rightSmoke</li>
					</turretIds>
				</li>
				<li>
					<key>passenger</key>
					<label>passenger</label>
					<slots>10</slots>
					<slotsToOperate>1</slotsToOperate>
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>hullMG</li>
					</turretIds>
				</li>
			</roles>
		</properties>
		<components>
			<!-- 各種零件 -->
			<!-- Internal mobile Part 內部驅動部件-->
			<li>
				<!--Engine 100-->
				<key>Engine</key>
				<label>Engine</label>
				<health>70</health>
				<priorityStatEfficiency>true</priorityStatEfficiency>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.25</chance>
						<maxHealth>0.3</maxHealth>
						<radius>3</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>
				<hitbox>
					<cells>
						<li>(0, 1)</li>
						<li>(1, 1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- fuel tank 100-->
				<key>FuelTank</key>
				<label>fuel tank</label>
				<health>70</health>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_FuelLeak"/>
				</reactors>
				<hitbox>
					<cells>
						<li>(-1, -1)</li>
						<li>(1, -1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- Gearbox 50-->
				<key>Gearbox</key>
				<label>gearbox</label>
				<health>35</health>
				<depth>Internal</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<hitbox>
					<cells>
						<li>(0, 2)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- transmission shaft 40 -->
				<key>TransmissionShaft</key>
				<label>transmission shaft</label>
				<health>28</health>
				<depth>Internal</depth>
			</li>
			<li>
				<!-- AmmoRack 50-->
				<key>AmmoRack</key>
				<label>ammo rack</label>
				<health>35</health>
				<depth>Internal</depth>
				<hitbox>
					<cells>
						<li>(0, -1)</li>
					</cells>
				</hitbox>
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.2</chance>
						<radius>2</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>
			</li>
			<!-- External mobile Part 外部驅動部件-->
			<li>
				<!-- LeftTrack 150-->
				<key>LeftTrack</key>
				<label>left track</label>
				<health>150</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitWeight>2</hitWeight>
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Left</side>
				</hitbox>
			</li>
			<li>
				<!-- RightTrack 150-->
				<key>RightTrack</key>
				<label>right track</label>
				<health>150</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitWeight>2</hitWeight>
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Right</side>
				</hitbox>
			</li>
			<li>
				<!-- LeftRoadWheels 100-->
				<key>LeftRoadWheels</key>
				<label>left road wheels</label>
				<health>100</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Left</side>
				</hitbox>
			</li>
			<li>
				<!-- RightRoadWheels 100-->
				<key>RightRoadWheels</key>
				<label>right road wheels</label>
				<health>100</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Right</side>
				</hitbox>
			</li>
			<li>
				<!-- LeftDriveSprocket 75-->
				<key>LeftDriveSprocket</key>
				<label>left drive sprocket</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(-1, 2)</li>
					</cells>
					<!--左前-->
				</hitbox>
			</li>
			<li>
				<!-- RightDriveSprocket 75-->
				<key>RightDriveSprocket</key>
				<label>right drive sprocket</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(1, 2)</li>
					</cells>
					<!--右前-->
				</hitbox>
			</li>
			<li>
				<!-- LeftTensionerWheel 75-->
				<key>LeftTensionerWheel</key>
				<label>left tensioner wheel</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(-1, -1)</li>
					</cells>
					<!--左後-->
				</hitbox>
			</li>
			<li>
				<!-- RightTensionerWheel 75-->
				<key>RightTensionerWheel</key>
				<label>right tensioner wheel</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(1, -1)</li>
					</cells>
					<!--右後-->
				</hitbox>
			</li>
			<!-- External Platings 外部防禦部件 -->
			<li>
				<!-- FrontArmorPlating 200-->
				<key>FrontArmorPlating</key>
				<label>front armor Plating</label>
				<health>189</health>
				<depth>External</depth>
				<hitWeight>8</hitWeight>
				<armor>
					<ArmorRating_Blunt>1.00</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.8</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Front</side>
				</hitbox>
			</li>
			<li>
				<!-- LeftArmorPlating 180-->
				<key>LeftArmorPlating</key>
				<label>left armor plating</label>
				<health>170</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<armor>
					<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Left</side>
				</hitbox>
			</li>
			<li>
				<!-- RightArmorPlating 180-->
				<key>RightArmorPlating</key>
				<label>right armor plating</label>
				<health>170</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<armor>
					<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Right</side>
				</hitbox>
			</li>
			<li>
				<!-- RoofArmorPlating 150 -->
				<key>RoofArmorPlating</key>
				<label>roof armor plating</label>
				<health>189</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<armor>
					<ArmorRating_Blunt>0.9</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.7</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Body</side>
				</hitbox>
			</li>
			<li>
				<!-- BackArmorPlating 150-->
				<key>BackArmorPlating</key>
				<label>rear armor plating</label>
				<health>142</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<hitbox>
					<side>Back</side>
				</hitbox>
			</li>
		</components>
		<comps>
			<li Class="Vehicles.CompProperties_FueledTravel">
				<!-- 油箱與油耗 -->
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>30</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>1</fuelConsumptionWorldMultiplier>
				<fuelCapacity>120</fuelCapacity>
			</li>
			<li Class="Vehicles.CompProperties_VehicleTurrets">
				<!-- 砲塔 -->
				<turrets>
					<li>
						<turretDef>RT_Type73_Tank_Turret</turretDef>
						<renderProperties>
							<north>(0.65, 0.7)</north>
							<south>(-0.65, 0)</south>
							<east>(0.05,-0.03)</east>
							<west>(-0.25, 0.84)</west>
						</renderProperties>

						<gizmoLabel>Main Turret</gizmoLabel>
						<aimPieOffset>(0, 1.5)</aimPieOffset>
						<!-- 預熱指示器的x,z偏移 -->
						<drawLayer>1</drawLayer>
						<key>mainTurret</key>
					</li>
					<li>
						<!--航向机枪-->
						<turretDef>RT_Type74_MGTurret</turretDef>
						<renderProperties>
							<north>(-0.5,2.6)</north>
							<south>(0.5,-2)</south>
							<east>(2.2,0.6)</east>
							<west>(-2.2,-0.2)</west>
						</renderProperties>
						<gizmoLabel>hull MG</gizmoLabel>
						<angleRestricted>(315,45)</angleRestricted>
						<aimPieOffset>(0, 0)</aimPieOffset>
						<key>hullMG</key>
						<drawLayer>0</drawLayer>
						<component>
							<key>FrontArmorPlating</key>
							<healthPercent>0.01</healthPercent>
						</component>
					</li>
					<li>
						<turretDef>RT_GrenadeLauncher73</turretDef>
						<gizmoLabel>Left Grenade Launcher</gizmoLabel>
						<renderProperties>
							<north>(-1.1, -1)</north>
							<south>(1.1, 1)</south>
							<east>(-1, 1.1)</east>
							<west>(1, -1.1)</west>
						</renderProperties>
						<aimPieOffset>(0, 0)</aimPieOffset>
						<drawLayer>2</drawLayer>
						<key>leftSmoke</key>
						<parentKey>mainTurret</parentKey>
					</li>
					<li>
						<turretDef>RT_GrenadeLauncher73</turretDef>
						<gizmoLabel>Right Grenade Launcher</gizmoLabel>
						<renderProperties>
							<north>(1.1, -1)</north>
							<south>(-1.1, 1)</south>
							<east>(-1, -1.1)</east>
							<west>(1, 1.1)</west>
						</renderProperties>
						<aimPieOffset>(0, 0)</aimPieOffset>
						<drawLayer>2</drawLayer>
						<key>rightSmoke</key>
						<parentKey>mainTurret</parentKey>
					</li>
				</turrets>
			</li>
		</comps>
	</Vehicles.VehicleDef>

	<!-- 主砲的Def -->
	<!--平衡相关-->
	<Vehicles.VehicleTurretDef ParentName="RT_BaseVehicleMG_Heavy">
		<defName>RT_Type73_Tank_Turret</defName>
		<label>machine gun</label>
		<!-- 砲塔的渲染顯示 -->
		<gizmoIconTexPath>Type73/vehicle_turret</gizmoIconTexPath>
		<graphicData>
			<texPath>Type73/vehicle_turret</texPath>
			<drawSize>(2,2)</drawSize>
		</graphicData>
		<ammunition Inherit="false">
			<thingDefs>
				<li>Steel</li>
			</thingDefs>
		</ammunition>
		<!-- 彈藥與裝填容量相關 -->
		<reloadTimer>6</reloadTimer>
		<magazineCapacity>60</magazineCapacity>
		<genericAmmo>true</genericAmmo>
		<rotationSpeed>2</rotationSpeed>
		<!-- 射程與射界相關 -->
		<!-- 射擊相關 -->
		<warmUpTimer>1.5</warmUpTimer>
		<projectileOffset>1.7</projectileOffset>
		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>
			<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<!-- <li>-1</li> -->
			<li>0</li>
		</projectileShifting>
	</Vehicles.VehicleTurretDef>
	<Vehicles.VehicleTurretDef ParentName="RT_BaseLauncher">
		<defName>RT_GrenadeLauncher73</defName>
		<label>Smoke grenade launcher</label>
		<magazineCapacity>1</magazineCapacity>
		<shotSound>RT_Shot_SmokeLauncherSound</shotSound>
		<fireModes Inherit = "false">
			<li>
				<shotsPerBurst>1</shotsPerBurst>
				<ticksBetweenShots>1</ticksBetweenShots>
				<ticksBetweenBursts>4</ticksBetweenBursts>
				<spreadRadius>2</spreadRadius>
				<label>Single</label>
				<texPath>UI/Gizmos/FireRate_Single</texPath>
			</li>
		</fireModes>
	</Vehicles.VehicleTurretDef>
</Defs>