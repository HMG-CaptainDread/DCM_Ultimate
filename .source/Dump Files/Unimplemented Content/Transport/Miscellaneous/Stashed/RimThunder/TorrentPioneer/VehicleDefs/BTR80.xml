		<label>BTR80</label>
		<description>A light wheeled APC, equipped with a 14.5mm machine gun, also with smoke launchers, can upgrade to BTR80A by changing the turret.</description>
		<graphicData>
			<texPath>Vehicles/BTR80/vehicle</texPath>
			<drawSize>(3.6,7.7)</drawSize>
		</graphicData>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>9500</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(3,6)</size>
		<researchPrerequisites>
			<li>MicroelectronicsBasics</li>
		</researchPrerequisites>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
