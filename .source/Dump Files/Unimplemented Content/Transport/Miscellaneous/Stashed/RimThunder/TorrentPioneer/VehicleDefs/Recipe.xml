<Defs>

	<RecipeDef ParentName="RT_BaseVehicleRecipe">
		<defName>RT_Make_BTR80_Blueprint</defName>
		<label>assemble BTR80</label>
		<description>assemble BTR80.</description>
		<workAmount>4000</workAmount>
		<!--20000 -->
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>EngineMedium</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentFuelTank</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentTransmission</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentWheelTire</li>
					</thingDefs>
				</filter>
				<count>8</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentIndustrial</li>
					</thingDefs>
				</filter>
				<count>10</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>200</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>EngineMedium</li>
				<li>ComponentFuelTank</li>
				<li>ComponentTransmission</li>
				<li>ComponentWheelTire</li>
				<li>ComponentIndustrial</li>
				<li>Steel</li>
			</thingDefs>
		</fixedIngredientFilter>
		<modExtensions>
			<li Class="Motorization.ModExt_RTCVehicleRecipe">
				<thing>RT_BTR80_Vehicle_Blueprint</thing>
			</li>
		</modExtensions>
	</RecipeDef>

