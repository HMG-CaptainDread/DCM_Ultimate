<?xml version="1.0" encoding="UTF-8"?>
<Defs>

	<Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild">
		<!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_Churchill_Vehicle_Blueprint</defName>
		<label>Churchill VII</label>
		<description>An infantry tank with heavy armor, slow but deadly, equipped with a 75mm gun and 2 7.92mm machine gun, can upgrade to Churchill AVRE by changing the Petard launcher.</description>
		<graphicData>
			<texPath>Vehicles/Churchill/vehicle</texPath>
			<drawSize>(6.8,6.8)</drawSize>
		</graphicData>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>16000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(3,7)</size>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		<costList>
			<EngineHeavy>1</EngineHeavy>
			<ComponentFuelTank>2</ComponentFuelTank>
			<ComponentTransmission>1</ComponentTransmission>
			<ComponentWheelRoad>26</ComponentWheelRoad>
			<ComponentIndustrial>12</ComponentIndustrial>
			<Steel>350</Steel>
		</costList>
		<thingToSpawn>RT_Churchill_Vehicle</thingToSpawn>
		<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

