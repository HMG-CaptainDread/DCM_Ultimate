	<!-- 主砲的Def -->
	<Vehicles.VehicleTurretDef ParentName="RT_BaseTurret">
		<defName>RT_Churchill_Tank_Turret</defName>
		<label>main turret</label>
		<!-- 炮塔图标 -->
		<gizmoIconTexPath>Vehicles/Churchill/vehicle_turret_full</gizmoIconTexPath>
		<!-- 炮塔部分 -->
		<graphicData>
			<texPath>Vehicles/Churchill/vehicle_turret</texPath>
			<graphicClass>Vehicles.Graphic_Turret</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType> 
			<drawSize>(8.4,8.4)</drawSize>
			<layer>0</layer>
		</graphicData>
		<!-- 炮管后座部分 -->
		<graphics>
			<li>
				<graphicData>
					<texPath>Vehicles/Churchill/vehicle_barrel</texPath>
					<drawSize>(8.4,8.4)</drawSize>
					<graphicClass>Vehicles.Graphic_Turret</graphicClass>
					<shaderType>CutoutComplexPattern</shaderType>
				</graphicData>
				<recoil>
					<distanceTotal>0.35</distanceTotal>
					<distancePerTick>0.05</distancePerTick>
					<speedMultiplierPostRecoil>0.1</speedMultiplierPostRecoil>
				</recoil>
			</li>	
		</graphics>
		
		<!-- 彈藥與裝填容量相關 -->
		<reloadTimer>5</reloadTimer>
		<reloadTimerMultiplierPerCrewCount>
			<points>
				<li>(1, 1.5)</li>
				<li>(2, 1)</li>
			</points>
		</reloadTimerMultiplierPerCrewCount>
		<magazineCapacity>1</magazineCapacity>
		<chargePerAmmoCount>5</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<ammunition>
			<thingDefs>
				<li>Steel</li>
			</thingDefs>
		</ammunition>
		<!-- 射程與射界相關 -->
		<minRange>2</minRange>
		<maxRange>40.9</maxRange>
		<rotationSpeed>1.0</rotationSpeed>
		<!-- 射擊相關 -->
		<warmUpTimer>2</warmUpTimer>
		<shotSound>RT_Shot_QF5Sound</shotSound>
		<reloadSound>RT_ManpowerReloadSound</reloadSound>
		<projectile>RT_Bullet_5Pounds</projectile>
		<projectileOffset>4.6</projectileOffset>
		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>
			<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<li>0</li>
		</projectileShifting>
		<!-- 炮口製退動畫 -->

		<!-- 射擊模式 -->
		<fireModes>
			<li>
				<shotsPerBurst>1</shotsPerBurst>
				<ticksBetweenBursts>1</ticksBetweenBursts>
				<spreadRadius>3</spreadRadius>
				<label>Single Shot</label>
				<texPath>UI/Gizmos/FireRate_Single</texPath>
			</li>
		</fireModes>
		<motes>
			<li>
				<cycles>1</cycles>
				<moteDef>Mote_CannonPlume</moteDef>
				<animationType>Reset</animationType>
				<offset>(0,0,4.0)</offset>
			</li>
		</motes>
	</Vehicles.VehicleTurretDef>

