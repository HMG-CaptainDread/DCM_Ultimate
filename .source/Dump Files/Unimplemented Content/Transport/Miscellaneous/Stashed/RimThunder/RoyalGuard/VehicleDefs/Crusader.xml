<?xml version="1.0" encoding="UTF-8"?>
<Defs>

	<Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild">
		<!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_Crusader_Vehicle_Blueprint</defName>
		<label>Crusader III</label>
		<description>A cruiser tank mainly served in desert, flexible and fast, equipped with a 57mm gun and a 7.92mm machine gun.</description>
		<graphicData>
			<texPath>Vehicles/Crusader/vehicle</texPath>
			<drawSize>(5.2,5.2)</drawSize>
		</graphicData>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>9000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(3,5)</size>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		<costList>
			<EngineMedium>1</EngineMedium>
			<ComponentFuelTank>1</ComponentFuelTank>
			<ComponentTransmission>1</ComponentTransmission>
			<ComponentWheelRoad>14</ComponentWheelRoad>
			<ComponentIndustrial>10</ComponentIndustrial>
			<Steel>180</Steel>
		</costList>
		<thingToSpawn>RT_Crusader_Vehicle</thingToSpawn>
		<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

	<!-- 載具本體 -->
	<Vehicles.VehicleDef ParentName="RT_BaseVehicle">
		<defName>RT_Crusader_Vehicle</defName>
		<label>Crusader III</label>
		<description>A cruiser tank mainly served in desert, flexible and fast, equipped with a 57mm gun and a 7.92mm machine gun.</description>
		<buildDef>RT_Crusader_Vehicle_Blueprint</buildDef>
		<graphicData>
			<texPath>Vehicles/Crusader/vehicle</texPath>
			<drawSize>(5.2,5.2)</drawSize>
		</graphicData>
		<size>(3,5)</size>
		<fillPercent>1</fillPercent>
		<vehicleCategory>Combat</vehicleCategory>
		<statBases>
			<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
			<Flammability>0</Flammability>
			<MarketValue>2450</MarketValue>
		</statBases>
		<vehicleStats>
			<Mass>1200</Mass>
			<MoveSpeed>10</MoveSpeed>
			<CargoCapacity>250</CargoCapacity>
			<RepairRate>0.5</RepairRate>
		</vehicleStats>
		<soundOneShotsOnEvent Inherit = "False">
			<li>
				<key>PawnEntered</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>PawnExited</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>IgnitionOn</key>
				<value>RT_M4A3VehicleStart</value>
			</li>
			<li>
				<key>IgnitionOff</key>
				<value>RT_M4A3VehicleStop</value>
			</li>
		</soundOneShotsOnEvent>
		<soundSustainersOnEvent Inherit="false"> 
			<li>
				<start>IgnitionOn</start>
				<stop>IgnitionOff</stop>
				<value>RT_M4A3VehicleEngine</value>
			</li>
		</soundSustainersOnEvent>
		<race>
			<baseBodySize>4</baseBodySize>
		</race>
		<properties>
			<!-- 座位與功能 -->
			<customRoadCosts AssignDefaults = "0.4"/>
			<worldSpeedMultiplier>1</worldSpeedMultiplier>
			<winterSpeedMultiplier>1</winterSpeedMultiplier>
			<customHillinessCosts>
				<SmallHills>0.2</SmallHills>
				<LargeHills>0.8</LargeHills>
				<Mountainous>1.5</Mountainous>
			</customHillinessCosts>
			<vehicleJobLimitations>
				<li>(RepairVehicle, 3)</li>
			</vehicleJobLimitations>
			<roles>
				<li>
					<key>driver</key>
					<label>driver</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<hitbox>
						<cells>
							<li>(0, 2)</li>
						</cells>
					</hitbox>
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
				</li>
				<li>
					<key>gunner</key>
					<label>gunner</label>
					<slots>2</slots>
					<slotsToOperate>1</slotsToOperate>
					<hitbox>
						<cells>
							<li>(0, 0)</li>
						</cells>
					</hitbox>
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>mainTurret</li>
						<li>coaxialMG</li>
						<li>Smoke</li>
					</turretIds>
				</li>
			</roles>
		</properties>
		<components>
			<!-- 各種零件 -->
			<!-- Internal mobile Part 內部驅動部件-->
			<li>
				<!--Engine 100-->
				<key>Engine</key>
				<label>Engine</label>
				<health>70</health>
				<priorityStatEfficiency>true</priorityStatEfficiency>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.25</chance>
						<maxHealth>0.3</maxHealth>
						<radius>3</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>		
				<hitbox>
					<cells>
						<li>(0, -1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- fuel tank 100-->
				<key>FuelTank</key>
				<label>fuel tank</label>
				<health>70</health>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_FuelLeak"/>
				</reactors>
				<hitbox>
					<cells>
						<li>(0, -1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- Gearbox 50-->
				<key>Gearbox</key>
				<label>gearbox</label>
				<health>35</health>
				<depth>Internal</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<hitbox>
					<cells>
						<li>(0, -2)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- AmmoRack 50-->
				<key>AmmoRack</key>
				<label>ammo rack</label>
				<health>35</health>
				<depth>Internal</depth>
				<hitWeight>0.2</hitWeight>
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.5</chance>
						<maxHealth>0.5</maxHealth>
						<radius>5</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>	
				<hitbox>
					<cells>
						<li>(0, 0)</li>
						<li>(0, 1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- transmission shaft 40 -->
				<key>TransmissionShaft</key>
				<label>transmission shaft</label>
				<health>28</health>
				<depth>Internal</depth>
			</li>
			<!-- External mobile Part 外部驅動部件-->
			<li>
				<!-- LeftTrack 150-->
				<key>LeftTrack</key>
				<label>left track</label>
				<health>150</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitWeight>2</hitWeight>
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Left</side>
				</hitbox>
			</li>
			<li>
				<!-- RightTrack 150-->
				<key>RightTrack</key>
				<label>right track</label>
				<health>150</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitWeight>2</hitWeight>
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Right</side>
				</hitbox>
			</li>
			<li>
				<!-- LeftRoadWheels 100-->
				<key>LeftRoadWheels</key>
				<label>left road wheels</label>
				<health>100</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Left</side>
				</hitbox>
			</li>
			<li>
				<!-- RightRoadWheels 100-->
				<key>RightRoadWheels</key>
				<label>right road wheels</label>
				<health>100</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Right</side>
				</hitbox>
			</li>
			<li>
				<!-- LeftDriveSprocket 75-->
				<key>LeftDriveSprocket</key>
				<label>left drive sprocket</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(-1, 2)</li>
					</cells>
					<!--左前-->
				</hitbox>
			</li>
			<li>
				<!-- RightDriveSprocket 75-->
				<key>RightDriveSprocket</key>
				<label>right drive sprocket</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(1, 2)</li>
					</cells>
					<!--右前-->
				</hitbox>
			</li>
			<li>
				<!-- LeftTensionerWheel 75-->
				<key>LeftTensionerWheel</key>
				<label>left tensioner wheel</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(-1, -2)</li>
					</cells>
					<!--左後-->
				</hitbox>
			</li>
			<li>
				<!-- RightTensionerWheel 75-->
				<key>RightTensionerWheel</key>
				<label>right tensioner wheel</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(1, -2)</li>
					</cells>
					<!--右後-->
				</hitbox>
			</li>
			<!-- External Platings 外部防禦部件 -->
			<li>
				<!-- FrontArmorPlating 200-->
				<key>FrontArmorPlating</key>
				<label>front armor Plating</label>
				<health>168</health>
				<depth>External</depth>
				<hitWeight>8</hitWeight>
				<armor>
					<ArmorRating_Blunt>1.00</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.8</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Front</side>
				</hitbox>
			</li>
			<li>
				<!-- LeftArmorPlating 180-->
				<key>LeftArmorPlating</key>
				<label>left armor plating</label>
				<health>151</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<armor>
					<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Left</side>
				</hitbox>
			</li>
			<li>
				<!-- RightArmorPlating 180-->
				<key>RightArmorPlating</key>
				<label>right armor plating</label>
				<health>151</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<armor>
					<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Right</side>
				</hitbox>
			</li>
			<li>
				<!-- RoofArmorPlating 150 -->
				<key>RoofArmorPlating</key>
				<label>roof armor plating</label>
				<health>168</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<hitbox><side>Body</side></hitbox>
				<armor>
					<ArmorRating_Blunt>0.9</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.7</ArmorRating_Sharp>
				</armor>
			</li>
			<li>
				<!-- BackArmorPlating 150-->
				<key>BackArmorPlating</key>
				<label>rear armor plating</label>
				<health>126</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<armor>
					<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Back</side>
				</hitbox>
			</li>
			<!-- 炮塔-->
			<li>
				<!-- mainTurret 250-->
				<key>MainTurret</key>
				<label>Main Turret</label>
				<health>168</health>
				<depth>External</depth>
				<hitWeight>6</hitWeight>
				<armor>
					<ArmorRating_Blunt>1.00</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.8</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<cells>
						<li>(-1, 1)</li>
						<li>(-1, 0)</li>
						<li>(0, 1)</li>
						<li>(1, 1)</li>
						<li>(0, 0)</li>
						<li>(1, 0)</li>
					</cells>
				</hitbox>
			</li>
		</components>
		<comps>
			<li Class="Vehicles.CompProperties_FueledTravel">
				<!-- 油箱與油耗 -->
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>20</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>0.8</fuelConsumptionWorldMultiplier>
				<fuelCapacity>120</fuelCapacity>
			</li>
			<li Class="Vehicles.CompProperties_VehicleTurrets">
				<!-- 砲塔 -->
				<turrets>
					<li>
						<turretDef>RT_Crusader_Tank_Turret</turretDef>
						<renderProperties>
							<north>(0, 0.45)</north>
							<south>(0, -0.1)</south>
							<east>(0.26, 0.3)</east>
							<west>(-0.26, 0.3)</west>
						</renderProperties>

						<gizmoLabel>Main Turret</gizmoLabel>
						<aimPieOffset>(0, 2)</aimPieOffset>
						<!-- 預熱指示器的x,z偏移 -->
						<drawLayer>1</drawLayer>
						<key>mainTurret</key>
						<component>
							<key>MainTurret</key>
							<healthPercent>0.01</healthPercent>
						</component>
					</li>

					<li>
						<!--同轴机枪-->
						<turretDef>RT_BESA_MGTurret</turretDef>
						<renderProperties>
							<north>(0.26,1.10)</north>
							<south>(-0.26,-1.10)</south>
							<east>(1.10,-0.26)</east>
							<west>(-1.10,0.26)</west>
						</renderProperties>
						<gizmoLabel>coaxial MG</gizmoLabel>
						<angleRestricted>(345,15)</angleRestricted>
						<aimPieOffset>(0, 0)</aimPieOffset>
						<key>coaxialMG</key>
						<drawLayer>2</drawLayer>
						<parentKey>mainTurret</parentKey>
						<component>
							<key>MainTurret</key>
							<healthPercent>0.01</healthPercent>
						</component>
					</li>
					<li>
						<turretDef>RT_GrenadeLauncherGB</turretDef>
						<gizmoLabel>Grenade Launcher</gizmoLabel>
						<renderProperties>
							<north>(1.1, 0.55)</north>
							<south>(-1.1, -0.55)</south>
							<east>(0.55, -1.1)</east>
							<west>(-0.55, 1.1)</west>
						</renderProperties>
						<aimPieOffset>(0, 0)</aimPieOffset>
						<drawLayer>2</drawLayer>
						<key>Smoke</key>
					</li>
				</turrets>
			</li>
		</comps>
	</Vehicles.VehicleDef>

	<!-- 主砲的Def -->
	<Vehicles.VehicleTurretDef ParentName="RT_BaseTurret">
		<defName>RT_Crusader_Tank_Turret</defName>
		<label>main turret</label>
		<!-- 炮塔图标 -->
		<gizmoIconTexPath>Vehicles/Crusader/vehicle_turret_full</gizmoIconTexPath>
		<!-- 炮塔部分 -->
		<graphicData>
			<texPath>Vehicles/Crusader/vehicle_turret</texPath>
			<graphicClass>Vehicles.Graphic_Turret</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType> 
			<drawSize>(5,5)</drawSize>
			<layer>0</layer>
		</graphicData>
		<!-- 炮管后座部分 -->
		<graphics>
			<li>
				<graphicData>
					<texPath>Vehicles/Crusader/vehicle_barrel</texPath>
					<drawSize>(5,5)</drawSize>
					<graphicClass>Vehicles.Graphic_Turret</graphicClass>
					<shaderType>CutoutComplexPattern</shaderType>
					<layer>2</layer>
				</graphicData>
				<recoil>
					<distanceTotal>0.25</distanceTotal>
					<distancePerTick>0.05</distancePerTick>
					<speedMultiplierPostRecoil>0.1</speedMultiplierPostRecoil>
				</recoil>
			</li>	
		</graphics>
		
		<!-- 彈藥與裝填容量相關 -->
		<reloadTimer>4</reloadTimer>
		<reloadTimerMultiplierPerCrewCount>
			<points>
				<li>(1, 1.5)</li>
				<li>(2, 1)</li>
			</points>
		</reloadTimerMultiplierPerCrewCount>
		<magazineCapacity>1</magazineCapacity>
		<chargePerAmmoCount>5</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<ammunition>
			<thingDefs>
				<li>Steel</li>
			</thingDefs>
		</ammunition>
		<!-- 射程與射界相關 -->
		<minRange>2</minRange>
		<maxRange>40.9</maxRange>
		<rotationSpeed>1</rotationSpeed>
		<!-- 射擊相關 -->
		<warmUpTimer>2</warmUpTimer>
		<shotSound>RT_Shot_QF6Sound</shotSound>
		<reloadSound>RT_ManpowerReloadSound</reloadSound>
		<projectile>RT_Bullet_CrusaderShell</projectile>
		<projectileOffset>3.28</projectileOffset>
		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>
			<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<li>0</li>
		</projectileShifting>
		<!-- 炮口製退動畫 -->

		<!-- 射擊模式 -->
		<fireModes>
			<li>
				<shotsPerBurst>1</shotsPerBurst>
				<ticksBetweenBursts>1</ticksBetweenBursts>
				<spreadRadius>3</spreadRadius>
				<label>Single Shot</label>
				<texPath>UI/Gizmos/FireRate_Single</texPath>
			</li>
		</fireModes>
		<motes>
			<li>
				<cycles>1</cycles>
				<moteDef>Mote_CannonPlume</moteDef>
				<animationType>Reset</animationType>
				<offset>(0,0,3.28)</offset>
			</li>
		</motes>
	</Vehicles.VehicleTurretDef>

	<!-- 主砲的投射物 -->
	<ThingDef ParentName="BaseBullet">
		<defName>RT_Bullet_CrusaderShell</defName>
		<label>high-explosive shell</label>
		<thingClass>Projectile_Explosive</thingClass>
		<graphicData>
			<texPath>Things/Projectile/Bullet_Big</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>2</drawSize>
		</graphicData>
		<projectile>
			<damageDef>Bomb</damageDef>
			<damageAmountBase>64</damageAmountBase>
			<armorPenetrationBase>0.6</armorPenetrationBase>
			<speed>75</speed>
			<explosionRadius>2.9</explosionRadius>
			<soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
			<soundExplode>Explosion_GiantBomb</soundExplode>
			<soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
			<soundAmbient>MortarRound_Ambient</soundAmbient>
		</projectile>
	</ThingDef>
</Defs>