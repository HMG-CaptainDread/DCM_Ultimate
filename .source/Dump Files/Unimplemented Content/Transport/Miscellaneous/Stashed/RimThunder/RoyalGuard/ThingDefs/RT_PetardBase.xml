<Defs>
	<ThingDef ParentName="RT_Tank_PetardBase">
		<defName>RT_Petard_HE</defName>
		<label>230mm Petard(HE)</label>
		<description>A Kind of HE shells based No.1 Demolition Bomb, provided by trade fleet for tanks from RimThunder.</description>
		<possessionCount>1</possessionCount>
		<graphicData>
			<texPath>Things/Ammo/Petard/HE</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>3.9</explosiveRadius>
				<explosiveDamageType>Bomb</explosiveDamageType>
				<explosiveExpandPerStackcount>0.4</explosiveExpandPerStackcount>
				<startWickHitPointsPercent>0.7</startWickHitPointsPercent>
				<wickTicks>30~60</wickTicks>
			</li>
		</comps>
		<projectileWhenLoaded>RT_PetardHE_Bullet</projectileWhenLoaded>
		<costList>
			<Steel>15</Steel>
			<Chemfuel>30</Chemfuel>
		</costList>
		<recipeMaker>
			<researchPrerequisite>Mortars</researchPrerequisite>
		</recipeMaker>
	</ThingDef>

	<ThingDef ParentName="BaseBullet">
		<defName>RT_PetardHE_Bullet</defName>
		<label>high-explosive shell</label>
		<graphicData>
			<texPath>Things/Projectile/Petard/HE</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<thingClass>Projectile_Explosive</thingClass>
		<projectile>
			<damageDef>Thump</damageDef>
			<damageAmountBase>180</damageAmountBase>
			<speed>40</speed>
			<flyOverhead>true</flyOverhead>
			<explosionRadius>5.9</explosionRadius>
			<soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
			<soundExplode>Explosion_GiantBomb</soundExplode>
			<soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
			<soundAmbient>MortarRound_Ambient</soundAmbient>
		</projectile>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>4.9</explosiveRadius>
				<explosiveDamageType>Stun</explosiveDamageType>
				<damageAmountBase>16</damageAmountBase>
				<explodeOnDestroyed>true</explodeOnDestroyed>
				<explodeOnKilled>true</explodeOnKilled>
				<applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
			</li>
		</comps>
	</ThingDef>

