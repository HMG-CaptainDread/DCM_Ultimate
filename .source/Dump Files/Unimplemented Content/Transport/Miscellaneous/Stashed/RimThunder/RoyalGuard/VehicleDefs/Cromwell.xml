		<comps>
			<li Class="Vehicles.CompProperties_FueledTravel">
				<!-- 油箱與油耗 -->
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>28</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>1</fuelConsumptionWorldMultiplier>
				<fuelCapacity>160</fuelCapacity>
			</li>
			<li Class="Vehicles.CompProperties_VehicleTurrets">
				<!-- 砲塔 -->
				<turrets>
					<li>
						<turretDef>RT_Cromwell_Turret</turretDef>
						<renderProperties>
							<north>(0,0.55)</north>
							<south>(0, 0)</south>
							<east>(0.35,0.3)</east>
							<west>(-0.35,0.3)</west>
						</renderProperties>
						<gizmoLabel>Main Turret</gizmoLabel>
						<aimPieOffset>(0, 2.4)</aimPieOffset>
						<!-- 預熱指示器的x,z偏移 -->
						<drawLayer>1</drawLayer>
						<key>mainTurret</key>
						<component>
							<key>MainTurret</key>
							<healthPercent>0.01</healthPercent>
						</component>
					</li>
					<li>
						<!--航向機槍-->
						<turretDef>RT_BESA_MGTurret</turretDef>
						<renderProperties>
							<!--這裡的坐標系是無視旋轉的,所以x就是恆定左右偏移-->
