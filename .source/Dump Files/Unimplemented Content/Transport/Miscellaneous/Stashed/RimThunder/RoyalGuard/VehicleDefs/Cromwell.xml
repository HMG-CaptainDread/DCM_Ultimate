				<hitbox>
					<cells>
						<li>(1,-1)</li>
						<li>(1,-2)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- Gearbox 50-->
				<key>Gearbox</key>
				<label>gearbox</label>
				<health>50</health>
				<depth>Internal</depth>
				<categories>
					<li>MoveSpeed</li>
