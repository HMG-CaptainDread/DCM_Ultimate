							<south>(0.3,-2.5)</south>
							<east>(2.5,0.3)</east>
							<west>(-2.5,-0.3)</west>
						</renderProperties>
						<gizmoLabel>hull MG</gizmoLabel>
						<angleRestricted>(315,45)</angleRestricted>
						<aimPieOffset>(0, -1)</aimPieOffset>
						<key>hullMG</key>
						<drawLayer>0</drawLayer>
					</li>
					<li>
						<turretDef>RT_BESA_MGTurret</turretDef>
						<renderProperties>
							<north>(0.25,0.70)</north>
							<south>(-0.25,-0.7)</south>
							<east>(0.7,-0.25)</east>
							<west>(-0.7,-0.25)</west>
						</renderProperties>
						<gizmoLabel>coaxialMG</gizmoLabel>
						<angleRestricted>(345,15)</angleRestricted>
						<aimPieOffset>(0, 0)</aimPieOffset>
						<key>coaxialMG</key>
						<drawLayer>1</drawLayer>
						<parentKey>mainTurret</parentKey>
						<component>
							<key>MainTurret</key>
							<healthPercent>0.01</healthPercent>
						</component>
					</li>
					<li>
						<turretDef>RT_GrenadeLauncherGB</turretDef>
						<gizmoLabel>Grenade Launcher</gizmoLabel>
						<renderProperties>
							<north>(1.1, 0.55)</north>
							<south>(-1.1, -0.55)</south>
							<east>(0.55, -1.1)</east>
							<west>(-0.55, 1.1)</west>
						</renderProperties>
						<aimPieOffset>(0, 0)</aimPieOffset>
						<drawLayer>2</drawLayer>
						<key>Smoke</key>
					</li>
				</turrets>
