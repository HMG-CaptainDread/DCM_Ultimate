				</hitbox>
			</li>
			<li>
				<!-- LeftRoadWheels 100-->
				<key>LeftRoadWheels</key>
				<label>left road wheels</label>
				<health>100</health>
				<depth>Internal</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
