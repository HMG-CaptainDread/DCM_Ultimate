<?xml version="1.0" encoding="UTF-8"?>
<Defs>

  <Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild"><!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_KV5_Vehicle_Blueprint</defName>
		<label>KV-5</label>
		<description>A super heavy tank equipped with a 107mm gun in a huge turret, you had better prepare a coffin for its radio opreator.</description>
		<graphicData>
			<texPath>Vehicles/KV5/vehicle</texPath>
			<drawSize>(7,7)</drawSize>
		</graphicData>	
		<statBases> 		
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>160000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(3,7)</size>
		<constructionSkillPrerequisite>8</constructionSkillPrerequisite>	
		<costList>
			<EngineHeavy>1</EngineHeavy>
			<ComponentFuelTank>2</ComponentFuelTank>
			<ComponentTransmission>2</ComponentTransmission>
			<ComponentWheelRoad>20</ComponentWheelRoad>
			<ComponentIndustrial>20</ComponentIndustrial>
			<Steel>450</Steel>
		</costList>
		<thingToSpawn>RT_KV5_Vehicle</thingToSpawn>	<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

	<!-- 載具本體 -->
	<Vehicles.VehicleDef ParentName="RT_BaseVehicle">
		<defName>RT_KV5_Vehicle</defName>
		<label>KV-5</label>
		<description>A super heavy tank equipped with a 107mm gun in a huge turret, you had better prepare a coffin for its radio opreator.</description>
		<buildDef>RT_KV5_Vehicle_Blueprint</buildDef>
		<graphicData>
			<texPath>Vehicles/KV5/vehicle</texPath>
			<drawSize>(7,7)</drawSize>
		</graphicData>
		<size>(3,7)</size>
		<fillPercent>1</fillPercent>
		<vehicleCategory>Combat</vehicleCategory>
		<statBases>
			<ArmorRating_Blunt>0.9</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.7</ArmorRating_Sharp>
			<Flammability>0</Flammability>
			<MarketValue>2240</MarketValue>
		</statBases>
		<vehicleStats>
			<Mass>5000</Mass>
			<MoveSpeed>8</MoveSpeed>
			<CargoCapacity>500</CargoCapacity>
			<RepairRate>1</RepairRate>
		</vehicleStats>
		<soundOneShotsOnEvent Inherit = "False">
			<li>
				<key>PawnEntered</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>PawnExited</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>IgnitionOn</key>
				<value>RT_T72VehicleStart</value>
			</li>
			<li>
				<key>IgnitionOff</key>
				<value>RT_T72VehicleStop</value>
			</li>
		</soundOneShotsOnEvent>
		<soundSustainersOnEvent Inherit="false">
			<li>
				<start>IgnitionOn</start>
				<stop>IgnitionOff</stop>
				<value>RT_T72VehicleEngine</value>
			</li>
		</soundSustainersOnEvent>
		<race>
			<baseBodySize>4</baseBodySize>
		</race>	
		<properties>	<!-- 座位與功能 -->
			<customRoadCosts AssignDefaults = "0.6"/>
			<worldSpeedMultiplier>1</worldSpeedMultiplier>
			<offRoadMultiplier>1.5</offRoadMultiplier>
			<winterSpeedMultiplier>2</winterSpeedMultiplier>
			<customHillinessCosts>
				<SmallHills>0.4</SmallHills>
				<LargeHills>1.2</LargeHills>
				<Mountainous>2.5</Mountainous>
			</customHillinessCosts>
			<vehicleJobLimitations>
				<li>(RepairVehicle, 5)</li>
			</vehicleJobLimitations>
			<roles>
				<li>
					<key>driver</key>
					<label>driver</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>				
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
				</li>				
				<li>
					<key>gunner</key>
					<label>gunner</label>
					<slots>4</slots>
					<slotsToOperate>2</slotsToOperate>			
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>mainTurret</li>
						<li>coaxialMG</li>
						<li>topMG</li>	
					</turretIds>
				</li>
				<li>
					<key>MGgunner</key>
					<label>radio operator</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>hullMG</li>
					</turretIds>
				</li>
			</roles>
		</properties>	
		<components>
		<!-- Internal mobile Part 內部驅動部件-->
			<li><!--Engine 100-->
				<key>Engine</key>
				<label>Engine</label>
				<health>100</health>
				<priorityStatEfficiency>true</priorityStatEfficiency>
				<categories><li>MoveSpeed</li></categories>
				<depth>Internal</depth>		
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.25</chance>
						<maxHealth>0.3</maxHealth>
						<radius>3</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>					
				<hitbox>
					<cells>
						<li>(0, -1)</li>
						<li>(0, -2)</li>
					</cells>
				</hitbox>				
			</li>		
			<li><!-- fuel tank 100-->
				<key>FuelTank</key>
				<label>fuel tank</label>
				<health>100</health>
				<depth>Internal</depth>			
				<reactors><li Class = "Vehicles.Reactor_FuelLeak"/></reactors>			
				<hitbox>
					<cells>
						<li>(0, 1)</li>
						<li>(0, 0)</li>
					</cells>
				</hitbox>	
			</li>
			<li><!-- Gearbox 50-->
				<key>Gearbox</key>
				<label>gearbox</label>
				<health>50</health>
				<depth>Internal</depth>
				<categories><li>MoveSpeed</li></categories>	
				<hitbox><cells><li>(0, -3)</li></cells></hitbox>			
			</li>
			<li><!-- AmmoRack 50-->
