					<li>
						<turretDef>KV5_Tank_Turret</turretDef>					
						<renderProperties>
							<north>(0, 0.55)</north>
							<south>(0, 0)</south>
							<east>(0.6,0.3)</east>
							<west>(-0.6,0.3)</west>
						</renderProperties>
						
						<gizmoLabel>Main Turret</gizmoLabel>
						<aimPieOffset>(0, 3.2)</aimPieOffset>	<!-- 預熱指示器的x,z偏移 -->
						<drawLayer>1</drawLayer>						
						<key>mainTurret</key>
					</li>

					<li>
						<!--同軸機槍-->
						<turretDef>RT_DT_Turret_b</turretDef>
						 <renderProperties><!--這裡的坐標系是無視旋轉的,所以x就是恆定左右偏移-->	
                            <north>(-0.4,0.8)</north>
                            <south>(0.4,-0.8)</south>
                            <east>(0.8,0.4)</east>
                            <west>(-0.8,0.4)</west>
                        </renderProperties>
						<gizmoLabel>coaxial MG</gizmoLabel>
						<angleRestricted>(345,15)</angleRestricted>
						<aimPieOffset>(0, 0)</aimPieOffset>
						<key>coaxialMG</key>
						<drawLayer>0</drawLayer>
						<parentKey>mainTurret</parentKey>
					</li>

					<li>
						<!--同軸機槍-->
						<turretDef>RT_KV5_Turret_a</turretDef>
						 <renderProperties><!--這裡的坐標系是無視旋轉的,所以x就是恆定左右偏移-->	
