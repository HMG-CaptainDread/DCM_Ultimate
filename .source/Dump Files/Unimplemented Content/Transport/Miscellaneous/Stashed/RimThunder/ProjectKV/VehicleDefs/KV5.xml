                            <south>(-0.4,-1.7)</south>
                            <east>(2.15,-0.15)</east>
                            <west>(-0.8,0.4)</west>
                        </renderProperties>
						<gizmoLabel>hull MG</gizmoLabel>
						<angleRestricted>(180,0)</angleRestricted>
						<aimPieOffset>(0, 0)</aimPieOffset>
						<key>hullMG</key>
						<drawLayer>0</drawLayer>
					</li>

					<li>
						<!--同軸機槍-->
						<turretDef>RT_KV5_Turret_b</turretDef>
						 <renderProperties><!--這裡的坐標系是無視旋轉的,所以x就是恆定左右偏移-->	
