  <Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild"><!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_T14_MainBattleTank_Blueprint</defName>
		<label>T-14 "Armata"</label>
		<description>The T-14 "Armata" main battle tank is a new generation of main battle tank in the Russian Federation, with unparalleled protection and advanced digital command system. The Unmanned turret is equipped with the invincible 2A82 main gun.</description>
		<graphicData>
			<texPath>Vehicles/T14/Vehicle</texPath>
			<drawSize>(8.2,8.2)</drawSize>
		</graphicData>	
		<statBases> 		
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>120000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<researchPrerequisites Inherit="False">
		  <li>Fabrication</li>
	  	</researchPrerequisites>
		<size>(4,8)</size>
		<constructionSkillPrerequisite>12</constructionSkillPrerequisite>
		<costList>
			<EngineHeavy>1</EngineHeavy>
			<ComponentFuelTank>4</ComponentFuelTank>
			<ComponentTransmission>4</ComponentTransmission>
			<ComponentWheelRoad>18</ComponentWheelRoad>
