			<ComponentHeavyCasting>6</ComponentHeavyCasting>
			<Steel>500</Steel>
			<Plasteel>350</Plasteel>
		</costList>
		<thingToSpawn>RT_T14_MainBattleTank</thingToSpawn>	<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

