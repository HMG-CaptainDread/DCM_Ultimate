			<ComponentHeavyCasting>4</ComponentHeavyCasting>
			<Steel>400</Steel>
			<Plasteel>270</Plasteel>
		</costList>
		<thingToSpawn>RT_T15_Vehicle</thingToSpawn>	<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

