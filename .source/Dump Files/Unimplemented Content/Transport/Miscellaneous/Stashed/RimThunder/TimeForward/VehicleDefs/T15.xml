  <Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild"><!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_T15_IFV_Blueprint</defName>
		<label>T-15 "Armata"</label>
		<description>The T-15 "Armata" IFV is a new generation of unique medium-sized tracked in the Russian Federation, with unparalleled protection and advanced digital command system. capable of adapting to a variety of turret modules.</description>
		<graphicData>
			<texPath>Vehicles/T15/Vehicle</texPath>
			<drawSize>(9.4,9.4)</drawSize>
		</graphicData>	
		<statBases> 		
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>120000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<researchPrerequisites Inherit="False">
		  <li>Fabrication</li>
	  	</researchPrerequisites>
		<size>(4,8)</size>
		<constructionSkillPrerequisite>12</constructionSkillPrerequisite>	
		<costList>
			<EngineHeavy>1</EngineHeavy>
			<ComponentFuelTank>4</ComponentFuelTank>
			<ComponentTransmission>4</ComponentTransmission>
			<ComponentWheelRoad>18</ComponentWheelRoad>
			<ComponentSpacer>2</ComponentSpacer>
