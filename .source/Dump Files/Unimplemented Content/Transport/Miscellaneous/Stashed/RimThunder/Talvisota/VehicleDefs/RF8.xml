<?xml version="1.0" encoding="UTF-8"?>
<Defs>

	<Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild">
		<!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_RF8_Vehicle_Blueprint</defName>
		<label>NKL-26</label>
		<description>An armored aerosan equipped with a 7.62mm MG, used to cover and transport ski infantry in snow.</description>
		<graphicData>
			<texPath>Vehicles/RF8/vehicle</texPath>
			<drawSize>(4,4)</drawSize>
		</graphicData>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>30000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(2,4)</size>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		<costList>
			<EngineLight>1</EngineLight>
			<ComponentFuelTank>1</ComponentFuelTank>
			<ComponentTransmission>1</ComponentTransmission>
			<ComponentIndustrial>5</ComponentIndustrial>
			<Steel>30</Steel>
			<WoodLog>150</WoodLog>
		</costList>
		<thingToSpawn>RT_RF8_Vehicle</thingToSpawn>
		<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

	<!-- 載具本體 -->
	<Vehicles.VehicleDef ParentName="RT_BaseVehicle">
		<defName>RT_RF8_Vehicle</defName>
		<label>NKL-26</label>
		<description>An armored aerosan equipped with a 7.62mm MG, used to cover and transport ski infantry in snow.</description>
		<buildDef>RT_RF8_Vehicle_Blueprint</buildDef>
		<graphicData>
			<texPath>Vehicles/RF8/vehicle</texPath>
			<drawSize>(4,4)</drawSize>
		</graphicData>
		<size>(2,4)</size>
		<fillPercent>1</fillPercent>
		<vehicleCategory>Combat</vehicleCategory>
		<statBases>
			<ArmorRating_Blunt>0.6</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.45</ArmorRating_Sharp>
			<Flammability>0</Flammability>
			<MarketValue>4150</MarketValue>
		</statBases>
		<vehicleStats>
			<Mass>2200</Mass>
			<MoveSpeed>8</MoveSpeed>
			<CargoCapacity>400</CargoCapacity>
			<RepairRate>0.4</RepairRate>
		</vehicleStats>
		<race>
			<baseBodySize>4</baseBodySize>
		</race>
		<properties>
			<!-- 座位與功能 -->
			<customBiomeCosts>
				<li>
					<key>Tundra</key>
					<value>1</value>
				</li>
				<li>
					<key>IceSheet</key>
					<value>1</value>
				</li>
				<li>
					<key>SeaIce</key>
					<value>1</value>
				</li>
				<li>
					<key>BorealForest</key>
					<value>2</value>
				</li>
				<li>
					<key>TemperateForest</key>
					<value>2</value>
				</li>
				<li>
					<key>TropicalRainforest</key>
					<value>4</value>
				</li>
				<li>
					<key>AridShrubland</key>
					<value>1.5</value>
				</li>
			</customBiomeCosts>
			<customTerrainCosts AllowTerrainWithTag="Soil" PathCost="1">
				<li>
					<key>Soil</key>
					<value>4</value>
				</li>
				<li>
					<key>SoilRich</key>
					<value>4</value>
				</li>
				<li>
					<key>Gravel</key>
					<value>4</value>
				</li>
				<li>
					<key>MossyTerrain</key>
					<value>6</value>
				</li>
				<li>
					<key>MarshyTerrain</key>
					<value>20</value>
				</li>
				<li>
					<key>Sand</key>
					<value>2</value>
				</li>
				<li>
					<key>SoftSand</key>
					<value>2</value>
				</li>
				<li>
					<key>Mud</key>
					<value>2</value>
				</li>
				<li>
					<key>Ice</key>
					<value>2</value>
				</li>
			</customTerrainCosts>
			<customHillinessCosts>
				<SmallHills>0.4</SmallHills>
				<LargeHills>1.2</LargeHills>
			</customHillinessCosts>
			<customSnowCategoryTicks AssignDefaults = "0"/>
			<customRoadCosts AssignDefaults = "0.4"/>
			<winterSpeedMultiplier>0</winterSpeedMultiplier>
			<worldSpeedMultiplier>1</worldSpeedMultiplier>
			<offRoadMultiplier>1.2</offRoadMultiplier>
			<vehicleJobLimitations>
				<li>(RepairVehicle, 2)</li>
			</vehicleJobLimitations>
			<roles>
				<li>
					<key>driver</key>
					<label>driver</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<hitbox>
						<cells>
							<li>(0, 1)</li>
						</cells>
					</hitbox>
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
				</li>
				<li>
					<key>gunner</key>
					<label>gunner</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<handlingTypes>Turret</handlingTypes>
					<hitbox>
						<cells>
							<li>(0, 0)</li>
						</cells>
					</hitbox>
					<turretIds>
						<li>mainTurret</li>
					</turretIds>
				</li>
			</roles>
		</properties>
		<components>
			<!-- 各種零件 -->
			<!-- Internal mobile Part 內部驅動部件-->
			<li>
				<!--Engine 100-->
				<key>Engine</key>
				<label>Engine</label>
				<health>50</health>
				<priorityStatEfficiency>true</priorityStatEfficiency>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.25</chance>
						<maxHealth>0.3</maxHealth>
						<radius>3</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>		
				<hitbox>
					<cells>
						<li>(0, -1)</li>
						<li>(1, -1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- fuel tank 100-->
				<key>FuelTank</key>
				<label>fuel tank</label>
				<health>50</health>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_FuelLeak"/>
				</reactors>
				<hitbox>
					<cells>
						<li>(1, -1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- Gearbox 50-->
				<key>Gearbox</key>
				<label>gearbox</label>
				<health>25</health>
				<depth>Internal</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<hitbox>
					<cells>
						<li>(0, -1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- transmission shaft 40 -->
				<key>TransmissionShaft</key>
				<label>transmission shaft</label>
				<health>20</health>
				<depth>Internal</depth>
			</li>
			<!-- External mobile Part 外部驅動部件-->
			<li>
				<!-- LeftTrack 150-->
				<key>LeftFrontSki</key>
				<label>left front ski</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitWeight>2</hitWeight>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(0, 1)</li>
						<li>(0, 2)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- RightTrack 150-->
				<key>RightFrontSki</key>
				<label>right front ski</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitWeight>2</hitWeight>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(1, 1)</li>
						<li>(1, 2)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- LeftRoadWheels 100-->
				<key>LeftRearSki</key>
				<label>left rear ski</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(0, -1)</li>
						<li>(0, 0)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- RightRoadWheels 100-->
				<key>RightRearSki</key>
				<label>right rear ski</label>
				<health>75</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(1, -1)</li>
						<li>(1, 0)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- LeftDriveSprocket 75-->
				<key>LeftFrontSuspension</key>
				<label>left front suspension</label>
				<health>50</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(0, 1)</li>
					</cells>
					<!--左前-->
				</hitbox>
			</li>
			<li>
				<!-- RightDriveSprocket 75-->
				<key>RightFrontSuspension</key>
				<label>right front suspension</label>
				<health>50</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(1, 1)</li>
					</cells>
					<!--右前-->
				</hitbox>
			</li>
			<li>
				<!-- LeftTensionerWheel 75-->
				<key>LeftRearSuspension</key>
				<label>left rear suspension</label>
				<health>50</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(0, 0)</li>
					</cells>
					<!--左後-->
				</hitbox>
			</li>
			<li>
				<!-- RightTensionerWheel 75-->
				<key>RightRearSuspension</key>
				<label>right rear suspension</label>
				<health>50</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(1, 0)</li>
					</cells>
					<!--右後-->
				</hitbox>
			</li>
			<!-- External Platings 外部防禦部件 -->
			<li>
				<!-- FrontArmorPlating 200-->
				<key>FrontArmorPlating</key>
				<label>front armor Plating</label>
				<health>120</health>
				<depth>External</depth>
				<hitWeight>8</hitWeight>
				<armor>
					<ArmorRating_Blunt>1.0</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.8</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Front</side>
				</hitbox>
			</li>
			<li>
				<!-- LeftArmorPlating 180-->
				<key>LeftArmorPlating</key>
				<label>left armor plating</label>
				<health>108</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<armor>
					<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Left</side>
				</hitbox>
			</li>
			<li>
				<!-- RightArmorPlating 180-->
				<key>RightArmorPlating</key>
				<label>right armor plating</label>
				<health>108</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<armor>
					<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Right</side>
				</hitbox>
			</li>
			<li>
				<!-- RoofArmorPlating 150 -->
				<key>RoofArmorPlating</key>
				<label>roof armor plating</label>
				<health>80</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<hitbox>
					<side>Body</side>
				</hitbox>
			</li>
			<li>
				<!-- BackArmorPlating 150-->
				<key>BackArmorPlating</key>
				<label>rear armor plating</label>
				<health>80</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<hitbox>
					<side>Back</side>
				</hitbox>
			</li>
		</components>
		<comps>
			<li Class="Vehicles.CompProperties_FueledTravel">
				<!-- 油箱與油耗 -->
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>20</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>0.8</fuelConsumptionWorldMultiplier>
				<fuelCapacity>100</fuelCapacity>
			</li>
			<li Class="Vehicles.CompProperties_VehicleTurrets">
				<!-- 砲塔 -->
				<turrets>
					<li>
						<!--航向机枪-->
						<turretDef>RT_DT_Turret_c</turretDef>
						<renderProperties>
							<north>(0,0.9)</north>
							<south>(0,-0.3)</south>
							<east>(0.6,0.45)</east>
							<west>(-0.6,0.45)</west>
						</renderProperties>
						<gizmoLabel>main Turret</gizmoLabel>
						<angleRestricted>(300,60)</angleRestricted>
						<aimPieOffset>(0, 0)</aimPieOffset>
						<key>mainTurret</key>
						<drawLayer>0</drawLayer>
					</li>
				</turrets>
			</li>
		</comps>
	</Vehicles.VehicleDef>
</Defs>