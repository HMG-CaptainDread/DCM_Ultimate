<?xml version="1.0" encoding="UTF-8"?>
<Defs>

	<Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild">
		<!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_T34_Vehicle_Blueprint</defName>
		<label>T-34 Obr.1940</label>
		<description>A medium tank with sloped armor and good productivity, equipped with a 76mm gun, have various upgrades for different needs.</description>
		<graphicData>
			<texPath>Vehicles/T34/vehicle</texPath>
			<drawSize>(5.6,5.6)</drawSize>
		</graphicData>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>50000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(3,5)</size>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		<costList>
			<EngineHeavy>1</EngineHeavy>
			<ComponentFuelTank>2</ComponentFuelTank>
			<ComponentTransmission>1</ComponentTransmission>
			<ComponentWheelRoad>14</ComponentWheelRoad>
			<ComponentIndustrial>10</ComponentIndustrial>
			<Steel>200</Steel>
		</costList>
		<thingToSpawn>RT_T34_Vehicle</thingToSpawn>
		<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

