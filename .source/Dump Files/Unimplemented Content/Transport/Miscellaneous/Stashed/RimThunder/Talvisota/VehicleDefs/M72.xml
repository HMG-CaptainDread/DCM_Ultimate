<?xml version="1.0" encoding="UTF-8"?>
<Defs>

	<Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild">
		<!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_M72_Vehicle_Blueprint</defName>
		<label>M-72</label>
		<description>A sidecar without armament, usually used in short range transport.</description>
		<graphicData>
			<texPath>Vehicles/M72/vehicle</texPath>
			<drawSize>(3,3)</drawSize>
		</graphicData>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>10000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(1,2)</size>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		<costList>
			<EngineLight>1</EngineLight>
			<ComponentFuelTank>1</ComponentFuelTank>
			<ComponentTransmission>1</ComponentTransmission>
			<ComponentWheelTire>3</ComponentWheelTire>
			<ComponentIndustrial>2</ComponentIndustrial>
			<Steel>50</Steel>
		</costList>
		<thingToSpawn>RT_M72_Vehicle</thingToSpawn>
		<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

	<!-- 載具本體 -->
	<Vehicles.VehicleDef ParentName="RT_BaseVehicle">
		<defName>RT_M72_Vehicle</defName>
		<label>M-72</label>
		<description>A sidecar without armament, usually used in short range transport.</description>
		<buildDef>RT_M72_Vehicle_Blueprint</buildDef>
		<graphicData>
			<texPath>Vehicles/M72/vehicle</texPath>
			<drawSize>(3,3)</drawSize>
		</graphicData>
		<size>(1,2)</size>
		<fillPercent>1</fillPercent>
		<vehicleCategory>Combat</vehicleCategory>
		<statBases>
			<ArmorRating_Blunt>0.3</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.2</ArmorRating_Sharp>
			<Flammability>0</Flammability>
			<MarketValue>4150</MarketValue>
		</statBases>
		<vehicleStats>
			<Mass>200</Mass>
			<MoveSpeed>12</MoveSpeed>
			<CargoCapacity>200</CargoCapacity>
			<RepairRate>0.4</RepairRate>
		</vehicleStats>
		<race>
			<baseBodySize>4</baseBodySize>
		</race>
		<properties>
			<diagonalRotation>false</diagonalRotation>
			<customRoadCosts AssignDefaults = "0.4"/>
			<worldSpeedMultiplier>1</worldSpeedMultiplier>
			<offRoadMultiplier>2</offRoadMultiplier>
			<winterSpeedMultiplier>2</winterSpeedMultiplier>
			<vehicleJobLimitations>
				<li>(RepairVehicle, 3)</li>
			</vehicleJobLimitations>
			<roles>
				<li>
					<key>driver</key>
					<label>driver</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<hitbox>
						<cells>
							<li>(0, 1)</li>
						</cells>
					</hitbox>
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
					<pawnRenderer>
						<layerEast>1</layerEast>
						<layerWest>1</layerWest>
						<layerNorth>1</layerNorth>
						<layerSouth>-1</layerSouth>
						<angleNorth>0</angleNorth>
						<angleEast>0</angleEast>
						<angleNorthEast>0</angleNorthEast>
						<angleSouthEast>0</angleSouthEast>
						<drawOffsetNorth>(-0.5,0,0.6)</drawOffsetNorth>
						<drawOffsetSouth>(0.4,0,0.9)</drawOffsetSouth>
						<drawOffsetEast>(0.1,0,0.7)</drawOffsetEast>
						<drawOffsetWest>(-0.1,0,0.25)</drawOffsetWest>
					</pawnRenderer>
				</li>
				<li>
					<key>gunner</key>
					<label>passengerA</label>
					<slots>1</slots>
					<hitbox>
						<cells>
							<li>(0, 0)</li>
						</cells>
					</hitbox>
					<pawnRenderer>
						<layer>1</layer>
						<layerNorth>-1</layerNorth>
						<layerSouth>-1</layerSouth>
						<angleNorth>0</angleNorth>
						<angleEast>0</angleEast>
						<angleNorthEast>0</angleNorthEast>
						<angleSouthEast>0</angleSouthEast>
						<drawOffsetNorth>(0.2,0,0.3)</drawOffsetNorth>
						<drawOffsetSouth>(-0.25,0,0.3)</drawOffsetSouth>
						<drawOffsetEast>(-0.1,0,0.25)</drawOffsetEast>
						<drawOffsetWest>(0.1,0,0.7)</drawOffsetWest>
					</pawnRenderer>
				</li>
				<li>
					<key>passenger</key>
					<label>passengerB</label>
					<slots>1</slots>
					<hitbox>
						<cells>
							<li>(0, 0)</li>
						</cells>
					</hitbox>
					<pawnRenderer>
						<layer>1</layer>
						<layerNorth>1</layerNorth>
						<layerSouth>-1</layerSouth>
						<angleNorth>0</angleNorth>
						<angleEast>0</angleEast>
						<angleNorthEast>0</angleNorthEast>
						<angleSouthEast>0</angleSouthEast>
						<drawOffsetNorth>(-0.5,0,0.3)</drawOffsetNorth>
						<drawOffsetSouth>(0.4,0,0.6)</drawOffsetSouth>
						<drawOffsetEast>(-0.45,0,0.7)</drawOffsetEast>
						<drawOffsetWest>(0.45,0,0.25)</drawOffsetWest>
					</pawnRenderer>
				</li>
			</roles>
		</properties>
		<components>
			<!-- 各種零件 -->
			<!-- Internal mobile Part 內部驅動部件-->
			<li>
				<!--Engine 100-->
				<key>Engine</key>
				<label>Engine</label>
				<health>50</health>
				<priorityStatEfficiency>true</priorityStatEfficiency>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.25</chance>
						<maxHealth>0.3</maxHealth>
						<radius>3</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>		
				<hitbox>
					<cells>
						<li>(0, 1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- fuel tank 100-->
				<key>FuelTank</key>
				<label>fuel tank</label>
				<health>50</health>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_FuelLeak"/>
				</reactors>
				<hitbox>
					<cells>
						<li>(0, 0)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- transmission shaft 40 -->
				<key>TransmissionShaft</key>
				<label>transmission shaft</label>
				<health>20</health>
				<depth>Internal</depth>
			</li>
			<!-- External mobile Part 外部驅動部件-->
			<li>
				<!-- LeftTrack 150-->
				<key>FrontWheel</key>
				<label>front wheel</label>
				<health>30</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitWeight>2</hitWeight>
				<armor>
					<ArmorRating_Blunt>0</ArmorRating_Blunt>
					<ArmorRating_Sharp>0</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(0, 1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- RightTrack 150-->
				<key>RearWheel</key>
				<label>rear wheel</label>
				<health>30</health>
				<depth>Internal</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitWeight>2</hitWeight>
				<armor>
					<ArmorRating_Blunt>0</ArmorRating_Blunt>
					<ArmorRating_Sharp>0</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(0, 0)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- LeftRoadWheels 100-->
				<key>SideWheel</key>
				<label>side wheel</label>
				<health>30</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<armor>
					<ArmorRating_Blunt>0</ArmorRating_Blunt>
					<ArmorRating_Sharp>0</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(0, 0)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- LeftDriveSprocket 75-->
				<key>FrontSuspension</key>
				<label>front suspension</label>
				<health>30</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(0, 1)</li>
					</cells>
					<!--左前-->
				</hitbox>
			</li>
			<li>
				<!-- RightDriveSprocket 75-->
				<key>RearSuspension</key>
				<label>rear suspension</label>
				<health>30</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(0, 0)</li>
					</cells>
					<!--右前-->
				</hitbox>
			</li>
			<li>
				<!-- LeftTensionerWheel 75-->
				<key>SideSuspension</key>
				<label>side suspension</label>
				<health>30</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(0, 0)</li>
					</cells>
					<!--左後-->
				</hitbox>
			</li>
		</components>
		<comps>
			<li Class="Vehicles.CompProperties_FueledTravel">
				<!-- 油箱與油耗 -->
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>10</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>1</fuelConsumptionWorldMultiplier>
				<fuelCapacity>50</fuelCapacity>
			</li>
		</comps>
	</Vehicles.VehicleDef>
</Defs>