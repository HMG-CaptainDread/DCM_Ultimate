<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="RT_Tank_MissileBase">
		<defName>RT_HJ10H_Missile</defName>
		<label>HJ10 Missile</label>
		<description>A Kind of Heavy ATGM with strong warhead provided by trade fleet for tanks from RimThunder.</description>
		<possessionCount>1</possessionCount>
		<graphicData>
			<texPath>Things/Ammo/Ammo_HJ10</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>3.9</explosiveRadius>
				<explosiveDamageType>Bomb</explosiveDamageType>
				<explosiveExpandPerStackcount>0.4</explosiveExpandPerStackcount>
				<startWickHitPointsPercent>0.7</startWickHitPointsPercent>
				<wickTicks>30~60</wickTicks>
			</li>
		</comps>
		<projectileWhenLoaded>RT_HJ10Missile</projectileWhenLoaded>
		<costList>
			<Steel>15</Steel>
			<Chemfuel>50</Chemfuel>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>
		<recipeMaker>
			<researchPrerequisite>MicroelectronicsBasics</researchPrerequisite>
		</recipeMaker>
	</ThingDef>

	<ThingDef Class="Missile_dml._ThingDef" ParentName="BaseBullet">
		<defName>RT_HJ10Missile</defName>
		<label>HJ10 anti tank missile</label>
		<thingClass>Missile_dml.missile_dml</thingClass>
		<graphicData>
			<texPath>Things/Projectile/Ammo_HJ10</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>2</drawSize>
		</graphicData>
		<fleck>RT_RocketSmoke</fleck>
		<fleck1>RT_RocketExhaust</fleck1>
		<frequency>0</frequency>
		<scale>2.5</scale>
		<shaking>0.3</shaking>
		<searchRange>6</searchRange>
		<projectile>
			<damageDef>Bomb</damageDef>
			<damageAmountBase>325</damageAmountBase>
			<flyOverhead>true</flyOverhead>
			<armorPenetrationBase>2</armorPenetrationBase>
			<explosionRadius>5.9</explosionRadius>
			<speed>60</speed>
			<soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
			<soundExplode>Explosion_GiantBomb</soundExplode>
			<soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
			<soundAmbient>MortarRound_Ambient</soundAmbient>
		</projectile>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>4.9</explosiveRadius>
				<explosiveDamageType>Stun</explosiveDamageType>
				<damageAmountBase>16</damageAmountBase>
				<explodeOnDestroyed>true</explodeOnDestroyed>
				<explodeOnKilled>true</explodeOnKilled>
				<applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
			</li>
		</comps>
	</ThingDef>

	<RecipeDef>
		<defName>Make5HJ10H_Missile</defName>
		<label>Make HJ10 Missile x5</label>
		<description>Make HJ10 Missiles.</description>
		<jobString>Making HJ10 Missiles.</jobString>
		<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
		<effectWorking>Cook</effectWorking>
		<soundWorking>Recipe_Machining</soundWorking>
		<targetCountAdjustment>5</targetCountAdjustment>
		<workSkill>Crafting</workSkill>
		<skillRequirements>
			<Crafting>8</Crafting>
		</skillRequirements>
		<workAmount>6000</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>75</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Chemfuel</li>
					</thingDefs>
				</filter>
				<count>250</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentIndustrial</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Steel</li>
				<li>Chemfuel</li>
				<li>ComponentIndustrial</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<RT_HJ10H_Missile>5</RT_HJ10H_Missile>
		</products>
		<recipeUsers>
			<li>TableMachining</li>
		</recipeUsers>
	</RecipeDef>

</Defs>