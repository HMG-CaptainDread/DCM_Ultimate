<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="RT_ACSmallShellBase">
		<defName>RT_ACHESmall_Shell</defName>
		<label>AutoCannon HE shell</label>
		<description>A Kind of autocannon HE shells provided by trade fleet for vehicles from RimThunder.</description>
		<possessionCount>1</possessionCount>
		<graphicData>
			<texPath>Things/Item/AC/AC_HE</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>1.9</explosiveRadius>
				<explosiveDamageType>Bomb</explosiveDamageType>
				<explosiveExpandPerStackcount>0.4</explosiveExpandPerStackcount>
				<startWickHitPointsPercent>0.7</startWickHitPointsPercent>
				<wickTicks>30~60</wickTicks>
			</li>
		</comps>
		<projectileWhenLoaded>RT_ACHE_Bullet</projectileWhenLoaded>
		<costList>
			<Steel>5</Steel>
			<Chemfuel>5</Chemfuel>
		</costList>
		<recipeMaker>
			<researchPrerequisite>Mortars</researchPrerequisite>
		</recipeMaker>
	</ThingDef>

	<ThingDef ParentName="BaseBullet">
		<defName>RT_ACHE_Bullet</defName>
		<label>AutoCannon HE shell</label>
		<graphicData>
			<texPath>Things/Projectile/Bullet_Big</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<thingClass>Projectile_Explosive</thingClass>
		<projectile>
			<damageDef>Bomb</damageDef>
			<damageAmountBase>55</damageAmountBase>
			<speed>68</speed>
			<explosionRadius>2.9</explosionRadius>
			<soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
			<soundExplode>Explosion_GiantBomb</soundExplode>
			<soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
			<soundAmbient>MortarRound_Ambient</soundAmbient>
		</projectile>
	</ThingDef>

	<RecipeDef>
		<defName>Make25AC_HE_SHell</defName>
		<label>Make HE AutoCannon shell x25</label>
		<description>Make HE AutoCannon shells.</description>
		<jobString>Making HE AutoCannon shells.</jobString>
		<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
		<effectWorking>Cook</effectWorking>
		<soundWorking>Recipe_Machining</soundWorking>
		<targetCountAdjustment>5</targetCountAdjustment>
		<workSkill>Crafting</workSkill>
		<skillRequirements>
			<Crafting>6</Crafting>
		</skillRequirements>
		<workAmount>6000</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>125</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Chemfuel</li>
					</thingDefs>
				</filter>
				<count>125</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Steel</li>
				<li>Chemfuel</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<RT_ACHESmall_Shell>25</RT_ACHESmall_Shell>
		</products>
		<recipeUsers>
			<li>TableMachining</li>
		</recipeUsers>
	</RecipeDef>

