<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="RT_TCLargeShellBase">
		<defName>RT_TCHE_Shell</defName>
		<label>Tank HE shell</label>
		<description>A Kind of high-caliber HE shells provided by trade fleet for tanks from RimThunder.</description>
		<possessionCount>1</possessionCount>
		<graphicData>
			<texPath>Things/Item/TC/TC_HE</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>2.9</explosiveRadius>
				<explosiveDamageType>Bomb</explosiveDamageType>
				<explosiveExpandPerStackcount>0.4</explosiveExpandPerStackcount>
				<startWickHitPointsPercent>0.7</startWickHitPointsPercent>
				<wickTicks>30~60</wickTicks>
			</li>
		</comps>
		<projectileWhenLoaded>RT_TCHE_Bullet</projectileWhenLoaded>
		<costList>
			<Steel>15</Steel>
			<Chemfuel>10</Chemfuel>
		</costList>
		<recipeMaker>
			<researchPrerequisite>Mortars</researchPrerequisite>
		</recipeMaker>
	</ThingDef>

	<ThingDef ParentName="BaseBullet">
		<defName>RT_TCHE_Bullet</defName>
		<label>high-explosive shell</label>
		<graphicData>
			<texPath>Things/Projectile/TC_HE_e</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<thingClass>Projectile_Explosive</thingClass>
		<projectile>
			<damageDef>Bomb</damageDef>
			<damageAmountBase>140</damageAmountBase>
			<speed>85</speed>
			<explosionRadius>4.9</explosionRadius>
			<soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
			<soundExplode>Explosion_GiantBomb</soundExplode>
			<soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
			<soundAmbient>MortarRound_Ambient</soundAmbient>
		</projectile>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>3.9</explosiveRadius>
				<explosiveDamageType>Stun</explosiveDamageType>
				<damageAmountBase>10</damageAmountBase>
				<explodeOnDestroyed>true</explodeOnDestroyed>
				<explodeOnKilled>true</explodeOnKilled>
				<applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
			</li>
		</comps>
	</ThingDef>

	<RecipeDef>
		<defName>Make10TC_HE_SHell</defName>
		<label>Make HE Tank shell x10</label>
		<description>Make HE Tank shells.</description>
		<jobString>Making HE Tank shells.</jobString>
		<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
		<effectWorking>Cook</effectWorking>
		<soundWorking>Recipe_Machining</soundWorking>
		<targetCountAdjustment>5</targetCountAdjustment>
		<workSkill>Crafting</workSkill>
		<skillRequirements>
			<Crafting>6</Crafting>
		</skillRequirements>
		<workAmount>6000</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>150</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Chemfuel</li>
					</thingDefs>
				</filter>
				<count>100</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Steel</li>
				<li>Chemfuel</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<RT_TCHE_Shell>10</RT_TCHE_Shell>
		</products>
		<recipeUsers>
			<li>TableMachining</li>
		</recipeUsers>
	</RecipeDef>

