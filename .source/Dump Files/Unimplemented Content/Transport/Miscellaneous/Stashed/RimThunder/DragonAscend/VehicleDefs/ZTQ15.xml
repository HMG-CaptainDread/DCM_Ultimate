	<!-- 主砲的Def -->
	<Vehicles.VehicleTurretDef ParentName="RT_BaseTurret">
		<defName>ZTQ15_Tank_Turret</defName>
		<label>main turret</label>
		<gizmoIconTexPath>Vehicles/ZTQ15/vehicle_turret_full</gizmoIconTexPath>
		<!-- 砲塔的渲染顯示 -->
		<graphicData>
			<texPath>Vehicles/ZTQ15/vehicle_turret</texPath>
			<drawSize>(12.7,12.7)</drawSize>
		</graphicData>
		<!-- 彈藥與裝填容量相關 -->
		<reloadTimer>5</reloadTimer>
		<magazineCapacity>1</magazineCapacity>
		<ammunition>
			<categories>
				<li>RT_TC_Large_Shell</li>
			</categories>
		</ammunition>
		<!-- 射程與射界相關 -->
		<minRange>6</minRange>
		<maxRange>65.9</maxRange>
		<rotationSpeed>1.8</rotationSpeed>
		<!-- 射擊相關 -->
		<warmUpTimer>1</warmUpTimer>
		<shotSound>RT_Shot_L7Sound</shotSound>
		<reloadSound>RT_AutoloaderTReloadSound</reloadSound>
		<projectileOffset>5</projectileOffset>		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>							<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<!-- <li>-1</li> -->
			<li>0</li>
		</projectileShifting>
		<!-- 炮口製退動畫 -->
		<graphics>
			<li>
				<graphicData>
					<texPath>Vehicles/ZTQ15/vehicle_barrel</texPath>
