  <Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild"><!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_ZTQ15_MainBattleTank_Blueprint</defName>
		<label>ZTQ15</label>
		<description>A 3rd generation Light MBT equipped with an 105mm gun with auto-loader, can add kits to improve defense.</description>
		<graphicData>
			<texPath>Vehicles/ZTQ15/vehicle</texPath>
			<drawSize>(4.5,7.5)</drawSize>
		</graphicData>	
		<statBases> 		
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>180000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(4,7)</size>
	 	<researchPrerequisites Inherit = "False">
		  <li>MicroelectronicsBasics</li>
	  	</researchPrerequisites>
		<constructionSkillPrerequisite>10</constructionSkillPrerequisite>	
		<costList>
			<EngineHeavy>1</EngineHeavy>
			<ComponentFuelTank>4</ComponentFuelTank>
			<ComponentTransmission>2</ComponentTransmission>
			<ComponentWheelRoad>16</ComponentWheelRoad>
			<ComponentIndustrial>25</ComponentIndustrial>
			<Steel>250</Steel>
			<Plasteel>100</Plasteel>
			<Chemfuel>150</Chemfuel>
		</costList>
		<thingToSpawn>RT_ZTQ15_MainBattleTank</thingToSpawn>	<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

