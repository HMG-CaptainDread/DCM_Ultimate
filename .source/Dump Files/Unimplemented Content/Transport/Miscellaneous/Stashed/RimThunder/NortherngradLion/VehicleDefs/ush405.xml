<?xml version="1.0" encoding="UTF-8"?>
<Defs>

	<Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild">
		<!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_Ush_405_Vehicle_Blueprint</defName>
		<label>U-SH 405</label>
		<description>The U-SH 405 is an experimental tank destroyer with 2 rocket launcher, developed from Unimog truck chassis of Daimler-Benz in the late 1950's.</description>
		<graphicData>
			<texPath>405/vehicle</texPath>
			<drawSize>(2.2,3.9)</drawSize>
		</graphicData>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>7000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(2,3)</size>
		<researchPrerequisites>
			<li>MicroelectronicsBasics</li>
		</researchPrerequisites>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		<costList>
			<EngineMedium>1</EngineMedium>
			<ComponentFuelTank>2</ComponentFuelTank>
			<ComponentTransmission>2</ComponentTransmission>
			<ComponentWheelTire>4</ComponentWheelTire>
			<ComponentIndustrial>10</ComponentIndustrial>
			<Steel>100</Steel>
			<Chemfuel>100</Chemfuel>
		</costList>
		<thingToSpawn>RT_Ush_405_Vehicle</thingToSpawn>
		<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

	<!-- 載具本體 -->
	<Vehicles.VehicleDef ParentName="RT_BaseVehicle">
		<defName>RT_Ush_405_Vehicle</defName>
		<label>U-SH 405</label>
		<description>The U-SH 405 is an experimental tank destroyer with 2 rocket launcher, developed from Unimog truck chassis of Daimler-Benz in the late 1950's.</description>
		<buildDef>RT_Ush_405_Vehicle_Blueprint</buildDef>
		<graphicData>
			<texPath>405/vehicle</texPath>
			<drawSize>(2.2,3.9)</drawSize>
		</graphicData>
		<size>(2,3)</size>
		<fillPercent>1</fillPercent>
		<vehicleCategory>Combat</vehicleCategory>
		<statBases>
			<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.4</ArmorRating_Sharp>
			<Flammability>0</Flammability>
			<MarketValue>2100</MarketValue>
		</statBases>
		<vehicleStats>
			<Mass>1000</Mass>
			<MoveSpeed>10</MoveSpeed>
			<CargoCapacity>100</CargoCapacity>
			<RepairRate>0.8</RepairRate>
		</vehicleStats>
		<soundOneShotsOnEvent Inherit = "False">
			<li>
				<key>PawnEntered</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>PawnExited</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>IgnitionOn</key>
				<value>RT_WheeledVehicleStart</value>
			</li>
			<li>
				<key>IgnitionOff</key>
				<value>RT_WheeledVehicleStop</value>
			</li>
		</soundOneShotsOnEvent>
		<soundSustainersOnEvent Inherit = "False"> 
			<li>
				<start>IgnitionOn</start>
				<stop>IgnitionOff</stop>
				<value>RT_WheeledVehicleEngine</value>
			</li>
		</soundSustainersOnEvent>
		<race>
			<baseBodySize>4</baseBodySize>
		</race>
		<properties>
			<!-- 座位與功能 -->
			<customRoadCosts AssignDefaults = "0.25"/>
			<worldSpeedMultiplier>1</worldSpeedMultiplier>
			<offRoadMultiplier>2</offRoadMultiplier>
			<winterSpeedMultiplier>4</winterSpeedMultiplier>
			<vehicleJobLimitations>
				<li>(RepairVehicle, 5)</li>
			</vehicleJobLimitations>
			<roles>
				<li>
					<key>driver</key>
					<label>driver</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<hitbox>
						<cells>
							<li>(0, 1)</li>
						</cells>
					</hitbox>
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
				</li>
				<li>
					<key>gunner</key>
					<label>gunner</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<hitbox>
						<cells>
							<li>(0, 0)</li>
						</cells>
					</hitbox>
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>mainTurret</li>
					</turretIds>
				</li>
			</roles>
		</properties>
		<components>
			<!-- 各種零件 -->
			<!-- Internal mobile Part 內部驅動部件-->
			<li>
				<!--Engine 100-->
				<key>Engine</key>
				<label>Engine</label>
				<health>50</health>
				<priorityStatEfficiency>true</priorityStatEfficiency>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.25</chance>
						<maxHealth>0.3</maxHealth>
						<radius>3</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>	
				<hitbox>
					<cells>
						<li>(1, -1)</li>
						<li>(0, -1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- fuel tank 100-->
				<key>FuelTank</key>
				<label>fuel tank</label>
				<health>50</health>
				<depth>Internal</depth>
				<reactors>
					<li Class = "Vehicles.Reactor_FuelLeak"/>
				</reactors>
				<hitbox>
					<cells>
						<li>(1, -1)</li>
						<li>(0, -1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- Gearbox 50-->
				<key>Gearbox</key>
				<label>gearbox</label>
				<health>25</health>
				<depth>Internal</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<hitbox>
					<cells>
						<li>(1, 1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- AmmoRack 50-->
				<key>AmmoRack</key>
				<label>ammo rack</label>
				<health>25</health>
				<depth>Internal</depth>
				<hitWeight>0.2</hitWeight>
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.5</chance>
						<maxHealth>0.5</maxHealth>
						<radius>5</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>
				<hitbox>
					<cells>
						<li>(1, 0)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- transmission shaft 40 -->
				<key>TransmissionShaft</key>
				<label>transmission shaft</label>
				<health>20</health>
				<depth>Internal</depth>
			</li>
			<!-- External mobile Part 外部驅動部件-->
			<li>
				<!-- LeftFrontWheel 30-->
				<key>LeftFrontWheel</key>
				<label>left front Wheel</label>
				<health>40</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<armor>
					<ArmorRating_Blunt>0.3</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.3</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(0, 1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- RightFrontWheel 30-->
				<key>RightFrontWheel</key>
				<label>right front Wheel</label>
				<health>40</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<armor>
					<ArmorRating_Blunt>0.3</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.3</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(1, 1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- LeftRearWheel	30-->
				<key>LeftRearWheel</key>
				<label>left rear wheel</label>
				<health>40</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<armor>
					<ArmorRating_Blunt>0.3</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.3</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(0, -1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<!-- RightRearWheel 30-->
				<key>RightRearWheel</key>
				<label>right rear Wheel</label>
				<health>40</health>
				<depth>External</depth>
				<categories>
					<li>MoveSpeed</li>
				</categories>
				<tags>
					<li>Wheel</li>
				</tags>
				<armor>
					<ArmorRating_Blunt>0.3</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.3</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells>
						<li>(1, -1)</li>
					</cells>
				</hitbox>
			</li>
			<!-- External Platings 外部防禦部件 -->
			<li>
				<!-- FrontArmorPlating 200-->
				<key>FrontArmorPlating</key>
				<label>front armor Plating</label>
				<health>100</health>
				<depth>External</depth>
				<hitWeight>6</hitWeight>
				<armor>
					<ArmorRating_Blunt>1.00</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.8</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Front</side>
				</hitbox>
			</li>
			<li>
				<!-- LeftArmorPlating 180-->
				<key>LeftArmorPlating</key>
				<label>left armor plating</label>
				<health>90</health>
				<depth>External</depth>
				<hitWeight>3</hitWeight>
				<armor>
					<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Left</side>
				</hitbox>
			</li>
			<li>
				<!-- RightArmorPlating 180-->
				<key>RightArmorPlating</key>
				<label>right armor plating</label>
				<health>90</health>
				<depth>External</depth>
				<hitWeight>3</hitWeight>
				<armor>
					<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Right</side>
				</hitbox>
			</li>
			<li>
				<!-- RoofArmorPlating 150 -->
				<key>RoofArmorPlating</key>
				<label>roof armor plating</label>
				<health>120</health>
				<depth>External</depth>
				<hitWeight>3</hitWeight>
				<armor>
					<ArmorRating_Blunt>0.9</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.7</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<side>Body</side>
				</hitbox>
			</li>
			<li>
				<!-- BackArmorPlating 150-->
				<key>BackArmorPlating</key>
				<label>rear armor plating</label>
				<health>90</health>
				<depth>External</depth>
				<hitWeight>3</hitWeight>
				<hitbox>
					<side>Back</side>
				</hitbox>
			</li>
			<!-- 炮塔-->
			<li>
				<!-- mainTurret 150-->
				<key>MainTurret</key>
				<label>Main Turret</label>
				<health>135</health>
				<depth>External</depth>
				<hitWeight>4</hitWeight>
				<armor>
					<ArmorRating_Blunt>1.00</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.8</ArmorRating_Sharp>
				</armor>
				<hitbox>
					<cells>
						<li>(0, 1)</li>
						<li>(0, 0)</li>
						<li>(1, 1)</li>
						<li>(1, 0)</li>
					</cells>
				</hitbox>
			</li>
		</components>
		<comps>
			<li Class="Vehicles.CompProperties_FueledTravel">
				<!-- 油箱與油耗 -->
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>20</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>1.0</fuelConsumptionWorldMultiplier>
				<fuelCapacity>160</fuelCapacity>
			</li>
			<li Class="Vehicles.CompProperties_VehicleTurrets">
				<!-- 砲塔 -->
				<turrets>
					<li>
						<turretDef>RT_Ush_405_Tank_Turret</turretDef>
						<renderProperties>
							<north>(0, 0.25)</north>
							<south>(0, -0.05)</south>
							<east>(0.15, 0.2)</east>
							<west>(-0.15, 0.2)</west>
						</renderProperties>
						<gizmoLabel>Main Turret</gizmoLabel>
						<aimPieOffset>(0, 1.5)</aimPieOffset>
						<!-- 預熱指示器的x,z偏移 -->
						<drawLayer>1</drawLayer>
						<key>mainTurret</key>
						<component>
							<key>MainTurret</key>
							<healthPercent>0.01</healthPercent>
						</component>
					</li>
				</turrets>
			</li>
		</comps>
	</Vehicles.VehicleDef>

	<!-- 主砲的Def -->
	<Vehicles.VehicleTurretDef ParentName="RT_BaseTurret">
		<defName>RT_Ush_405_Tank_Turret</defName>
		<label>main turret</label>
		<!-- 炮塔图标 -->
		<gizmoIconTexPath>405/vehicle_turret_gizmo</gizmoIconTexPath>
		<!-- 炮塔部分 -->
		<graphicData>
			<texPath>405/vehicle_turret</texPath>
			<graphicClass>Vehicles.Graphic_Turret</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType> 
			<drawSize>(4.9,4.9)</drawSize>
			<layer>0</layer>
		</graphicData>
		<!-- 炮管后座部分 -->
		
		<!-- 彈藥與裝填容量相關 -->
		<reloadTimer>24</reloadTimer>
		<magazineCapacity>18</magazineCapacity>
		<chargePerAmmoCount>10</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<ammunition>
			<thingDefs>
				<li>Chemfuel</li>
			</thingDefs>
		</ammunition>
		<!-- 射程與射界相關 -->
		<minRange>2</minRange>
		<maxRange>40.9</maxRange>
		<rotationSpeed>2</rotationSpeed>
		<!-- 射擊相關 -->
		<warmUpTimer>1</warmUpTimer>
		<shotSound>405rct</shotSound>
		<reloadSound>RT_AutoCannonReloadSound</reloadSound>
		<projectile>RT_Bullet_Ush_405Shell</projectile>
		<projectileOffset>2</projectileOffset>
		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>
			<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<li>0.5</li>
			<li>-0.5</li>
		</projectileShifting>
		<!-- 射擊模式 -->
		<fireModes Inherit = "false">
			<li>
				<shotsPerBurst>4</shotsPerBurst>
				<ticksBetweenShots>30</ticksBetweenShots>
				<ticksBetweenBursts>160</ticksBetweenBursts>
				<label>Auto</label>
				<texPath>UI/Gizmos/FireRate_Auto</texPath>
			</li>
			<li>
				<shotsPerBurst>8</shotsPerBurst>
				<ticksBetweenShots>30</ticksBetweenShots>
				<ticksBetweenBursts>320</ticksBetweenBursts>
				<label>Burst</label>
				<texPath>UI/Gizmos/FireRate_Burst</texPath>
			</li>
		</fireModes>
	</Vehicles.VehicleTurretDef>

	<ThingDef Class="Missile_dml._ThingDef" ParentName="BaseBullet">
		<defName>RT_Bullet_Ush_405Shell</defName>
		<label>swarmer rocket</label>
		<thingClass>Missile_dml.missile_dml</thingClass>
		<graphicData>
			<texPath>Things/Projectile/Rocket_Swarm</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.4</drawSize>
		</graphicData>
		<fleck>RT_Ush_RocketSmoke</fleck>
		<fleck1>RT_Ush_RocketExhaust</fleck1>
		<frequency>0</frequency>
		<scale>1.5</scale>
		<shaking>0.3</shaking>
		<projectile>
			<damageDef>Bomb</damageDef>
			<damageAmountBase>84</damageAmountBase>
			<armorPenetrationBase>0.8</armorPenetrationBase>
			<flyOverhead>true</flyOverhead>
			<speed>40</speed>
			<explosionRadius>3.9</explosionRadius>
			<soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
			<soundExplode>Explosion_Rocket</soundExplode>
			<soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
			<soundAmbient>MortarRound_Ambient</soundAmbient>
		</projectile>
		<drawOffscreen>true</drawOffscreen>
	</ThingDef>
	
	<FleckDef ParentName = "FleckBase_Thrown">
		<defName>RT_Ush_RocketSmoke</defName>
		<graphicData>
			<texPath>Things/Mote/Smoke</texPath>
			<renderInstanced>true</renderInstanced>
		</graphicData>
		
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<fadeInTime>0.5</fadeInTime>
		<solidTime>2</solidTime>
		<fadeOutTime>1</fadeOutTime>
		<growthRate>0.01</growthRate>
	</FleckDef>
	
	<FleckDef ParentName="FleckBaseSmoke">
		<defName>RT_Ush_RocketExhaust</defName>
		<graphicData>
			<texPath>Things/Mote/FireGlow</texPath>
			<shaderType>MoteGlow</shaderType>
		</graphicData>
		<altitudeLayer>MoteOverheadLow</altitudeLayer>
		<solidTime>0.03</solidTime>
		<fadeOutTime>0.15</fadeOutTime>
	</FleckDef>

</Defs>