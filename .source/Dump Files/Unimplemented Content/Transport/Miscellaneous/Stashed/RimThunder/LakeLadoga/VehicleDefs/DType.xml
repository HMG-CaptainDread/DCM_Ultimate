<?xml version="1.0" encoding="utf-8" ?>

<Defs>
	<Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild">
		<defName>RT_DType_Blueprint</defName>
		<label>DType</label>
		<description>A small gunboat for river escort, equipped with a machinegun.</description>
		
		<graphicData>
			<texPath>DType/vehicle</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(2.4, 8.4)</drawSize>
		</graphicData>
		
		<statBases>
			<MaxHitPoints>250</MaxHitPoints>
			<WorkToBuild>60000</WorkToBuild>
			<Flammability>0.65</Flammability>
		</statBases>
		<terrainAffordanceNeeded>ShallowWater</terrainAffordanceNeeded>
		<size>(2, 7)</size>
		
		<costList>
			<EngineMedium>1</EngineMedium>
			<ComponentFuelTank>1</ComponentFuelTank>
			<ComponentTransmission>1</ComponentTransmission>
			<ComponentHeavyCasting>1</ComponentHeavyCasting>
			<ComponentIndustrial>8</ComponentIndustrial>
			<Steel>300</Steel>
		</costList>
		
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		
		<thingToSpawn>RT_DType</thingToSpawn>
	</Vehicles.VehicleBuildDef>
	
	<Vehicles.VehicleDef ParentName="RT_BaseVehicle">
		<defName>RT_DType</defName>
		<label>DType</label>
		<description>A small gunboat for river escort, equipped with a machinegun.</description>
		
		<graphicData>
			<texPath>DType/vehicle</texPath>
			<drawSize>(2.4, 8.4)</drawSize>
		</graphicData>
		
		<fillPercent>0.7</fillPercent>
		<buildDef>RT_DType_Blueprint</buildDef>
		
		<size>(2, 7)</size>
		
		<vehicleMovementPermissions>DriverNeeded</vehicleMovementPermissions>
		<vehicleCategory>Transport</vehicleCategory>
		<techLevel>Industrial</techLevel>
		<vehicleType>Sea</vehicleType>
				
		<statBases>
			<ArmorRating_Blunt>0.8</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.6</ArmorRating_Sharp>
			<ArmorRating_Heat>1.0</ArmorRating_Heat>
			<MarketValue>1900</MarketValue>
			<Flammability>0</Flammability>
		</statBases>
		
		<vehicleStats>
			<Mass>8000</Mass>
			<MoveSpeed>10</MoveSpeed>
			<CargoCapacity>1000</CargoCapacity>
			<RepairRate>1</RepairRate>
		</vehicleStats>
		<soundOneShotsOnEvent Inherit = "False">
			<li>
				<key>PawnEntered</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>PawnExited</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>IgnitionOn</key>
				<value>RT_WheeledVehicleStart</value>
			</li>
			<li>
				<key>IgnitionOff</key>
				<value>RT_WheeledVehicleStop</value>
			</li>
		</soundOneShotsOnEvent>
		<soundSustainersOnEvent Inherit="false"> 
			<li>
				<start>IgnitionOn</start>
				<stop>IgnitionOff</stop>
				<value>RT_LightShipEngine</value>
			</li>
		</soundSustainersOnEvent>
		<race>
			<baseBodySize>3.25</baseBodySize>
		</race>
		
		<properties>
			<fishing>true</fishing>
			<riverCost>1</riverCost>
			
			<track Class = "Vehicles.VehicleTrack_Wake">
				<speed>1</speed>
			</track>
			
			<defaultBiomesImpassable>true</defaultBiomesImpassable>
			<defaultTerrainImpassable>true</defaultTerrainImpassable>
			<customTerrainCosts AllowTerrainWithTag="Water" PathCost="1"/>
			<customBiomeCosts>
				<li>
					<key>Ocean</key>
					<value>1</value>
				</li>
				<li>
					<key>Lake</key>
					<value>1</value>
				</li>
				</customBiomeCosts>
			<worldSpeedMultiplier>1</worldSpeedMultiplier>
			<winterSpeedMultiplier>5</winterSpeedMultiplier>
			<vehicleJobLimitations>
				<li>(RepairVehicle, 5)</li>
			</vehicleJobLimitations>
			<roles>
				<li>
					<key>driver</key>
					<label>Captain</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
				</li>
				<li>
					<key>gunner</key>
					<label>Gunner</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>maxim</li>
					</turretIds>			
				</li>
				<li>
					<key>passenger</key>
					<label>Passenger</label>
					<slots>5</slots>
				</li>
			</roles>
		</properties>
		
		<components>
			<li><!--Engine 100-->
				<key>Engine</key>
				<label>Engine</label>
				<health>100</health>
				<priorityStatEfficiency>true</priorityStatEfficiency>
				<categories><li>MoveSpeed</li></categories>
				<depth>Internal</depth>		
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.25</chance>
						<maxHealth>0.5</maxHealth>
						<radius>3</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>	
				<hitbox>
					<cells>
						<li>(0, -2)</li>
					</cells>
				</hitbox>					
			</li>			
			<li><!-- fuel tank 100-->
				<key>FuelTank</key>
				<label>fuel tank</label>
				<health>100</health>
				<depth>Internal</depth>			
				<reactors><li Class = "Vehicles.Reactor_FuelLeak"/></reactors>		
				<hitbox>
					<cells>
						<li>(1, -2)</li>
					</cells>
				</hitbox>		
			</li>
			<li><!-- Gearbox 50-->
				<key>DriveShaft</key>
				<label>drive shaft</label>
				<health>100</health>
				<depth>Internal</depth>
				<categories><li>MoveSpeed</li></categories>			
			</li>
			<!-- External mobile Part 外部驅動部件-->		
			<li><!-- RightTrack 150-->
				<key>Prop</key>
				<label>propeller</label>
				<health>150</health>
				<depth>Internal</depth>
				<categories><li>MoveSpeed</li></categories>	
				<tags><li>Wheel</li></tags>
				<hitWeight>1</hitWeight>
				<hitbox>
					<side>Back</side>
				</hitbox>
			</li>
			<li><!-- RightTrack 150-->
				<key>rudder</key>
				<label>rudder</label>
				<health>150</health>
				<depth>Internal</depth>
				<hitWeight>1</hitWeight>
				<hitbox>
					<side>Back</side>
				</hitbox>
			</li>
		<!-- External Platings 外部防禦部件 -->
			<li><!-- FrontArmorPlating 200-->
				<key>FrontArmorPlating</key>
				<label>front armor Plating</label>
				<health>200</health>
				<depth>External</depth>
				<hitWeight>4</hitWeight>		
				<hitbox><side>Front</side></hitbox>
			</li>
			<li><!-- LeftArmorPlating 180-->
				<key>LeftArmorPlating</key>
				<label>left armor plating</label>
				<health>150</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>				
				<hitbox><side>Left</side></hitbox>
			</li>
			<li><!-- RightArmorPlating 180-->
				<key>RightArmorPlating</key>
				<label>right armor plating</label>
				<health>150</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>			
				<hitbox><side>Right</side></hitbox>
			</li>
			<li><!-- RoofArmorPlating 150 -->
				<key>RoofArmorPlating</key>
				<label>roof armor plating</label>
				<health>200</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<hitbox><side>Body</side></hitbox>
			</li>
			<li><!-- BackArmorPlating 150-->
				<key>BackArmorPlating</key>
				<label>rear armor plating</label>
				<health>150</health>
				<depth>External</depth>
				<hitWeight>5</hitWeight>
				<hitbox>
					<side>Back</side>
				</hitbox>
			</li>
			<li><!-- RoofArmorPlating 150 -->
				<key>ArmoredBridge</key>
				<label>Armored bridge</label>
				<health>150</health>
				<depth>External</depth>
				<hitWeight>12</hitWeight>
				<hitbox>
					<cells>
						<li>(0, 1)</li>
						<li>(0, 2)</li>
						<li>(1, 1)</li>
						<li>(1, 2)</li>
					</cells>
				</hitbox>
			</li>
			<li><!-- RoofArmorPlating 150 -->
				<key>maximturret</key>
				<label>Maxim turret</label>
				<health>150</health>
				<depth>External</depth>
				<hitWeight>12</hitWeight>
				<hitbox>
					<cells>
						<li>(0, 1)</li>
						<li>(0, 2)</li>
						<li>(1, 1)</li>
						<li>(1, 2)</li>
					</cells>
				</hitbox>
			</li>
		</components>
		
		<comps>
			<li Class="Vehicles.CompProperties_FueledTravel">
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>8</fuelConsumptionRate>
				<fuelCapacity>160</fuelCapacity>
				<fuelConsumptionWorldMultiplier>0.6</fuelConsumptionWorldMultiplier>
			</li>
			<li Class="Vehicles.CompProperties_VehicleTurrets">
				<!-- 砲塔 -->
				<turrets>
					<li>
						<turretDef>RT_maxim_Turret</turretDef>
						<renderProperties>
							<north>(0, 1.8)</north>
							<south>(0, -1.3)</south>
							<east>(1.5, 0.3)</east>
							<west>(-1.5, 0.3)</west>
						</renderProperties>

						<gizmoLabel>maxim</gizmoLabel>
						<aimPieOffset>(0, 0.5)</aimPieOffset>
						<!-- 預熱指示器的x,z偏移 -->
						<key>maxim</key>
						<component>
							<key>maximturret</key>
							<healthPercent>0.01</healthPercent>
						</component>
					</li>
				</turrets>
			</li>
		</comps>
	</Vehicles.VehicleDef>

	<Vehicles.VehicleTurretDef ParentName="RT_BaseVehicleMG_Medium">
		<defName>RT_maxim_Turret</defName>
		<label>maxim</label>
		<!-- 炮塔部分 -->
		<graphicData>
			<texPath>DType/vehicle_turret</texPath>
			<drawSize>(2.5,2.5)</drawSize>
			<layer>2</layer>
		</graphicData>
		<!-- 彈藥與裝填容量相關 -->
		<shotSound>RT_Shot_DTSound</shotSound>
		<reloadTimer>6</reloadTimer>
		<magazineCapacity>250</magazineCapacity>
		<chargePerAmmoCount>0.1</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<!-- 射程與射界相關 -->
		<rotationSpeed>1.7</rotationSpeed>
		<!-- 射擊相關 -->
		<warmUpTimer>1.5</warmUpTimer>
		<projectileShifting>
			<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<li>0</li>
		</projectileShifting>
	</Vehicles.VehicleTurretDef>
</Defs>