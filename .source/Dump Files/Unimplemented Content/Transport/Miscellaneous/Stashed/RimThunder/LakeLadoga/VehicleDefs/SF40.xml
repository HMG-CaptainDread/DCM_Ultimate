<Defs>
	<Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild">
		<defName>RT_SF40light_Blueprint</defName>
		<label>SF40</label>
		<description>An anti-air ferry for air defence and convoy escort, also used in transport, equipped with lots of AA guns.</description>
		
		<graphicData>
			<texPath>SF40/vehicle</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(20, 20)</drawSize>
		</graphicData>
		
		<statBases>
			<MaxHitPoints>250</MaxHitPoints>
			<WorkToBuild>240000</WorkToBuild>
			<Flammability>0.65</Flammability>
		</statBases>
		<terrainAffordanceNeeded>ShallowWater</terrainAffordanceNeeded>
		<size>(10, 15)</size>
		
		<costList>
			<EngineHeavy>2</EngineHeavy>
			<ComponentFuelTank>4</ComponentFuelTank>
			<ComponentTransmission>2</ComponentTransmission>
			<ComponentHeavyCasting>6</ComponentHeavyCasting>
			<ComponentIndustrial>32</ComponentIndustrial>
			<Steel>1800</Steel>
			<WoodLog>600</WoodLog>
		</costList>
		
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		
		<thingToSpawn>RT_SF40light</thingToSpawn>
	</Vehicles.VehicleBuildDef>
	
