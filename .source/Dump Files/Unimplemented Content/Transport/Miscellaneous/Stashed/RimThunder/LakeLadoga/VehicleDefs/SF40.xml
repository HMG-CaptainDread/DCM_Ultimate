	<Vehicles.VehicleTurretDef ParentName="RT_BaseTurret">
		<defName>RT_Flak38_Tank_Turret</defName>
		<label>Flak38</label>
		<!-- 炮塔部分 -->
		<graphicData>
			<texPath>SF40/flak38</texPath>
			<drawSize>(4.5,4.5)</drawSize>
		</graphicData>

		<!-- 彈藥與裝填容量相關 -->
		<reloadTimer>6</reloadTimer>
		<magazineCapacity>40</magazineCapacity>
		<chargePerAmmoCount>1</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<ammunition>
			<thingDefs>
