		<label>T-90M</label>
		<description>The T-90M main battle tank is the final upgraded type of the T-90A tank,it's absolute the mainstay of the Russian Federation's armed forces.</description>
		<graphicData>
			<texPath>Vehicles/T90M/T90M</texPath>
			<drawSize>(7.5,7.5)</drawSize>
		</graphicData>	
		<statBases> 		
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>100000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
