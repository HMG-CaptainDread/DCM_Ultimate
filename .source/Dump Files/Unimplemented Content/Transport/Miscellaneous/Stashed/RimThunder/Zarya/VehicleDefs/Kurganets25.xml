	<!-- 主砲的Def -->
	<Vehicles.VehicleTurretDef ParentName="RT_BaseTurret">
		<defName>RT_KPVT_Turret</defName>
		<label>KPVT turret</label>
		<gizmoIconTexPath>Vehicles/Kurganets25/KPVTTurret_gizmo</gizmoIconTexPath>
		<!-- 砲塔的渲染顯示 -->
		<graphicData>
			<texPath>Vehicles/Kurganets25/KPVTTurret</texPath>
			<graphicClass>Vehicles.graphic_turret</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType>
			<drawSize>(7,7)</drawSize>
		</graphicData>
		<!-- 彈藥與裝填容量相關 -->
		<reloadTimer>4.2</reloadTimer>
		<magazineCapacity>300</magazineCapacity>
		<chargePerAmmoCount>0.5</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<ammunition>
			<thingDefs>
				<li>Steel</li>
			</thingDefs>
		</ammunition>
		<!-- 射程與射界相關 -->
		<minRange>4</minRange>
		<maxRange>45.9</maxRange>
		<rotationSpeed>3</rotationSpeed>
		<!-- 射擊相關 -->
		<warmUpTimer>0.5</warmUpTimer>
		<shotSound>RT_Shot_KPVSound</shotSound>
		<reloadSound>RT_AutoCannonReloadSound</reloadSound>
		<projectile>RT_Bullet_KPVT</projectile>
		<projectileOffset>1.88</projectileOffset>		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>							<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<!-- <li>-1</li> -->
			<li>0</li>
		</projectileShifting>
		<!-- 射擊模式 -->
		<fireModes>
			<li>
				<shotsPerBurst>12</shotsPerBurst>
				<ticksBetweenShots>10</ticksBetweenShots>
				<ticksBetweenBursts>60</ticksBetweenBursts>
				<accuracyTouch>0.45</accuracyTouch>
				<accuracyShort>0.7</accuracyShort>
				<accuracyMedium>0.75</accuracyMedium>
				<accuracyLong>0.4</accuracyLong>
				<label>Auto</label>
				<texPath>UI/Gizmos/FireRate_Auto</texPath>
			</li>
			<li>
				<shotsPerBurst>6</shotsPerBurst>
				<ticksBetweenShots>10</ticksBetweenShots>
				<ticksBetweenBursts>60</ticksBetweenBursts>
				<accuracyTouch>0.5</accuracyTouch>
				<accuracyShort>0.7</accuracyShort>
				<accuracyMedium>0.8</accuracyMedium>
				<accuracyLong>0.6</accuracyLong>
				<label>Burst</label>
				<texPath>UI/Gizmos/FireRate_Burst</texPath>
			</li>
			<li>
				<shotsPerBurst>1</shotsPerBurst>
				<ticksBetweenShots>10</ticksBetweenShots>
				<ticksBetweenBursts>60</ticksBetweenBursts>
				<accuracyTouch>0.5</accuracyTouch>
				<accuracyShort>0.7</accuracyShort>
				<accuracyMedium>0.8</accuracyMedium>
				<accuracyLong>0.75</accuracyLong>
				<label>Single Shot</label>
				<texPath>UI/Gizmos/FireRate_Single</texPath>
			</li>
		</fireModes>
		<motes>
			<li>
				<cycles>1</cycles>
				<moteDef>Mote_CannonPlume</moteDef>
				<animationType>Reset</animationType>
				<offset>(0,0,2)</offset>
			</li>
		</motes>
	</Vehicles.VehicleTurretDef>

	
	<!-- 主砲的投射物 -->
	<ThingDef ParentName="BaseBullet">
		<defName>RT_Bullet_KPVT</defName>
		<label>14.5mm high caliber machine gun bullet</label>
		<graphicData>
			<texPath>Things/Projectile/Bullet_Small</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>27</damageAmountBase>
			<armorPenetrationBase>0.34</armorPenetrationBase>
			<stoppingPower>3</stoppingPower>
			<speed>80</speed>
		</projectile>
	</ThingDef>

	<Vehicles.VehicleTurretDef ParentName="RT_BaseLauncher">
