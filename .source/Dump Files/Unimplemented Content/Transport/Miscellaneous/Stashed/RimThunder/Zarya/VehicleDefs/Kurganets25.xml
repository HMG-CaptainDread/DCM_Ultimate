						<maxHealth>0.3</maxHealth>
						<radius>3</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>				
				<hitbox>
					<cells>
						<li>(1,2)</li>
						<li>(2,2)</li>
						<li>(1,1)</li>
						<li>(2,1)</li>
					</cells>
				</hitbox>				
			</li>		
			<li><!-- fuel tank 100-->
