<?xml version="1.0" encoding="UTF-8"?>
<Defs>

  <Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild"><!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_Kurganets25_Blueprint</defName>
		<label>Kurganets25</label>
		<description>Kurganets-25 IFV is a unique medium-sized tracked general-purpose platform, capable of adapting to a variety of turret modules.</description>
		<graphicData>
			<texPath>Vehicles/Kurganets25/Kurganets</texPath>
			<drawSize>(7,7)</drawSize>
		</graphicData>	
		<statBases> 		
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>80000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(4,7)</size>
	  	<researchPrerequisites Inherit="False">
		  <li>MicroelectronicsBasics</li>
	  	</researchPrerequisites>
		<constructionSkillPrerequisite>8</constructionSkillPrerequisite>	
		<costList>
			<EngineHeavy>1</EngineHeavy>
			<ComponentFuelTank>2</ComponentFuelTank>
			<ComponentTransmission>2</ComponentTransmission>
			<ComponentWheelRoad>18</ComponentWheelRoad>
			<ComponentIndustrial>15</ComponentIndustrial>
			<Steel>150</Steel>
			<Chemfuel>100</Chemfuel>
		</costList>
		<thingToSpawn>RT_Kurganets25_Vehicle</thingToSpawn>	<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

	<!-- 載具本體 -->
	<Vehicles.VehicleDef ParentName="RT_BaseVehicle">
