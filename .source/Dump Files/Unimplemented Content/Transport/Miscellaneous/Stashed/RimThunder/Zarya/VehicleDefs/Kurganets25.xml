					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>				
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
				</li>				
				<li>
					<key>gunner</key>
					<label>gunner</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>			
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>KPVT</li>
						<li>EpochAlmaty</li>
						<li>Baikal</li>
						<li>BaikalPKT</li>
						<li>EpochPKT</li>
					</turretIds>
				</li>
				<li>
					<key>Commander</key>
					<label>Commander</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>EAKornetL</li>
						<li>EAKornetR</li>
						<li>BaikalKornet</li>
