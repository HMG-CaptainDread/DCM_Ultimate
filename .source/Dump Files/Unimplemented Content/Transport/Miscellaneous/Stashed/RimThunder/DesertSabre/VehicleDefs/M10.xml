<Defs>

  <Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild"><!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_M10_MainBattleTank_Blueprint</defName>
		<label>M10 Booker</label>
		<description>A 3rd generation Light MBT equipped with an 120mm gun, without APS due to export restrictions on trade fleet, but got free firepower upgrades in exchange.</description>
		<graphicData>
			<texPath>Vehicles/M10/vehicle</texPath>
			<drawSize>(8.6,8.6)</drawSize>
		</graphicData>	
		<statBases> 		
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>180000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(4,7)</size>
		<researchPrerequisites Inherit = "False">
		  <li>MicroelectronicsBasics</li>
	  	</researchPrerequisites>
		<constructionSkillPrerequisite>8</constructionSkillPrerequisite>	
		<costList>
			<EngineHeavy>1</EngineHeavy>
			<ComponentFuelTank>4</ComponentFuelTank>
			<ComponentTransmission>2</ComponentTransmission>
			<ComponentWheelRoad>16</ComponentWheelRoad>
			<ComponentIndustrial>25</ComponentIndustrial>
			<Steel>250</Steel>
			<Plasteel>100</Plasteel>
		</costList>
		<thingToSpawn>RT_M10_MainBattleTank</thingToSpawn>	<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

