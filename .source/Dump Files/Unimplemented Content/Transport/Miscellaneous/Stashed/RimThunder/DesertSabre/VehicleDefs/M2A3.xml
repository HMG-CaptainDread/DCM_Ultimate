	<!-- 主砲的Def -->
	<Vehicles.VehicleTurretDef ParentName="RT_BaseTurret">
		<defName>RT_M2A3_Tank_Turret</defName>
		<label>main turret</label>
		<gizmoIconTexPath>Vehicles/M2A3/vehicle_turret_full</gizmoIconTexPath>
		<!-- 砲塔的渲染顯示 -->
