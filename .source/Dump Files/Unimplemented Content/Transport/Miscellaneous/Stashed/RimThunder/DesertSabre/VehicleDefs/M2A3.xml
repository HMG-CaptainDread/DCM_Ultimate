  <Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild"><!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_M2A3_Vehicle_Blueprint</defName>
		<label>M2A3 Bradley</label>
		<description>An IFV equipped with a 25mm autocannon and missile launcher, can add BUSK kits to improve defense.</description>
		<graphicData>
			<texPath>Vehicles/M2A3/vehicle</texPath>
			<drawSize>(7.2,7.2)</drawSize>
		</graphicData>	
		<statBases> 		
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>160000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(3,6)</size>
		<researchPrerequisites Inherit = "False">
		  <li>MicroelectronicsBasics</li>
	  	</researchPrerequisites>
		<constructionSkillPrerequisite>8</constructionSkillPrerequisite>	
		<costList>
			<EngineHeavy>1</EngineHeavy>
			<ComponentFuelTank>1</ComponentFuelTank>
