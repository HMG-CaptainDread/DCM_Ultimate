				<li>ComponentTransmission</li>
				<li>ComponentWheelRoad</li>
				<li>ComponentIndustrial</li>
				<li>Steel</li>
				<li>Plasteel</li>
				<li>Chemfuel</li>
			</thingDefs>
		</fixedIngredientFilter>
		<modExtensions>
			<li Class="Motorization.ModExt_RTCVehicleRecipe">
				<thing>RT_T80BVM_MainBattleTank_Blueprint</thing>
			</li>
		</modExtensions>
  	</RecipeDef>

