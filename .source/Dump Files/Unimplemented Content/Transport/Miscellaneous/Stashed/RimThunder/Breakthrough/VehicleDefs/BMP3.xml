		<graphicData>
			<texPath>Vehicles/BMP3/vehicle_turret</texPath>
			<graphicClass>Vehicles.Graphic_Turret</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType> 
			<drawSize>(7.5,7.5)</drawSize>
			<layer>0</layer>
		</graphicData>
		<!-- 炮管后座部分 -->
