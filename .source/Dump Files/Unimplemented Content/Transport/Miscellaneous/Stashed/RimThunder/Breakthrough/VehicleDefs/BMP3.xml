	<!-- 主砲的Def -->
	<Vehicles.VehicleTurretDef ParentName="RT_BaseTurret">
		<defName>RT_BMP3_Tank_Turret</defName>
		<label>main turret</label>
		<gizmoIconTexPath>Vehicles/BMP3/vehicle_turret_full</gizmoIconTexPath>
