					<speedMultiplierPostRecoil>0.1</speedMultiplierPostRecoil>
				</recoil>
			</li>	
		</graphics>
		<!-- 彈藥與裝填容量相關 -->
		<reloadTimer>4</reloadTimer>
		<magazineCapacity>1</magazineCapacity>
		<chargePerAmmoCount>10</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<ammunition>
			<thingDefs>
				<li>Steel</li>
			</thingDefs>
		</ammunition>
		<!-- 射程與射界相關 -->
		<minRange>2</minRange>
		<maxRange>50.9</maxRange>
		<rotationSpeed>2</rotationSpeed>
		<!-- 射擊相關 -->
		<warmUpTimer>0.5</warmUpTimer>
		<shotSound>RT_Shot_2A70Sound</shotSound>
		<reloadSound>RT_2A70ReloadSound</reloadSound>
		<projectile>RT_Bullet_2A70Shell</projectile>
		<projectileOffset>4.18</projectileOffset>
		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
