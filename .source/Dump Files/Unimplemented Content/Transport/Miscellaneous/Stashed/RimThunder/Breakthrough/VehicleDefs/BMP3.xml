<?xml version="1.0" encoding="UTF-8"?>
<Defs>

	<Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild">
		<!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_BMP3_Vehicle_Blueprint</defName>
		<label>BMP3</label>
		<description>An IFV equipped with a 100mm cannon with auto-loader and a coaxial autocannon, has ability to update to 2S38 by changing the turret.</description>
		<graphicData>
			<texPath>Vehicles/BMP3/vehicle</texPath>
			<drawSize>(3.6,6.4)</drawSize>
		</graphicData>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>120000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(3,6)</size>
		<researchPrerequisites Inherit = "False">
		  <li>MicroelectronicsBasics</li>
	  	</researchPrerequisites>
		<constructionSkillPrerequisite>8</constructionSkillPrerequisite>
		<costList>
			<EngineHeavy>1</EngineHeavy>
			<ComponentFuelTank>1</ComponentFuelTank>
			<ComponentTransmission>2</ComponentTransmission>
			<ComponentWheelRoad>16</ComponentWheelRoad>
			<ComponentIndustrial>20</ComponentIndustrial>
			<Steel>220</Steel>
		</costList>
		<thingToSpawn>RT_BMP3_Vehicle</thingToSpawn>
		<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

