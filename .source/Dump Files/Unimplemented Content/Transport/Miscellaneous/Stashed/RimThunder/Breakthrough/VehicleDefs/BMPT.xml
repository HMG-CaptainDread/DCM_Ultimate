		<shotSound>RT_Shot_2A42Sound</shotSound>
		<reloadSound>RT_AutoCannonReloadSound</reloadSound>
		<projectile>RT_Bullet_2A42M</projectile>
		<projectileOffset>1.88</projectileOffset>		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
