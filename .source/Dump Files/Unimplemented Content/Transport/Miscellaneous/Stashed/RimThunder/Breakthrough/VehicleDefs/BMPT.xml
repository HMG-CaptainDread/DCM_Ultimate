			<Chemfuel>100</Chemfuel>
		</costList>
		<thingToSpawn>RT_BMPT_Vehicle</thingToSpawn>	<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

