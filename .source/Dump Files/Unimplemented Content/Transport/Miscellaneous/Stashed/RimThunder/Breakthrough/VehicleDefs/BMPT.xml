  <Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild"><!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_BMPT_Blueprint</defName>
		<label>BMPT</label>
		<description>The BMPT combat support tank is the new generation support vehicels,Due to its rich weapon configuration and fierce firepower, it is also known as a death harvester.</description>
		<graphicData>
			<texPath>Vehicles/BMPT/BMPT</texPath>
			<drawSize>(7.5,7.5)</drawSize>
		</graphicData>	
		<statBases> 		
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>200000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(4,7)</size>
	  	<researchPrerequisites Inherit = "False">
		  <li>MicroelectronicsBasics</li>
	  	</researchPrerequisites>
		<constructionSkillPrerequisite>10</constructionSkillPrerequisite>	
