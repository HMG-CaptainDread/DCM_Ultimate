	<!-- 主砲的Def --><!--平衡相关-->
	<Vehicles.VehicleTurretDef ParentName="RT_BaseTurret">
		<defName>RT_Striker_CAV_Main_Turret</defName>
		<label>main turret</label>
		<!-- 砲塔的渲染顯示 -->
		<graphicData>
			<texPath>Vehicles/CAV/CAV_CannonTop</texPath>
			<drawSize>(2.8,2.8)</drawSize>
		</graphicData>
		<!-- 彈藥與裝填容量相關 -->
		<reloadTimer>3</reloadTimer>
		<magazineCapacity>8</magazineCapacity>
		<chargePerAmmoCount>2</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<ammunition>
			<thingDefs>
				<li>Steel</li>
			</thingDefs>
		</ammunition>
		<!-- 射程與射界相關 -->
		<minRange>2</minRange>
		<maxRange>39.9</maxRange>
		<rotationSpeed>1.4</rotationSpeed>
		<!-- 射擊相關 -->
		<warmUpTimer>1</warmUpTimer>
		<shotSound>RT_Shot_AutoCannonSound</shotSound>
		<reloadSound>RT_AutoCannonReloadSound</reloadSound>
		<projectile>RT_Bullet_Striker</projectile>
		<projectileOffset>1.28</projectileOffset>		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>							<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<!-- <li>-1</li> -->
			<li>0</li>
		  </projectileShifting>
		<!-- 炮口製退動畫 -->
		<recoil>
			<distanceTotal>0.15</distanceTotal>
			<distancePerTick>0.05</distancePerTick>
			<speedMultiplierPostRecoil>0.1</speedMultiplierPostRecoil>
		</recoil>
		<!-- 射擊模式 -->
		<fireModes>
			<li>
				<shotsPerBurst>4</shotsPerBurst>
				<ticksBetweenShots>20</ticksBetweenShots>
				<ticksBetweenBursts>60</ticksBetweenBursts>
				<spreadRadius>0</spreadRadius>
				<label>Burst</label>
				<texPath>UI/Gizmos/FireRate_Burst</texPath>
			</li>
			<li>
				<shotsPerBurst>8</shotsPerBurst>
				<ticksBetweenShots>20</ticksBetweenShots>
				<ticksBetweenBursts>120</ticksBetweenBursts>
				<spreadRadius>1</spreadRadius>
				<label>Auto</label>
				<texPath>UI/Gizmos/FireRate_Auto</texPath>
			</li>
		</fireModes>
		<motes>
			<li>
				<cycles>1</cycles>
				<moteDef>Mote_CannonPlume</moteDef>
				<animationType>Reset</animationType>
				<offset>(0,0,2)</offset>
			</li>
		</motes>
	</Vehicles.VehicleTurretDef>
