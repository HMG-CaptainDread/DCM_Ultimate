<?xml version="1.0" encoding="UTF-8"?>
<Defs>

  <Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild"><!-- 建築型態的載具，基本上與BuildingDef相同-->
		<defName>RT_Chain_Saw_Blueprint</defName>
		<label>Chain Saw</label>
		<description>An APC with a small machine gun, weak but useable at its price.</description>
		<graphicData>
			<texPath>Vehicles/Bolte/BolteFast</texPath>
			<drawSize>(2.25,4.5)</drawSize>
		</graphicData>	
		<statBases> 		
			<MaxHitPoints>700</MaxHitPoints>
			<WorkToBuild>11500</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(2,4)</size>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>	
		<costList>
			<EngineLight>2</EngineLight>
			<ComponentWheelRoad>12</ComponentWheelRoad>
			<ComponentIndustrial>10</ComponentIndustrial>
			<Steel>150</Steel>
		</costList>
		<thingToSpawn>RT_Chain_Saw_Vehicle</thingToSpawn>	<!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
	</Vehicles.VehicleBuildDef>

	<!-- 載具本體 -->
	<Vehicles.VehicleDef ParentName="RT_BaseVehicle">
		<defName>RT_Chain_Saw_Vehicle</defName>
		<label>Chain Saw</label>
		<description>An APC with a small machine gun, weak but useable at its price.</description>
		<buildDef>RT_Chain_Saw_Blueprint</buildDef>
		<graphicData>
			<texPath>Vehicles/Bolte/BolteFast</texPath>
			<drawSize>(2.25,4.5)</drawSize>
		</graphicData>
		<size>(2,4)</size>
		<fillPercent>1</fillPercent>
		<vehicleCategory>Combat</vehicleCategory>
		<statBases><!--平衡相关-->
			<ArmorRating_Blunt>0.45</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.80</ArmorRating_Sharp>
			<Flammability>0</Flammability>
			<MarketValue>1050</MarketValue>
		</statBases>
		<vehicleStats><!--平衡相关-->
			<Mass>600</Mass>
			<MoveSpeed>8</MoveSpeed>
			<CargoCapacity>180</CargoCapacity>
			<RepairRate>1.0</RepairRate>
		</vehicleStats>
		<soundOneShotsOnEvent Inherit = "False">
			<li>
				<key>PawnEntered</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>PawnExited</key>
				<value>VVE_VehicleEnter</value>
			</li>
			<li>
				<key>IgnitionOn</key>
				<value>RT_BMPVehicleStart</value>
			</li>
			<li>
				<key>IgnitionOff</key>
				<value>RT_BMPVehicleStop</value>
			</li>
		</soundOneShotsOnEvent>
		<soundSustainersOnEvent Inherit="false">
			<li>
				<start>IgnitionOn</start>
				<stop>IgnitionOff</stop>
				<value>RT_BMPVehicleEngine</value>
			</li>
		</soundSustainersOnEvent>
		<race>
			<baseBodySize>3</baseBodySize>
		</race>	
		<properties>	<!-- 座位與功能 -->
			<customRoadCosts AssignDefaults = "0.4"/>
			<worldSpeedMultiplier>1.1</worldSpeedMultiplier>
			<offRoadMultiplier>0.8</offRoadMultiplier>
			<winterSpeedMultiplier>0.8</winterSpeedMultiplier>
			<customHillinessCosts>
				<SmallHills>0.2</SmallHills>
				<LargeHills>0.8</LargeHills>
				<Mountainous>1.5</Mountainous>
			</customHillinessCosts>
			<vehicleJobLimitations>
				<li>(RepairVehicle, 2)</li>
			</vehicleJobLimitations>
			<roles>
				<li>
					<key>driver</key>
					<label>driver</label>
					<slots>1</slots>	
					<slotsToOperate>1</slotsToOperate>		
					<handlingTypes>
						<li>Movement</li>
						<li>Turret</li>
					</handlingTypes>
					<turretIds>
						<li>fragLauncher</li>
					</turretIds>
				</li>				
				<li>
					<key>gunner</key>
					<label>gunner</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>			
					<handlingTypes>Turret</handlingTypes>
					<turretIds>
						<li>MG</li>
						<li>Minigun</li>
						<li>Rocket</li>
						<li>Autocannon</li>
					</turretIds>
				</li>
				<li>
					<key>passenger</key>
					<label>passenger</label>
					<slots>1</slots>
				</li>		
			</roles>
		</properties>	
		<components>	<!-- 各種零件 --><!--平衡相关-->
			<!-- Internal mobile Part 內部驅動部件-->
				<li><!--Engine 100-->
					<key>Engine</key>
					<label>engine</label>
					<health>50</health>
					<priorityStatEfficiency>true</priorityStatEfficiency>
					<categories><li>MoveSpeed</li></categories>
					<depth>Internal</depth>		
					<reactors>
						<li Class = "Vehicles.Reactor_Explosive">
							<indicator>VF_Explosive</indicator>
							<chance>0.25</chance>
							<maxHealth>0.3</maxHealth>
							<radius>3</radius>
							<damageDef>Bomb</damageDef>
						</li>
					</reactors>			
					<hitbox>
						<cells>
							<li>(0, -1)</li>
						</cells>
					</hitbox>				
				</li>		
				<li><!-- fuel tank 100-->
					<key>FuelTank</key>
					<label>fuel tank</label>
					<health>50</health>
					<depth>Internal</depth>			
					<reactors><li Class = "Vehicles.Reactor_FuelLeak"/></reactors>			
					<hitbox>
						<cells>
							<li>(0, -1)</li>
						</cells>
					</hitbox>
				</li>
				<li><!-- Gearbox 50-->
					<key>Gearbox</key>
					<label>gearbox</label>
					<health>25</health>
					<depth>Internal</depth>
					<categories><li>MoveSpeed</li></categories>	
					<hitbox><cells>
						<li>(1, 1)</li>
					</cells></hitbox>			
				</li>
				<li><!-- AmmoRack 50-->
					<key>AmmoRack</key>
					<label>ammo rack</label>
					<health>25</health>
					<depth>Internal</depth>
					<reactors>
						<li Class = "Vehicles.Reactor_Explosive">
							<indicator>VF_Explosive</indicator>
							<chance>0.5</chance>
							<maxHealth>0.5</maxHealth>
							<radius>3</radius>
							<damageDef>Bomb</damageDef>
						</li>
					</reactors>	
					<hitbox><cells><li>(0, 0)</li></cells></hitbox>
				</li>
				<li><!-- transmission shaft 40 -->
					<key>TransmissionShaft</key>
					<label>transmission shaft</label>
					<health>30</health>
					<depth>Internal</depth>
				</li>			
			<!-- External mobile Part 外部驅動部件-->		
			<li><!-- LeftTrack 150-->
				<key>LeftTrack</key>
				<label>left track</label>
				<health>75</health>
				<depth>External</depth>
				<categories><li>MoveSpeed</li></categories>
				<tags><li>Wheel</li></tags>
				<hitWeight>2</hitWeight>
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Left</side>
				</hitbox>
			</li>
			<li><!-- RightTrack 150-->
				<key>RightTrack</key>
				<label>right track</label>
				<health>75</health>
				<depth>External</depth>
				<categories><li>MoveSpeed</li></categories>	
				<tags><li>Wheel</li></tags>
				<hitWeight>2</hitWeight>
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Right</side>
				</hitbox>
			</li>
			<li><!-- LeftRoadWheels 100-->
				<key>LeftRoadWheels</key>
				<label>left road wheels</label>
				<health>50</health>
				<depth>External</depth>
				<categories><li>MoveSpeed</li></categories>				
				<tags><li>Wheel</li></tags>		
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Left</side>
				</hitbox>
			</li>
			<li><!-- RightRoadWheels 100-->
				<key>RightRoadWheels</key>
				<label>right road wheels</label>
				<health>50</health>
				<depth>External</depth>
				<categories><li>MoveSpeed</li></categories>				
				<tags><li>Wheel</li></tags>		
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Right</side>
				</hitbox>
			</li>
			<li><!-- LeftDriveSprocket 75-->
				<key>LeftDriveSprocket</key>
				<label>left drive sprocket</label>
				<health>38</health>
				<depth>External</depth>
				<categories><li>MoveSpeed</li></categories>				
				<tags><li>Wheel</li></tags>		
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells><li>(0, 2)</li></cells><!--左前-->
				</hitbox>
			</li>
			<li><!-- RightDriveSprocket 75-->
				<key>RightDriveSprocket</key>
				<label>right drive sprocket</label>
				<health>38</health>
				<depth>External</depth>
				<categories><li>MoveSpeed</li></categories>				
				<tags><li>Wheel</li></tags>		
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells><li>(1, 2)</li></cells><!--右前-->
				</hitbox>
			</li>
			<li><!-- LeftTensionerWheel 75-->
				<key>LeftTensionerWheel</key>
				<label>left tensioner wheel</label>
				<health>38</health>
				<depth>External</depth>
				<categories><li>MoveSpeed</li></categories>				
				<tags><li>Wheel</li></tags>					
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells><li>(0, -1)</li></cells><!--左後-->
				</hitbox>
			</li>
			<li><!-- RightTensionerWheel 75-->
				<key>RightTensionerWheel</key>
				<label>right tensioner wheel</label>
				<health>38</health>
				<depth>External</depth>
				<categories><li>MoveSpeed</li></categories>				
				<tags><li>Wheel</li></tags>				
				<hitbox>
					<fallthrough>false</fallthrough>
					<cells><li>(1, -1)</li></cells><!--右後-->
				</hitbox>
			</li>
			<!-- External Platings 外部防禦部件 -->
				<li><!-- FrontArmorPlating 200-->
					<key>FrontArmorPlating</key>
					<label>front armor Plating</label>
					<health>100</health>
					<depth>External</depth>
					<hitWeight>8</hitWeight>	
					<armor>
						<ArmorRating_Blunt>1.00</ArmorRating_Blunt>
						<ArmorRating_Sharp>0.8</ArmorRating_Sharp>
					</armor>		
					<hitbox><side>Front</side></hitbox>
				</li>
				<li><!-- LeftArmorPlating 180-->
					<key>LeftArmorPlating</key>
					<label>left armor plating</label>
					<health>90</health>
					<depth>External</depth>
					<hitWeight>5</hitWeight>		
					<armor>
						<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
						<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
					</armor>			
					<hitbox><side>Left</side></hitbox>
				</li>
				<li><!-- RightArmorPlating 180-->
					<key>RightArmorPlating</key>
					<label>right armor plating</label>
					<health>90</health>
					<depth>External</depth>
					<hitWeight>5</hitWeight>	
					<armor>
						<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
						<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
					</armor>			
					<hitbox><side>Right</side></hitbox>
				</li>
				<li><!-- RoofArmorPlating 150 -->
					<key>RoofArmorPlating</key>
					<label>roof armor plating</label>
					<health>75</health>
					<depth>External</depth>
					<hitWeight>5</hitWeight>
					<armor>
						<ArmorRating_Blunt>0.9</ArmorRating_Blunt>
						<ArmorRating_Sharp>0.7</ArmorRating_Sharp>
					</armor>
					<hitbox><side>Body</side></hitbox>
				</li>
				<li><!-- BackArmorPlating 150-->
					<key>BackArmorPlating</key>
					<label>rear armor plating</label>
					<health>75</health>
					<depth>External</depth>
					<hitWeight>5</hitWeight>
					<hitbox>
						<side>Back</side>
					</hitbox>
				</li>
			</components>
		<comps><!--平衡相关-->
			<li Class="Vehicles.CompProperties_FueledTravel">	<!-- 油箱與油耗 -->
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>15</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>1</fuelConsumptionWorldMultiplier>
				<fuelCapacity>75</fuelCapacity>
			</li>
			<li Class="Vehicles.CompProperties_UpgradeTree">
				<def>Bolte_Vehicle_UpgradeTree</def>
			</li>
			<li Class="Vehicles.CompProperties_VehicleTurrets">	<!-- 砲塔 -->
				<turrets>
					<li>
						<turretDef>RT_Chain_Saw_Main_Turret</turretDef>					
						<renderProperties>
							<north>(0, 0.5)</north>
							<south>(0, 0)</south>
							<east>(0.06, 0.24)</east>
							<west>(-0.06, 0.24)</west>
						</renderProperties>
						
						<gizmoLabel>Main Turret</gizmoLabel>
						<aimPieOffset>(0, 0)</aimPieOffset>	<!-- 預熱指示器的x,z偏移 -->
						<drawLayer>1</drawLayer>						
						<key>MG</key>
					</li>
					<li>
						<turretDef>RT_Frag_Flashpoint</turretDef>					
						<renderProperties>
							<north>(0, 0.5)</north>
							<south>(0, 0)</south>
							<east>(0.06, 0.24)</east>
							<west>(-0.06, 0.24)</west>
						</renderProperties>
						<gizmoLabel>Frag Grenade Launcher</gizmoLabel>
						<aimPieOffset>(0, 0)</aimPieOffset>	<!-- 預熱指示器的x,z偏移 -->
						<drawLayer>1</drawLayer>
						<key>fragLauncher</key>
					</li>
				</turrets>
			</li>
		</comps>
	</Vehicles.VehicleDef>

	<!-- 主砲的Def --><!--平衡相关-->
	<Vehicles.VehicleTurretDef ParentName="RT_BaseVehicleMG_Medium">
		<defName>RT_Chain_Saw_Main_Turret</defName>
		<label>machine gun</label>
		<!-- 砲塔的渲染顯示 -->
		<graphicData>
			<texPath>Vehicles/Bolte/Bolte_Cannon1</texPath>
			<drawSize>(3.5,3.5)</drawSize>
		</graphicData>
		<!-- 彈藥與裝填容量相關 -->
		<chargePerAmmoCount>0.1</chargePerAmmoCount>
		<reloadTimer>3</reloadTimer>
		<genericAmmo>true</genericAmmo>
		<!-- 射程與射界相關 -->
		<rotationSpeed>1.7</rotationSpeed>
		<!-- 射擊相關 -->
		<warmUpTimer>1</warmUpTimer>
		<projectileOffset>1.3</projectileOffset>		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>							<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<!-- <li>-1</li> -->
			<li>0</li>
		  </projectileShifting>
	</Vehicles.VehicleTurretDef>

	<Vehicles.VehicleTurretDef ParentName="VehicleTurretBase">
		<gizmoIconTexPath>VehicleGuns/Smoke</gizmoIconTexPath>
		<defName>RT_Frag_Flashpoint</defName>
		<label>frag grenade launcher</label>
		<turretType>Static</turretType>
		<reloadTimer>10</reloadTimer>
		<magazineCapacity>3</magazineCapacity>
		<chargePerAmmoCount>5</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<ammunition>
			<thingDefs>
				<li>Chemfuel</li>
			</thingDefs>
		</ammunition>
		<maxRange>15</maxRange>
		<shotSound>Shot_IncendiaryLauncher</shotSound>
		<projectile>RT_Frag_FlashpointShell</projectile>
		<hitFlags>IntendedTarget</hitFlags>
		<fireModes>
			<li>
				<shotsPerBurst>1</shotsPerBurst>
				<ticksBetweenShots>120</ticksBetweenShots>
				<ticksBetweenBursts>120</ticksBetweenBursts>
				<label>Suppressive</label>
				<texPath>UI/Gizmos/FireRate_Auto</texPath>
			</li>
		</fireModes>
	</Vehicles.VehicleTurretDef>
	
	<ThingDef ParentName="BaseBullet">
		<defName>RT_Frag_FlashpointShell</defName>
		<label>frag grenade</label>
		<graphicData>
			<texPath>Things/Projectile/LauncherShot</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
			<color>(140,135,156)</color>
		</graphicData>
		<thingClass>Motorization.Projectile_ArcSpread</thingClass>
		<projectile>
			<speed>40</speed>
			<damageDef>Smoke</damageDef>
		</projectile>
		<modExtensions>
			<li Class="Motorization.RotationalArcSpreadExtension">
				<projectile>Proj_GrenadeFrag</projectile>
				<range>8~12</range>
				<amount>10</amount>
				<arc>135</arc>
			</li>
		</modExtensions>
	</ThingDef>
</Defs>