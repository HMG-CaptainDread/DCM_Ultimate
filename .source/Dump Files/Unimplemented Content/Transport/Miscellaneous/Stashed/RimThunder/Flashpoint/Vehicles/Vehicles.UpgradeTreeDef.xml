<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<Vehicles.UpgradeTreeDef>
		<defName>Bolte_Vehicle_UpgradeTree</defName>
		<nodes>
			<li>
				<key>CircularSaw</key>
				<label>Circular Saw</label>
				<description>Upgrade to Circular Saw with a minigun, works well as a scout vehicle.</description>
				<icon>Vehicles/Bolte/Bolte_Cannon2a</icon>
				<work>200</work>
				<gridCoordinate>(3,3)</gridCoordinate>
				<drawSize>(50, 50)</drawSize>
				<disableIfUpgradeNodesEnabled>
					<li>RipperSaw</li>
					<li>ElectricSaw</li>
				</disableIfUpgradeNodesEnabled>
				<upgrades>
					<li Class = "Vehicles.StatUpgrade"> <!--基础属性修改，可用add/set，具体修改范围参考文档-->
						<vehicleStats>
							<li>
								<def>MoveSpeed</def>
								<value>4</value>
								<type>Add</type>
							</li>
						</vehicleStats>
					</li>
					<li Class = "Vehicles.VehicleUpgrade">
   						<roles>
							<li>
								<key>passenger</key>
								<label>passenger</label>
								<remove>true</remove>
								<slots>1</slots>
							</li>
   						</roles>
					</li>
					<li Class="Vehicles.TurretUpgrade"><!--炮塔升级相关，直接从空炮塔升级为有炮塔不可行，需要空白comps，参见Trucks.xml-->
						<turrets>
							<li>
								<turretDef>RT_Circular_Saw_Main_Turret</turretDef>					
								<renderProperties>
									<north>(0, 0.5)</north>
									<south>(0, 0)</south>
									<east>(0.06, 0.24)</east>
									<west>(-0.06, 0.24)</west>
								</renderProperties>
								
								<gizmoLabel>Main Turret</gizmoLabel>
								<aimPieOffset>(0, 1.3)</aimPieOffset>	<!-- 預熱指示器的x,z偏移 -->
								<drawLayer>1</drawLayer>						
								<key>Minigun</key>
							</li>
						</turrets><!--可以用replace或者remove移除其他改装中的互斥部分，例如从已有的炮塔换新炮塔-->
						<removeTurrets>
							<li>MG</li>
						</removeTurrets>
					</li>
					<li Class = "Vehicles.VehicleUpgrade">
   						<retextureDef>Bolte_Hull</retextureDef>
					</li>
				</upgrades>
				<ingredients>
					<ComponentIndustrial>5</ComponentIndustrial>
					<ComponentHeavyCasting>1</ComponentHeavyCasting>
				</ingredients>
			</li>
