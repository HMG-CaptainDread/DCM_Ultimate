<?xml version="1.0" encoding="utf-8"?>

<Defs>
	<Vehicles.VehicleTurretDef ParentName="RT_BaseVehicleMG_Medium">
		<defName>RT_Circular_Saw_Main_Turret</defName>
		<label>m134 minigun</label>
		<!-- 砲塔的渲染顯示 -->
		<graphicData>
			<texPath>Vehicles/Bolte/Bolte_Cannon2</texPath>
			<drawSize>(3.5,3.5)</drawSize>
		</graphicData>
		<!-- 彈藥與裝填容量相關 -->
		<chargePerAmmoCount>0.1</chargePerAmmoCount>
		<reloadTimer>3</reloadTimer>
		<genericAmmo>true</genericAmmo>
		<magazineCapacity>120</magazineCapacity>
		<shotSound>Shot_Minigun</shotSound>
		<!-- 射程與射界相關 -->
		<minRange>2</minRange>
		<maxRange>36.9</maxRange>
		<rotationSpeed>1.5</rotationSpeed>
		<!-- 射擊相關 -->
		<warmUpTimer>1</warmUpTimer>
		<projectileOffset>1.3</projectileOffset>		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>							<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<!-- <li>-1</li> -->
			<li>0</li>
		  </projectileShifting>
		<!-- 炮口製退動畫 -->
		<recoil>
			<distanceTotal>0.1</distanceTotal>
			<distancePerTick>0.05</distancePerTick>
			<speedMultiplierPostRecoil>0.1</speedMultiplierPostRecoil>
		</recoil>
		<!-- 射擊模式 -->
		<fireModes Inherit = "false">
			<li>
				<shotsPerBurst>12</shotsPerBurst>
				<ticksBetweenShots>3</ticksBetweenShots>
				<ticksBetweenBursts>50</ticksBetweenBursts>
				<label>Burst</label>
				<texPath>UI/Gizmos/FireRate_Burst</texPath>
			</li>
			<li>
				<shotsPerBurst>25</shotsPerBurst>
				<ticksBetweenShots>3</ticksBetweenShots>
				<ticksBetweenBursts>50</ticksBetweenBursts>
				<label>Auto</label>
				<texPath>UI/Gizmos/FireRate_Auto</texPath>
			</li>
		</fireModes>
	</Vehicles.VehicleTurretDef>
	
	<Vehicles.VehicleTurretDef ParentName="RT_BaseTurret">
		<defName>RT_Electric_Saw_Main_Turret</defName>
		<label>Rocket Launcher</label>
		<!-- 砲塔的渲染顯示 -->
		<graphicData>
			<texPath>Vehicles/Bolte/Bolte_Cannon3</texPath>
			<drawSize>(3.5,3.5)</drawSize>
		</graphicData>
		<!-- 彈藥與裝填容量相關 -->
		<reloadTimer>4</reloadTimer>
		<magazineCapacity>4</magazineCapacity>
		<chargePerAmmoCount>5</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<ammunition>
			<thingDefs>
				<li>Chemfuel</li>
			</thingDefs>
		</ammunition>
		<!-- 射程與射界相關 -->
		<minRange>2</minRange>
		<maxRange>52</maxRange>
		<rotationSpeed>1.95</rotationSpeed>	
		<!-- 射擊相關 -->
		<warmUpTimer>1.5</warmUpTimer>
		<shotSound>RocketswarmLauncher_Fire</shotSound>
		<projectile>RT_Electric_Saw_Bullet</projectile>
		<projectileOffset>0.35</projectileOffset>		<!-- 出膛前后偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>							<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<li>-0.08</li>
			<li>0.08</li>
		  </projectileShifting>
		<!-- 炮口製退動畫 -->
		<recoil>
			<distanceTotal>0.15</distanceTotal>
			<distancePerTick>0.05</distancePerTick>
			<speedMultiplierPostRecoil>0.1</speedMultiplierPostRecoil>
		</recoil>
		<!-- 射擊模式 -->
		<fireModes>
			<li>
				<shotsPerBurst>1</shotsPerBurst>
				<ticksBetweenBursts>30</ticksBetweenBursts>
				<spreadRadius>3</spreadRadius>
				<label>Single shot</label>
				<texPath>UI/Gizmos/FireRate_Single</texPath>
			</li>
			<li>
				<shotsPerBurst>4</shotsPerBurst>
				<ticksBetweenShots>30</ticksBetweenShots>
				<ticksBetweenBursts>120</ticksBetweenBursts>
				<spreadRadius>6</spreadRadius>
				<label>Burst</label>
				<texPath>UI/Gizmos/FireRate_Auto</texPath>
			</li>
		</fireModes>
	</Vehicles.VehicleTurretDef>

	<ThingDef ParentName="BaseBullet">
    	<defName>RT_Electric_Saw_Bullet</defName>
    	<label>Rocket</label>
    	<graphicData>
      		<texPath>Things/Projectile/Rocket_Swarm</texPath>
      		<graphicClass>Graphic_Single</graphicClass>
      		<shaderType>TransparentPostLight</shaderType>
    	</graphicData>
    	<thingClass>Projectile_Explosive</thingClass>
    	<projectile>
      		<damageDef>Bomb</damageDef>
			<damageAmountBase>36</damageAmountBase>
      		<speed>100</speed>
      		<explosionRadius>2.9</explosionRadius>
      		<flyOverhead>true</flyOverhead>
      		<soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
      		<soundExplode>MortarBomb_Explode</soundExplode>
      		<soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
      		<soundAmbient>MortarRound_Ambient</soundAmbient>
    	</projectile>
  	</ThingDef>

	<Vehicles.VehicleTurretDef ParentName="RT_BaseTurret">
		<defName>RT_Ripper_Saw_Main_Turret</defName>
		<label>main turret</label>
		<!-- 砲塔的渲染顯示 -->
		<graphicData>
			<texPath>Vehicles/Bolte/Bolte_Cannon4</texPath>
			<drawSize>(5.5,5.5)</drawSize>
		</graphicData>
		<!-- 彈藥與裝填容量相關 -->
		<reloadTimer>3</reloadTimer>
		<magazineCapacity>10</magazineCapacity>
		<chargePerAmmoCount>2</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<ammunition>
			<thingDefs>
				<li>Steel</li>
			</thingDefs>
		</ammunition>
		<!-- 射程與射界相關 -->
		<minRange>2</minRange>
		<maxRange>34.9</maxRange>
		<rotationSpeed>1.2</rotationSpeed>
		<!-- 射擊相關 -->
		<warmUpTimer>1</warmUpTimer>
		<shotSound>RT_Shot_AutoCannonSound</shotSound>
		<reloadSound>RT_AutoCannonReloadSound</reloadSound>
		<projectile>RT_Bullet_RipperShell</projectile>
		<projectileOffset>2.6</projectileOffset>		<!-- 出膛前後偏移，主要是能讓子彈能從炮口飛出去 -->
		<projectileShifting>							<!-- 出膛左右偏移，多砲管可以根據list來回切 -->
			<!-- <li>-1</li> -->
			<li>0</li>
		  </projectileShifting>
		<!-- 炮口製退動畫 -->
		<recoil>
			<distanceTotal>0.15</distanceTotal>
			<distancePerTick>0.05</distancePerTick>
			<speedMultiplierPostRecoil>0.1</speedMultiplierPostRecoil>
		</recoil>
		<!-- 射擊模式 -->
		<fireModes>
			<li>
				<shotsPerBurst>3</shotsPerBurst>
				<ticksBetweenShots>30</ticksBetweenShots>
				<ticksBetweenBursts>90</ticksBetweenBursts>
				<spreadRadius>2</spreadRadius>
				<label>Burst</label>
				<texPath>UI/Gizmos/FireRate_Burst</texPath>
			</li>
			<li>
				<shotsPerBurst>5</shotsPerBurst>
				<ticksBetweenShots>30</ticksBetweenShots>
				<ticksBetweenBursts>150</ticksBetweenBursts>
				<spreadRadius>3</spreadRadius>
				<label>Auto</label>
				<texPath>UI/Gizmos/FireRate_Auto</texPath>
			</li>
		</fireModes>
		<motes>
			<li>
				<cycles>1</cycles>
				<moteDef>Mote_CannonPlume</moteDef>
				<animationType>Reset</animationType>
				<offset>(0,0,2)</offset>
			</li>
		</motes>
	</Vehicles.VehicleTurretDef>
		<!-- 主砲的投射物 -->
	<ThingDef ParentName="BaseBullet">
		<defName>RT_Bullet_RipperShell</defName>
		<label>high-explosive shell</label>
		<thingClass>Projectile_Explosive</thingClass>
		<graphicData>
			<texPath>Things/Projectile/Bullet_Big</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>2</drawSize>
		</graphicData>
		<projectile>
			<damageDef>Bomb</damageDef>
			<damageAmountBase>48</damageAmountBase>
			<speed>75</speed>
			<explosionRadius>1.9</explosionRadius>
			<soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
			<soundExplode>Explosion_GiantBomb</soundExplode>
			<soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
			<soundAmbient>MortarRound_Ambient</soundAmbient>
		</projectile>
	</ThingDef>
</Defs>