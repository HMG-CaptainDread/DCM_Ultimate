<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>ZAInertialCandleONE</defName>
    <label>Inertial Candle</label>
    <description>The REcycle DIsposal PROcessor is an specialized environmental cleanup machine designed to quickly take care of toxic waste in heavily polluted planets undergoing reclamation efforts. The system is also known as the "Inertial Candle" as it originated from a repurposed Inertial powerpack reconfigured to accept toxic trash as its main fuel source, but because of the modifications and the unstable nature of its fuel source, it produces extreme amounts of heat, light and a mere residual amount of usable energy in operation. The REDIPRO is a delicate machine derived from an spacecraft powerplant capable of catasthropic failure if tampered under any circumstances.</description>
    <thingClass>Building</thingClass>
    <drawerType>MapMeshAndRealTime</drawerType>
    <graphicData>
      <texPath>Things/Power/InertialCandle</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(2,2)</drawSize>
      <shadowData>
        <volume>(1.93,1,1.69)</volume>
        <offset>(-0.03,0,-0.1)</offset>
      </shadowData>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.9</fillPercent>
    <pathCost>50</pathCost>
    <rotatable>false</rotatable>
    <blockWind>true</blockWind>
	<minifiedDef>MinifiedThing</minifiedDef>
	<thingCategories>
      <li>BuildingsPower</li>
    </thingCategories>
    <statBases>
	  <Mass>95</Mass>
      <MaxHitPoints>300</MaxHitPoints>
      <WorkToBuild>6500</WorkToBuild>
      <Flammability>0.0</Flammability>
      <Beauty>-90</Beauty>
    </statBases>
    <tickerType>Normal</tickerType>
    <canOverlapZones>false</canOverlapZones>
    <size>(2,2)</size>
    <building>
      <destroySound>BuildingDestroyed_Metal_Medium</destroySound>
    </building>
    <costList>
      <Steel>200</Steel>
	  <ComponentSpacer>7</ComponentSpacer>
	  <ZAinertialengine>1</ZAinertialengine>
    </costList>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerPlant</compClass>
        <basePowerConsumption>-2500</basePowerConsumption>
        <transmitsPower>true</transmitsPower>
        <soundAmbientProducingPower>GeothermalPlant_Ambience</soundAmbientProducingPower>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Refuelable">
        <fuelConsumptionRate>4.5</fuelConsumptionRate>
        <fuelCapacity>60.0</fuelCapacity>
		<targetFuelLevelConfigurable>true</targetFuelLevelConfigurable>
        <initialConfigurableTargetFuelLevel>60</initialConfigurableTargetFuelLevel>
        <fuelFilter>
          <thingDefs>
            <li>Wastepack</li>
          </thingDefs>
        </fuelFilter>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
      </li>
      <li Class="CompProperties_Glower">
        <overlightRadius>7.0</overlightRadius>
        <glowRadius>14</glowRadius>
        <glowColor>(370,370,370,0)</glowColor>
      </li>
      <li Class="CompProperties_HeatPusher">
        <compClass>CompHeatPusherPowered</compClass>
        <heatPerSecond>800</heatPerSecond>
      </li>
      <li Class="CompProperties_Breakdownable"/>
      <li Class="CompProperties_Explosive">
        <explosiveRadius>14.9</explosiveRadius>
        <explosiveDamageType>BombSuper</explosiveDamageType>
        <destroyThingOnExplosionSize>2</destroyThingOnExplosionSize>
        <chanceToStartFire>0.22</chanceToStartFire>
        <damageFalloff>true</damageFalloff>
        <explosionEffect>GiantExplosion</explosionEffect>
        <explosionSound>Explosion_GiantBomb</explosionSound>
        <startWickHitPointsPercent>0.333</startWickHitPointsPercent>
		<preExplosionSpawnThingDef>Wastepack</preExplosionSpawnThingDef>
		<preExplosionSpawnChance>0.5</preExplosionSpawnChance>
        <wickTicks>10~50</wickTicks>
        <startWickOnDamageTaken>
          <li>Bullet</li>
          <li>Arrow</li>
          <li>ArrowHighVelocity</li>
        </startWickOnDamageTaken>
      </li>
      <li Class="CompProperties_Stunnable">
        <useLargeEMPEffecter>true</useLargeEMPEffecter>
        <affectedDamageDefs>
          <li>EMP</li>
        </affectedDamageDefs>
      </li>
    </comps>
    <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
    <designationCategory>Power</designationCategory>
    <constructEffect>ConstructMetal</constructEffect>
    <researchPrerequisites>
      <li>ZA_InertialSubsystems</li>
    </researchPrerequisites>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
  </ThingDef>


</Defs>