<?xml version="1.0" encoding="utf-8" ?>

<Defs>

  <ThingDef Abstract="True" Name="BaseArtillerySTOLRWeapon" ParentName="BaseWeapon">
    <destroyOnDrop>True</destroyOnDrop>
    <drawerType>MapMeshAndRealTime</drawerType>
    <canGenerateDefaultDesignator>false</canGenerateDefaultDesignator>
    <tradeability>None</tradeability>
    <useHitPoints>false</useHitPoints>
    <weaponTags>
      <li>TurretGun</li>
    </weaponTags>
    <weaponClasses>
      <li>Ranged</li>
    </weaponClasses>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
	  <drawSize>(4.05, 1.05)</drawSize>
    </graphicData>
    <allowedArchonexusCount>0</allowedArchonexusCount>
	<building>
		<paintable>true</paintable>
	</building>
  </ThingDef>

  <ThingDef Name="BaseArtillerySTOLRBuilding" ParentName="BuildingBase" Abstract="True">
    <thingClass>Building_TurretGun</thingClass>
    <drawerType>MapMeshAndRealTime</drawerType>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/Turrets/STOLRS/STOLRS_base</texPath>
      <drawSize>(4,4)</drawSize>
      <damageData>
        <rect>(0.38,0.2,0.56375,0.8)</rect>
        <cornerTL>Damage/Corner</cornerTL>
      </damageData>
      <shadowData>
        <offset>(-0.13,-0.87,-0.1)</offset>
        <volume>(0.5,0.4,1.05)</volume>
      </shadowData>
    </graphicData>
    <minifiedDef>MinifiedThing</minifiedDef>
    <altitudeLayer>Building</altitudeLayer>
    <hasInteractionCell>True</hasInteractionCell>
    <interactionCellOffset>(0,0,-1)</interactionCellOffset>
    <stealable>false</stealable>
    <size>(3,3)</size>
    <passability>PassThroughOnly</passability>
    <pathCost>50</pathCost>
    <fillPercent>0.4</fillPercent>
    <thingCategories>
      <li>BuildingsSecurity</li>
    </thingCategories>
    <tickerType>Normal</tickerType>
    <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
    <designationCategory>Security</designationCategory>
    <constructionSkillPrerequisite>8</constructionSkillPrerequisite>
    <costList>
	  <Chemfuel>50</Chemfuel>
	  <Plasteel>200</Plasteel>
      <Steel>210</Steel>
	  <ComponentSpacer>6</ComponentSpacer>
	  <ComponentHeavyCasting>4</ComponentHeavyCasting>
      <ComponentIndustrial>7</ComponentIndustrial>
    </costList>
    <inspectorTabs>
      <li>ITab_Shells</li>
    </inspectorTabs>
    <comps>
      <li Class="CompProperties_Forbiddable"/>
      <li Class="CompProperties_Mannable">
        <manWorkType>Violent</manWorkType>
      </li>
    </comps>
    <statBases>
      <MaxHitPoints>610</MaxHitPoints>
      <Flammability>0.2</Flammability>
      <WorkToBuild>4300</WorkToBuild>
      <Mass>90</Mass>
      <Beauty>-55</Beauty>
    </statBases>
    <building>
      <paintable>true</paintable>
      <turretBurstWarmupTime>3.4</turretBurstWarmupTime>
      <turretBurstCooldownTime>4.4</turretBurstCooldownTime>
      <buildingTags>
        <li>Artillery</li>
      </buildingTags>
    </building>
    <placeWorkers>
      <li>PlaceWorker_NotUnderRoof</li>
      <li>PlaceWorker_TurretTop</li>
      <li>PlaceWorker_PreventInteractionSpotOverlap</li>
    </placeWorkers>
    <researchPrerequisites>
      <li>ZA_Repurposeddefense</li>
    </researchPrerequisites>
    <uiIconScale>1</uiIconScale>
  </ThingDef>
  
  <ThingDef ParentName="BaseArtillerySTOLRBuilding">
    <defName>Turret_STOLRS</defName>
    <label>STOLRS</label>
    <description>(Stablilized Thermobaric Ordnance - Long Range, Stationary) A hefty gun with reduced recoil and high power coupled with an integrated fast loader for 2 shot salvos. Requires standard STOLR ammo to fire and is compatible with the expanded ammo selection. May explode when damaged.</description>
    <comps>
      <li Class="CompProperties_Explosive">
        <wickTicks>240</wickTicks>
        <explosiveRadius>6.9</explosiveRadius>
        <explosiveDamageType>Bomb</explosiveDamageType>
      </li>
       <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>250</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Breakdownable"/>     
	  <li Class="CompProperties_Refuelable">
        <fuelLabel>Shots until barrel change</fuelLabel>
        <fuelGizmoLabel>Barrel durability</fuelGizmoLabel>
        <outOfFuelMessage>Barrel worn out</outOfFuelMessage>
        <fuelFilter><thingDefs><li>ReinforcedBarrel</li></thingDefs></fuelFilter>
        <fuelIsMortarBarrel>true</fuelIsMortarBarrel>
        <fuelCapacity>20</fuelCapacity>
        <fuelMultiplier>20</fuelMultiplier>
        <initialFuelPercent>1</initialFuelPercent>
        <showFuelGizmo>true</showFuelGizmo>
        <minimumFueledThreshold>2</minimumFueledThreshold>
        <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
        <initialAllowAutoRefuel>true</initialAllowAutoRefuel>
        <autoRefuelPercent>0</autoRefuelPercent>
        <fuelIconPath>Things/Item/Resource/ReinforcedBarrel/ReinforcedBarrel</fuelIconPath>
      </li>
      <li Class="CompProperties_Stunnable">
        <affectedDamageDefs>
          <li>Stun</li>
          <li>EMP</li>
        </affectedDamageDefs>
      </li>
    </comps>
    <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
    <building>
      <turretTopDrawSize>8.2</turretTopDrawSize>
      <turretTopOffset>(0, 0)</turretTopOffset>
      <turretGunDef>Turret_STOLRSTUr</turretGunDef>
      <buildingTags>
        <li>Artillery_BaseDestroyer</li>
        <li>Artillery_MannedMortar</li>
      </buildingTags>
	  <paintable>true</paintable>
    </building>
	<uiIconPath>Things/Turrets/STOLRS/STOLRSicon</uiIconPath>
	<uiIconScale>0.9</uiIconScale>
  </ThingDef>

  <ThingDef ParentName="BaseArtillerySTOLRWeapon">
    <defName>Turret_STOLRSTUr</defName>
    <label>STOLRS</label>
    <description>A STOLRS gun placement. Trades the TraSSTraH's version mobility for volume of fire.</description>
    <recoilPower>1</recoilPower>
    <graphicData>
	  <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/Turrets/STOLRS/STOLRS_top</texPath>
    </graphicData>
    <statBases>
      <RangedWeapon_Cooldown>3.4</RangedWeapon_Cooldown>
      <DeteriorationRate>0</DeteriorationRate>
      <Mass>35</Mass>
      <Flammability>0</Flammability>
	  <AccuracyTouch>0.60</AccuracyTouch>
	  <AccuracyShort>0.70</AccuracyShort>
	  <AccuracyMedium>0.80</AccuracyMedium>
	  <AccuracyLong>0.60</AccuracyLong>
    </statBases>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <forceNormalTimeSpeed>false</forceNormalTimeSpeed>
        <warmupTime>4.4</warmupTime>
        <isMortar>true</isMortar>
        <requireLineOfSight>false</requireLineOfSight>
        <minRange>16</minRange>
        <range>850</range>
        <burstShotCount>2</burstShotCount>
        <soundCast>trashmaingunfire</soundCast>
		<soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>12</muzzleFlashScale>
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
        </targetParams>
        <ticksBetweenBurstShots>30</ticksBetweenBurstShots>
      </li>
    </verbs>
    <comps>
      <li Class="CompProperties_ChangeableProjectile" />
    </comps>
    <building>
	  <paintable>true</paintable>
      <fixedStorageSettings>
        <filter>
          <categories>
			<li>TraMortarShells</li>
          </categories>
        </filter>
      </fixedStorageSettings>
      <defaultStorageSettings>
        <filter>
          <categories>
			<li>TraMortarShells</li>
          </categories>
          <disallowedThingDefs>
            <li>ZAtrash_SMK</li>
            <li>ZAtrash_AG</li>
          </disallowedThingDefs>
        </filter>
      </defaultStorageSettings>
    </building>
  </ThingDef>

