<?xml version="1.0" encoding="utf-8" ?>

<Defs>

	<Vehicles.VehicleBuildDef ParentName="VehicleBaseBuildable">
		<defName>ZA_scalbots_Blueprint</defName>
		<label>Kestrel SCALBOTS</label>
		<description>the Kestrel is an SCALBOTS (Space CApable Lifting BOdy Transport Shuttle) designed primarily to support transfer operations from ground to low planetary orbits as well as "jumping" into suborbital trajectories to avoid the harsher, unforgiving terrains of planets of the outer rim. It's main engine is capable of maneuvering the entire craft with mild magnetic pulses, relying on a conventional rocket for major adjustments in presence of atmosphere. Despite it's spacer applications its powerplant and  accomodations deem it unrated for interstellar flight. without support from a mothership</description>
		<designationCategory>VF_Vehicles</designationCategory>
		
		<graphicData>
			<texPath>Things/Vehicles/SCALBOTS/kestrel</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType>
			<drawSize>(8, 16)</drawSize>
		</graphicData>
		
		<statBases>
			<MaxHitPoints>1500</MaxHitPoints>
			<WorkToBuild>52000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		
		<size>(5, 13)</size>
		
		<researchPrerequisites>
			<li>ZA_Rudimentaryinertialpropulsion</li>
		</researchPrerequisites>
		<!--COSTS-->
		<costList>
			<ComponentWheelRoad>6</ComponentWheelRoad>
			<ComponentHeavyCasting>10</ComponentHeavyCasting>
			<ComponentIndustrial>15</ComponentIndustrial>
			<ComponentSpacer>7</ComponentSpacer>
			<ZAinertialengine>1</ZAinertialengine>
			<Steel>1540</Steel>
		</costList>
		
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		
		<thingToSpawn>ZA_scalbots</thingToSpawn>
		<constructionSkillPrerequisite>12</constructionSkillPrerequisite>
	</Vehicles.VehicleBuildDef>
	
	<Vehicles.VehicleDef ParentName="BaseVehiclePawn">
		<defName>ZA_scalbots</defName>
		<label>Kestrel SCALBOTS</label>
		<description>the Kestrel is an SCALBOTS (Space CApable Lifting BOdy Transport Shuttle) designed primarily to support transfer operations from ground to low planetary orbits as well as "jumping" into suborbital trajectories to avoid the harsher, unforgiving terrains of planets of the outer rim. It's main engine is capable of maneuvering the entire craft with mild magnetic pulses, relying on a conventional rocket for major adjustments in presence of atmosphere. Despite it's spacer applications its powerplant and  accomodations deem it unrated for interstellar flight. without support from a mothership</description>
		<!--COLOR-->
		<graphicData>
			<texPath>Things/Vehicles/SCALBOTS/kestrel</texPath>
			<graphicClass>Vehicles.Graphic_Vehicle</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType>
			<drawSize>(8, 16)</drawSize>
			<color>(155, 155, 155)</color>
			<colorTwo>(65, 75, 80)</colorTwo>
			<colorThree>(45, 50, 45)</colorThree>
		</graphicData>
		
		<fillPercent>1</fillPercent>
		
		<buildDef>ZA_scalbots_Blueprint</buildDef>
		
		<size>(5, 13)</size>
		

		<canCaravan LockSetting = "True">false</canCaravan>
		<vehicleCategory>Transport</vehicleCategory>
		<techLevel>Industrial</techLevel>
		<vehicleType>Air</vehicleType>
		
		<statBases>
			<ArmorRating_Blunt>0.42</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.92</ArmorRating_Sharp>
			<ArmorRating_Heat>1.0</ArmorRating_Heat>
			<Flammability>0.05</Flammability>
			<MarketValue>15000</MarketValue>
		</statBases>
		
		<vehicleStats>
			<Mass>5650</Mass>
			<MoveSpeed LockSetting="True">0</MoveSpeed>
			<CargoCapacity>3760</CargoCapacity>
			<RepairRate>0.4</RepairRate>
			<FlightSpeed>75</FlightSpeed>
		</vehicleStats>
		
		<soundSustainersOnEvent>
			<li>
				<start>AerialVehicleLaunch</start>
				<stop>Despawned</stop>
				<value>Inertialtakeoff</value>
			</li>
			<li>
				<start>AerialVehicleLanding</start>
				<stop>Spawned</stop>
				<value>Inertiallanding</value>
			</li>
		</soundSustainersOnEvent>
		
		<race>
			<baseBodySize>4.5</baseBodySize>
		</race>
		
		<properties>
			
			<vehicleJobLimitations>
				<li>(RepairVehicle, 3)</li>
			</vehicleJobLimitations>
			
			<roles>
				<li>
					<key>pilot</key>
					<label>Pilot</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
				</li>
				<li>
					<key>passenger</key>
					<label>Passenger</label>
					<slots>3</slots>
				</li>
			</roles>
		</properties>
		
		<components>
			<li>
				<key>Engine</key>
				<label>Inertial Engine</label>
				<health>150</health>
				<priorityStatEfficiency>true</priorityStatEfficiency>
				<depth>External</depth>
				
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.25</chance>
						<radius>4</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>
				
				<hitbox>
					<cells>
						<li>(0, -1)</li>
						<li>(1, -2)</li>
					</cells>
				</hitbox>
				
				<categories>
					<li>MoveSpeed</li>
					<li>FlightControl</li>
					<li>FlightSpeed</li>
				</categories>
			</li>
			<li>
				<key>RCSthruster</key>
				<label>Auxiliary Thruster</label>
				<health>180</health>
				<depth>External</depth>
				
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.1</chance>
						<maxHealth>0.4</maxHealth>
						<radius>1</radius>
						<damageDef>Flame</damageDef>
					</li>
				</reactors>
				
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Back</side>
				</hitbox>
				
				<categories>
					<li>MoveSpeed</li>
					<li>FlightControl</li>
					<li>FlightSpeed</li>
				</categories>
			</li>			
			<li>
				<key>RCS2thruster</key>
				<label>Main Thruster</label>
				<health>250</health>
				<depth>External</depth>
				
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.1</chance>
						<maxHealth>0.4</maxHealth>
						<radius>1</radius>
						<damageDef>Flame</damageDef>
					</li>
				</reactors>
				
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Back</side>
				</hitbox>
				
				<categories>
					<li>MoveSpeed</li>
					<li>FlightControl</li>
					<li>FlightSpeed</li>
				</categories>
			</li>	
			<li>
				<key>engine2</key>
				<label>Thruster valves</label>
				<health>70</health>
				<depth>Internal</depth>
				
				<hitbox>
					<cells>
						<li>(0, 1)</li>
					</cells>
				</hitbox>
				
				<categories>
					<li>MoveSpeed</li>
				</categories>
			</li>
			<li>
				<key>FrontPlating</key>
				<label>Front Plating</label>
				<health>300</health>
				<depth>External</depth>
				
				<hitbox>
					<side>Front</side>
				</hitbox>
			</li>
			<li>
				<key>LeftPlating</key>
				<label>Left Plating</label>
				<health>250</health>
				<depth>External</depth>
				
				<hitbox>
					<side>Left</side>
				</hitbox>
			</li>
			<li>
				<key>RightPlating</key>
				<label>Right Plating</label>
				<health>250</health>
				<depth>External</depth>

				<hitbox>
					<side>Right</side>
				</hitbox>
			</li>
			<li>
				<key>BackPlating</key>
				<label>Rear Plating</label>
				<health>180</health>
				<depth>External</depth>
				
				<hitbox>
					<side>Back</side>
				</hitbox>
			</li>
			<li>
				<key>Fueltank</key>
				<label>Fuel tank</label>
				<health>200</health>
				<depth>Internal</depth>
				
				<reactors>
					<li Class="Vehicles.Reactor_FuelLeak"/>
				</reactors>
				
				<hitbox>
					<cells>
						<li>(0, -1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<key>DriverStation</key>
				<label>Cockpit</label>
				<health>150</health>
				<depth>Internal</depth>
				<hitWeight>1</hitWeight>
			</li>
			<li>
				<key>StarflightControlSystem</key>
				<label>Starflight Control Systems</label>
				<health>100</health>
				<depth>Internal</depth>
			</li>
			<li>
				<key>RCS</key>
				<label>RCS Systems</label>
				<health>100</health>
				<depth>Internal</depth>
			</li>
			<li>
				<key>Alternator</key>
				<label>Alternator</label>
				<health>100</health>
				<depth>Internal</depth>
			</li>
			<li>
				<key>Roof</key>
				<label>Roof</label>
				<health>320</health>
				<depth>External</depth>
				<hitWeight>10</hitWeight>
				
				<armor>
					<ArmorRating_Blunt>0.92</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.52</ArmorRating_Sharp>
				</armor>
			</li>
		</components>
		
		<comps>
			<li Class="Vehicles.CompProperties_FueledTravel">
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>55</fuelConsumptionRate>
				<fuelCapacity>265</fuelCapacity>
			</li>
			<li Class="Vehicles.CompProperties_VehicleLauncher">
				<controlInFlight>True</controlInFlight>
				<spaceFlight>true</spaceFlight>
				<canRoofPunch>true</canRoofPunch>
				<animationPunchAt>2</animationPunchAt>
				<launchProtocol Class="Vehicles.DefaultTakeoff">
					<maxFlightNodes>1</maxFlightNodes>
					<launchProperties>
						<maxTicks>1200</maxTicks>
						<forcedRotation>East</forcedRotation>
						<renderShadow>false</renderShadow>
						
						<events>
							<li>
								<triggerAt>0</triggerAt>
								<method>Vehicles.LaunchProtocol.SetOverlayStatus(false)</method>
							</li>
							<li>
								<triggerAt>0.3</triggerAt>
								<method>Vehicles.LaunchProtocol.SetOverlayStatus(true)</method>
							</li>
						</events>

						<xPositionCurve Class="SmashTools.BezierCurve">
							<points>
								<li>(0, 0)</li>
								<li>(0.6, 20.77)</li>
								<li>(1.79, 21.16)</li>
								<li>(5.05, 41.8)</li>
								<li>(1.03, 189.79)</li>
							</points>
						</xPositionCurve>
						<zPositionCurve Class="SmashTools.BezierCurve">
							<points>
								<li>(0, 0)</li>
								<li>(5.48, 48.98)</li>
								<li>(3.44, 29.98)</li>
								<li>(27.56, 103.26)</li>
								<li>(1.57, 184.76)</li>
							</points>
						</zPositionCurve>
					</launchProperties>
					
					<landingProperties>
						<maxTicks>1200</maxTicks>
						<renderShadow>false</renderShadow>
						
						<events>
							<li>
								<triggerAt>0.65</triggerAt>
								<method>Vehicles.LaunchProtocol.SetOverlayStatus(false)</method>
							</li>
							<li>
								<triggerAt>0.95</triggerAt>
								<method>Vehicles.AerialAnimationEvents.ShakeCamera(0.1)</method>
							</li>
						</events>

						<zPositionCurve Class = "SmashTools.BezierCurve">
							<points>
								<li>(0, 200)</li>
								<li>(0.05, 91.95)</li>
								<li>(0.13, 37.29)</li>
								<li>(0.34, 6.14)</li>
								<li>(0.74, 3.81)</li>
								<li>(0.98, 3.18)</li>
								<li>(1, 0)</li>
							</points>
						</zPositionCurve>
					</landingProperties>
				</launchProtocol>
			</li>
		</comps>
	</Vehicles.VehicleDef>
	
</Defs>
