<?xml version="1.0" encoding="utf-8" ?>

<Defs>

	<Vehicles.VehicleBuildDef ParentName="VehicleBaseBuildable">
		<defName>ZA_scalbotstern_Blueprint</defName>
		<label>Tern SCALBOTS</label>
		<description>the Tern is an smaller scale SCALBOTS (Space CApable Lifting BOdy Transport Shuttle) Designed for entry level planetary prospecting and survey. Its compact design and cheap procurement and service costs have made the Tern much more affordable than the Kestrel Class for starting settlements, but its limitations in cargo and crew space have made it suboptimal for higher logistical use.</description>
		<designationCategory>VF_Vehicles</designationCategory>
		
		<graphicData>
			<texPath>Things/Vehicles/SCALBOTStern/Tern</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType>
			<drawSize>(4.72, 9.85)</drawSize>
		</graphicData>
		<statBases>
			<MaxHitPoints>1500</MaxHitPoints>
			<WorkToBuild>52000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		<size>(3, 9)</size>
		
		<researchPrerequisites>
			<li>ZA_Rudimentaryinertialpropulsion</li>
		</researchPrerequisites>
		<!--COSTS-->
		<costList>
			<ComponentWheelRoad>3</ComponentWheelRoad>
			<ComponentHeavyCasting>6</ComponentHeavyCasting>
			<ComponentIndustrial>15</ComponentIndustrial>
			<ComponentSpacer>5</ComponentSpacer>
			<ZAinertialengine>1</ZAinertialengine>
			<Steel>780</Steel>
		</costList>
		
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		
		<thingToSpawn>ZA_scalbotstern</thingToSpawn>
		<constructionSkillPrerequisite>8</constructionSkillPrerequisite>
	</Vehicles.VehicleBuildDef>
	
	<Vehicles.VehicleDef ParentName="BaseVehiclePawn">
		<defName>ZA_scalbotstern</defName>
		<label>Tern SCALBOTS</label>
		<description>the Tern is an smaller scale SCALBOTS (Space CApable Lifting BOdy Transport Shuttle) Designed for entry level planetary prospecting and survey. Its compact design and cheap procurement and service costs have made the Tern much more affordable than the Kestrel Class for starting settlements, but its limitations in cargo and crew space have made it suboptimal for higher logistical use.</description>
		<!--COLOR-->
		<graphicData>
			<texPath>Things/Vehicles/SCALBOTStern/Tern</texPath>
			<graphicClass>Vehicles.Graphic_Vehicle</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType>
			<drawSize>(4.72, 9.85)</drawSize>
			<color>(155, 155, 155)</color>
			<colorTwo>(65, 75, 80)</colorTwo>
			<colorThree>(45, 50, 45)</colorThree>
		</graphicData>
		 
		<fillPercent>1</fillPercent>
		
		<buildDef>ZA_scalbotstern_Blueprint</buildDef>
		
		<size>(3, 9)</size>
		
		<canCaravan LockSetting = "True">false</canCaravan>
		<vehicleCategory>Transport</vehicleCategory>
		<techLevel>Industrial</techLevel>
		<vehicleType>Air</vehicleType>
		
		<statBases>
			<ArmorRating_Blunt>0.42</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.92</ArmorRating_Sharp>
			<ArmorRating_Heat>1.0</ArmorRating_Heat>
			<Flammability>0.05</Flammability>
			<MarketValue>9000</MarketValue>
		</statBases>
		
		<vehicleStats>
			<Mass>3650</Mass>
			<MoveSpeed LockSetting="True">0</MoveSpeed>
			<CargoCapacity>1000</CargoCapacity>
			<RepairRate>0.75</RepairRate>
			<FlightSpeed>95</FlightSpeed>
		</vehicleStats>
		
		<soundSustainersOnEvent>
			<li>
				<start>AerialVehicleLaunch</start>
				<stop>Despawned</stop>
				<value>Inertialtakeoff</value>
			</li>
			<li>
				<start>AerialVehicleLanding</start>
				<stop>Spawned</stop>
				<value>Inertiallanding</value>
			</li>
		</soundSustainersOnEvent>
		
		<race>
			<baseBodySize>4.5</baseBodySize>
		</race>
		
		<properties>
			
			<vehicleJobLimitations>
				<li>(RepairVehicle, 3)</li>
			</vehicleJobLimitations>
			
			<roles>
				<li>
					<key>pilot</key>
					<label>Pilot</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
				</li>
				<li>
					<key>passenger</key>
					<label>Passenger</label>
					<slots>1</slots>
				</li>
			</roles>
		</properties>
		
		<components>
			<li>
				<key>Engine</key>
				<label>Inertial Engine</label>
				<health>110</health>
				<priorityStatEfficiency>true</priorityStatEfficiency>
				<depth>External</depth>
				
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.25</chance>
						<radius>3</radius>
						<damageDef>Bomb</damageDef>
					</li>
				</reactors>
				
				<hitbox>
					<cells>
						<li>(0, -1)</li>
						<li>(1, -2)</li>
					</cells>
				</hitbox>
				
				<categories>
					<li>MoveSpeed</li>
					<li>FlightControl</li>
					<li>FlightSpeed</li>
				</categories>
			</li>
			<li>
				<key>RCSthruster</key>
				<label>Auxiliary Thruster</label>
				<health>140</health>
				<depth>External</depth>
				
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.1</chance>
						<maxHealth>0.4</maxHealth>
						<radius>1</radius>
						<damageDef>Flame</damageDef>
					</li>
				</reactors>
				
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Back</side>
				</hitbox>
				
				<categories>
					<li>MoveSpeed</li>
					<li>FlightControl</li>
					<li>FlightSpeed</li>
				</categories>
			</li>			
			<li>
				<key>RCS2thruster</key>
				<label>Main Thruster</label>
				<health>200</health>
				<depth>External</depth>
				
				<reactors>
					<li Class = "Vehicles.Reactor_Explosive">
						<indicator>VF_Explosive</indicator>
						<chance>0.1</chance>
						<maxHealth>0.4</maxHealth>
						<radius>1</radius>
						<damageDef>Flame</damageDef>
					</li>
				</reactors>
				
				<hitbox>
					<fallthrough>false</fallthrough>
					<side>Back</side>
				</hitbox>
				
				<categories>
					<li>MoveSpeed</li>
					<li>FlightControl</li>
					<li>FlightSpeed</li>
				</categories>
			</li>	
			<li>
				<key>engine2</key>
				<label>Thruster valves</label>
				<health>70</health>
				<depth>Internal</depth>
				
				<hitbox>
					<cells>
						<li>(0, 1)</li>
					</cells>
				</hitbox>
				
				<categories>
					<li>MoveSpeed</li>
				</categories>
			</li>
			<li>
				<key>FrontPlating</key>
				<label>Front Plating</label>
				<health>200</health>
				<depth>External</depth>
				
				<hitbox>
					<side>Front</side>
				</hitbox>
			</li>
			<li>
				<key>LeftPlating</key>
				<label>Left Plating</label>
				<health>150</health>
				<depth>External</depth>
				
				<hitbox>
					<side>Left</side>
				</hitbox>
			</li>
			<li>
				<key>RightPlating</key>
				<label>Right Plating</label>
				<health>150</health>
				<depth>External</depth>

				<hitbox>
					<side>Right</side>
				</hitbox>
			</li>
			<li>
				<key>BackPlating</key>
				<label>Rear Plating</label>
				<health>180</health>
				<depth>External</depth>
				
				<hitbox>
					<side>Back</side>
				</hitbox>
			</li>
			<li>
				<key>Fueltank</key>
				<label>Fuel tank</label>
				<health>200</health>
				<depth>Internal</depth>
				
				<reactors>
					<li Class="Vehicles.Reactor_FuelLeak"/>
				</reactors>
				
				<hitbox>
					<cells>
						<li>(0, -1)</li>
					</cells>
				</hitbox>
			</li>
			<li>
				<key>DriverStation</key>
				<label>Cockpit</label>
				<health>150</health>
				<depth>Internal</depth>
				<hitWeight>1</hitWeight>
			</li>
			<li>
				<key>StarflightControlSystem</key>
				<label>Starflight Control Systems</label>
				<health>100</health>
				<depth>Internal</depth>
			</li>
			<li>
				<key>RCS</key>
				<label>RCS Systems</label>
				<health>100</health>
				<depth>Internal</depth>
			</li>
			<li>
				<key>Alternator</key>
				<label>Alternator</label>
				<health>100</health>
				<depth>Internal</depth>
			</li>
			<li>
				<key>Roof</key>
				<label>Roof</label>
				<health>220</health>
				<depth>External</depth>
				<hitWeight>10</hitWeight>
				
				<armor>
					<ArmorRating_Blunt>0.92</ArmorRating_Blunt>
					<ArmorRating_Sharp>0.52</ArmorRating_Sharp>
				</armor>
			</li>
		</components>
		
		<comps>
			<li Class="Vehicles.CompProperties_FueledTravel">
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>55</fuelConsumptionRate>
				<fuelCapacity>165</fuelCapacity>
			</li>
			<li Class="Vehicles.CompProperties_VehicleLauncher">
				<controlInFlight>True</controlInFlight>
				<spaceFlight>true</spaceFlight>
				<canRoofPunch>true</canRoofPunch>
				<animationPunchAt>2</animationPunchAt>
				<launchProtocol Class="Vehicles.DefaultTakeoff">
					<maxFlightNodes>1</maxFlightNodes>
					<launchProperties>
						<maxTicks>1200</maxTicks>
						<forcedRotation>East</forcedRotation>
						<renderShadow>false</renderShadow>
						
						<events>
							<li>
								<triggerAt>0</triggerAt>
								<method>Vehicles.LaunchProtocol.SetOverlayStatus(false)</method>
							</li>
							<li>
								<triggerAt>0.3</triggerAt>
								<method>Vehicles.LaunchProtocol.SetOverlayStatus(true)</method>
							</li>
						</events>

						<xPositionCurve Class="SmashTools.BezierCurve">
							<points>
								<li>(0, 0)</li>
								<li>(0.6, 20.77)</li>
								<li>(1.79, 21.16)</li>
								<li>(5.05, 41.8)</li>
								<li>(1.03, 189.79)</li>
							</points>
						</xPositionCurve>
						<zPositionCurve Class="SmashTools.BezierCurve">
							<points>
								<li>(0, 0)</li>
								<li>(5.48, 48.98)</li>
								<li>(3.44, 29.98)</li>
								<li>(27.56, 103.26)</li>
								<li>(1.57, 184.76)</li>
							</points>
						</zPositionCurve>
					</launchProperties>
					
					<landingProperties>
						<maxTicks>1200</maxTicks>
						<renderShadow>false</renderShadow>
						
						<events>
							<li>
								<triggerAt>0.65</triggerAt>
								<method>Vehicles.LaunchProtocol.SetOverlayStatus(false)</method>
							</li>
							<li>
								<triggerAt>0.95</triggerAt>
								<method>Vehicles.AerialAnimationEvents.ShakeCamera(0.1)</method>
							</li>
						</events>

						<zPositionCurve Class = "SmashTools.BezierCurve">
							<points>
								<li>(0, 200)</li>
								<li>(0.05, 91.95)</li>
								<li>(0.13, 37.29)</li>
								<li>(0.34, 6.14)</li>
								<li>(0.74, 3.81)</li>
								<li>(0.98, 3.18)</li>
								<li>(1, 0)</li>
							</points>
						</zPositionCurve>
					</landingProperties>
				</launchProtocol>
			</li>
		</comps>
	</Vehicles.VehicleDef>
	
</Defs>
