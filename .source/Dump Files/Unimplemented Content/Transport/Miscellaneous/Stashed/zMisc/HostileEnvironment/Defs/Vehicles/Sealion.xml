<?xml version="1.0" encoding="utf-8" ?>

<Defs>

	<Vehicles.VehicleBuildDef ParentName="VehicleBaseBuildable">
		<defName>ZA_Sealion_Blueprint</defName>
		<label>Sea Lion ATTTra</label>
		<description>The ATTTra "Sea Lion" (Amphibious Tug Transport - Tracked) is an specialized tractor designed to support expeditions working in proximity to bodies of water of any kind without major complications. The Sea Lion features a sizeable boat hull equipped with a turboshaft engine powering 2 propellers, a lightly armored hull and plenty of room to accommodate 20 passengers</description>
		<designationCategory>VF_Vehicles</designationCategory>
		
		<graphicData>
			<texPath>Things/Vehicles/ATTTra/sealion</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType>
			<drawSize>(4, 9)</drawSize>
		</graphicData>
		
		<statBases>
			<MaxHitPoints>800</MaxHitPoints>
			<WorkToBuild>12000</WorkToBuild>
			<Flammability>0.05</Flammability>
		</statBases>
		
		<size>(3, 8)</size>
		
		<researchPrerequisites>
		<li>Machining</li>
		</researchPrerequisites>
		<!--COSTS-->
		<costList>
			<Cloth>120</Cloth>
			<ComponentWheelRoad>16</ComponentWheelRoad>
			<ComponentHeavyCasting>6</ComponentHeavyCasting>
			<ComponentIndustrial>16</ComponentIndustrial>
			<EngineTurbine>1</EngineTurbine>
			<Steel>300</Steel>
		</costList>
		
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		
		<thingToSpawn>ZA_Sealion</thingToSpawn>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
	</Vehicles.VehicleBuildDef>
	
	
	
	
	
