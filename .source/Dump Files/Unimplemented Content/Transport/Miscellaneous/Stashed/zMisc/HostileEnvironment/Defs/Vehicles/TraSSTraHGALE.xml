	<!--MAIN GUN-->
	
	<Vehicles.VehicleTurretDef ParentName="VehicleTurretBase">
		<defName>ZA_trashtraG_MainTurret</defName>
		<label>STOLR HV cannon</label>
		<description>A modified gun from the standard with increased breech pressure, it's even more destructive.</description>
		
		<turretType>Rotatable</turretType>
		<shotSound>trashmaingunfire</shotSound>
		<reloadSound>trashtrareload</reloadSound>
		
		<projectile>Bullet_trashtra_MainTurreta</projectile>
		<reloadTimer>4.4</reloadTimer>
		<warmUpTimer>3.4</warmUpTimer>
		<magazineCapacity>1</magazineCapacity>
		<chargePerAmmoCount>1</chargePerAmmoCount>
		<genericAmmo>False</genericAmmo>
		
		<autoSnapTargeting>false</autoSnapTargeting>
		<rotationSpeed>1.2</rotationSpeed>
		
		<projectileOffset>5.25</projectileOffset>
		<maxRange>58.9</maxRange>
		<minRange>4</minRange>
		
		<recoil>
			<distanceTotal>0.6</distanceTotal>
			<distancePerTick>0.2</distancePerTick>
			<speedMultiplierPostRecoil>0.35</speedMultiplierPostRecoil>
		</recoil>
		
		<vehicleRecoil>
			<distanceTotal>0.1</distanceTotal>
			<distancePerTick>0.05</distancePerTick>
			<speedMultiplierPostRecoil>0.55</speedMultiplierPostRecoil>
		</vehicleRecoil>
		
		<fireModes>
			<li>
				<shotsPerBurst>1</shotsPerBurst>
				<ticksBetweenBursts>1</ticksBetweenBursts>
				<spreadRadius>4</spreadRadius>
				<label>Single Shot</label>
				<texPath>UI/Gizmos/FireRate_Single</texPath>
			</li>
		</fireModes>
		
		<graphicData>
			<texPath>Things/Vehicles/TraSSTraH1GALE/turretshortg</texPath>
			<graphicClass>Vehicles.Graphic_Turret</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType>
			<drawSize>(9.5, 9.5)</drawSize>
		</graphicData>
		
		<ammunition>
			<thingDefs>
				<li>ZAtrash_HE</li>
				<li>ZAtrash_HEHV</li>
				<li >ZAtrash_AG</li>
				<li MayRequire="Ludeon.RimWorld.Biotech" >ZAtrash_TOX</li>
				<li>ZAtrash_SMK</li>
				<li>ZAtrash_EMP</li>
				<li>ZAtrash_FF</li>
			</thingDefs>
		</ammunition>
		
		<motes>
			<li>
				<cycles>1</cycles>
				<moteDef>Mote_CannonPlume</moteDef>
				<animationType>Reset</animationType>
			</li>
		</motes>
	</Vehicles.VehicleTurretDef>
