	<Vehicles.VehicleBuildDef ParentName="VehicleBaseBuildable">
		<defName>ZA_trashtraG_Blueprint</defName>
		<label>The Rim Demon</label>
		<description>A well seasoned TraSSTraH vehicle with a custom livery, it is believed to having belonged to the planet Terracota-E expedition team, although it somehow appeared here</description>
		<designationCategory>VF_Vehicles</designationCategory>
		
		<graphicData>
			<texPath>Things/Vehicles/TraSSTraH1/tra</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType>
			<drawSize>(4, 7)</drawSize>
		</graphicData>
		
		<statBases>
			<MaxHitPoints>4500</MaxHitPoints>
			<WorkToBuild>12000</WorkToBuild>
			<Flammability>0.0</Flammability>
		</statBases>
		
		<size>(3, 6)</size>
		
		<researchPrerequisites>
			<li>ZA_Trashgaleworkaround</li>
		</researchPrerequisites>
		<!--COSTS-->
		<costList>
			<ComponentWheelRoad>16</ComponentWheelRoad>
			<ComponentHeavyCasting>40</ComponentHeavyCasting>
			<ComponentIndustrial>30</ComponentIndustrial>
			<ComponentSpacer>16</ComponentSpacer>
			<EngineTurbine>1</EngineTurbine>
			<ZAspecialcoat>1</ZAspecialcoat>
			<Plasteel>440</Plasteel>
		</costList>
		
		<soundImpactDefault>Ricochettra</soundImpactDefault>
		
		<thingToSpawn>ZA_trashtraG</thingToSpawn>
		<constructionSkillPrerequisite>4</constructionSkillPrerequisite>
	</Vehicles.VehicleBuildDef>
	
