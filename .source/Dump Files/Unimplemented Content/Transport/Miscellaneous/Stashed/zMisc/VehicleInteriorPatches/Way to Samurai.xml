<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>RimThunder - Way to Samurai</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>

        <li Class="PatchOperationConditional">
          <xpath>Defs/Vehicles.VehicleDef[defName='RT_Type73_Vehicle']</xpath>
          <match Class="PatchOperationConditional">
            <xpath>Defs/Vehicles.VehicleDef[defName='RT_Type73_Vehicle']/comps</xpath>
            <nomatch Class="PatchOperationAdd">
              <xpath>Defs/Vehicles.VehicleDef[defName='RT_Type73_Vehicle']</xpath>
              <value>
                <comps></comps>
              </value>
            </nomatch>
          </match>
        </li>

        <li Class="PatchOperationConditional">
          <xpath>Defs/Vehicles.VehicleDef[defName='RT_Type73_Vehicle']/comps</xpath>
          <match Class="PatchOperationAdd">
            <xpath>Defs/Vehicles.VehicleDef[defName='RT_Type73_Vehicle']/comps</xpath>
            <value>
              <li Class="RVwithPD.CompProperties_RVwitPD">
                <mapWidth>7</mapWidth>
                <mapHeight>7</mapHeight>
              </li>
            </value>
          </match>
        </li>

			</operations>
		</match>
	</Operation>

</Patch>