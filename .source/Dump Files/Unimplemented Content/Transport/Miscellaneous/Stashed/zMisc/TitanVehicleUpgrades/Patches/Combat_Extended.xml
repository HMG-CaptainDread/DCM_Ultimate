<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Combat Extended</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/Vehicles.VehicleTurretDef[defName="SEX_SuperchiefMainCannon"]/maxRange</xpath>
					<value>
						<maxRange>78</maxRange>
					</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/Vehicles.VehicleTurretDef[defName="SEX_SuperchiefMainCannon"]</xpath>
					<value>
						<modExtensions Inherit="False">
							<li Class="Vehicles.CETurretDataDefModExtension">
								<ammoSet>AmmoSet_338Lapua</ammoSet>
								<shotHeight>2.0</shotHeight>
								<speed>126</speed>
								<sway>0.68</sway>
								<spread>0.01</spread>
							</li>
						</modExtensions>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/Vehicles.VehicleTurretDef[defName="SEX_SuperchiefMainCannon"]/magazineCapacity</xpath>
					<value>
						<magazineCapacity>600</magazineCapacity>
					</value>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/Vehicles.VehicleTurretDef[defName="SEX_SuperchiefMainCannon"]/projectileShifting</xpath>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/Vehicles.VehicleTurretDef[defName="SEX_SuperchiefMainCannon"]/fireModes</xpath>
					<value>
						<fireModes>
							<li>
								<shotsPerBurst>100</shotsPerBurst>
								<ticksBetweenShots>3</ticksBetweenShots>
								<ticksBetweenBursts>160</ticksBetweenBursts>
								<label>Full auto</label>
								<texPath>UI/Gizmos/FireRate_Auto</texPath>
							</li>
							<li>
								<shotsPerBurst>30</shotsPerBurst>
								<ticksBetweenShots>3</ticksBetweenShots>
								<ticksBetweenBursts>120</ticksBetweenBursts>
								<label>Controlled burst</label>
								<texPath>UI/Gizmos/FireRate_Burst</texPath>
							</li>
						</fireModes>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/Vehicles.VehicleTurretDef[defName="SEX_SuperchiefMainCannon"]/projectile</xpath>
					<value>
						<projectile>Bullet_338Lapua_FMJ</projectile>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/Vehicles.VehicleTurretDef[defName="SEX_SuperchiefMainCannon"]/reloadTimer</xpath>
					<value>
						<reloadTimer>11.8</reloadTimer>
					</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/Vehicles.VehicleDef[defName="JASV_Warchief"]</xpath>
					<value>
						<descriptionHyperlinks>
							<CombatExtended.AmmoSetDef>AmmoSet_120mmCannonShell</CombatExtended.AmmoSetDef>
							<CombatExtended.AmmoSetDef>AmmoSet_20x102mmNATO</CombatExtended.AmmoSetDef>
							<CombatExtended.AmmoSetDef>AmmoSet_338Lapua</CombatExtended.AmmoSetDef>
							<CombatExtended.AmmoSetDef>AmmoSet_Flamethrower</CombatExtended.AmmoSetDef>
							<CombatExtended.AmmoSetDef>AmmoSet_57x307mmR</CombatExtended.AmmoSetDef>
						</descriptionHyperlinks>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
</Patch>