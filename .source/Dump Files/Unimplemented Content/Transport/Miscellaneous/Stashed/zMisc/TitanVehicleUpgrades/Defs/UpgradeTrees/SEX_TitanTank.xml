<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="BaseBullet">
		<defName>SEX_Superchief_Bullet</defName>
		<thingClass>Projectile_Explosive</thingClass>
		<label>superchief main cannon shot</label>
		<graphicData>
			<texPath>Things/Projectile/Charge_Small</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile>
			<damageDef>Bomb</damageDef>
			<explosionRadius>2.9</explosionRadius>
			<armorPenetrationBase>0.8</armorPenetrationBase>
			<damageAmountBase>6</damageAmountBase>
			<stoppingPower>1.5</stoppingPower>
			<speed>88</speed>
		</projectile>
	</ThingDef>
	<Vehicles.VehicleTurretDef ParentName="VehicleTurretBase">
		<defName>SEX_SuperchiefMainCannon</defName>
		<label>Main cannon</label>
		<graphicData>
			<texPath>Things/Vehicles/Ground/Warchief/Superchief_Main_Cannon</texPath>
			<graphicClass>Vehicles.Graphic_Turret</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType>
			<drawSize>(11.4, 11.4)</drawSize>
			<layer>2</layer>
		</graphicData>
		<turretType>Rotatable</turretType>
		<shotSound>JAHV_Conquistador_Heavycannon_Shot</shotSound>
		<projectile>SEX_Superchief_Bullet</projectile>
		<reloadTimer>5.0</reloadTimer>
		<warmUpTimer>1.2 </warmUpTimer>
		<magazineCapacity>300</magazineCapacity>
		<chargePerAmmoCount>1</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<ammunition>
			<thingDefs>
				<li>Steel</li>
			</thingDefs>
		</ammunition>
		<hitFlags>IntendedTarget</hitFlags>
		<autoSnapTargeting>false</autoSnapTargeting>
		<rotationSpeed>2.5</rotationSpeed>
		<maxRange>37.9</maxRange>
		<minRange>4.9</minRange>
		<projectileOffset>4.1</projectileOffset>
		<projectileShifting>
			<li>0.5</li>
			<li>-0.5</li>
		</projectileShifting>
		<recoil>
			<distanceTotal>0.15</distanceTotal>
			<distancePerTick>0.05</distancePerTick>
			<speedMultiplierPostRecoil>0.1</speedMultiplierPostRecoil>
		</recoil>
		<fireModes>
			<li>
				<shotsPerBurst>30</shotsPerBurst>
				<ticksBetweenShots>3</ticksBetweenShots>
				<ticksBetweenBursts>15</ticksBetweenBursts>
				<label>Burst</label>
				<texPath>UI/Gizmos/FireRate_Burst</texPath>
				<spreadRadius>3.9</spreadRadius>
			</li>
		</fireModes>
	</Vehicles.VehicleTurretDef>
	<Vehicles.VehicleTurretDef ParentName="SEX_BunsenShortTurret">
		<defName>SEX_TitanTank_Flamer</defName>
		<label>flamespewer</label>
		<graphicData>
			<drawSize>(2.6, 2.6)</drawSize>
		</graphicData>
	</Vehicles.VehicleTurretDef>
	<Vehicles.VehicleTurretDef ParentName="RoadkillMainTurret">
		<defName>SEX_TitanTank_LightCannon</defName>
		<label>light cannon</label>
		<graphicData>
			<drawSize>(3.6, 3.6)</drawSize>
		</graphicData>
	</Vehicles.VehicleTurretDef>
