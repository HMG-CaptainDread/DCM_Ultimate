  <Vehicles.VehicleBuildDef ParentName="RT_BaseVehicleBuild">
    <!-- 建築型態的載具，基本上與BuildingDef相同-->
    <defName>HD2_Pelican_Blueprint</defName>
    <label>Pelican</label>
    <description>Pelican shuttles are tiltwing single-stage-to-orbit (SSTO) transport craft. Pelicans are restricted to vertical take-off and landing only due to the design of their landing gear. Each shuttle can transport up to four passengers at a time.</description>
    <graphicData>
      <texPath>pelican/pelican</texPath>
      <drawSize>(8, 11)</drawSize>
    </graphicData>
    <statBases>
      <MaxHitPoints>710</MaxHitPoints>
      <WorkToBuild>19000</WorkToBuild>
      <Flammability>0.05</Flammability>
    </statBases>
    <size>(5,10)</size>
    <constructionSkillPrerequisite>12</constructionSkillPrerequisite>
    <costList>
      <EngineJet>4</EngineJet>
      <ComponentFuelTank>4</ComponentFuelTank>
      <ComponentTransmission>2</ComponentTransmission>
      <ComponentIndustrial>50</ComponentIndustrial>
      <Steel>400</Steel>
      <Plasteel>200</Plasteel>
      <Silver>50</Silver>
      <Chemfuel>40</Chemfuel>
    </costList>
    <thingToSpawn>HD2_Pelican_Vehicle</thingToSpawn>
    <!-- 建造後生成的載具Kind,這是與建築唯一不一樣的-->
  </Vehicles.VehicleBuildDef>
